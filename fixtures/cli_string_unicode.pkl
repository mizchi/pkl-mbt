// PKL-122: surrogate-pair aware String access. Apple Pkl's
// `String.length` returns the code-point count — the upstream
// `api/stringUnicode` fixture asserts
// `"😀😈😍😎😡🤢🤣".length == 7`, not the 14 UTF-16 units a Java
// `String.length` would report. `codePointCount` is a synonym;
// `codePoints`, `chars`, and `codePointAt(i)` walk the same
// Unicode view.
//
// `🍣` is U+1F363, a supplementary plane code point, so `length`
// and `codePointCount` both report `4` for the four-glyph string
// "abc🍣". A renderer that wants the UTF-16 view should walk
// `s.chars` and count surrogate pairs explicitly.
s = "abc🍣"

cp_length = s.length

cp_count = s.codePointCount

points = s.codePoints

chars = s.chars

sushi_cp = s.codePointAt(3)
