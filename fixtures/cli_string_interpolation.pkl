// PKL-128a: Apple Pkl's `"... \(expr) ..."` string interpolation.
// The parser splits the literal at `\(` boundaries and parses each
// segment as a Pkl expression; the evaluator concatenates the
// rendered string form of each part into the final value. The
// lexer walks balanced parens (escape- and inner-string-aware) so
// the outer string's closing `"` isn't confused with a `"` inside
// a `\(...)` segment.
name = "alpha"

count = 3

greeting = "hello \(name), count is \(count + 1)"

xs = new Listing { "a"; "b"; "c" }

joined = "items: \(xs.join(", "))"

plain = "no interp here"
