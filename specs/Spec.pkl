amends "../pkspec/Spec.pkl"

feature = "Pure MoonBit Pkl parser and interpreter"

local pureMoonBitCore = new Goal {
  id = "GOAL-PKL-PURE"
  name = "Pure MoonBit Pkl core"
  description =
    "Provide a MoonBit-only Pkl parser, evaluator, and typechecker core that can run without a native Pkl dependency."
  priority = 100
  reviewStatus = "approved"
  rationale =
    "The project should be embeddable in MoonBit targets and keep implementation layers regenerable from strict contracts."
}

local parseArithmetic = new Scenario {
  id = "PKL-001"
  name = "parse arithmetic expressions"
  description =
    "The parser builds a CST-backed program for integer arithmetic expressions and preserves source length."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Start with expression parsing as the first executable slice"
      rationale =
        "Arithmetic precedence is small enough for TDD and exercises the cst-backed parser shape."
    }
  }
}

local evalArithmetic = new Scenario {
  id = "PKL-002"
  name = "evaluate arithmetic and let bindings"
  description =
    "The interpreter evaluates integer arithmetic with precedence and resolves top-level let bindings."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "critical"
}

local rejectInvalidTypes = new Scenario {
  id = "PKL-003"
  name = "reject invalid integer operations"
  description = "The typechecker rejects binary arithmetic when either operand is not an Int."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "critical"
}

local incrementalTypecheck = new Scenario {
  id = "PKL-004"
  name = "typecheck source through ripple"
  description =
    "A source-backed analysis session uses ripple input and query nodes to recompute typechecking after source changes."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
}

local pklObjectModel = new Scenario {
  id = "PKL-005"
  name = "support initial Pkl object and module syntax"
  description =
    "The parser accepts module declarations, top-level properties, object literals, and member access; evaluator and typechecker resolve object fields."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Add object/module syntax before import and stdlib work"
      rationale =
        "Object fields and member lookup are the minimum model needed before import resolution or richer Pkl type semantics can be useful."
    }
  }
}

local pklImports = new Scenario {
  id = "PKL-006"
  name = "support Pkl imports and module resolution"
  description =
    "Import clauses resolve modules from the AnalysisSession source graph and make imported modules available for evaluation and typechecking."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Resolve import clauses through AnalysisSession inputs"
      rationale =
        "A source-backed resolver keeps the implementation pure MoonBit and lets ripple track imported source dependencies."
    }
  }
}

local pklStdlib = new Scenario {
  id = "PKL-007"
  name = "support Pkl standard library surface"
  description =
    "The AnalysisSession resolver recognizes selected pkl: standard library modules and exposes them as pure MoonBit module sources."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Seed standard library support with pkl:math"
      rationale =
        "Representing pkl: modules as built-in source keeps the parser/evaluator path uniform while letting coverage grow incrementally."
    }
  }
}

local pklRichTypes = new Scenario {
  id = "PKL-008"
  name = "support richer Pkl type semantics"
  description =
    "The parser and typechecker accept primitive Pkl-style type annotations and reject mismatched property/member values."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Start richer type semantics with primitive annotations"
      rationale =
        "Primitive annotations provide a testable type contract before class, union, and runtime validation semantics are added."
    }
  }
}

local pklCli = new Scenario {
  id = "PKL-009"
  name = "provide a usable CLI"
  description =
    "The native command-line entrypoint can parse, typecheck, and evaluate Pkl source files."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Add parse/check/eval native CLI subcommands"
      rationale =
        "A small CLI gives pkspec an end-to-end surface while the embeddable AnalysisSession remains the core API."
    }
  }
}

local pklStringEscapes = new Scenario {
  id = "PKL-010"
  name = "support Pkl string escape compatibility"
  description =
    "Common string escapes are decoded by the parser and rendered by the evaluator/CLI output path."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Decode and render common string escapes"
      rationale =
        "Escaped quotes and line breaks are required for realistic module properties and CLI output."
    }
  }
}

local upstreamPklFixtures = new Scenario {
  id = "PKL-011"
  name = "use upstream apple/pkl fixtures as compatibility checks"
  description =
    "The contract suite references Apple's Pkl repository as a git submodule and runs selected upstream LanguageSnippetTests fixtures through the pure MoonBit CLI."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Track upstream Pkl fixtures through a git submodule"
      rationale =
        "The implementation is still a Pkl subset, so an explicit smoke list keeps upstream compatibility executable without pretending the full upstream suite is supported."
    }
  }
}

local pklCommentsAndForwardRefs = new Scenario {
  id = "PKL-012"
  name = "support Pkl comments and module property forward references"
  description =
    "The lexer preserves line/block comments as trivia, and module property evaluation/typechecking resolves sibling properties regardless of declaration order."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Add trivia comments and lazy module property resolution"
      rationale =
        "Upstream snippets commonly use comments, and apple/pkl fixtures such as basic/import1.pkl rely on module properties referencing later sibling properties."
    }
  }
}

local pklObjectBodyProperties = new Scenario {
  id = "PKL-013"
  name = "support Pkl object body property shorthand"
  description =
    "Module and object members can use `name { ... }` object bodies as shorthand for object-valued properties."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Parse object body property shorthand"
      rationale =
        "Apple Pkl snippets use nested object bodies heavily; modules/objects.pkl is the smallest upstream fixture for this syntax."
    }
  }
}

local pklLocalAndImportExpressions = new Scenario {
  id = "PKL-014"
  name = "support Pkl local module bindings and import expressions"
  description =
    "Module-level `local` bindings are available to sibling properties without being exported, and `import(\"...\")` expressions resolve through the same pure MoonBit module resolver as import clauses."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Add local bindings and import expressions"
      rationale =
        "Apple Pkl's basic/import2.pkl fixture uses `local i = import(\"imported.pkl\")`, so import expressions need to participate in both analysis and CLI file loading."
    }
  }
}

local upstreamParserSuite = new Scenario {
  id = "PKL-015"
  name = "parse upstream apple/pkl snippet corpus"
  description =
    "The native parser accepts every syntactically valid fixture selected by apple/pkl's ParserComparisonTest LanguageSnippetTests input corpus."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Use apple/pkl ParserComparisonTest exclusions for parse-only compatibility"
      rationale =
        "Parser completion needs a broad upstream oracle. Matching the upstream parser test's invalid fixture exclusions gives this project an executable parse coverage target without requiring evaluator/typechecker parity."
    }
  }
}

local unsupportedSyntaxInventory = new Scenario {
  id = "PKL-016"
  name = "inventory unsupported syntax in tolerant parser output"
  description =
    "ParseResult exposes an unsupported_syntax coverage report with source ranges, text, and syntax kind for accepted code that still lowers to UnsupportedExpr."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-015" }
  tags { "parser" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Make parser completion resume from unsupported syntax inventory"
      rationale =
        "The parser now accepts the upstream corpus, but many constructs are intentionally tolerant. The next parser work needs a measurable unsupported-syntax inventory before expanding AST coverage."
    }
    new Decision {
      date = "2026-05-14"
      summary = "Expose unsupported syntax separately from parser diagnostics"
      rationale =
        "Unsupported syntax is an implementation coverage gap in otherwise accepted input, not a parse error. Keeping it on ParseResult preserves tolerant parsing while making the remaining AST work measurable."
    }
  }
}

local collectionExpressions = new Scenario {
  id = "PKL-017"
  name = "parse and evaluate Pkl collection expressions"
  description =
    "The parser lowers explicit `new Listing` elements and `new Mapping` entries into AST nodes, and evaluator/typechecker support collection values plus subscript access without using UnsupportedExpr."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-013"; "PKL-014" }
  tags { "parser"; "evaluator"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Start collection semantics with explicit Listing and Mapping values"
      rationale =
        "Explicit `new Listing` elements, `new Mapping` entries, and subscript access are a small interpreter slice that establishes public Value/Type shapes before broader object amendments and collection generators."
    }
  }
}

local callableExpressions = new Scenario {
  id = "PKL-018"
  name = "parse Pkl call lambda and operator expressions"
  description =
    "The parser lowers calls, lambdas, unary operators, comparisons, boolean operators, null-coalescing, and conditional expressions into explicit AST nodes with precedence matching Pkl."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-016" }
  tags { "parser" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Split expression AST coverage from declaration work"
      rationale =
        "Calls, lambdas, and non-arithmetic operators are a coherent parser precedence problem and can be tested independently from classes and module inheritance."
    }
    new Decision {
      date = "2026-05-14"
      summary = "Keep calls and lambdas parser-only while enabling simple expression semantics"
      rationale =
        "Call and function-value evaluation need a closure model and function declaration environment. This slice only makes them structured AST nodes; boolean, comparison, coalescing, unary, and conditional expressions are small enough to typecheck and evaluate directly."
    }
  }
}

local declarationsAndClassTypes = new Scenario {
  id = "PKL-019"
  name = "model Pkl class function and typealias declarations"
  description =
    "Program retains class, function, and typealias declarations, and the typechecker resolves declared class and typealias names in property annotations."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-016"; "PKL-008" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Track declaration AST work as the typechecker bridge"
      rationale =
        "The parser currently skips declarations to keep parse-only compatibility. Typechecker progress needs declarations preserved as structured contracts."
    }
    new Decision {
      date = "2026-05-14"
      summary = "Keep functions parse-only and use class properties as contracts"
      rationale =
        "Function evaluation is outside this slice, but retaining function declarations prevents parser coverage from hiding them. Class properties provide enough structure to validate object literals assigned to declared class annotations."
    }
  }
}

local moduleInheritanceAndAmends = new Scenario {
  id = "PKL-020"
  name = "support module extends amends and object amendments"
  description =
    "Module `extends`/`amends` clauses and object amendment syntax merge inherited members through AnalysisSession resolution for parsing, evaluation, and typechecking."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-006"; "PKL-013"; "PKL-019" }
  tags { "parser"; "evaluator"; "typechecker" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Make amends and extends the next semantic milestone"
      rationale =
        "Real Pkl modules compose through amends and extends. This is the next end-to-end semantic milestone after AST coverage for declarations and object bodies."
    }
    new Decision {
      date = "2026-05-14"
      summary = "Share one property merge model for modules and object amendments"
      rationale =
        "Module amends/extends and `(base) { ... }` both start with inherited members, replace matching names, and append new members. Class inheritance remains separate from this slice because it also needs constructor and method semantics."
    }
  }
}

local incrementalTypecheckGraph = new Scenario {
  id = "PKL-021"
  name = "typecheck incrementally through ripple dependency graph"
  description =
    "AnalysisSession registers source, parse, and typecheck query nodes with ripple so unrelated source edits do not re-run typechecking, and unchanged dependency type results are backdated."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-004"; "PKL-006"; "PKL-020" }
  tags { "typechecker"; "incremental"; "ripple" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Split module typechecking into parse and type queries"
      rationale =
        "Importing modules through a ripple type query lets dependency edges point at module type results instead of raw recursive calls, so unchanged inferred types can avoid downstream recomputation."
    }
    new Decision {
      date = "2026-05-14"
      summary = "Register ripple inputs and queries for deep verification"
      rationale =
        "Without registered verifiers, low-durability source edits conservatively invalidate too much work. Registering source, parse, and typecheck nodes lets ripple verify only the keys touched by a diff."
    }
  }
}

local callableTypechecking = new Scenario {
  id = "PKL-022"
  name = "typecheck Pkl function declarations lambdas and calls"
  description =
    "The typechecker resolves function declarations and lambda bindings at call sites, infers return types from argument-bound parameter types, and reports call arity and non-function call errors."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-018"; "PKL-019" }
  tags { "typechecker" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Typecheck callables without committing to evaluator closures"
      rationale =
        "The parser already retains function declarations, calls, and lambdas, but evaluator closure semantics are still separate work. A call-site typecheck model can validate Pkl function usage now by binding argument types to parameters while keeping runtime function evaluation out of scope."
    }
  }
}

local callableAnnotationTypechecking = new Scenario {
  id = "PKL-023"
  name = "typecheck Pkl callable parameter and return annotations"
  description =
    "Function declarations and lambda expressions retain parameter and return type annotations, and the typechecker validates call arguments plus annotated return values."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-022"; "PKL-008" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Preserve callable annotations in AST"
      rationale =
        "Call-site inference is useful for unannotated functions, but Pkl code commonly declares parameter and return contracts. Keeping these annotations in the parser AST lets the typechecker reject invalid calls and return bodies without implementing runtime function closures."
    }
  }
}

local nullableTypechecking = new Scenario {
  id = "PKL-024"
  name = "typecheck Pkl nullable annotations"
  description =
    "The parser preserves nullable type annotation suffixes such as `String?`, and the typechecker accepts null or the inner type while narrowing null-coalescing expressions."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-008"; "PKL-018"; "PKL-023" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Represent nullable annotations explicitly"
      rationale =
        "Pkl commonly uses `T?` for optional properties and parameters. Preserving the suffix in parser output and modeling it as a distinct type lets annotations accept null while keeping invalid inner values rejected."
    }
  }
}

local genericCollectionTypechecking = new Scenario {
  id = "PKL-025"
  name = "typecheck Pkl generic collection annotations"
  description =
    "The parser preserves generic annotation text for Listing and Mapping types, and the typechecker validates listing element and mapping key/value types."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-017"; "PKL-024" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Validate generic collection annotations structurally"
      rationale =
        "Collections already carry literal element and entry types. Parsing `Listing<T>` and `Mapping<K,V>` into expected element contracts catches mismatches without requiring a full Pkl generic type system yet."
    }
  }
}

local richTypealiasTypechecking = new Scenario {
  id = "PKL-026"
  name = "typecheck Pkl nullable and generic typealias annotations"
  description =
    "Typealias declarations preserve nullable and generic target annotation text, and the typechecker resolves aliases to nullable, Listing, and Mapping contracts."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-024"; "PKL-025" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Reuse annotation parsing for typealias targets"
      rationale =
        "Aliases are part of the type contract surface. Keeping only the first identifier loses optional and generic structure, so typealias parsing should preserve the same normalized annotation text as property and parameter annotations."
    }
  }
}

local unionTypechecking = new Scenario {
  id = "PKL-027"
  name = "typecheck Pkl union type annotations"
  description =
    "The parser preserves union annotation text such as `String | Int`, and the typechecker accepts values that match any union branch, including nested collection and callable annotations."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-023"; "PKL-025"; "PKL-026" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Model unions as explicit expected types"
      rationale =
        "Nullable and generic annotations cover common shapes, but Pkl modules also use union contracts. Representing unions in the typechecker keeps annotation acceptance precise without changing parser expression precedence."
    }
  }
}

local richTypeOperandTypechecking = new Scenario {
  id = "PKL-028"
  name = "typecheck rich Pkl is and as type operands"
  description =
    "`is` and `as` expressions preserve nullable, generic, and union type operand text, and the typechecker validates the referenced type before returning the Boolean or cast result type."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-018"; "PKL-027" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Use annotation text for type operands"
      rationale =
        "The parser already treats `is` and `as` right operands as type-like expressions. Reusing normalized annotation text prevents `String | Int` and collection operands from being truncated to the first identifier."
    }
  }
}

local isGuardTypeNarrowing = new Scenario {
  id = "PKL-029"
  name = "narrow union types through Pkl is guards"
  description =
    "The typechecker narrows union-typed identifiers inside `if (x is T)` branches so callable bodies and property expressions can use the guarded branch type."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-027"; "PKL-028" }
  tags { "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Track control-flow narrowing separately"
      rationale =
        "`is` operand validation is now implemented, but using that predicate to refine identifier types requires branch-local environments. Keeping narrowing as the next spec avoids mixing parser operand work with control-flow analysis."
    }
  }
}

local compoundGuardTypeNarrowing = new Scenario {
  id = "PKL-030"
  name = "narrow union types through compound Pkl boolean guards"
  description =
    "The typechecker carries `is` guard narrowing through compound Boolean conditions such as `x is Int && x > 0`, so guarded subexpressions and then branches see the narrowed type."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-029" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Keep compound guard flow as the next slice"
      rationale =
        "Direct `if (x is T)` narrowing is implemented. Conditions joined with `&&` need short-circuit-aware narrowing for the right side and the then branch, which is a separate control-flow step."
    }
  }
}

local nullGuardTypeNarrowing = new Scenario {
  id = "PKL-031"
  name = "narrow nullable types through Pkl null guards"
  description =
    "The typechecker narrows nullable identifiers through `x != null` and `x == null` guards so non-null branches can use the inner type without explicit coalescing."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-024"; "PKL-030" }
  tags { "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Continue guard narrowing with null checks"
      rationale =
        "The control-flow machinery now handles `is` guards and compound Boolean conditions. Nullable values are the next common branch-local refinement because `x != null` should expose the inner type in the guarded branch."
    }
  }
}

local nullablePostfixTypechecking = new Scenario {
  id = "PKL-032"
  name = "typecheck Pkl nullable postfix operators"
  description =
    "The parser and typechecker support nullable postfix operators such as non-null assertion `!!` and safe member access `?.`, producing inner or nullable member types with diagnostics for invalid targets."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-024"; "PKL-031" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Continue nullable semantics with postfix operators"
      rationale =
        "Nullable annotations, coalescing, and control-flow narrowing are now covered. Pkl's postfix null operators are the next parser/typechecker boundary before deeper object/member semantics."
    }
  }
}

local nullSafeInvocationTypechecking = new Scenario {
  id = "PKL-033"
  name = "typecheck Pkl null-safe invocation chains"
  description =
    "The parser and typechecker distinguish null-safe member invocation chains such as `value?.method()` from ordinary calls, preserving nullable short-circuit behavior through calls and chained accesses."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-032"; "PKL-022" }
  tags { "parser"; "typechecker"; "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Track null-safe invocation after safe member access"
      rationale =
        "Safe member access and non-null assertion are now modeled. Upstream Pkl fixtures also use `?.` before method calls, which needs call-chain semantics rather than treating the member lookup and call as independent expressions."
    }
  }
}

local classDefaultPropertyTypechecking = new Scenario {
  id = "PKL-034"
  name = "infer Pkl class property default types"
  description =
    "Class declarations use property default expressions as member type contracts when no explicit annotation is present, so assignments to declared class types still reject incompatible object members."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-019"; "PKL-022" }
  tags { "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Use class defaults as contract sources"
      rationale =
        "Class property AST already retains default expressions, but the typechecker currently treats unannotated class properties as Unknown. Inferring default expression types will make class contracts stricter without adding constructor semantics."
    }
  }
}

local classDefaultMemberCompletion = new Scenario {
  id = "PKL-035"
  name = "allow Pkl class property defaults to satisfy missing members"
  description =
    "Assignments to declared class types accept object literals that omit class properties with defaults, while still requiring properties without annotations or defaults."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-034" }
  tags { "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Track default-backed member completion separately"
      rationale =
        "Class default expressions now provide member contract types. The next class-semantics step is to distinguish required members from default-backed members so object literals can omit values that the class supplies."
    }
  }
}

local typedObjectExpressionTypechecking = new Scenario {
  id = "PKL-036"
  name = "typecheck Pkl typed object expressions"
  description =
    "Object literals that spell an explicit class name, such as `new Bird { ... }`, preserve that type in the AST and are checked against the class contract even without a separate property annotation."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-017"; "PKL-019"; "PKL-035" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Move class checking from annotations into object expressions"
      rationale =
        "The parser currently accepts `new Type { ... }` syntax but lowers non-collection names to plain object literals. Preserving the explicit type name will let class defaults and member contracts apply at the expression boundary."
    }
  }
}

local typedObjectDefaultEvaluation = new Scenario {
  id = "PKL-037"
  name = "evaluate Pkl typed object class defaults"
  description =
    "Typed object expressions such as `new Bird { ... }` materialize class property defaults during evaluation while preserving explicitly supplied object members as overrides."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-036"; "PKL-035" }
  tags { "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Make typed object evaluation match class default contracts"
      rationale =
        "Typed object expressions can now be checked against class contracts, but the evaluator still treats them as plain object literals. Materializing class defaults closes the gap between accepted `new Class {}` code and its runtime object value."
    }
  }
}

local classInheritanceDefaults = new Scenario {
  id = "PKL-038"
  name = "support Pkl class inheritance defaults"
  description =
    "Class declarations with inheritance merge base class property contracts and defaults so typed object expressions can omit inherited default-backed members and override inherited properties."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-037"; "PKL-036"; "PKL-019" }
  tags { "parser"; "typechecker"; "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Extend typed object semantics through class inheritance"
      rationale =
        "Typed object expressions now have class contracts and class default values. The next class-model step is to preserve inheritance clauses and reuse the same contract/default merge behavior across base and derived classes."
    }
  }
}

local classInheritanceQualifiedTypes = new Scenario {
  id = "PKL-039"
  name = "support Pkl qualified class inheritance types"
  description =
    "Class inheritance and typed object expressions preserve qualified class names such as `library.Person` so imported class contracts can be resolved through the analysis session."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-038"; "PKL-006"; "PKL-036" }
  tags { "parser"; "typechecker"; "imports" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Track cross-module class contract resolution after local inheritance"
      rationale =
        "Local class inheritance establishes contract/default merging. Pkl code also refers to imported class names with qualified paths, which requires preserving full type references and making imported declaration contracts available to the analysis session."
    }
  }
}

local classMethodDeclarations = new Scenario {
  id = "PKL-040"
  name = "model Pkl class method declarations"
  description =
    "Class bodies retain method declarations and typed object member access can resolve method signatures without treating methods as object properties."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-039"; "PKL-022" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Separate class methods from property contracts"
      rationale =
        "Class inheritance and imported class contracts are now property-focused. Pkl classes also contain methods, which need AST coverage and type signatures before method calls can be checked on typed objects."
    }
  }
}

local classMethodInvocationEvaluation = new Scenario {
  id = "PKL-041"
  name = "evaluate Pkl class method invocations"
  description =
    "Typed object method calls dispatch to class method bodies with receiver and argument bindings, while method declarations remain separate from object value members."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-040"; "PKL-022"; "PKL-037" }
  tags { "evaluator"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Defer runtime method dispatch until method signatures are modeled"
      rationale =
        "Class method declarations are now available to the parser and typechecker. Executing method bodies needs receiver-aware bindings and call dispatch in the interpreter, which is a separate runtime slice."
    }
  }
}

local callableEvaluation = new Scenario {
  id = "PKL-042"
  name = "evaluate Pkl function declarations lambdas and calls"
  description =
    "The evaluator can call top-level function declarations and lambda values with argument bindings, aligning runtime behavior with the callable AST and typechecker support."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-022"; "PKL-023"; "PKL-041" }
  tags { "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Move from method-only dispatch to general callable evaluation"
      rationale =
        "Method invocation now evaluates function bodies with scoped argument bindings. The same closure model should be generalized to top-level function declarations and lambda values without coupling it to class receiver lookup."
    }
  }
}

local classMethodBodyTypechecking = new Scenario {
  id = "PKL-043"
  name = "typecheck Pkl class method bodies with receiver bindings"
  description =
    "Class method bodies are checked with parameter bindings plus the receiver's property contract, so annotated method signatures reject invalid implementations before runtime."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-040"; "PKL-041"; "PKL-023" }
  tags { "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Close the method signature/body gap"
      rationale =
        "Class methods now have AST signatures and runtime dispatch. The remaining semantic gap is that method body expressions are not validated with receiver member types the way top-level callable bodies are checked at call sites."
    }
  }
}

local callableRuntimeValues = new Scenario {
  id = "PKL-044"
  name = "model Pkl callable runtime values"
  description =
    "The evaluator represents function and lambda expressions as callable runtime values so callables can be stored, passed as arguments, and invoked beyond direct AST call sites."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-042"; "PKL-023" }
  tags { "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Generalize callable evaluation into values"
      rationale =
        "Function declarations and lambda bindings can now be called directly. Pkl code also passes callables around, so the next runtime step is a proper callable value representation instead of only AST-pattern dispatch."
    }
  }
}

local constrainedTypeAnnotations = new Scenario {
  id = "PKL-045"
  name = "typecheck Pkl constrained type annotations"
  description =
    "Type annotations with constraint calls such as `Int(isBetween(0, 10))` retain their base type contract so stdlib-like signatures can be parsed and checked before full constraint evaluation exists."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-023"; "PKL-028"; "PKL-044" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Handle constraint annotations as base-type contracts first"
      rationale =
        "The upstream stdlib uses annotations like `Int(this.isBetween(...))`. Evaluating the constraint expressions is separate work, but recognizing the base type removes a common blocker for stdlib and method signatures."
    }
  }
}

local constrainedAnnotationEvaluation = new Scenario {
  id = "PKL-046"
  name = "evaluate Pkl constrained type annotation predicates"
  description =
    "Constrained annotations evaluate supported predicate expressions against the annotated value so contracts such as `Int(isBetween(0, 10))` can reject out-of-range values."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-045"; "PKL-041"; "PKL-044" }
  tags { "typechecker"; "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Move from base-type recognition to constraint checking"
      rationale =
        "Constraint annotation text now preserves the base type contract. The next step is evaluating supported predicates with receiver bindings instead of accepting every value that matches only the base type."
    }
  }
}

local constrainedParameterEvaluation = new Scenario {
  id = "PKL-047"
  name = "enforce Pkl constrained function parameter annotations"
  description =
    "Function and lambda calls validate constrained parameter annotations such as `x: Int(isBetween(0, 10))`, rejecting invalid arguments at call boundaries in the typechecker and evaluator."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-046"; "PKL-023"; "PKL-044" }
  tags { "typechecker"; "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Carry constrained annotation checks into callable boundaries"
      rationale =
        "Top-level and object member annotations now reject supported `isBetween` violations. Function parameters need the same contract enforcement so constraints continue to hold when values cross callable boundaries."
    }
  }
}

local constrainedCallableSignatureMetadata = new Scenario {
  id = "PKL-048"
  name = "preserve Pkl constrained callable signature metadata"
  description =
    "Callable values retain constrained parameter annotations through aliases and stored callable values so the typechecker can reject invalid calls after functions are assigned to other names."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-047"; "PKL-044"; "PKL-028" }
  tags { "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Track callable constraints beyond direct AST calls"
      rationale =
        "Direct function and lambda calls now check constrained parameter annotations, and runtime callable values keep the original parameters. The typechecker still erases constraint text into plain function types when callables flow through aliases or higher-order parameters."
    }
  }
}

local constrainedHigherOrderCallableMetadata = new Scenario {
  id = "PKL-049"
  name = "propagate Pkl constrained callable metadata through higher-order calls"
  description =
    "The typechecker preserves constrained callable metadata when functions are passed as higher-order arguments, so downstream calls through parameters can still reject invalid constrained arguments when enough static information is available."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-048"; "PKL-047"; "PKL-044" }
  tags { "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Keep higher-order callable constraints separate"
      rationale =
        "Callable aliases now keep constrained parameter metadata in function types. Propagating those contracts through higher-order parameters needs richer flow-sensitive call information than simple aliases."
    }
  }
}

local constrainedMethodParameterEvaluation = new Scenario {
  id = "PKL-050"
  name = "enforce Pkl constrained method parameter annotations"
  description =
    "Class method calls validate constrained method parameter annotations in the typechecker and evaluator, so typed object method calls reject invalid constrained arguments."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-049"; "PKL-041"; "PKL-046" }
  tags { "typechecker"; "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Apply constrained callable checks to method dispatch"
      rationale =
        "Free functions and callable aliases now preserve and check constrained arguments. Class method calls still need the same contract treatment through receiver-based method lookup and member-call typechecking."
    }
  }
}

local constrainedTypealiasMetadata = new Scenario {
  id = "PKL-051"
  name = "preserve Pkl constrained typealias metadata"
  description =
    "Type aliases that target constrained annotations such as `typealias Small = Int(isBetween(0, 10))` preserve enough metadata for annotated values and callable parameters to keep enforcing the constraint."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-050"; "PKL-045"; "PKL-028" }
  tags { "typechecker"; "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Carry constrained annotations through aliases"
      rationale =
        "Constraint metadata now survives callable aliases and method calls, but type aliases still resolve primarily to their base type. Alias targets need to preserve supported constraint metadata before more stdlib-style signatures can be checked."
    }
  }
}

local constrainedTypealiasObjectMembers = new Scenario {
  id = "PKL-052"
  name = "evaluate Pkl constrained typealias object member annotations"
  description =
    "Object member annotations that use constrained type aliases preserve alias metadata during evaluation, so nested object values reject invalid constrained members."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-051"; "PKL-046"; "PKL-017" }
  tags { "evaluator"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Move alias metadata into nested object evaluation"
      rationale =
        "Constrained type aliases now work for top-level values and callable parameter typechecking. Evaluating nested object member annotations needs alias metadata to flow through object evaluation instead of only the top-level binding loop."
    }
  }
}

local numericConstraintPredicates = new Scenario {
  id = "PKL-053"
  name = "support additional Pkl numeric constraint predicates"
  description =
    "Constrained integer annotations support common numeric predicate calls beyond `isBetween`, such as greater-than and less-than checks, in both typechecking and evaluation paths."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-052"; "PKL-046"; "PKL-051" }
  tags { "typechecker"; "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Broaden constraint predicate coverage after metadata flow"
      rationale =
        "Constraint metadata now survives values, callable boundaries, methods, aliases, and nested object members for `isBetween`. The next compatibility step is expanding the supported numeric predicate set used by real Pkl schemas."
    }
  }
}

local multipleConstraintPredicates = new Scenario {
  id = "PKL-054"
  name = "support multiple Pkl type constraint predicates"
  description =
    "Type annotations with multiple constraints, such as `Int(isPositive, isBetween(0, 10))`, evaluate each supported predicate and reject values that violate any predicate."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-053"; "PKL-046"; "PKL-052" }
  tags { "typechecker"; "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Evaluate constraint lists after individual predicates"
      rationale =
        "The parser already preserves comma-separated constraint text from upstream fixtures. Once individual numeric predicates are supported, the next step is splitting top-level constraint lists and checking each supported predicate."
    }
  }
}

local negatedConstraintPredicates = new Scenario {
  id = "PKL-055"
  name = "support negated Pkl type constraint predicates"
  description =
    "Type annotations with negated constraints, such as `Int(!isPositive)`, invert supported predicate results in typechecking and evaluation paths."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-054"; "PKL-053"; "PKL-046" }
  tags { "typechecker"; "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Add constraint negation after list evaluation"
      rationale =
        "Upstream fixtures include negated constraints such as `!isPositive`. Once constraint lists are evaluated in order, negation can be represented as a predicate wrapper without changing the surrounding metadata flow."
    }
  }
}

local userDefinedConstraintFunctions = new Scenario {
  id = "PKL-056"
  name = "evaluate Pkl user-defined type constraint functions"
  description =
    "Type constraints can call user-defined predicate factories such as `isGreaterThan(5)`, so supported function declarations can participate in annotation checking instead of being matched only by built-in names."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-055"; "PKL-044"; "PKL-046" }
  tags { "typechecker"; "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Move from name-matched constraints to callable predicates"
      rationale =
        "Built-in-style numeric predicates and negation are now supported by syntax matching. Upstream fixtures also define custom predicate factories; evaluating those requires connecting type-constraint expressions to callable runtime/typecheck information."
    }
  }
}

local constFunctionDeclarations = new Scenario {
  id = "PKL-057"
  name = "parse Pkl const function declarations"
  description =
    "Const-qualified function declarations such as `const function isGreaterThan(n) = (x) -> x > n` parse as function declarations, so upstream constraint-factory fixtures can use their original syntax."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-056"; "PKL-015" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Handle declaration modifiers after callable constraints"
      rationale =
        "User-defined constraint factories now work for plain function declarations. Upstream fixtures commonly mark these declarations as `const`, so the parser needs to accept modifier-qualified function declarations before those fixtures can run unchanged."
    }
  }
}

local constrainedClassProperties = new Scenario {
  id = "PKL-058"
  name = "evaluate Pkl constrained class property annotations"
  description =
    "Typed object values enforce constrained class property annotations, including user-defined numeric constraint factories from top-level function declarations."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-057"; "PKL-056"; "PKL-035" }
  tags { "evaluator"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Move constraint checks into class property materialization"
      rationale =
        "Upstream constraints fixtures combine `const function` predicate factories with class property annotations. The parser can now keep those declarations, so typed object evaluation and checking need to enforce the constrained property contracts."
    }
  }
}

local constrainedClassPropertyDefaults = new Scenario {
  id = "PKL-059"
  name = "evaluate Pkl constrained class property default values"
  description =
    "Class property default expressions enforce their constrained annotations during typechecking and evaluation, including user-defined numeric constraint factories."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-058"; "PKL-057"; "PKL-056" }
  tags { "evaluator"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Apply class property constraints to defaults as well as overrides"
      rationale =
        "Typed object overrides now honor constrained class property annotations. Class defaults are materialized through a separate path, so the same annotation checks need to run for default expressions before class constraints are complete."
    }
  }
}

local pklTestCatchConstraintsFixture = new Scenario {
  id = "PKL-060"
  name = "evaluate upstream Pkl constraint fixture catch flow"
  description =
    "The evaluator supports enough of `pkl:test.catch` and lazy lambda invocation to run upstream constraint fixtures that capture failed constrained object construction."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-059"; "PKL-058"; "PKL-011" }
  tags { "evaluator"; "stdlib"; "upstream" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Turn class constraint support into an upstream fixture"
      rationale =
        "User-defined class property constraints and defaults now work in direct tests. The next compatibility slice should exercise the upstream `classes/constraints8.pkl` shape, which relies on `pkl:test.catch` to observe a rejected object."
    }
  }
}

local callableClosureCaptures = new Scenario {
  id = "PKL-061"
  name = "evaluate simple Pkl callable closure captures"
  description =
    "Function and lambda values preserve simple scalar lexical bindings so returned lambdas and higher-order callables can evaluate variables from their defining scope."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-044"; "PKL-060" }
  tags { "evaluator"; "callable" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Generalize callable values after catch-specific lazy invocation"
      rationale =
        "`pkl:test.catch` now evaluates a lazy lambda in a targeted path, and user-defined constraint factories are still recognized structurally. Full callable compatibility needs function values to retain lexical captures instead of relying on call-site caches."
    }
  }
}

local nonScalarClosureCaptures = new Scenario {
  id = "PKL-062"
  name = "evaluate non-scalar Pkl callable closure captures"
  description =
    "Function and lambda values preserve captured object and callable bindings instead of only scalar literals."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-061"; "PKL-044" }
  tags { "evaluator"; "callable" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Move closure capture from literal substitution to value environments"
      rationale =
        "Simple scalar captures can be represented by substituting literal AST nodes, but object and callable captures need a real environment-preserving function value representation."
    }
  }
}

local callableReturnAnnotationEvaluation = new Scenario {
  id = "PKL-063"
  name = "evaluate Pkl callable return annotations"
  description =
    "Function and lambda calls validate declared return annotations at runtime so callable values reject bodies that return incompatible values."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-062"; "PKL-044"; "PKL-023" }
  tags { "evaluator"; "callable" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Use preserved callable metadata for runtime return checks"
      rationale =
        "Callable values now carry lexical environments and still preserve return annotation text. The evaluator should enforce those annotations at call boundaries instead of leaving return validation only to the typechecker."
    }
  }
}

local classMethodReturnAnnotationEvaluation = new Scenario {
  id = "PKL-064"
  name = "evaluate Pkl class method return annotations"
  description =
    "Class method calls validate declared return annotations at runtime so method bodies reject incompatible returned values."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-063"; "PKL-036"; "PKL-040" }
  tags { "evaluator"; "class"; "next" }
  reviewStatus = "draft"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Extend runtime return validation to methods"
      rationale =
        "Function and lambda values now enforce return annotations at call boundaries. Class methods carry the same return annotation metadata but use a separate receiver-aware evaluation path, so they need the same runtime check."
    }
  }
}

