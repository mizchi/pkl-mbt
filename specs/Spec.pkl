amends "../pkspec/Spec.pkl"

import "Roadmap.pkl" as roadmap

feature = "Pure MoonBit Pkl parser and interpreter"

local pureMoonBitCore = new Goal {
  id = "GOAL-PKL-PURE"
  name = "Pure MoonBit Pkl core"
  description =
    "Provide a MoonBit-only Pkl parser, evaluator, and typechecker core that can run without a native Pkl dependency."
  priority = 100
  reviewStatus = "approved"
  rationale =
    "The project should be embeddable in MoonBit targets and keep implementation layers regenerable from strict contracts."
}

local parseArithmetic = new Scenario {
  id = "PKL-001"
  name = "parse arithmetic expressions"
  description =
    "The parser builds a CST-backed program for integer arithmetic expressions and preserves source length."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Start with expression parsing as the first executable slice"
      rationale =
        "Arithmetic precedence is small enough for TDD and exercises the cst-backed parser shape."
    }
  }
}

local evalArithmetic = new Scenario {
  id = "PKL-002"
  name = "evaluate arithmetic and let bindings"
  description =
    "The interpreter evaluates integer arithmetic with precedence and resolves top-level let bindings."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "critical"
}

local rejectInvalidTypes = new Scenario {
  id = "PKL-003"
  name = "reject invalid integer operations"
  description = "The typechecker rejects binary arithmetic when either operand is not an Int."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "critical"
}

local incrementalTypecheck = new Scenario {
  id = "PKL-004"
  name = "typecheck source through ripple"
  description =
    "A source-backed analysis session uses ripple input and query nodes to recompute typechecking after source changes."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
}

local pklObjectModel = new Scenario {
  id = "PKL-005"
  name = "support initial Pkl object and module syntax"
  description =
    "The parser accepts module declarations, top-level properties, object literals, and member access; evaluator and typechecker resolve object fields."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Add object/module syntax before import and stdlib work"
      rationale =
        "Object fields and member lookup are the minimum model needed before import resolution or richer Pkl type semantics can be useful."
    }
  }
}

local pklImports = new Scenario {
  id = "PKL-006"
  name = "support Pkl imports and module resolution"
  description =
    "Import clauses resolve modules from the AnalysisSession source graph and make imported modules available for evaluation and typechecking."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Resolve import clauses through AnalysisSession inputs"
      rationale =
        "A source-backed resolver keeps the implementation pure MoonBit and lets ripple track imported source dependencies."
    }
  }
}

local pklStdlib = new Scenario {
  id = "PKL-007"
  name = "support Pkl standard library surface"
  description =
    "The AnalysisSession resolver recognizes selected pkl: standard library modules and exposes them as pure MoonBit module sources."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Seed standard library support with pkl:math"
      rationale =
        "Representing pkl: modules as built-in source keeps the parser/evaluator path uniform while letting coverage grow incrementally."
    }
  }
}

local pklRichTypes = new Scenario {
  id = "PKL-008"
  name = "support richer Pkl type semantics"
  description =
    "The parser and typechecker accept primitive Pkl-style type annotations and reject mismatched property/member values."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Start richer type semantics with primitive annotations"
      rationale =
        "Primitive annotations provide a testable type contract before class, union, and runtime validation semantics are added."
    }
  }
}

local pklCli = new Scenario {
  id = "PKL-009"
  name = "provide a usable CLI"
  description =
    "The native command-line entrypoint can parse, typecheck, and evaluate Pkl source files."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Add parse/check/eval native CLI subcommands"
      rationale =
        "A small CLI gives pkspec an end-to-end surface while the embeddable AnalysisSession remains the core API."
    }
  }
}

local pklStringEscapes = new Scenario {
  id = "PKL-010"
  name = "support Pkl string escape compatibility"
  description =
    "Common string escapes are decoded by the parser and rendered by the evaluator/CLI output path."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Decode and render common string escapes"
      rationale =
        "Escaped quotes and line breaks are required for realistic module properties and CLI output."
    }
  }
}

local upstreamPklFixtures = new Scenario {
  id = "PKL-011"
  name = "use upstream apple/pkl fixtures as compatibility checks"
  description =
    "The contract suite references Apple's Pkl repository as a git submodule and runs selected upstream LanguageSnippetTests fixtures through the pure MoonBit CLI."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Track upstream Pkl fixtures through a git submodule"
      rationale =
        "The implementation is still a Pkl subset, so an explicit smoke list keeps upstream compatibility executable without pretending the full upstream suite is supported."
    }
  }
}

local pklCommentsAndForwardRefs = new Scenario {
  id = "PKL-012"
  name = "support Pkl comments and module property forward references"
  description =
    "The lexer preserves line/block comments as trivia, and module property evaluation/typechecking resolves sibling properties regardless of declaration order."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Add trivia comments and lazy module property resolution"
      rationale =
        "Upstream snippets commonly use comments, and apple/pkl fixtures such as basic/import1.pkl rely on module properties referencing later sibling properties."
    }
  }
}

local pklObjectBodyProperties = new Scenario {
  id = "PKL-013"
  name = "support Pkl object body property shorthand"
  description =
    "Module and object members can use `name { ... }` object bodies as shorthand for object-valued properties."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Parse object body property shorthand"
      rationale =
        "Apple Pkl snippets use nested object bodies heavily; modules/objects.pkl is the smallest upstream fixture for this syntax."
    }
  }
}

local pklLocalAndImportExpressions = new Scenario {
  id = "PKL-014"
  name = "support Pkl local module bindings and import expressions"
  description =
    "Module-level `local` bindings are available to sibling properties without being exported, and `import(\"...\")` expressions resolve through the same pure MoonBit module resolver as import clauses."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Add local bindings and import expressions"
      rationale =
        "Apple Pkl's basic/import2.pkl fixture uses `local i = import(\"imported.pkl\")`, so import expressions need to participate in both analysis and CLI file loading."
    }
  }
}

local upstreamParserSuite = new Scenario {
  id = "PKL-015"
  name = "parse upstream apple/pkl snippet corpus"
  description =
    "The native parser accepts every syntactically valid fixture selected by apple/pkl's ParserComparisonTest LanguageSnippetTests input corpus."
  contributes { "GOAL-PKL-PURE" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Use apple/pkl ParserComparisonTest exclusions for parse-only compatibility"
      rationale =
        "Parser completion needs a broad upstream oracle. Matching the upstream parser test's invalid fixture exclusions gives this project an executable parse coverage target without requiring evaluator/typechecker parity."
    }
  }
}

local unsupportedSyntaxInventory = new Scenario {
  id = "PKL-016"
  name = "inventory unsupported syntax in tolerant parser output"
  description =
    "ParseResult exposes an unsupported_syntax coverage report with source ranges, text, and syntax kind for accepted code that still lowers to UnsupportedExpr."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-015" }
  tags { "parser" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Make parser completion resume from unsupported syntax inventory"
      rationale =
        "The parser now accepts the upstream corpus, but many constructs are intentionally tolerant. The next parser work needs a measurable unsupported-syntax inventory before expanding AST coverage."
    }
    new Decision {
      date = "2026-05-14"
      summary = "Expose unsupported syntax separately from parser diagnostics"
      rationale =
        "Unsupported syntax is an implementation coverage gap in otherwise accepted input, not a parse error. Keeping it on ParseResult preserves tolerant parsing while making the remaining AST work measurable."
    }
  }
}

local collectionExpressions = new Scenario {
  id = "PKL-017"
  name = "parse and evaluate Pkl collection expressions"
  description =
    "The parser lowers explicit `new Listing` elements and `new Mapping` entries into AST nodes, and evaluator/typechecker support collection values plus subscript access without using UnsupportedExpr."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-013"; "PKL-014" }
  tags { "parser"; "evaluator"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Start collection semantics with explicit Listing and Mapping values"
      rationale =
        "Explicit `new Listing` elements, `new Mapping` entries, and subscript access are a small interpreter slice that establishes public Value/Type shapes before broader object amendments and collection generators."
    }
  }
}

local callableExpressions = new Scenario {
  id = "PKL-018"
  name = "parse Pkl call lambda and operator expressions"
  description =
    "The parser lowers calls, lambdas, unary operators, comparisons, boolean operators, null-coalescing, and conditional expressions into explicit AST nodes with precedence matching Pkl."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-016" }
  tags { "parser" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Split expression AST coverage from declaration work"
      rationale =
        "Calls, lambdas, and non-arithmetic operators are a coherent parser precedence problem and can be tested independently from classes and module inheritance."
    }
    new Decision {
      date = "2026-05-14"
      summary = "Keep calls and lambdas parser-only while enabling simple expression semantics"
      rationale =
        "Call and function-value evaluation need a closure model and function declaration environment. This slice only makes them structured AST nodes; boolean, comparison, coalescing, unary, and conditional expressions are small enough to typecheck and evaluate directly."
    }
  }
}

local declarationsAndClassTypes = new Scenario {
  id = "PKL-019"
  name = "model Pkl class function and typealias declarations"
  description =
    "Program retains class, function, and typealias declarations, and the typechecker resolves declared class and typealias names in property annotations."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-016"; "PKL-008" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Track declaration AST work as the typechecker bridge"
      rationale =
        "The parser currently skips declarations to keep parse-only compatibility. Typechecker progress needs declarations preserved as structured contracts."
    }
    new Decision {
      date = "2026-05-14"
      summary = "Keep functions parse-only and use class properties as contracts"
      rationale =
        "Function evaluation is outside this slice, but retaining function declarations prevents parser coverage from hiding them. Class properties provide enough structure to validate object literals assigned to declared class annotations."
    }
  }
}

local moduleInheritanceAndAmends = new Scenario {
  id = "PKL-020"
  name = "support module extends amends and object amendments"
  description =
    "Module `extends`/`amends` clauses and object amendment syntax merge inherited members through AnalysisSession resolution for parsing, evaluation, and typechecking."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-006"; "PKL-013"; "PKL-019" }
  tags { "parser"; "evaluator"; "typechecker" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Make amends and extends the next semantic milestone"
      rationale =
        "Real Pkl modules compose through amends and extends. This is the next end-to-end semantic milestone after AST coverage for declarations and object bodies."
    }
    new Decision {
      date = "2026-05-14"
      summary = "Share one property merge model for modules and object amendments"
      rationale =
        "Module amends/extends and `(base) { ... }` both start with inherited members, replace matching names, and append new members. Class inheritance remains separate from this slice because it also needs constructor and method semantics."
    }
  }
}

local incrementalTypecheckGraph = new Scenario {
  id = "PKL-021"
  name = "typecheck incrementally through ripple dependency graph"
  description =
    "AnalysisSession registers source, parse, and typecheck query nodes with ripple so unrelated source edits do not re-run typechecking, and unchanged dependency type results are backdated."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-004"; "PKL-006"; "PKL-020" }
  tags { "typechecker"; "incremental"; "ripple" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Split module typechecking into parse and type queries"
      rationale =
        "Importing modules through a ripple type query lets dependency edges point at module type results instead of raw recursive calls, so unchanged inferred types can avoid downstream recomputation."
    }
    new Decision {
      date = "2026-05-14"
      summary = "Register ripple inputs and queries for deep verification"
      rationale =
        "Without registered verifiers, low-durability source edits conservatively invalidate too much work. Registering source, parse, and typecheck nodes lets ripple verify only the keys touched by a diff."
    }
  }
}

local callableTypechecking = new Scenario {
  id = "PKL-022"
  name = "typecheck Pkl function declarations lambdas and calls"
  description =
    "The typechecker resolves function declarations and lambda bindings at call sites, infers return types from argument-bound parameter types, and reports call arity and non-function call errors."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-018"; "PKL-019" }
  tags { "typechecker" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Typecheck callables without committing to evaluator closures"
      rationale =
        "The parser already retains function declarations, calls, and lambdas, but evaluator closure semantics are still separate work. A call-site typecheck model can validate Pkl function usage now by binding argument types to parameters while keeping runtime function evaluation out of scope."
    }
  }
}

local callableAnnotationTypechecking = new Scenario {
  id = "PKL-023"
  name = "typecheck Pkl callable parameter and return annotations"
  description =
    "Function declarations and lambda expressions retain parameter and return type annotations, and the typechecker validates call arguments plus annotated return values."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-022"; "PKL-008" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Preserve callable annotations in AST"
      rationale =
        "Call-site inference is useful for unannotated functions, but Pkl code commonly declares parameter and return contracts. Keeping these annotations in the parser AST lets the typechecker reject invalid calls and return bodies without implementing runtime function closures."
    }
  }
}

local nullableTypechecking = new Scenario {
  id = "PKL-024"
  name = "typecheck Pkl nullable annotations"
  description =
    "The parser preserves nullable type annotation suffixes such as `String?`, and the typechecker accepts null or the inner type while narrowing null-coalescing expressions."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-008"; "PKL-018"; "PKL-023" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "critical"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Represent nullable annotations explicitly"
      rationale =
        "Pkl commonly uses `T?` for optional properties and parameters. Preserving the suffix in parser output and modeling it as a distinct type lets annotations accept null while keeping invalid inner values rejected."
    }
  }
}

local genericCollectionTypechecking = new Scenario {
  id = "PKL-025"
  name = "typecheck Pkl generic collection annotations"
  description =
    "The parser preserves generic annotation text for Listing and Mapping types, and the typechecker validates listing element and mapping key/value types."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-017"; "PKL-024" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Validate generic collection annotations structurally"
      rationale =
        "Collections already carry literal element and entry types. Parsing `Listing<T>` and `Mapping<K,V>` into expected element contracts catches mismatches without requiring a full Pkl generic type system yet."
    }
  }
}

local richTypealiasTypechecking = new Scenario {
  id = "PKL-026"
  name = "typecheck Pkl nullable and generic typealias annotations"
  description =
    "Typealias declarations preserve nullable and generic target annotation text, and the typechecker resolves aliases to nullable, Listing, and Mapping contracts."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-024"; "PKL-025" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-14"
      summary = "Reuse annotation parsing for typealias targets"
      rationale =
        "Aliases are part of the type contract surface. Keeping only the first identifier loses optional and generic structure, so typealias parsing should preserve the same normalized annotation text as property and parameter annotations."
    }
  }
}

local unionTypechecking = new Scenario {
  id = "PKL-027"
  name = "typecheck Pkl union type annotations"
  description =
    "The parser preserves union annotation text such as `String | Int`, and the typechecker accepts values that match any union branch, including nested collection and callable annotations."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-023"; "PKL-025"; "PKL-026" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Model unions as explicit expected types"
      rationale =
        "Nullable and generic annotations cover common shapes, but Pkl modules also use union contracts. Representing unions in the typechecker keeps annotation acceptance precise without changing parser expression precedence."
    }
  }
}

local richTypeOperandTypechecking = new Scenario {
  id = "PKL-028"
  name = "typecheck rich Pkl is and as type operands"
  description =
    "`is` and `as` expressions preserve nullable, generic, and union type operand text, and the typechecker validates the referenced type before returning the Boolean or cast result type."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-018"; "PKL-027" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Use annotation text for type operands"
      rationale =
        "The parser already treats `is` and `as` right operands as type-like expressions. Reusing normalized annotation text prevents `String | Int` and collection operands from being truncated to the first identifier."
    }
  }
}

local isGuardTypeNarrowing = new Scenario {
  id = "PKL-029"
  name = "narrow union types through Pkl is guards"
  description =
    "The typechecker narrows union-typed identifiers inside `if (x is T)` branches so callable bodies and property expressions can use the guarded branch type."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-027"; "PKL-028" }
  tags { "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Track control-flow narrowing separately"
      rationale =
        "`is` operand validation is now implemented, but using that predicate to refine identifier types requires branch-local environments. Keeping narrowing as the next spec avoids mixing parser operand work with control-flow analysis."
    }
  }
}

local compoundGuardTypeNarrowing = new Scenario {
  id = "PKL-030"
  name = "narrow union types through compound Pkl boolean guards"
  description =
    "The typechecker carries `is` guard narrowing through compound Boolean conditions such as `x is Int && x > 0`, so guarded subexpressions and then branches see the narrowed type."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-029" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Keep compound guard flow as the next slice"
      rationale =
        "Direct `if (x is T)` narrowing is implemented. Conditions joined with `&&` need short-circuit-aware narrowing for the right side and the then branch, which is a separate control-flow step."
    }
  }
}

local nullGuardTypeNarrowing = new Scenario {
  id = "PKL-031"
  name = "narrow nullable types through Pkl null guards"
  description =
    "The typechecker narrows nullable identifiers through `x != null` and `x == null` guards so non-null branches can use the inner type without explicit coalescing."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-024"; "PKL-030" }
  tags { "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Continue guard narrowing with null checks"
      rationale =
        "The control-flow machinery now handles `is` guards and compound Boolean conditions. Nullable values are the next common branch-local refinement because `x != null` should expose the inner type in the guarded branch."
    }
  }
}

local nullablePostfixTypechecking = new Scenario {
  id = "PKL-032"
  name = "typecheck Pkl nullable postfix operators"
  description =
    "The parser and typechecker support nullable postfix operators such as non-null assertion `!!` and safe member access `?.`, producing inner or nullable member types with diagnostics for invalid targets."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-024"; "PKL-031" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Continue nullable semantics with postfix operators"
      rationale =
        "Nullable annotations, coalescing, and control-flow narrowing are now covered. Pkl's postfix null operators are the next parser/typechecker boundary before deeper object/member semantics."
    }
  }
}

local nullSafeInvocationTypechecking = new Scenario {
  id = "PKL-033"
  name = "typecheck Pkl null-safe invocation chains"
  description =
    "The parser and typechecker distinguish null-safe member invocation chains such as `value?.method()` from ordinary calls, preserving nullable short-circuit behavior through calls and chained accesses."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-032"; "PKL-022" }
  tags { "parser"; "typechecker"; "evaluator" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Track null-safe invocation after safe member access"
      rationale =
        "Safe member access and non-null assertion are now modeled. Upstream Pkl fixtures also use `?.` before method calls, which needs call-chain semantics rather than treating the member lookup and call as independent expressions."
    }
  }
}

local classDefaultPropertyTypechecking = new Scenario {
  id = "PKL-034"
  name = "infer Pkl class property default types"
  description =
    "Class declarations use property default expressions as member type contracts when no explicit annotation is present, so assignments to declared class types still reject incompatible object members."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-019"; "PKL-022" }
  tags { "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Use class defaults as contract sources"
      rationale =
        "Class property AST already retains default expressions, but the typechecker currently treats unannotated class properties as Unknown. Inferring default expression types will make class contracts stricter without adding constructor semantics."
    }
  }
}

local classDefaultMemberCompletion = new Scenario {
  id = "PKL-035"
  name = "allow Pkl class property defaults to satisfy missing members"
  description =
    "Assignments to declared class types accept object literals that omit class properties with defaults, while still requiring properties without annotations or defaults."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-034" }
