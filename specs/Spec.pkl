    }
  }
}

local typedObjectExpressionTypechecking = new Scenario {
  id = "PKL-036"
  name = "typecheck Pkl typed object expressions"
  description =
    "Object literals that spell an explicit class name, such as `new Bird { ... }`, preserve that type in the AST and are checked against the class contract even without a separate property annotation."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-017"; "PKL-019"; "PKL-035" }
  tags { "parser"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Move class checking from annotations into object expressions"
      rationale =
        "The parser currently accepts `new Type { ... }` syntax but lowers non-collection names to plain object literals. Preserving the explicit type name will let class defaults and member contracts apply at the expression boundary."
    }
  }
}

local typedObjectDefaultEvaluation = new Scenario {
  id = "PKL-037"
  name = "evaluate Pkl typed object class defaults"
