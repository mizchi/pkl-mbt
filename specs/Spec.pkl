local userDefinedConstrainedCallableArgumentEvaluation = new Scenario {
  id = "PKL-066"
  name = "evaluate user-defined constrained Pkl callable arguments"
  description =
    "Function, lambda, and class method calls enforce user-defined numeric predicate factories on parameter annotations at runtime, matching the existing built-in numeric predicate behavior."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-065"; "PKL-056" }
  tags { "evaluator"; "callable" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Extend argument validation to user-defined constraint predicates"
      rationale =
        "Return validation now applies built-in and user-defined predicates, but callable and method parameter checks only run the built-in predicate machinery. Extending the parameter validation to call the user-defined predicate helper closes the symmetry gap."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Share a callable argument rejection helper"
      rationale =
        "Both eval_lambda_application and eval_class_method_call needed to combine the built-in and user-defined predicate checks. A shared eval_callable_argument_rejection_message helper keeps the message format aligned with the existing argument diagnostics and avoids duplicating the predicate cascade."
    }
  }
}

local constrainedCallableReturnBodyTypechecking = new Scenario {
  id = "PKL-067"
  name = "typecheck constrained Pkl callable return bodies"
  description =
    "Function, lambda, and class method declarations whose body is a literal that violates the declared constrained return annotation are rejected by the typechecker, mirroring the existing constrained binding behavior for built-in and user-defined numeric predicates."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-065"; "PKL-066" }
  tags { "typechecker"; "callable" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Lift literal-body return checks into the typechecker"
      rationale =
        "Constrained value bindings already use push_constrained_type_annotation_expr_diagnostic and the user-defined variant to flag literal violations at typecheck time. Callable return bodies currently only run the runtime check, leaving a static-analysis gap when the body is a known literal."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Walk declarations once at typecheck entry"
      rationale =
        "Function and class method bodies are visited from different paths in the inference flow, so a dedicated post-typecheck walker that visits all declarations once keeps the rule centralized and avoids threading declarations through every infer_call path."
    }
  }
}

local typeAliasedCallableReturnEvaluation = new Scenario {
  id = "PKL-068"
  name = "evaluate typealiased Pkl callable return annotations"
  description =
    "Function, lambda, and class method return annotations whose declared type name is a typealias resolve through the alias chain at runtime, accepting alias targets such as Int when the alias is declared as typealias Small = Int."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-065"; "PKL-039" }
  tags { "evaluator"; "callable"; "typealias" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Resolve callable return aliases before runtime base-type validation"
      rationale =
        "eval_value_accepts_type_annotation rejects typealiased return annotations because it only matches the literal alias name against the value type. Value bindings already resolve aliases through the type alias environment, and the same resolution should happen for callable returns so user code can name the return through a typealias."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Preserve the alias display name in diagnostics"
      rationale =
        "The constraint rejection helpers accept separate display and source names, so the runtime can resolve the alias to drive the base-type and constraint checks while still surfacing the alias in the user-facing diagnostic for parity with constrained value binding messages."
    }
  }
}

local pcfRendererPrimitives = new Scenario {
  id = "PKL-070"
  name = "render Pkl values as PCF primitives"
  description =
    "Module rendering as the canonical Pkl Configuration Format (PCF) emits Int, Boolean, String, and Null values with the same lexical form Apple Pkl uses, so module bindings reparse to the same value graph and the basic LanguageSnippetTests fixtures match the upstream gold output byte-for-byte."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "renderer"; "pcf" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Lock the existing CLI renderer in as the PCF baseline"
      rationale =
        "The CLI `eval` command already emits PCF-shaped output for Int, Boolean, String, and Null primitives, and the basic upstream parens / import1 fixtures match the gold .pcf files byte-for-byte. PKL-070 locks that contract with explicit unit tests, a round-trip test, and a doc comment on render_value identifying it as the PCF entry point so future JSON / YAML renderers (PKL-072..074) land alongside without ambiguity."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer Float values to a dedicated slice"
      rationale =
        "Float values, literals, and the matching FloatType are not yet in the AST, evaluator, or typechecker. Adding them would inflate PKL-070 well beyond a renderer slice, so Float rendering is queued as a follow-up alongside Float constraint predicates (PKL-092)."
    }
  }
}

local pcfRendererObjects = new Scenario {
  id = "PKL-071"
  name = "render Pkl objects and listings as PCF"
  description =
    "PCF rendering emits nested objects, listings, and mappings with the brace / element conventions Apple Pkl uses, including 2-space indentation, type-tag-free `new { ... }` wrappers for non-scalar listing / mapping values, and the empty `{}` form. The basic, modules, and classes upstream fixtures match the gold `.pcf` output byte-for-byte."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-070" }
  tags { "renderer"; "pcf" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Drop the explicit type tag from nested PCF blocks"
      rationale =
        "Apple Pkl PCF emits `new { ... }` (no `Listing` / `Mapping` / `Dynamic` tag) for non-scalar values that appear as listing elements or mapping keys / values, and `name { ... }` for typed and untyped block-valued properties. Re-introducing the tags broke byte-for-byte parity with the upstream gold outputs."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Treat module top-level as ObjectValue with a flat layout"
      rationale =
        "The CLI evaluation result is always an ObjectValue at the module boundary, so render_value treats ObjectValue at the entry point as a module (no enclosing braces, no indentation, members on their own lines) and dispatches every nested value through the inline path. This keeps the top-level layout indistinguishable from `pkl eval` and lets render_value still produce a self-contained value for non-module callers such as pkl:test.catch."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Skip the listing / mapping round-trip test"
      rationale =
        "PCF rendering drops the `Listing` / `Mapping` tag and uses Pkl's listing / mapping shorthand syntax for elements, which this evaluator's parser does not yet accept. The round-trip unit test stays on the object-member subset until the parser slice that accepts the shorthand lands; byte-for-byte parity with upstream gold output is enforced via the upstream smoke check instead."
    }
  }
}

local jsonRenderer = new Scenario {
  id = "PKL-072"
  name = "render Pkl values as JSON"
  description =
    "The CLI `eval -f json` (or `--format json`) flag emits a JSON document matching Apple Pkl's `pkl eval -f json` shape: ObjectValue and MappingValue project to JSON objects (Mapping keys are coerced to strings), ListingValue projects to JSON arrays, IntValue / BoolValue / NullValue use the JSON scalar form, and StringValue applies the standard `\"`, `\\`, control-character (`\\b`, `\\f`, `\\n`, `\\r`, `\\t`, `\\uXXXX`) escapes. Indentation is fixed at two spaces. The default `eval` output remains PCF."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-071" }
  tags { "renderer"; "json"; "cli" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror the `pkl eval -f json` projection rules"
      rationale =
        "Apple Pkl's JSON output has specific rules for ObjectValue / MappingValue / ListingValue, Mapping key coercion, and JSON string escapes. Mirroring them at this stage means existing Pkl configs ported here can serialize to JSON without divergence; re-deriving the rules from scratch later would invite per-feature drift."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Wire JSON through a CLI flag rather than an `output { renderer }` block"
      rationale =
        "Apple Pkl primarily selects renderers via the module-level `output { renderer = new JsonRenderer { ... } }` block, which depends on the stdlib `JsonRenderer` class and `output { value }` projection. Those are independent slices (PKL-079 stdlib expansion). A `-f json` CLI flag covers the common `pkl eval -f json` workflow without blocking on stdlib work, and the renderer code itself is decoupled so the `output { ... }` path can call it later."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Coerce Mapping keys via PCF inline form for composite keys"
      rationale =
        "Apple Pkl forbids non-string JSON object keys; for scalar keys (Int, Bool, Null) the upstream renderer formats them as the corresponding scalar string (`\"1\"`, `\"true\"`, `\"null\"`). For composite keys the upstream behavior is implementation-defined and rarely used, so we reuse the PCF inline form to keep the output deterministic and readable, instead of failing."
    }
  }
}

local durationAndDataSizeLiterals = new Scenario {
  id = "PKL-082"
  name = "Duration and DataSize literals with arithmetic comparison and unit conversion"
  description =
    "Member access on an Int literal whose name is a recognised Duration unit (`ns` / `us` / `ms` / `s` / `min` / `h` / `d`) produces a `DurationValue(Int, String)` carrying the original magnitude and unit; the matching DataSize units (`b` / `kb` / `kib` / `mb` / `mib` / `gb` / `gib` / `tb` / `tib` / `pb` / `pib`) produce a `DataSizeValue`. Same-unit `+` / `-` operate on the raw magnitudes and preserve the unit; mixed-unit `+` / `-` and comparison (`<` / `<=` / `>` / `>=` / `==` / `!=`) normalize to the smaller of the two units by stepping along the unit ladder one factor at a time so the running magnitude never overflows Int32. `.value` and `.unit` accessors expose the underlying Int and unit name; `.toUnit(name)` re-expresses the value in another aligned unit (e.g. `1.h.toUnit(\"min\") == 60.min`). Unary negation flips the sign while keeping the unit. The PCF renderer emits the values back as the `<n>.<unit>` literal; JSON / YAML / Properties project them as the same lexical form coerced to a string."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "evaluator"; "renderer"; "duration"; "datasize" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Restrict the slice to Int magnitudes and document the Float gap"
      rationale =
        "Apple Pkl tracks the magnitude as a `Number` (Int or Float) and switches to Float on the first fractional-result mixed-unit operation (e.g. `2.s + 3.min` yields `3.033333333333333.min`). The MoonBit value model has no `FloatValue` yet (that lands with PKL-092), so this slice ships Int-only magnitudes. Same-unit arithmetic is exact; mixed-unit arithmetic rounds toward the smaller unit by integer division when the step is non-aligned (notably the binary↔decimal DataSize crossings `kb ↔ kib`). The decision is documented in the slice scope so callers know which operations are reliable and which are deferred."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Pick the smaller of two units as the result of mixed-unit arithmetic"
      rationale =
        "The natural alternative — normalize to the base unit (ns / b) — overflows Int32 immediately: `1.s` is already 1e9 ns and `1.h` is 3.6e12 ns. Picking the smaller of the two operand units keeps the multiplier small (`min → s` is 60, `gb → mb` is 1000) and matches the way most user input flows (people add minutes to a base of seconds, not seconds to a base of nanoseconds). The result type stays exact for aligned-unit ladders (ns..d for Duration; the decimal-only and binary-only paths for DataSize)."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Walk the unit ladder step-by-step instead of multiplying through a flat factor"
      rationale =
        "A flat `factor_in_ns(from) * magnitude / factor_in_ns(to)` table already overflows Int32 once `from` is `min` or coarser (1 min = 6e10 ns). Walking the unit ladder one step at a time — `h → min × 60`, `min → s × 60`, `s → ms × 1000`, etc. — keeps every intermediate value as small as possible and lets us defer Int64 to the PKL-092 Float slice. The DataSize side reuses a single-step `byte_factor` lookup capped at `gib` (~1.07e9 b, the last value that fits in Int32); `tb` and coarser construct fine but a `-1` sentinel from `datasize_byte_factor` makes the mixed-unit path bail rather than silently corrupt the result."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Render to PCF as the literal form, project JSON / YAML / Properties as the same string"
      rationale =
        "Apple Pkl rounds the PCF projection of a Duration / DataSize to its original literal form (`5.min`, `3.kib`); reusing that exact lexical shape lets the value round-trip through the parser cleanly. JSON / YAML / Properties do not have a native Duration / DataSize type, so the upstream renderer also emits them as quoted strings (e.g. `\"5.min\"`); matching that shape keeps the output deterministic without requiring a dedicated `pkl:base` projection table this slice."
    }
  }
}

local regexLiteralAndMethods = new Scenario {
  id = "PKL-081"
  name = "Regex literal and Regex methods"
  description =
    "`Regex(\"<pattern>\")` is recognized as a constructor form before the generic call path runs; the call's single String argument is captured verbatim as a `RegexValue(String)` carrying the pattern. The `.pattern` property exposes the original source pattern as a `String`. Five Regex methods dispatch through the same MemberAccess / SafeMemberAccess sites as the other stdlib value methods: `.matches(input)` returns true only when the regex covers the entire input (anchored on both ends), `.find(input)` returns the first match's text or `null`, `.findAll(input)` returns a `Listing<String>` of every non-overlapping match, `.replace(input, repl)` substitutes the first match, and `.replaceAll(input, repl)` substitutes every non-overlapping match. Compilation is deferred to the first method call so a Regex value can be constructed even if its pattern is later unused; an invalid pattern reports a diagnostic at method-call time. The PCF renderer round-trips a `RegexValue(p)` back as `Regex(\"<escaped-p>\")`; JSON / YAML / Properties project the pattern as a plain string."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-077" }
  tags { "evaluator"; "renderer"; "regex"; "stdlib" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Pull in moonbitlang/regexp instead of writing a pure-MoonBit regex engine"
      rationale =
        "Apple Pkl's regex grammar is the standard PCRE-compatible flavor; reimplementing it for this slice would dwarf every other stdlib slice combined and gain nothing for compatibility. `moonbitlang/regexp` 0.3.5 is a maintained MoonBit-native package with PCRE-style features (character classes, anchors, alternation, repetition, capture groups). Adding it as a dep keeps the slice focused on Pkl-side wiring (value variant, method dispatch, renderer surface) and lets the regex semantics inherit a well-tested implementation."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Compile the pattern lazily at method-call time, not at constructor time"
      rationale =
        "Compiling `Regex(\"<pat>\")` eagerly forces the entire program to fail at construction even when the regex is dead code (e.g. a typealias body that's never instantiated). Lazy compilation localizes the failure to the actual `.matches` / `.find` / etc. call, which both matches user intuition and lets a Regex value participate in renderers (PCF / JSON / YAML / Properties) without ever invoking the engine."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Anchor `.matches` to the whole input rather than searching for a substring match"
      rationale =
        "Apple Pkl's `String.matches(regex)` returns true iff the entire input matches; `.find` / `.findAll` cover the unanchored substring case. Mirroring that split here keeps the Regex API consistent with the existing String API (`.contains` / `.startsWith` / `.endsWith` for unanchored checks, `.matches` for full-input). The implementation checks the match's `before` and `after` views are both empty to distinguish a full match from a partial one."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Project Regex as the pattern string in JSON / YAML / Properties; round-trip as Regex(\"...\") in PCF"
      rationale =
        "JSON / YAML / Properties have no native regex type, so the only deterministic projection is the source pattern as a quoted string — matching the same shape we use for Duration / DataSize. PCF, on the other hand, is the format that flows back into the parser; emitting `Regex(\"<escaped-pattern>\")` lets the same Regex value re-evaluate to itself, which is the property the rest of the renderer surface relies on."
    }
  }
}

local typeAliasedCallableArgumentEvaluation = new Scenario {
  id = "PKL-069"
  name = "evaluate typealiased Pkl callable argument annotations"
  description =
    "Function, lambda, and class method calls resolve typealiased parameter annotations through the alias chain at runtime, so a parameter declared `x: Small` with `typealias Small = Int(isBetween(0, 10))` triggers the same predicate cascade as `x: Int(isBetween(0, 10))`. Built-in and user-defined constrained predicates fire alike, and the diagnostic preserves the original alias name (`Small`) while running the resolved constraint against the argument value."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-066"; "PKL-068" }
  tags { "evaluator"; "callable"; "typealias" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror the return-side alias resolution on the argument side"
      rationale =
        "`eval_callable_return_rejection_message` already resolves a return-type alias via `eval_resolved_type_alias` before running the predicate cascade. The argument side was bypassing alias resolution entirely — it called the non-`_from_source` predicate variants on the raw type name, which silently ignored anything that wasn't an inline constrained type. Switching the argument path to the same `_from_source` predicate variants closes the bypass and reuses the existing typealias chain walker."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Reuse the typealias bindings collected from the program's declarations"
      rationale =
        "`eval_type_alias_bindings(declarations)` is the same input used by the return-side path. Computing it inside the argument-rejection helper keeps the call sites unchanged: every dispatcher (lambda application, function call, class method call) already passes `declarations`, so no new threading is needed."
    }
  }
}

local hiddenAndLocalMembers = new Scenario {
  id = "PKL-087"
  name = "hidden and local object members"
  description =
    "Object-body members declared with the `hidden` modifier or the `local` keyword are kept inside the evaluated `ObjectValue` (so `lookup_member` still resolves bare-name reads against them) but are skipped by every renderer (PCF / JSON / YAML / Properties). Module-level `hidden` bindings get the same render-side filter; module-level `local` already routed through `parse_local_decl`, which marks the binding `exported: false` so the renderer never sees it in the first place. The render filter is a single `visible_members` projection applied at the entry of each renderer's member loop, keyed off a reserved `@hidden$` name prefix that the lexer rejects as an identifier character so it cannot collide with user-declared properties."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-070"; "PKL-071"; "PKL-072"; "PKL-073"; "PKL-074" }
  tags { "evaluator"; "renderer"; "object" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mark hidden members via a name-prefix marker instead of widening ValueMember"
      rationale =
        "Adding a `hidden : Bool` field to `ValueMember` would force updating ~334 struct-literal constructions in the test suite (the source uses shorthand field-name punning that MoonBit cannot extend with a default). A reserved name prefix (`@hidden$`) achieves the same goal — distinguishing renderable from non-renderable members — without touching the struct shape, and the lexer's rejection of `@` / `$` in identifiers guarantees the prefix cannot collide with anything in user source."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Resolve bare-name reads against either the bare or prefixed form in `lookup_member`"
      rationale =
        "Apple Pkl's `hidden` keeps the member reachable from outside the object (renderers drop it; member access still resolves it). The bare-name lookup must therefore match the prefixed entry transparently. Extending `lookup_member` to try both forms keeps the visibility contract intact without forcing every caller to know about the prefix."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Split visibility-consumption between module-level and object-body parsers"
      rationale =
        "Module-level `local` is a binding-declaration keyword that routes through `parse_local_decl` and produces `exported: false` bindings. Reusing the object-body visibility consumer at module level would swallow that keyword before `parse_local_decl` could see it, breaking 16 existing tests. The split — `consume_member_visibility_modifiers` for object bodies (handles both `hidden` text and `local` keyword) and `consume_module_visibility_modifiers` for module level (handles only `hidden` text) — keeps the keyword's existing role intact."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Treat `local` and `hidden` identically on the render side"
      rationale =
        "Apple Pkl's `hidden` keeps the member reachable via member access; `local` is supposed to be scoped to the declaring body and unreachable from outside. Our evaluator currently lacks sibling-visibility for object-body members (the existing tests of sibling references show `unbound identifier`), so the stricter `local` scoping isn't observable yet. Producing identical render-filtering for both modifiers ships the renderer contract now and leaves the stricter scoping for a follow-up slice that bundles sibling visibility."
    }
  }
}

local objectBodyForGenerators = new Scenario {
  id = "PKL-085"
  name = "evaluate object body for-generators"
  description =
    "`for (var in source) { ... }` and `for (var1, var2 in source) { ... }` inside an object body iterate the source (Listing or Mapping) and splice each iteration's members into the surrounding object. For Listings, the single-variable form binds the element; the two-variable form binds (index, element). For Mappings, the two-variable form binds (key, value). Per-iteration members are merged via `merge_value_members`, so later iterations overwrite earlier writes to the same name (matching Apple Pkl's `for`-as-property-generator semantics). The construct is encoded as a synthetic `@for` ObjectMember whose value is a new `ForGenerator(var1, var2, source, body)` `Expr` variant; `eval_object_members` recognises the reserved name and spreads the resulting `ObjectValue`'s members into the parent. Composes with `when`-conditionals inside the body — the @when spread per iteration contributes (or skips) members according to the condition."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075"; "PKL-086" }
  tags { "evaluator"; "object" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Promote `for` and `in` to reserved keywords"
      rationale =
        "Apple Pkl marks both as reserved words — they can never be property names. Adding them to `keyword_or_identifier` lets `parse_object_body_members` dispatch on the keyword's syntax kind directly and lets the binding-form parser look for `in_kw` as the source separator. The upstream parser suite (802 fixtures) still passes after the change, so no fixture uses `for` or `in` as an identifier."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Add a dedicated `ForGenerator` `Expr` variant instead of reusing a wrapper expression"
      rationale =
        "The for-generator's payload — loop variable name(s), source expression, and body members — does not fit into any existing `Expr` shape (the body is an `Array[ObjectMember]`, not an `Expr`). Encoding it as `(var1, var2_opt, source, body)` in a new variant keeps the surface explicit at every parser / evaluator / typechecker site. The typechecker treats the variant as `UnknownType` because for-generators only appear inside object bodies via the synthetic `@for` member, never as a free-standing expression."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Merge per-iteration members across iterations rather than appending duplicates"
      rationale =
        "Apple Pkl's `for`-as-property-generator semantics are last-write-wins per name — writing `result = x` inside the body for each iteration yields one `result` member set to the final iteration's value, not three duplicates. Our regular object-body evaluation keeps duplicate names (the renderer / amend chain resolves them downstream), but per-iteration spreading is a stronger contract; using `merge_value_members` between iterations matches the user's mental model and prevents the resulting `ObjectValue` from growing without bound for large sources."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Custom in-place skipper for binding-side type annotations"
      rationale =
        "Apple Pkl allows `for (n: Int in source)` and `for (n: Listing<Pair<Int, Int>> in source)`. Reusing `parse_type_annotation` here doesn't work because its `parse_type_text` greedily consumes tokens until `=` / `{` / `}` / `,`, which swallows the `in` keyword and the source expression. A small custom loop that stops at `,` / `in` / `)` while balancing parens / brackets / angles keeps the typed-binding contract intact without weakening the existing type-annotation parser."
    }
  }
}

local objectBodyWhenConditionals = new Scenario {
  id = "PKL-086"
  name = "evaluate object body when-conditionals"
  description =
    "`when (cond) { ... } else { ... }` inside an object body picks the then-branch when the condition evaluates to `true` and the else-branch otherwise; the picked branch's members are spliced into the surrounding object body alongside any sibling properties. `else` is optional — a false condition without an `else` contributes no members. The condition expression sees the enclosing module's bindings (so `when (stage == \"prod\")` works), and each branch may declare multiple members. The construct is desugared at parse time into a synthetic `@when` object member whose value is a `ConditionalExpr` between the two branch `ObjectLiteral`s; `eval_object_members` recognises the reserved name and spreads the resulting `ObjectValue`'s members into the parent."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "evaluator"; "object" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Encode `when` as a synthetic `@when` ObjectMember rather than changing the ObjectMember shape"
      rationale =
        "Promoting `ObjectMember` from a struct to an enum (with separate `Property` and `WhenBranch` variants) would ripple through every place that constructs or inspects object members — parser, evaluator, typechecker, renderers, four separate match arms. Encoding `when` as a reserved-named ObjectMember whose value is a `ConditionalExpr` between two `ObjectLiteral`s keeps the change local: the parser emits one extra branch in `parse_object_body_members`, and the evaluator spreads on the reserved name. `@` is rejected as an identifier character by the lexer, so the reserved name cannot collide with anything in user source."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Spread branch members at evaluation time rather than at parse time"
      rationale =
        "Apple Pkl evaluates the condition at module-evaluation time and the branches see the surrounding object's bindings (forward references, class defaults, amend chains). Spreading at parse time would require copying the branch's `ObjectMember`s into the surrounding array, which loses the source position for diagnostics and forces the parser to know about evaluation order. Spreading at evaluation time, after `eval_expr_with_bindings` resolves the conditional, keeps the parser oblivious to runtime semantics and lets the existing scoping machinery (`eval_object_members` already iterates in order with forward-reference support) handle the resolution."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Promote `when` from an identifier to a reserved keyword"
      rationale =
        "Apple Pkl marks `when` as a reserved word — it can never be a property name. Adding `when` to `keyword_or_identifier` matches that contract and lets `parse_object_body_members` dispatch on the keyword's syntax kind directly. The upstream parser suite (802 fixtures) and smoke tests still pass, so no existing fixture uses `when` as an identifier."
    }
  }
}

local nullCoalescingAndLet = new Scenario {
  id = "PKL-088"
  name = "null-coalescing operator and let expressions"
  description =
    "The `??` operator picks the right-hand value when the left evaluates to `NullValue`, and is right-associative so `a ?? b ?? fallback` short-circuits left-to-right. `let (name = value) body` introduces a single scoped binding, with the body able to reference outer bindings and inner let-expressions able to shadow the outer name. The two compose: `let (fallback = ...) raw ?? fallback`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "evaluator"; "expressions" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Desugar `let (name = value) body` into `((name) -> body)(value)` at parse time"
      rationale =
        "Pkl's let-expression is just a single-parameter lambda applied to one value — same scoping rules, same closure capture, same return-validation. Desugaring at the parser level means the rest of the evaluator continues to operate on the existing `LambdaExpr` + `CallExpr` machinery (closure capture, parameter rejection, return validation) without a new AST node or eval arm. The CST node keeps the `let_decl` kind so the source-mapped diagnostic surface stays intact."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Lean on the existing `NullCoalesce` binary operator rather than synthesizing a new short-circuit form"
      rationale =
        "The lexer / parser / typechecker / evaluator already wire `??` through `BinaryOp::NullCoalesce` (it lit up the moment the existing slice landed), with `NullCoalesce` evaluating the right-hand side only when the left produces `NullValue`. PKL-088 ships the spec contract that pins down the behavior — right-associativity, short-circuit semantics, type-of-result — without changing the implementation."
    }
  }
}

local pklMathExpansion = new Scenario {
  id = "PKL-079"
  name = "expand pkl:math beyond maxInt32"
  description =
    "`pkl:math` exposes Int range constants (`maxInt32`, `minInt32`, `maxInt`, `minInt`) and Int-side helpers (`abs(x)`, `min(a, b)`, `max(a, b)`). The helpers are declared as top-level lambda bindings inside the synthetic `pkl:math` source so they round-trip through the regular `exported: true` path and become members of the imported module's `ObjectValue` — `import \"pkl:math\" as math; math.max(a, b)` evaluates without further dispatch work. `maxInt` / `minInt` track the 32-bit `Int` representation; once a 64-bit slot exists they expand to match the Java-derived Apple Pkl bounds."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-007"; "PKL-078" }
  tags { "stdlib"; "pkl-math" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Declare helpers as lambda bindings, not `function` declarations"
      rationale =
        "Our parser marks `function name(...) = body` declarations with `exported: false`, which keeps them out of the imported module's `ObjectValue`. Apple Pkl's `pkl:math` exposes these helpers as plain functions on the module, so to match the reachable-from-an-import contract we declare them as `name = (...) -> body` instead. The semantics are identical (both forms produce a `FunctionValue`), but the binding flag flips the lambda form into the exported set."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Track `maxInt` / `minInt` against the implemented Int width"
      rationale =
        "Apple Pkl's `Int` is 64-bit (Java `long`), so its `maxInt` / `minInt` are `+/-2^63`. Our `IntValue` carries a 32-bit MoonBit `Int`. Reporting Apple Pkl's 64-bit limits here would mean lying about what literals will actually round-trip through evaluation (anything beyond 32-bit overflows during parsing today). The constants therefore expose the implementation-actual range; PKL-092 / a follow-up Int-64 slice will widen them once the value model supports the bigger slot."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer Float-bearing math (`sqrt` / `pow` / `log` / `exp` / `ceil` / `floor` / `round`) to PKL-092"
      rationale =
        "Apple Pkl's `pkl:math` exposes `sqrt(Float)`, `pow(Float, Float)`, `log(Float)`, etc. None of these can be implemented honestly against `IntValue` alone — `sqrt(4) = 2` happens to be integer but `sqrt(2)` cannot be represented. Float-bearing math arrives with `FloatValue` in PKL-092, alongside the Float constraint predicates."
    }
  }
}

local pklBaseInt = new Scenario {
  id = "PKL-078"
  name = "expose pkl:base Int operations"
  description =
    "Int properties (`abs`, `isEven`, `isOdd`) and methods (`toString()`, `toString(radix)`, `toChar()`) dispatch against `IntValue` receivers via the same `MemberAccess` / `CallExpr` interception as the Listing / Mapping / String builtins. `toString(radix)` accepts radices 2..36 and writes a leading `-` for negative inputs. `toChar()` projects a Unicode code point (0..0x10FFFF) to a single-character `StringValue`. Int builtins compose with String / Listing pipelines, so `xs.map((n) -> n.toString(16)).join(\",\")` returns a hex-CSV `StringValue`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-077" }
  tags { "stdlib"; "pkl-base"; "numeric" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Implement radix conversion in-tree rather than via a third-party crate"
      rationale =
        "MoonBit's `Int` type does not expose a built-in radix-aware `toString`. Pulling in a numeric-formatting library for one method would balloon the dependency surface; implementing the loop ourselves (a 20-line helper that walks the digit table) keeps the slice focused. The radix bound (2..36) matches Java's `Integer.toString(int, int radix)` and Apple Pkl's `Int.toString(radix: Int(isBetween(2, 36)))` constraint."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer `toFloat()` and Float-side projections until a real `Float` value lands"
      rationale =
        "Apple Pkl's Int surface includes `toFloat(): Float`, and the Roadmap entry called for matching Float-side projections. Our value model has no `FloatValue` yet — numeric literals like `1.23` currently fail to evaluate. Implementing `toFloat` against `IntValue` alone would mean returning an `IntValue` again (since there's no other slot), which is misleading. The Float surface arrives with PKL-092, at which point `toFloat()` slots in alongside the new value variant."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Reject `toChar` code points outside the Unicode range explicitly"
      rationale =
        "Apple Pkl's `Int.toChar()` errors when the receiver is outside `0..0x10FFFF`. Our `Char::unsafe_to_char` would happily accept any 32-bit input, but a code point above `0x10FFFF` is not a valid Unicode scalar and the resulting `StringValue` would be ill-formed. The explicit bound check matches Apple Pkl's behavior and protects downstream renderers (JSON / YAML / Properties string-escape paths) from surrogate-pair leakage."
    }
  }
}

local pklBaseString = new Scenario {
  id = "PKL-077"
  name = "expose pkl:base String operations"
  description =
    "String properties (`length`, `isEmpty`) and methods (`toUpperCase()`, `toLowerCase()`, `contains(s)`, `startsWith(p)`, `endsWith(s)`, `indexOf(s)`, `replaceAll(old, new)`, `replaceFirst(old, new)`, `take(n)`, `drop(n)`, `split(sep)`, `padStart(width, padStr)`, `padEnd(width, padStr)`) dispatch against `StringValue` receivers via the same `MemberAccess` / `CallExpr` interception as the Listing / Mapping builtins. `indexOf` returns `-1` for missing substrings (matching Apple Pkl rather than returning null). `split` projects to `Listing<String>`, so `s.split(\",\").map(...).join(...)` pipelines through the Listing builtins. `take` and `drop` saturate at the string bounds. All operations are code-unit-based (matching Apple Pkl's Java-string-derived semantics)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-076" }
  tags { "stdlib"; "pkl-base"; "string" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Map `indexOf` absent result to `-1`, not `null`"
      rationale =
        "Apple Pkl's `String.indexOf` returns `Int` with `-1` for absent substrings; a separate `indexOfOrNull` returns the nullable form. Mirroring that convention here keeps Pkl source ported from upstream working without rewriting `if (idx == -1)` checks into null guards. The MoonBit primitive (`String::find`) returns `Int?`, so the wrapper applies the `-1` fallback at the dispatch boundary."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Accept `padChar` as a single-character String, not a `Char` value"
      rationale =
        "Apple Pkl's `padStart` / `padEnd` take a `Char` parameter, but our value model has no separate `Char` type — character literals evaluate to `StringValue` of length one. Accepting a String and using its full content as the pad sequence is a strict superset of the Apple Pkl behavior for single-character pads and avoids forcing a `Char` value into the model for one builtin. If a future slice introduces `Char`, the pad parameter narrows naturally."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer regex-bearing String operations (`matches`, `replaceAllMapped`) to PKL-081"
      rationale =
        "Apple Pkl's String surface includes regex-bearing operations (`matches(Regex)`, `replaceAllMapped(Regex, (MatchResult) -> String)`). The regex slice (PKL-081) brings its own value type and constraint integration; folding those into this slice would force premature design choices. PKL-077 ships the non-regex slice — toUpperCase / split / replaceAll etc. — and PKL-081 will extend it without touching the dispatcher."
    }
  }
}

local pklBaseMapping = new Scenario {
  id = "PKL-076"
  name = "expose pkl:base Mapping operations"
  description =
    "Mapping properties (`length`, `isEmpty`, `keys`, `values`) and methods (`containsKey(k)`, `getOrNull(k)`, `fold(init, op)`) dispatch against `MappingValue` receivers via the same `MemberAccess` / `CallExpr` interception as the Listing builtins. `keys` and `values` project to `ListingValue` in declaration order (Apple Pkl returns `Set<K>` for `keys`, but our value model has no separate Set yet — the deviation is documented in the decisions). `getOrNull(k)` returns `NullValue` when the key is missing. `fold` invokes a 3-argument callback `(acc, key, value)` per entry via the shared `apply_function_value` helper. Listing builtins continue to dispatch on Listing receivers, so `m.values.filter(...).fold(...)` pipelines through both surfaces correctly."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075" }
  tags { "stdlib"; "pkl-base"; "mapping" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Project `keys` as `Listing<K>` until a real `Set` value lands"
      rationale =
        "Apple Pkl's `Mapping.keys` returns `Set<K>`, which has its own equality / iteration semantics. Our value model represents `Set(...)` literals as `ListingValue` already, so synthesizing a separate `SetValue` just for `keys` would mean either retrofitting Set throughout the evaluator now (large slice) or returning a one-off type the rest of the code can't manipulate. Returning `Listing<K>` matches what `Set(...)` becomes after evaluation today, and the contract upgrades naturally when a real `Set` lands."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Fold callback receives `(acc, key, value)` triple"
      rationale =
        "Apple Pkl's `Mapping.fold` exposes both the entry key and value to the accumulator. Reusing the `apply_function_value` helper with a 3-element argument array keeps the per-call validation / return checking consistent with Listing's `fold`, and means the only Mapping-specific code is the per-entry iteration shape."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer `entries -> Listing<Pair>` projection to a later slice"
      rationale =
        "Apple Pkl's `Mapping.entries` returns a `Listing<Pair<K,V>>`. We do not have a `Pair` value type yet (it depends on the broader `pkl:base` class surface in PKL-080). Implementing `entries` ahead of `Pair` would force an ad-hoc representation we'd need to migrate later, so this slice ships `keys` / `values` instead and `entries` arrives with Pair / reflect."
    }
  }
}

local pklBaseListing = new Scenario {
  id = "PKL-075"
  name = "expose pkl:base Listing operations"
  description =
    "Listing properties (`length`, `isEmpty`, `first`, `last`, `distinct`) and methods (`contains(x)`, `reverse()`, `take(n)`, `drop(n)`, `join(sep)`, `map(fn)`, `filter(p)`, `fold(init, op)`) dispatch against `ListingValue` receivers in the evaluator. Property-style access (`xs.length`) is handled in the `MemberAccess` arm; method calls (`xs.contains(1)`) are handled in the `CallExpr(MemberAccess(...), args)` arm before falling through to the regular callable path. Higher-order methods (`map` / `filter` / `fold`) accept a `FunctionValue` callback and invoke it per element via a shared `apply_function_value` helper that mirrors `eval_lambda_application` for already-evaluated arguments. Chained calls (`xs.filter(p).map(f).fold(0, g)`) work because each step re-evaluates its receiver as a `ListingValue`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009"; "PKL-066" }
  tags { "stdlib"; "pkl-base"; "listing" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Dispatch builtins on the receiver shape, not via a synthetic class binding"
      rationale =
        "Apple Pkl exposes Listing operations through a `pkl:base.Listing<T>` class. Our class lookup is keyed off typed-object class names, and `ListingValue` is not represented as a typed object — synthesizing one just to satisfy the dispatcher would balloon the surface (constructor flow, amend rules, etc.). Intercepting `MemberAccess` / `CallExpr` for `ListingValue` receivers keeps the evaluator changes local and leaves the class system unchanged for PKL-089 generics work later."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Share `apply_function_value` between Listing higher-order builtins"
      rationale =
        "`map` / `filter` / `fold` all need to invoke a `FunctionValue` against already-evaluated element values, which differs from the existing `eval_lambda_application` (Expr-based arguments). Extracting `apply_function_value` once means each Listing builtin's body stays focused on its iteration shape and the per-call rejection / return validation lives in one place. The helper is reusable by Mapping (PKL-076) and String (PKL-077) builtins once those land."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Saturate `take` / `drop` instead of erroring on out-of-range counts"
      rationale =
        "Apple Pkl's `Listing.take(n)` and `.drop(n)` clamp `n` to the listing's bounds rather than raising — `xs.take(100)` on a 3-element listing returns the whole listing, and `xs.drop(100)` returns the empty listing. Mirroring that policy keeps user-facing behavior intuitive and avoids leaking an internal index-bounds error from data-shape variation."
    }
  }
}

local propertiesRenderer = new Scenario {
  id = "PKL-074"
  name = "render Pkl values as Java Properties"
  description =
    "The CLI `eval -f properties` (or `--format properties`) flag emits a Java Properties document matching Apple Pkl's `pkl eval -f properties` shape: ObjectValue and MappingValue members flatten into dotted keys (`a.b.c`), Mapping keys are coerced to strings, scalar values emit as unquoted `key = value` lines with property-style escaping for `\\`, `\\n`, `\\t`, `\\r`, `\\f`, leading space, `:`, `=`, `!`, and `#`. ListingValue renders as a compact JSON-style single-line value (`[1,2,3]`), with the JSON `:` separators property-escaped to `\\:`. NullValue leaves are omitted (mirroring Apple Pkl's `omitNullProperties = true` default), empty Object / Mapping leaves are dropped entirely, and empty Listings emit `key = []`. Top-level non-mapping values produce an empty document."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-072"; "PKL-073" }
  tags { "renderer"; "properties"; "cli" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror Apple Pkl's dotted-flatten Properties projection"
      rationale =
        "Apple Pkl's Properties renderer commits to a deterministic projection: nested Object / Mapping flatten into dot-joined keys, ListingValue stays as a single inline JSON-style scalar (so the line count matches the leaf count, not the listing length), and NullValue leaves are dropped by default. Mirroring that projection now means existing Pkl configurations ported here serialize to .properties without divergence, and adding `omitNullProperties = false` / `restrictCharset = true` / converters later remains an opaque extension instead of a re-architecting."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Apply property-style escaping symmetrically to keys and values"
      rationale =
        "Java Properties readers strip leading whitespace and use `=`, `:`, ` ` (space), `!`, `#`, and `\\` as syntactic delimiters. Apple Pkl's renderer escapes all of those in both keys and values (with a slight asymmetry: leading space is escaped in values, every space is escaped in keys, trailing space is left alone in values). Following that scheme here keeps round-trip behavior intact for any conforming Java Properties parser."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer `restrictCharset = true` Unicode escaping to a stdlib slice"
      rationale =
        "Apple Pkl's `restrictCharset = true` mode emits `\\uXXXX` escapes for every non-ASCII code point so the resulting file is safe for legacy ISO-8859-1 .properties readers. That knob lives on the `PropertiesRenderer` stdlib class, which arrives as part of PKL-079 stdlib expansion. Until then, the default `restrictCharset = false` behavior — pass Unicode through verbatim — is enough for modern JVM consumers."
    }
  }
}

local yamlRenderer = new Scenario {
  id = "PKL-073"
  name = "render Pkl values as YAML"
  description =
    "The CLI `eval -f yaml` (or `--format yaml`) flag emits a YAML document matching Apple Pkl's `pkl eval -f yaml` block-style shape: ObjectValue and MappingValue project to block mappings (Mapping keys are coerced to strings, indented two spaces per level), ListingValue projects to block sequences at the parent column with `- value` entries, and empty composites use the `[]` / `{}` flow form. String scalars stay bare when they parse as plain YAML, switch to single-quoted with `''` escapes for leading indicators / numeric-or-keyword shapes / inline `: ` / ` #` / trailing whitespace, and switch to double-quoted with `\\n`, `\\t`, `\\r`, `\\\\`, `\\\"`, and `\\uXXXX` escapes when the value contains control characters or a backslash. The default `eval` output stays PCF."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-072" }
  tags { "renderer"; "yaml"; "cli" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror Apple Pkl's block-style YAML projection rules"
      rationale =
        "Apple Pkl's YAML renderer commits to a deterministic block-style projection (sequences emit `- item` at the parent column, mappings emit `key: value` with two-space indentation, empties use the flow `[]` / `{}` form). Mirroring that projection now means existing Pkl configurations ported here serialize to YAML without divergence, and adding `indentWidth` / `omitNullProperties` / converters later remains an opaque extension instead of a re-architecting."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Reuse the JSON `-f` CLI flag rather than the `output { renderer }` block"
      rationale =
        "PKL-072 wires `eval -f json` through a CLI flag because the `output { renderer = new JsonRenderer { ... } }` shape depends on stdlib classes (`JsonRenderer`, `YamlRenderer`) that we have not implemented yet — that lives in PKL-079 stdlib expansion. Reusing the same flag for YAML keeps the CLI surface uniform; once the stdlib renderer classes land, the `output { renderer }` path simply re-invokes the same internal `render_value_as_yaml` entry point."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Use double-quoted form for control-character strings instead of block scalars"
      rationale =
        "Apple Pkl uses `|`, `|-`, and `|+` block scalars for multiline / control-character strings to keep YAML output human-readable. That projection is non-trivial (indentation indicators, chomping indicators, leading-whitespace handling) and is best implemented as its own slice. Until then, double-quoted strings with the JSON-style `\\n` / `\\t` / `\\uXXXX` escapes produce equivalent YAML — slightly less readable but still spec-compliant and round-trippable through any YAML 1.1 parser."
    }
  }
}

