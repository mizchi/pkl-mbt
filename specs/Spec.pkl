local userDefinedConstrainedCallableArgumentEvaluation = new Scenario {
  id = "PKL-066"
  name = "evaluate user-defined constrained Pkl callable arguments"
  description =
    "Function, lambda, and class method calls enforce user-defined numeric predicate factories on parameter annotations at runtime, matching the existing built-in numeric predicate behavior."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-065"; "PKL-056" }
  tags { "evaluator"; "callable" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Extend argument validation to user-defined constraint predicates"
      rationale =
        "Return validation now applies built-in and user-defined predicates, but callable and method parameter checks only run the built-in predicate machinery. Extending the parameter validation to call the user-defined predicate helper closes the symmetry gap."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Share a callable argument rejection helper"
      rationale =
        "Both eval_lambda_application and eval_class_method_call needed to combine the built-in and user-defined predicate checks. A shared eval_callable_argument_rejection_message helper keeps the message format aligned with the existing argument diagnostics and avoids duplicating the predicate cascade."
    }
  }
}

local constrainedCallableReturnBodyTypechecking = new Scenario {
  id = "PKL-067"
  name = "typecheck constrained Pkl callable return bodies"
  description =
    "Function, lambda, and class method declarations whose body is a literal that violates the declared constrained return annotation are rejected by the typechecker, mirroring the existing constrained binding behavior for built-in and user-defined numeric predicates."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-065"; "PKL-066" }
  tags { "typechecker"; "callable" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Lift literal-body return checks into the typechecker"
      rationale =
        "Constrained value bindings already use push_constrained_type_annotation_expr_diagnostic and the user-defined variant to flag literal violations at typecheck time. Callable return bodies currently only run the runtime check, leaving a static-analysis gap when the body is a known literal."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Walk declarations once at typecheck entry"
      rationale =
        "Function and class method bodies are visited from different paths in the inference flow, so a dedicated post-typecheck walker that visits all declarations once keeps the rule centralized and avoids threading declarations through every infer_call path."
    }
  }
}

local typeAliasedCallableReturnEvaluation = new Scenario {
  id = "PKL-068"
  name = "evaluate typealiased Pkl callable return annotations"
  description =
    "Function, lambda, and class method return annotations whose declared type name is a typealias resolve through the alias chain at runtime, accepting alias targets such as Int when the alias is declared as typealias Small = Int."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-065"; "PKL-039" }
  tags { "evaluator"; "callable"; "typealias" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Resolve callable return aliases before runtime base-type validation"
      rationale =
        "eval_value_accepts_type_annotation rejects typealiased return annotations because it only matches the literal alias name against the value type. Value bindings already resolve aliases through the type alias environment, and the same resolution should happen for callable returns so user code can name the return through a typealias."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Preserve the alias display name in diagnostics"
      rationale =
        "The constraint rejection helpers accept separate display and source names, so the runtime can resolve the alias to drive the base-type and constraint checks while still surfacing the alias in the user-facing diagnostic for parity with constrained value binding messages."
    }
  }
}

local pcfRendererPrimitives = new Scenario {
  id = "PKL-070"
  name = "render Pkl values as PCF primitives"
  description =
    "Module rendering as the canonical Pkl Configuration Format (PCF) emits Int, Boolean, String, and Null values with the same lexical form Apple Pkl uses, so module bindings reparse to the same value graph and the basic LanguageSnippetTests fixtures match the upstream gold output byte-for-byte."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "renderer"; "pcf" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Lock the existing CLI renderer in as the PCF baseline"
      rationale =
        "The CLI `eval` command already emits PCF-shaped output for Int, Boolean, String, and Null primitives, and the basic upstream parens / import1 fixtures match the gold .pcf files byte-for-byte. PKL-070 locks that contract with explicit unit tests, a round-trip test, and a doc comment on render_value identifying it as the PCF entry point so future JSON / YAML renderers (PKL-072..074) land alongside without ambiguity."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer Float values to a dedicated slice"
      rationale =
        "Float values, literals, and the matching FloatType are not yet in the AST, evaluator, or typechecker. Adding them would inflate PKL-070 well beyond a renderer slice, so Float rendering is queued as a follow-up alongside Float constraint predicates (PKL-092)."
    }
  }
}

local pcfRendererObjects = new Scenario {
  id = "PKL-071"
  name = "render Pkl objects and listings as PCF"
  description =
    "PCF rendering emits nested objects, listings, and mappings with the brace / element conventions Apple Pkl uses, including 2-space indentation, type-tag-free `new { ... }` wrappers for non-scalar listing / mapping values, and the empty `{}` form. The basic, modules, and classes upstream fixtures match the gold `.pcf` output byte-for-byte."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-070" }
  tags { "renderer"; "pcf" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Drop the explicit type tag from nested PCF blocks"
      rationale =
        "Apple Pkl PCF emits `new { ... }` (no `Listing` / `Mapping` / `Dynamic` tag) for non-scalar values that appear as listing elements or mapping keys / values, and `name { ... }` for typed and untyped block-valued properties. Re-introducing the tags broke byte-for-byte parity with the upstream gold outputs."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Treat module top-level as ObjectValue with a flat layout"
      rationale =
        "The CLI evaluation result is always an ObjectValue at the module boundary, so render_value treats ObjectValue at the entry point as a module (no enclosing braces, no indentation, members on their own lines) and dispatches every nested value through the inline path. This keeps the top-level layout indistinguishable from `pkl eval` and lets render_value still produce a self-contained value for non-module callers such as pkl:test.catch."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Skip the listing / mapping round-trip test"
      rationale =
        "PCF rendering drops the `Listing` / `Mapping` tag and uses Pkl's listing / mapping shorthand syntax for elements, which this evaluator's parser does not yet accept. The round-trip unit test stays on the object-member subset until the parser slice that accepts the shorthand lands; byte-for-byte parity with upstream gold output is enforced via the upstream smoke check instead."
    }
  }
}

local jsonRenderer = new Scenario {
  id = "PKL-072"
  name = "render Pkl values as JSON"
  description =
    "The CLI `eval -f json` (or `--format json`) flag emits a JSON document matching Apple Pkl's `pkl eval -f json` shape: ObjectValue and MappingValue project to JSON objects (Mapping keys are coerced to strings), ListingValue projects to JSON arrays, IntValue / BoolValue / NullValue use the JSON scalar form, and StringValue applies the standard `\"`, `\\`, control-character (`\\b`, `\\f`, `\\n`, `\\r`, `\\t`, `\\uXXXX`) escapes. Indentation is fixed at two spaces. The default `eval` output remains PCF."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-071" }
  tags { "renderer"; "json"; "cli" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror the `pkl eval -f json` projection rules"
      rationale =
        "Apple Pkl's JSON output has specific rules for ObjectValue / MappingValue / ListingValue, Mapping key coercion, and JSON string escapes. Mirroring them at this stage means existing Pkl configs ported here can serialize to JSON without divergence; re-deriving the rules from scratch later would invite per-feature drift."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Wire JSON through a CLI flag rather than an `output { renderer }` block"
      rationale =
        "Apple Pkl primarily selects renderers via the module-level `output { renderer = new JsonRenderer { ... } }` block, which depends on the stdlib `JsonRenderer` class and `output { value }` projection. Those are independent slices (PKL-079 stdlib expansion). A `-f json` CLI flag covers the common `pkl eval -f json` workflow without blocking on stdlib work, and the renderer code itself is decoupled so the `output { ... }` path can call it later."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Coerce Mapping keys via PCF inline form for composite keys"
      rationale =
        "Apple Pkl forbids non-string JSON object keys; for scalar keys (Int, Bool, Null) the upstream renderer formats them as the corresponding scalar string (`\"1\"`, `\"true\"`, `\"null\"`). For composite keys the upstream behavior is implementation-defined and rarely used, so we reuse the PCF inline form to keep the output deterministic and readable, instead of failing."
    }
  }
}

local durationAndDataSizeLiterals = new Scenario {
  id = "PKL-082"
  name = "Duration and DataSize literals with arithmetic comparison and unit conversion"
  description =
    "Member access on an Int literal whose name is a recognised Duration unit (`ns` / `us` / `ms` / `s` / `min` / `h` / `d`) produces a `DurationValue(Int, String)` carrying the original magnitude and unit; the matching DataSize units (`b` / `kb` / `kib` / `mb` / `mib` / `gb` / `gib` / `tb` / `tib` / `pb` / `pib`) produce a `DataSizeValue`. Same-unit `+` / `-` operate on the raw magnitudes and preserve the unit; mixed-unit `+` / `-` and comparison (`<` / `<=` / `>` / `>=` / `==` / `!=`) normalize to the smaller of the two units by stepping along the unit ladder one factor at a time so the running magnitude never overflows Int32. `.value` and `.unit` accessors expose the underlying Int and unit name; `.toUnit(name)` re-expresses the value in another aligned unit (e.g. `1.h.toUnit(\"min\") == 60.min`). Unary negation flips the sign while keeping the unit. The PCF renderer emits the values back as the `<n>.<unit>` literal; JSON / YAML / Properties project them as the same lexical form coerced to a string."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "evaluator"; "renderer"; "duration"; "datasize" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Restrict the slice to Int magnitudes and document the Float gap"
      rationale =
        "Apple Pkl tracks the magnitude as a `Number` (Int or Float) and switches to Float on the first fractional-result mixed-unit operation (e.g. `2.s + 3.min` yields `3.033333333333333.min`). The MoonBit value model has no `FloatValue` yet (that lands with PKL-092), so this slice ships Int-only magnitudes. Same-unit arithmetic is exact; mixed-unit arithmetic rounds toward the smaller unit by integer division when the step is non-aligned (notably the binary↔decimal DataSize crossings `kb ↔ kib`). The decision is documented in the slice scope so callers know which operations are reliable and which are deferred."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Pick the smaller of two units as the result of mixed-unit arithmetic"
      rationale =
        "The natural alternative — normalize to the base unit (ns / b) — overflows Int32 immediately: `1.s` is already 1e9 ns and `1.h` is 3.6e12 ns. Picking the smaller of the two operand units keeps the multiplier small (`min → s` is 60, `gb → mb` is 1000) and matches the way most user input flows (people add minutes to a base of seconds, not seconds to a base of nanoseconds). The result type stays exact for aligned-unit ladders (ns..d for Duration; the decimal-only and binary-only paths for DataSize)."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Walk the unit ladder step-by-step instead of multiplying through a flat factor"
      rationale =
        "A flat `factor_in_ns(from) * magnitude / factor_in_ns(to)` table already overflows Int32 once `from` is `min` or coarser (1 min = 6e10 ns). Walking the unit ladder one step at a time — `h → min × 60`, `min → s × 60`, `s → ms × 1000`, etc. — keeps every intermediate value as small as possible and lets us defer Int64 to the PKL-092 Float slice. The DataSize side reuses a single-step `byte_factor` lookup capped at `gib` (~1.07e9 b, the last value that fits in Int32); `tb` and coarser construct fine but a `-1` sentinel from `datasize_byte_factor` makes the mixed-unit path bail rather than silently corrupt the result."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Render to PCF as the literal form, project JSON / YAML / Properties as the same string"
      rationale =
        "Apple Pkl rounds the PCF projection of a Duration / DataSize to its original literal form (`5.min`, `3.kib`); reusing that exact lexical shape lets the value round-trip through the parser cleanly. JSON / YAML / Properties do not have a native Duration / DataSize type, so the upstream renderer also emits them as quoted strings (e.g. `\"5.min\"`); matching that shape keeps the output deterministic without requiring a dedicated `pkl:base` projection table this slice."
    }
  }
}

local floatPowerAndDivisionSemantics = new Scenario {
  id = "PKL-111"
  name = "Float Power IntDivide and Modulo semantics"
  description =
    "Apple Pkl's `**` / `~/` / `%` operators accept Float operands and produce results that match the JVM evaluator's golden output. `**` (Power) widens to Float on any Float operand: `2.0 ** 3 = 8.0`, `2.3 ** 4.0 ≈ 27.984099999999998` (Apple's exact bit pattern). `~/` (IntDivide) always returns an Int even when both operands are Float, using truncation toward zero: `5.0 ~/ 3.0 = 1`, `5 ~/ 3.0 = 1`, `5.1 ~/ 3.1 = 1`. `%` (Modulo) widens to Float on any Float operand and computes the truncated remainder `a - b * trunc(a / b)`: `5.5 % 6.5 = 5.5`, `5 % 6.5 = 5.0`. The evaluator routes these through `eval_float_binary`'s extended branches, using `@math.pow` from `moonbitlang/core/math` for exponentiation and a local `double_trunc` helper that round-trips through Int64 for truncation. Division-by-zero on `~/` and `%` against a zero divisor surfaces the same `division by zero` diagnostic as the Int-side path. The typechecker mirrors the runtime rule: when both operands are numeric and at least one is Float, the result is Float for `**` / `%` and Int for `~/`; Int × Int keeps the existing Int-only result type."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-092" }
  tags { "evaluator"; "typechecker"; "float"; "operator" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Match Apple Pkl exactly rather than route through a `pkl:math` stdlib wrapper"
      rationale =
        "The roadmap entry posed two paths: widen the operators in-place or surface them as `math.pow` / `math.floorDiv` / `math.remainder` stdlib calls. The upstream golden output in `third_party/apple-pkl/.../basic/float.pcf` is unambiguous — Apple just widens the operators directly. Routing through `pkl:math` would require additional fixtures and naming decisions; widening in `eval_float_binary` matches the upstream test data and keeps the change local to the binary-operator dispatch."
    }
    new Decision {
      date = "2026-05-15"
      summary = "`~/` returns Int even on Float operands"
      rationale =
        "Apple Pkl's golden output for `5.0 ~/ 3.0` and `5.1 ~/ 3.1` is `1` (the bare integer, not `1.0`). The natural reading is that `~/` is `truncating-divide-to-Int` regardless of operand type. Following the upstream output keeps `intResult: Int = 5.0 ~/ 3.0` typechecking on the Int side instead of forcing call-sites to wrap with `.toInt()`."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Compute `%` as `a - b * trunc(a / b)` instead of `a.mod(b)` to dodge ambiguous Float remainder semantics"
      rationale =
        "Apple Pkl's `5.5 % 6.5 = 5.5` matches truncated (toward-zero) remainder, not floored modulo (which would give `5.5` for the same case but differ on negatives). Encoding the formula explicitly avoids depending on the stdlib's Double remainder convention and makes the Float / Int sign behavior explicit at the call site."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Import `moonbitlang/core/math` for `pow` rather than implementing it locally"
      rationale =
        "The stdlib `pow` is a thin libm wrapper; reimplementing it would either duplicate the libm call or invent a Taylor-series variant whose precision drifts from libm on the standard test inputs. The dependency is already transitively available, so importing it costs nothing at link time."
    }
  }
}

local floatThresholdConstraints = new Scenario {
  id = "PKL-112"
  name = "Float-threshold constraint predicates"
  description =
    "Numeric constraint predicates (`isBetween`, `isGreaterThan`, `isLessThan`, plus the user-defined comparison factories) accept Float literals as thresholds. `Float(isBetween(0.5, 1.5))` now parses and runs without losing precision — previously the threshold parser only accepted Int text, so `0.5` failed to parse and the predicate was silently dropped. The `ConstraintIntPredicate` enum keeps its name (still scoped to the numeric host `Int` / `Float` / `Number`) but its arguments are encoded as `Double` instead of `Int`. The text parser `pkl_parse_constraint_double_text` accepts an optional leading `-`, a digit-run integer part, and an optional `.<digits>` fractional part; the existing `pkl_parse_constraint_int_text` stays in place for `String(length OP N)` paths where `length` is always Int. Int-side value comparison flows through `pkl_constraint_predicate_accepts_float(predicate, value.to_double())` so `Int(isBetween(0, 10))` keeps working uniformly with `Float(isBetween(0.5, 1.5))`. The `length.is*` reuse of the numeric grammar truncates the Double threshold back to Int with `Double::to_int` — `length.isBetween(2.5, 3.5)` therefore behaves like `length.isBetween(2, 3)`, matching Apple Pkl's truncation toward zero. Rejection messages format the Double via the existing `\\{value}` interpolation, so `Float(isLessThan(1.5))` rejecting `2.0` surfaces as `rejects 2` (the MoonBit `Double::to_string` strips the trailing `.0` for integral Doubles, which the existing PKL-092 fixtures already documented for `rejects -0.5`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-092" }
  tags { "typechecker"; "constraint"; "float" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Lift the predicate enum's Int arguments to Double across the board"
      rationale =
        "The alternative was to keep `ConstraintIntPredicate` Int-shaped and bolt on a parallel `ConstraintFloatPredicate` enum with the same variant set. That would double the maintenance surface (every variant added in the future needs both copies, every negation / dispatch lookup needs both arms). Promoting the Int arguments to Double once unifies the dispatch — Int values widen via `to_double` at the top of `pkl_constraint_predicate_accepts`, and the Float path drops its previous `lower.to_double()` widenings since both sides are already Double."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Keep `pkl_parse_constraint_int_text` for the String length predicate path"
      rationale =
        "`String(length > N)` and `String(length.isBetween(0, 10))` always carry Int thresholds — `length` is itself an Int. Routing those through the Double parser would force a `.to_int` round-trip at every length comparison and risk silently truncating thresholds the user meant to fail. Leaving the Int parser in place keeps the existing String constraint grammar bit-for-bit identical."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Truncate Double thresholds back to Int when they flow into `length.isBetween` style predicates"
      rationale =
        "The numeric predicate parser is shared between the `Float(isBetween(...))` host and the `String(length.isBetween(...))` host. The String host's downstream variant `StringLengthIsBetween` still takes Int because `length` is Int. Truncation via `Double::to_int` matches Apple Pkl's `length.isBetween(2.5, 3.5)` reading (round toward zero, identical to writing `length.isBetween(2, 3)`); the alternative (rejecting Float thresholds for length) would require a separate Int-only parser variant and a third error message."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Hand-roll the Double text parser instead of leaning on `@strconv.parse_double`"
      rationale =
        "The constraint-text parser sits next to `pkl_parse_constraint_int_text` and follows the same hand-rolled walk style. Pulling in `moonbitlang/core/strconv` for the Double form would add a dependency for one helper, and the surface here is small (`-?<digits>(\\.<digits>)?`) — exponent notation is parser-level (PKL-128) and not reached from constraint text. The hand-rolled walk also returns `None` on trailing garbage, which lets the predicate parser fall through cleanly instead of catching a strconv exception."
    }
  }
}

local isOperatorRuntime = new Scenario {
  id = "PKL-114"
  name = "is operator runtime evaluation"
  description =
    "The `is` operator evaluates at runtime: `5 is Int` returns `true`, `1.5 is Float` returns `true`, `5 is Number` and `1.5 is Number` both return `true`, `\"x\" is Int` returns `false`, and `if (x is Int) ...` actually branches on the runtime type of `x` instead of failing with `operator is is parser-only`. The new `value_is_type(value, type_name)` helper in `eval.mbt` mirrors the surface that the typechecker's `type_from_annotation` accepts: union (`String | Int`), nullable (`Float?`), constrained (`Int(isPositive)` strips the predicate and falls back on the base type), and generic (`Listing<Int>` / `Mapping<String, Int>` route to `ListingValue` / `MappingValue` without inspecting elements). User-defined class names fall through to `false` for now — class-instance dispatch needs class tags on `ObjectValue`, which is out of scope for this slice. The typechecker's is-guard narrowing was already generic enough for `Float / Number / TypeVariable` paths via the existing `UnionType` / `NullableType` recursion (PKL-092 widened `Number` to `UnionType([IntType, FloatType])` and PKL-110 made `TypeVariable(_)` accept-any in `type_accepts`), so the scope reduces to the evaluator side."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-092"; "PKL-110" }
  tags { "evaluator"; "is-operator"; "narrowing" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Drop the parser-only stub and add a value-classification helper on the evaluator side"
      rationale =
        "The `Is | As | Pipe => parser-only` branch was a stub from the earliest evaluator that signalled 'parsed but not interpretable'. With the typechecker's `Number = UnionType([IntType, FloatType])` and `TypeVariable(_)` accept-any in place, the typecheck side already routes is-guards through the structural narrowing pass for every type the surface admits. The missing piece was the evaluator's runtime classification — `value_is_type` covers the same shape and lets `if (x is Int) ...` finally branch instead of erroring."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Reuse `pkl_constraint_trim` / `split_top_level_union_choices` / `generic_argument_text` / `pkl_constrained_type_base_name` instead of forking a new parser"
      rationale =
        "The type-annotation text the parser stores in the `is` right operand has the same grammar the typechecker already parses for `Listing<T>` / `Mapping<K, V>` / `Float?` / `Int(isPositive)`. Reusing the existing helpers keeps the classification rules in lock-step — when the parser surface grows (e.g. PKL-128 scientific notation, triple-quoted strings) only one set of helpers needs to update."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Leave user-defined class names returning `false` from `value_is_type` for now"
      rationale =
        "Class-instance dispatch needs `ObjectValue` to carry a class tag (the typechecker has `ClassType(name, _)` but the evaluator's `ObjectValue([members])` does not). Tagging is a separate slice (the design touches `new <ClassName> { ... }` instantiation, amends, and renderer round-trips). Returning `false` for unknown class names is the conservative choice — `if (x is Box) ...` always takes the else branch, preserving sound runtime behaviour."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Leave `As` and `Pipe` on the parser-only stub"
      rationale =
        "`As` (type coercion) and `Pipe` (`|>` operator) are independent slices in the roadmap (PKL-128 parser surface expansion covers `|>`). PKL-114's scope is the `is` operator; mixing `as` runtime evaluation in would muddle the slice boundary. The error message stays the same for those two, so authoring still gets a clear `parser-only` hint when they reach for them."
    }
  }
}

local genericTypealiasInstantiation = new Scenario {
  id = "PKL-115"
  name = "generic typealias instantiation"
  description =
    "`typealias Box<T> = Listing<T>` parses and binds T in the target text. At an instantiation site like `Box<Int>`, the typechecker looks up the alias binding for `Box`, matches its declared type parameters against the provided arguments, substitutes the parameter names in the recorded target text, and re-evaluates the resulting type. `b: Box<Int> = new Listing { 1; 2; 3 }` typechecks (the target rewrites to `Listing<Int>`), `b: Box<Int> = new Listing { \"a\"; \"b\" }` rejects (Int-element listing expected, String elements found). Multi-parameter aliases (`typealias Pair<K, V> = Mapping<K, V>`) work the same way — parameters substitute positionally. The substitution pass is textual (`is_typealias_identifier_start` / `_continue` walks the target string and replaces full identifier tokens that match a parameter name); generic alias bindings carry the original `TypeAliasDecl` on a new `alias_decl: TypeAliasDecl?` field on `TypeBinding` so the use-site rewriter does not need to re-walk the declarations array. Non-generic aliases keep `alias_decl = None` and the previous resolution path unchanged."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-110" }
  tags { "parser"; "typechecker"; "typealias"; "generics" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Substitute textually in the alias target instead of representing parameters as a new Type variant"
      rationale =
        "Two designs were on the table. (A) Add a new `TypeAlias(name, parameters, target_type)` variant to the Type enum and substitute at use sites via the Type tree. (B) Keep the alias target as a String on `TypeAliasDecl` and substitute textually before re-running `type_from_annotation`. (B) is much smaller — the Type enum and every consumer of it stays untouched, the substitution is a 20-line tokenizer that walks identifier characters, and the resolution path that `Box<Int>` takes is `try_generic_alias_substitution → type_from_annotation`, which reuses every existing case (union / nullable / constrained / generic). (A) would have given better introspection (`render_type` could show `Box<Int>` instead of the substituted form) but at the cost of touching every Type-walking pass."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Inject declared type parameters as scoped TypeVariables when resolving the alias at definition time"
      rationale =
        "Without this, `typealias Box<T> = Listing<T>` fails to resolve at definition time — `T` is unknown in the surrounding `type_env`, so `type_from_alias_target_annotation` returns `None` and the typechecker emits `unknown type annotation Listing<T>`. Scoping `T` as `TypeVariable(\"T\")` for the duration of the alias's target resolution mirrors how PKL-090 / PKL-110 already handle generic class / function declarations (parameters bind to TypeVariable inside the body). The resulting binding's `typ` is `ListingType([TypeVariable(\"T\")])` — an unresolved generic, never observed by user code because every use site re-runs through `try_generic_alias_substitution` which produces a fully concrete type."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Carry the decl on TypeBinding rather than maintain a parallel alias table"
      rationale =
        "The alternative was to thread `Array[Declaration]` through every call to `type_from_annotation` so the alias resolver could re-walk declarations at use time. That would have grown the signature of ~20 functions for a single new dependency. Embedding the decl on the binding itself keeps `type_from_annotation`'s signature stable; bindings that were never aliases (the vast majority) carry `alias_decl = None` and pay no cost. The trade-off is that all `TypeBinding` construction sites had to update (13 callers, mechanical), which sed handled in one shot."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Tokenize identifiers manually rather than reach for the regex module"
      rationale =
        "`@regexp` is available (constraints.mbt uses it), but a regex like `\\bT\\b` over the target text is a recipe for substitution interference when type parameter names share prefixes (`T` vs `TList`). The character-class identifier walk (`is_typealias_identifier_start` / `_continue` + iterate) gives us full identifier boundaries by construction. The walker is ~25 lines and matches Pkl's identifier grammar precisely — `T` does not replace inside `TList` even if both are referenced in the same target text."
    }
  }
}

local typeParameterBounds = new Scenario {
  id = "PKL-116"
  name = "type parameter bounds"
  description =
    "`class Box<T : Number>` and `function pick<T : Number>(x: T): T` constrain T to a supertype. The parser collects the `: <bound>` suffix per type parameter and stores it as a parallel `type_parameter_bounds: Array[String?]` on `ClassDecl` and `FunctionDecl`. `collect_declared_types` resolves each bound text against the surrounding `type_env` and stores the resulting Type on the new `bound: Type?` field of `TypeBinding`. At call sites, `unify_for_substitution` consults `binding.bound` when it records `T := <actual>`; if the bound is set and `type_accepts(bound, actual)` returns false, a diagnostic surfaces as `type parameter T bound <bound> rejects <actual>` (with Number rendered as `Int|Float` since the union form is canonical). Unbounded parameters keep `bound = None` and the existing accept-any behaviour. Class type literal sites flow through the same path via `substitute_class_type_variables`, which now threads `type_env` and `diagnostics` so bound failures inside `new Container { value = \"x\" }` (where `Container<T : Number>`) reach the user."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-089"; "PKL-110" }
  tags { "parser"; "typechecker"; "generics"; "bounds" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Carry the resolved bound on `TypeBinding` rather than re-walking declarations at use sites"
      rationale =
        "Same trade-off as PKL-115's `alias_decl`: threading `Array[Declaration]` through every typecheck signature would touch ~20 functions. Storing the resolved `bound: Type?` on the `TypeBinding` that already exists for each type parameter is local — the binding is constructed once during `collect_declared_types`, then `unify_for_substitution` reads it during call-site unification. The trade-off is that all `TypeBinding` construction sites had to grow another field; sed handled the 13 update again in one shot."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Render the bound through `render_type` instead of preserving the original `: <text>` literal"
      rationale =
        "The bound was authored as the text `Number`, but it lives on `TypeBinding` as `UnionType([IntType, FloatType])` after resolution. Reporting `bound Int|Float rejects String` keeps the diagnostic faithful to the typechecker's internal representation; preserving the user-authored text would diverge once the bound is built from a typealias or a union literal. Tests and authoring docs reflect this trade — when a bound is `Number`, the diagnostic surfaces as `Int|Float`."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Apply bound check on every unify_for_substitution descent, not only at the top level"
      rationale =
        "Nested TypeVariable references (`function f<T : Number>(xs: Listing<T>) = ...`) need the same bound enforcement when the call site supplies `Listing<String>`. The unifier already recurses into Listing / Mapping / FunctionType / ClassType shapes — adding the bound check inside the `(TypeVariable(name), _) =>` arm guarantees it fires at every nested instantiation site without a separate top-level pass."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer typealias parameter bounds to a later slice"
      rationale =
        "`typealias Box<T : Number> = ...` would also be useful, but PKL-115 introduced generic typealias substitution only days ago and its substitution path is textual rather than Type-based. Adding bound checks there means either re-resolving the typealias target inside `try_generic_alias_substitution` (a string-level operation) or rewiring the path to operate on Types. Both are bigger changes than the class / function bound work; the typealias case can land as a follow-up once the substitution path settles."
    }
    new Decision {
      date = "2026-05-15"
      summary = "The `<T : Bound>` suffix is a pkl-mbt extension over upstream Apple Pkl"
      rationale =
        "Apple Pkl's type parameter grammar admits only `in T` / `out T` variance modifiers plus an identifier — there is no `: Bound` suffix on the upstream side. PKL-116 adds the bound suffix as a pkl-mbt extension so generic functions and classes can statically reject calls like `pick(\"hi\")` against `function pick<T : Number>(x: T)`. Side effect: the upstream Pkl formatter does not recognise the suffix, so the CLI fixture `fixtures/cli_type_parameter_bounds.pkl` intentionally uses the unbounded form to keep `pkf run fmt` clean across the tree. The bounded form is exercised end-to-end through the unit tests in `pkl_test.mbt`."
    }
  }
}

local pklAnyType = new Scenario {
  id = "PKL-133"
  name = "Any top type"
  description =
    "`Any` is Pkl's top type — every value flows through it. The Type enum gains a dedicated `AnyType` variant (distinct from `UnknownType`, which signals parser / inference fallback). `builtin_type_from_annotation(\"Any\")` returns `AnyType`. `type_accepts` short-circuits to `true` whenever either side is `AnyType`, mirroring the relation `Any` plays in Pkl's type lattice: a concrete value flows into `Any`, and a value of `Any` flows back into any concrete annotation that expects it. `equality_compatible` accepts the same pattern so `x: Any = 5; res = x == 5` typechecks without a matching-types diagnostic. `render_type` emits `Any` so error messages preserve the user-facing name; collapsing into `UnknownType` would hide the difference from `Unknown`. The change is parser-transparent — no new tokens, no new AST nodes — and lights up `Any?`, `Mapping<String, Any>`, and `bodyJson: Any?` annotations across pkspec's schema without touching the evaluator at all."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-004" }
  tags { "typechecker"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Introduce a dedicated `AnyType` variant instead of aliasing to `UnknownType`"
      rationale =
        "`UnknownType` was already accept-any in `type_accepts`, so reusing it would have lit up the existing tests. But the two carry distinct semantics: `UnknownType` is `we couldn't determine the type` (parse / inference failure); `AnyType` is `the user wrote Any explicitly`. Renderer output and future error messages should distinguish them (`expected Int, got Unknown` reads as a bug; `expected Int, got Any` reads as a typed-Any flow that needs a cast). Keeping the variants separate preserves the diagnostic surface."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Symmetric `(_, AnyType)` accept-any to mirror Pkl's top-type semantics"
      rationale =
        "Apple Pkl's `Any` accepts any value (variance: covariant) and a value typed as `Any` can be assigned to any annotation (variance: contravariant under the user-facing model, even though the typechecker doesn't track variance). Both arms of `type_accepts` short-circuit to keep the relation symmetric. `as` (PKL-128) will eventually require a downcast, but until then accepting unconditional flow on both sides reflects what works in upstream when the user writes `Any` explicitly."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Wire `Any` into `equality_compatible` alongside `type_accepts`"
      rationale =
        "Without it, `x: Any = 5; res = x == 5` would surface as `operator == expects operands of matching types` once PKL-113 landed. The equality relation already had wildcards for `UnknownType` and `TypeVariable`; adding `AnyType` to the same list keeps the symmetric matching contract consistent. The alternative (treating `Any` differently across `type_accepts` vs `equality_compatible`) would make `x == y` and `x = y` diverge in surprising ways."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Evaluator stays untouched"
      rationale =
        "`AnyType` is a typechecker-side concept; at runtime every value is already self-describing (`IntValue`, `StringValue`, `ObjectValue`, etc.). The fixture exercises `Any = 5`, `Any = \"hello\"`, `Any = true`, and `Mapping<String, Any> = new Mapping { ... }` and the rendered output is identical to what the concrete annotations produce — same path through `eval_property_binding`, same renderer."
    }
  }
}

local listingMappingStdlibCore = new Scenario {
  id = "PKL-134"
  name = "Listing and Mapping stdlib core methods"
  description =
    "The read-only conversion / shape methods on `Listing` and `Mapping` resolve as expected. `Listing.toList()` returns the same elements (pkl-mbt collapses Listing / List into one Value variant); `Listing.toMap()` returns the empty Mapping (Pair-based projections are deferred to PKL-119). `Mapping.toMap()` is the identity, `Mapping.toList()` projects the values. `length`, `isEmpty`, `keys`, `values` were already wired by earlier slices and stay green. Type annotation `List<T>` resolves to `ListingType([T])` via a new alias in `builtin_type_from_annotation` and `generic_argument_text(..., \"List\")` — the typechecker treats Listing / List as the same shape until PKL-119 introduces dedicated value variants. The method dispatch routes through `is_listing_method_name` / `is_mapping_method_name` + the existing `eval_listing_method` / `eval_mapping_method`, so the call-site grammar (`xs.toList()`) follows the same path as `xs.contains(v)`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075" }
  tags { "stdlib"; "evaluator"; "typechecker"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Collapse `Listing.toList()` and `Mapping.toMap()` into runtime identity"
      rationale =
        "Apple Pkl distinguishes the builder type `Listing` from the immutable indexed `List`, and the keyed-builder `Mapping` from the immutable `Map`. pkl-mbt has a single `ListingValue` and `MappingValue` variant for now (PKL-119 is the deferred slice that splits Set / Pair / Map / IntSeq into dedicated variants). Until that split happens, `toList` / `toMap` are runtime identities — they return the same Value with the same elements. The cost is that downstream methods that rely on a distinct List shape (e.g. `take`, `drop`) operate on a `Listing` and a `List` identically, which matches pkf / pkspec's use sites today (shape inspection chains) and surfaces no observable difference."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Add `List<T>` as an alias for `Listing<T>` in `type_from_annotation`"
      rationale =
        "Without this, pkspec's `local testNames: List<String> = tests.toList().map((t) -> t.name)` triggers `unknown type annotation List<String>`. The simplest fix is a dedicated lookup arm for `List` (both the bare name and the generic form) that produces the same `ListingType`. When PKL-119 introduces a `ListValue` variant, the alias can be replaced with a distinct binding — the call site stays the same."
    }
    new Decision {
      date = "2026-05-16"
      summary = "`Mapping.toList()` projects values rather than Pairs"
      rationale =
        "Apple Pkl's `Mapping.toList()` produces a `List<Pair<K, V>>`. pkl-mbt doesn't have `PairValue` yet (PKL-119 again), so the projection has to pick something representable. Values-only projection is what most pkspec chains end up doing (`m.values.toList()` is the idiomatic form), and emitting Pairs would either require a synthetic `ObjectValue` wrapper that downstream methods can't pattern-match, or block the slice entirely. Once Pair lands, the projection becomes a List<Pair>. Documented here so the future change is bounded."
    }
    new Decision {
      date = "2026-05-16"
      summary =
        "Defer functional methods (`map` / `filter` / `flatMap` / `count` / `every` / `distinct`) to PKL-135"
      rationale =
        "The roadmap entry splits `Listing.toList()` (this slice) from the higher-order functional layer (PKL-135). The split keeps each slice tight: PKL-134 is purely dispatch + identity; PKL-135 introduces lambda-binding evaluation per element, which is a different mechanic. Several functional methods (`map`, `filter`, `fold`, `contains`, `take`, `drop`, `join`, `reverse`) are already wired — they were drive-by additions during PKL-075 — so PKL-135's scope narrows to the methods that remain unimplemented (`every`, `count`, `distinct` on Mapping, `flatMap`, `find`, `none`)."
    }
  }
}

local readNullable = new Scenario {
  id = "PKL-103"
  name = "nullable read form"
  description =
    "Apple Pkl's `read?(uri)` mirrors `read(uri)` but returns `null` instead of pushing a diagnostic when the URI scheme is rejected by the sandbox or the resource is missing. The parser recognises `?` followed by `(` after a primary expression and emits a new `NullSafeCallExpr(callee, args)` AST node; the evaluator handles the `read?` case by routing through `eval_read_uri` with a throwaway diagnostic sink — anything that would have surfaced an error becomes `NullValue` instead. The typechecker reports the result as `NullableType(StringType)` so downstream nullable chains see the right shape. A `?` not followed by `(` stays the existing unsupported-syntax fall-through."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-098" }
  tags { "parser"; "evaluator"; "read"; "nullable" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Introduce a generic `NullSafeCallExpr` even though only `read?` is wired"
      rationale =
        "Apple Pkl's `f?(...)` is a generic null-safe call form — `read?` is the only intrinsic that uses it today but the AST node generalises so future intrinsics (`import?`, `getProperty?`, etc.) can plug into the same dispatch arm without parser changes. Encoding the form as a separate Expr variant rather than overloading `CallExpr` with a flag keeps every existing CallExpr consumer untouched."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Reuse `eval_read_uri` with a throwaway diagnostic sink"
      rationale =
        "The non-nullable `read` path already encodes the sandbox policy and the env-var lookup. Routing `read?` through the same helper with a local `probe_diagnostics : Array[Diagnostic]` avoids duplicating the sandbox-rejection logic. Diagnostics raised during the probe are dropped (they're not user-visible — the user explicitly asked for the null-safe form) and the result is collapsed to `Some(NullValue)` on failure."
    }
  }
}

local pklMathFloatOps = new Scenario {
  id = "PKL-120"
  name = "pkl:math Float operations"
  description =
    "`pkl:math` exposes the Float-side helpers `sqrt`, `pow`, `log`, `exp`, `floor`, `ceil`, `round`, `sin`, `cos`, `tan`, `atan`, `atan2`, plus the constants `pi` and `e`. The synthetic `pkl:math` source forwards each public name to a `_pkl_math_<op>` intrinsic identifier; the CallExpr dispatcher in `eval.mbt` intercepts those names, evaluates the numeric arguments (Int promotes to Double), and computes the result via MoonBit's `math` module (or the `Double` intrinsics for `sqrt` / `floor` / `ceil` / `round`). Existing Int helpers (`maxInt32`, `minInt32`, `abs`, `min`, `max`) stay unchanged."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-092" }
  tags { "stdlib"; "pkl-math"; "float" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Forward through `_pkl_math_<op>` intrinsics rather than tagging FunctionValues"
      rationale =
        "An alternative is to add a `BuiltinFunctionValue(String)` Value variant that the runtime recognises directly. That would duplicate the existing FunctionValue dispatch path and require a new pattern in every place a callee is evaluated. Keeping the public surface as a regular Pkl lambda (`sqrt = (x) -> _pkl_math_sqrt(x)`) lets the existing FunctionValue / CallExpr machinery handle the dispatch; the intrinsic name is just one more case in the global identifier table that already holds `throw`, `read`, `trace`, `Regex`, `List`, `Set`, `Map`, `Pair`."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Reuse MoonBit's Double intrinsics for sqrt / floor / ceil / round"
      rationale =
        "`Double::sqrt` / `Double::floor` / `Double::ceil` / `Double::round` are method intrinsics on `Double`, not free functions in `@math`. Calling them as methods keeps each math op a one-liner without indirecting through a wrapper."
    }
  }
}

local superMethodCall = new Scenario {
  id = "PKL-117a"
  name = "super method call"
  description =
    "`super.method(args)` inside a subclass method body dispatches to the parent class's implementation while keeping the current `this`. `eval_class_method_call` pushes a synthetic `@current_class` marker onto the method cache when it enters a class body; `eval_super_method_call` reads that marker, looks up the class binding's `parent_name`, finds the named method on the parent, and invokes it with the same receiver members plus the freshly bound parameters. Errors surface cleanly when `super` is used outside a class body, when the current class has no parent, or when the parent class doesn't define the method. The abstract-method enforcement and override-direction type compatibility halves of PKL-117 remain on the original ticket — the dispatch slice unblocks the most common usage in pkspec adapters."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-040" }
  tags { "evaluator"; "inheritance" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary =
        "Encode the current class on the method cache via a synthetic `@current_class` marker"
      rationale =
        "Threading a `current_class : String?` argument through every eval call (and the recursive helper that follows) would touch dozens of signatures across `eval_expr_with_bindings`, `apply_function_value`, and the constraint check pipeline. Stashing the value on the method cache as a Value-typed entry under a key that can't collide with a user identifier (`@` prefix — the lexer keeps `@` as its own token) reuses an existing scope mechanism with one push at entry and one lookup inside `eval_super_method_call`."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Defer abstract enforcement and override-direction checks"
      rationale =
        "Both checks are typecheck-side: scanning all transitive parents for `body is None` abstract slots, and unifying override-direction subtype rules across method parameters / return types. Each is a non-trivial typecheck pass that's better landed when there are tests to anchor it. The dispatch slice covers the runtime path; the diagnostic for an abstract method without an override already fires at the call site (`method <name> has no body`)."
    }
  }
}

local constraintComposition = new Scenario {
  id = "PKL-128c"
  name = "constraint predicate composition"
  description =
    "Multi-argument constraint annotations like `Int(isPositive, isLessThan(10))` already split into per-predicate parts; this slice adds whitespace trimming so each part is dispatched with the surrounding spaces stripped (`pkl_int_constraint_predicate` no longer needs to defend against leading / trailing tabs). The lone-`&` predicate-composition form that some Pkl-adjacent dialects use isn't part of upstream Apple Pkl syntax — its formatter rejects `&` here — so this slice intentionally stops at the comma-separated form Apple Pkl supports."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-076" }
  tags { "parser"; "constraints" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Defer the lone-`&` composition operator"
      rationale =
        "Apple Pkl's official formatter rejects a bare `&` in constraint position (`Did you mean &&?`), and no upstream stdlib module uses the form. Implementing it on the pkl-mbt side would create a corpus pkl-mbt accepts but Apple Pkl rejects, which works against the round-trip goal. Comma-separated multi-args cover every composition case Apple Pkl actually supports; `&&` inside `this`-style expression predicates is a separate evaluator concern unrelated to splitting."
    }
  }
}

local scientificFloatAndHeredoc = new Scenario {
  id = "PKL-128b"
  name = "scientific Float and triple-quoted heredoc"
  description =
    "Two parser-surface extensions that landed together because they share the lexer's literal-token path. (1) Scientific-notation Float literals — `1e10`, `2.5e-3`, `4E+8`. The lexer extends the existing Int / Float scan with an optional `e` / `E` + sign + digit suffix; `parse_float_text` splits at the exponent, parses the mantissa, then multiplies by 10^exp. (2) Triple-quoted heredoc strings — `\"\"\"<newline>...<indent>\"\"\"`. The lexer captures the whole literal as one `string_token` (three opening `\"`, body, three closing `\"`); `strip_heredoc_indent` then drops the leading newline and dedents each body line by the closing delimiter's indentation. The existing escape decoder still runs on the dedented body so `\\n`, `\\t`, etc. continue to work. String interpolation (PKL-128a) operates on the same dedented body."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-001"; "PKL-128a" }
  tags { "parser"; "lexer"; "string"; "float" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Lex heredoc as one token, dedent at parse time"
      rationale =
        "An alternative is to emit one token per body line so the dedent happens in the lexer. That would scatter indent logic across two stages (lexer for split, parser for unwrap) and break the assumption that one source range corresponds to one token. Keeping the whole literal in one `string_token` mirrors the regular-string path; `strip_heredoc_indent` runs once in `parse_string_literal_text` and shares the escape / interpolation pipeline."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Compute `10^exp` with a multiply loop"
      rationale =
        "MoonBit's stdlib `Double::pow` would be one call, but pkl-mbt's parser is target-agnostic and doesn't currently depend on `moonbitlang/core/math.pow`. A bounded `exp_value`-step multiply loop keeps the parser zero-cost in deps. Scientific exponents in real-world Pkl never exceed a few hundred, so the loop is microseconds at worst."
    }
  }
}

local stringInterpolation = new Scenario {
  id = "PKL-128a"
  name = "string interpolation"
  description =
    "Apple Pkl's `\"... \\(expr) ...\"` string interpolation parses and evaluates. The lexer walks balanced parens (escape- and inner-string-aware) so the outer string's closing `\"` isn't confused with a `\"` inside a `\\(...)` segment. The parser's `parse_string_literal_text` helper splits the inner text at `\\(` boundaries, parses each segment via `parse_source`, and builds an `InterpolatedString(Array[Expr])` AST node — strings with no interpolation collapse back to a plain `StringLiteral` so the hot path stays untouched. The evaluator concatenates each part's `value_to_string_for_join` projection (the helper already used by `Listing.join`). The typechecker reports the result as `StringType` regardless of inner expression types but still walks each part so nested diagnostics surface."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-001"; "PKL-002" }
  tags { "parser"; "evaluator"; "string" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Split-time AST: store alternating segments rather than synthesising `+` chains"
      rationale =
        "An alternative encoding is to translate `\"hello \\(name)\"` into `\"hello \" + name.toString() + \"\"`. That reuses `+` and existing infix machinery, but pkl-mbt's `+` is Int / Float-only — wiring String concat through `+` would need a typechecker rule, an evaluator rule, and a renderer policy. `InterpolatedString(parts)` is an additive AST node that the eval / typecheck / render paths can handle on their own terms without affecting `+` overload resolution. Parser-side this also lets us collapse a no-interpolation string back to `StringLiteral` so the hot path is unchanged for the common case."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Re-enter the parser for each `\\(...)` segment via `parse_source`"
      rationale =
        "An interpolation segment can contain arbitrary Pkl: method calls, nested interpolations, lambdas, etc. Hand-rolling a separate parser for expression-position content would duplicate maintenance. Routing the segment text back through `parse_source` reuses every existing precedence / operator / call rule, including PKL-139 polish (dot-chain across newlines etc.). The cost is one extra `Parser::new` per segment — negligible against the rest of the eval pipeline."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Lexer tracks paren depth + inner-string state for `\\(...)` skipping"
      rationale =
        "The lexer used to close the outer string at the first `\"` it saw, which broke `\"\\(xs.join(\\\", \\\"))\"` — the `\"` inside the inner string call ended the outer prematurely. Walking balanced parens while tracking whether we're inside a nested string literal keeps the outer token intact. Other escapes (`\\n`, `\\t`, ...) still consume two characters as before."
    }
  }
}

local diagnosticSourcePosition = new Scenario {
  id = "PKL-107"
  name = "source position in diagnostics"
  description =
    "Every `Diagnostic` carries `start` / `end` byte offsets into the originating source. The parser sets the offset on every `add_error` site so syntax errors point at the failing token. The CLI's `print_diagnostics_with_source` projects the offset onto a `path:line:column: message` format that editors and IDEs can jump to. Sites that don't have a position yet (most typechecker / evaluator emissions) keep `start = -1`; those still render as just `message` — the migration is incremental. `Parser::current_offset` is now O(1) (cached on the parser struct, incremented by `bump`) instead of summing all preceding token texts on every emit. The helper `diag(message)` covers the common case of an unknown position; explicit `Diagnostic::{ message, start, end }` construction is the path for positioned diagnostics."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-004" }
  tags { "diagnostics"; "position" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Use byte offsets as the canonical position, project to line:column on demand"
      rationale =
        "Tracking `line:column` directly inside `Diagnostic` would require every emit site to know the current source layout, and the CST's natural unit is the byte offset. Storing the offset and projecting it via `offset_to_line_column(source, offset)` at print time keeps each diagnostic small and makes the source-walk a one-shot cost only when the CLI actually formats output. Editors can also use the raw offsets directly when consuming pkl-mbt as a library."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Migrate sites lazily; `-1` is a valid sentinel for unknown"
      rationale =
        "Threading positions through every typechecker / evaluator diagnostic would require carrying `start` / `end` on every `Expr` node. That's a larger refactor (PKL-107 follow-up). The minimum-viable slice wires parser sites only; the helper `diag(message)` returns `start = -1, end = -1` for the rest so the existing 259 emit sites compile without touching them. Future slices can promote sites incrementally — each one becomes more useful as it's positioned."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Cache `byte_offset` on the parser struct for O(1) reads"
      rationale =
        "The original `Parser::current_offset` summed token text lengths from index 0 every call. With ~30K tokens in a stdlib base.pkl and every diagnostic site calling current_offset, the cost would have compounded. Maintaining `byte_offset` incrementally on `bump` (and on the lone `self.pos = trivia_end` jump used by the multi-line dot-chain handler) keeps the diagnostic-emit path constant-time."
    }
  }
}

local rendererConverters = new Scenario {
  id = "PKL-105"
  name = "renderer converters"
  description =
    "`output { renderer = new JsonRenderer { converters { [\"path.to.field\"] = (value) -> ... } } }` rewrites the value at the named dotted path before the renderer serialises the module. Each converter is a `(value) -> newValue` lambda; `eval_program` collects the path-keyed converters from the post-eval result's `output.renderer.converters` MappingValue, then walks the value tree applying `apply_function_value(callback, [matched_node])` at each matching path. Both `ObjectValue` members and `MappingValue` entries with `StringValue` keys participate; unmatched paths are silently skipped (matching Apple Pkl's lenient behaviour). Class-keyed converters (`[\"MyClass\"] = ...`) are recognised but deferred — pkl-mbt's `ObjectValue` doesn't yet carry its source class. The `parse_object_member` brace-body parser now delegates to `parse_inferred_new_body` (mirroring the property-decl fix in PKL-137) so `converters { [\"k\"] = v }` parses as a mapping rather than an object body that silently drops bracket-keyed entries."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-104" }
  tags { "renderer"; "converter" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Apply converters in eval_program's post-processing pass rather than at render time"
      rationale =
        "An alternative is to thread converters into the renderers themselves (`render_value_as_json` etc.) so each format applies them just before serialising each node. That's the design Apple Pkl uses, but it requires every renderer to accept an `Array[(path, callback)]` parameter and an eval context to invoke the callback. Doing it once at the end of `eval_program` keeps the converters in the eval pipeline where `apply_function_value` is already in scope, and every renderer downstream sees the already-converted tree. The cost is that converters can't see the partially-rendered form of a node (they always see the source Value) — that's exactly Apple Pkl's contract."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Defer class-keyed converters until ObjectValue carries source class"
      rationale =
        "PKL-104 chose AST-side detection of the renderer class precisely because ObjectValue doesn't tag its source class. Class-keyed converters (`[\"MyClass\"] = ...`) need that tag to match values. Wiring class-keyed entries today would require visiting every TypedObjectLiteral eval site to attach the class name — a much bigger change. Apple Pkl's path-keyed form covers the common cases (single-field rewrites, format conversions) and unblocks the renderer.converters surface; class-keyed lands when PKL-119's variant split arrives or when an explicit class tag is added."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Walk `parse_object_member` brace bodies through `parse_inferred_new_body`"
      rationale =
        "Without this change, `converters { [\"k\"] = v }` inside `new JsonRenderer { ... }` parses as an empty ObjectLiteral — the object-body parser doesn't know about bracket-keyed entries. Delegating to the same inferred-body dispatcher PKL-137 uses for module-level property bodies fixes nested mappings (and listings) inside class amend bodies as a free side effect. The behaviour was already correct for module-level `tests { ... }` after PKL-137; this slice extends it to nested members."
    }
  }
}

local outputRendererDriver = new Scenario {
  id = "PKL-104"
  name = "output renderer driver"
  description =
    "The CLI's `eval` command picks its rendered format from the module's `output { renderer = new JsonRenderer { ... } }` block when the user did not pass `-f` / `--format`. The renderer's class name is read directly from the parsed AST — `parse_source(source).program.bindings` is walked for an `output` binding whose `ObjectLiteral` body has a `renderer` member; the renderer's `TypedObjectLiteral(class_name, _)` (or an `AmendExpr` peeling back to one) maps onto the existing format string (`JsonRenderer` → `\"json\"`, `YamlRenderer` → `\"yaml\"`, `PropertiesRenderer` → `\"properties\"`, `PcfRenderer` → `\"pcf\"`). The eval result's `ObjectValue` does not carry the source class, so this path stays AST-driven rather than tagging values. The `output` block itself is then stripped from the rendered envelope by `extract_output_value` (when there's no explicit `output.value` subtree) so the renderer doesn't echo its own configuration. An explicit `-f` flag still wins over the renderer-class detection so existing fixtures behave unchanged."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-097" }
  tags { "renderer"; "output"; "driver"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Read the renderer class from the parsed AST, not from a tagged ObjectValue"
      rationale =
        "A more general design tags every `ObjectValue` with its source class name so `new JsonRenderer {...}` survives the eval pipeline as a class-bound value. That would touch every `ObjectValue` pattern match across eval / typecheck / render — a substantial refactor. Reading the class straight from the parsed `TypedObjectLiteral` in the module's `output.renderer` slot is a tight, AST-local solution that lands the user-facing feature without the platform churn. When PKL-119 introduces dedicated value variants for Set / Pair / Map, an OO-aware tag may emerge organically; until then the simpler design pulls its weight."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Strip the `output` block from the rendered envelope"
      rationale =
        "Apple Pkl treats `output` as a module-level control block: it doesn't appear in the module's rendered output. The pre-existing `extract_output_value` only stripped the envelope when `output.value` was explicit; now it strips the `output` member whenever it's present (with no `output.value`), so `output { renderer = ... }` no longer round-trips its own configuration into the JSON / YAML / etc. output. The behaviour is consistent across renderers — every format sees the same `value` payload."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Explicit `-f` always wins"
      rationale =
        "Test fixtures and the upstream gold-diff workflow rely on `-f json` / `-f yaml` overriding the module's declared renderer. Honoring the `output.renderer` only when `-f` is absent keeps every existing test green while letting end users drop the flag once their module declares its target format."
    }
  }
}

local amendsBaseMerge = new Scenario {
  id = "PKL-137"
  name = "amends base module property and type merge"
  description =
    "`amends \"base.pkl\"` / `extends \"base.pkl\"` flows the base module's typealiases and class declarations into the child's unqualified type scope, in addition to the property values that PKL-006 already merged at eval time. (1) `infer_program` resolves `program.module_relation`, calls `resolve_import_types(relation.uri)`, and seeds the child's `type_env` with the base's `TypeExport`s so a bare `Test` annotation in the child resolves to the base's `class Test`. (2) `type_exports_from_parse_result` now exports `TypeAliasDeclaration`s alongside `ClassDeclaration`s. (3) `collect_declared_types_with_imports` falls back to `type_from_annotation` (not just `builtin_type_from_annotation`) so union / constrained / nullable alias targets resolve. (4) `type_from_annotation` strips a balanced outer paren wrapper before dispatch so target text like `(\"draft\" | \"review\" | \"approved\")` splits correctly. (5) `builtin_type_from_annotation` recognises a quoted string literal in type position as `StringType` so string-literal union types (`\"critical\" | \"major\" | \"minor\"`) resolve. (6) `type_accepts` admits an empty `ObjectType([])` against `ListingType(_)` / `MappingType(_)`. (7) `parse_property_decl` routes a brace-bodied amend (`tests { entry }`) through `parse_inferred_new_body` so the body shape follows the first significant token."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-006"; "PKL-118"; "PKL-138" }
  tags { "evaluator"; "typechecker"; "amends"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Inject relation type exports unqualified"
      rationale =
        "Apple Pkl's `amends` brings the base's names into the child's scope without a prefix, unlike `import \"base\" as base` which exposes them as `base.Foo`. Mirror that: the relation's TypeExports are pushed straight into the child's `type_env` with their original names. The `imported_type_bindings` path (qualified) keeps working for explicit `import` declarations."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Approximate string-literal types as `StringType`"
      rationale =
        "A full string-literal type would need a refined `StringLiteralType(String)` variant + narrowing in `type_accepts` + render adjustments. Collapsing each literal to `StringType` lets union typealiases (`\"critical\" | \"major\" | \"minor\"`) typecheck cleanly. A future slice can add the refined variant if call sites need it."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Empty `new {}` typecheck coercion mirrors PKL-138 eval coercion"
      rationale =
        "PKL-138 already coerced an empty `ObjectValue([])` to `ListingValue([])` / `MappingValue([])` at eval time. The typechecker had no matching rule, so `tests: Listing<Test> = new {}` typechecked as `Listing<Test> does not accept Object`. Adding the corresponding rule in `type_accepts` keeps the two phases in sync."
    }
  }
}

local stdlibModifiers = new Scenario {
  id = "PKL-140"
  name = "Apple Pkl stdlib declaration modifiers"
  description =
    "Parser and evaluator accept four Apple Pkl stdlib idioms that previously tripped `unsupported expression` / `missing expression body` / `expected type parameter, got in`. (1) `external` modifier on properties / classes / functions: already recognised by `is_modifier_text` and consumed by `skip_member_header`; the gap was the resulting property with no `=` body, which the parser now flags as an abstract slot. (2) Abstract property slots (`foo: Int?`): the parser sets a new `Binding.abstract_slot = true` field, stores a `NullLiteral` placeholder value, and both evaluator + typechecker skip the binding (eval: not pushed onto ObjectValue; typecheck: type recorded as the declared slot type, no validation against the placeholder). (3) Variance modifiers `<in T>` / `<out T>` on class / function / typealias type parameters: parser consumes the modifier before the identifier; pkl-mbt treats type parameters invariantly so the marker is purely a parse-side acknowledgement. (4) Function type annotations on properties (`comparator: (V, V) -> Boolean = ...`): new `parse_property_type_annotation` helper uses `stop_at_arrow=false` because property declarations end at `=` / `{`, making the arrow unambiguous. The same helper is wired into class-property declarations. (5) Declarations-only modules (`module pkl.math` with only `external` properties) now evaluate to the empty ObjectValue rather than `missing expression body`, mirroring Apple Pkl's stdlib loading model."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-001"; "PKL-002"; "PKL-116" }
  tags { "parser"; "evaluator"; "typechecker"; "stdlib" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary =
        "Promote abstract slots to a dedicated `Binding.abstract_slot` flag rather than a sentinel Expr"
      rationale =
        "An alternative is to overload `UnsupportedExpr` for the abstract case, but then every eval / typecheck arm has to disambiguate `legitimate abstract slot` from `parse failure`. A dedicated boolean keeps the two cases factored and lets the parser still emit `UnsupportedExpr` for actual parse errors."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Variance modifiers are parsed but not enforced"
      rationale =
        "Apple Pkl's variance semantics (`out T` covariant, `in T` contravariant) interact with the typechecker's subtype relation. pkl-mbt is fully invariant under the hood and the test suite doesn't exercise variance-dependent assignments yet. Accepting the modifier without enforcing it unblocks every stdlib class declaration immediately; correctness is a future slice once subtype-relation tests are in place."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Function type annotations only accept arrows in property position"
      rationale =
        "`parse_type_annotation` defaults to `stop_at_arrow=true` because lambda parameter type annotations (`(x: Int) -> x + 1`) need the arrow to terminate the type so the lambda body starts. Property declarations always end the type at `=` or `{`, so the arrow is unambiguous there. Splitting the helper into `parse_property_type_annotation` (arrow allowed) and `parse_type_annotation` (arrow stops) keeps each call site honest."
    }
  }
}

local httpsImports = new Scenario {
  id = "PKL-129"
  name = "URI imports via https with mizchi/x/http"
  description =
    "`import \"https://...\"` and the entry-point path resolve through `mizchi/x/http.get` running under a `moonbitlang/async` event loop. The CLI's `main` is now `async fn main`, so `load_path` can await the fetch directly — no `run_async_main` wrapper / Ref-capture dance. Both native and JS targets ship a working fetcher (mizchi/x supplies a socket-backed implementation on native and a `fetch`-backed one on JS, both behind the same `@http.get` surface). The WASM target prints a clear diagnostic — WASI support is the follow-up. `package://` URIs (Apple Pkl's registry protocol — zipball metadata + per-file path fragments) are recognised by the dispatcher but always raise; pointing the import at the raw GitHub URL is the workaround until that slice lands."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-006" }
  tags { "parser"; "imports"; "sandbox"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary =
        "Convert the CLI `main` to `async fn main` rather than wrapping each fetch in a sync trampoline"
      rationale =
        "The first cut used `@async.run_async_main(() => { ... })` to capture the fetch result into a `Ref` from a sync `fn main`. That works on native (the native event loop blocks until the closure returns), but on JS `run_async_main` only schedules — the result `Ref` is still `None` when control returns to the caller. Promoting `fn main` to `async fn main` lets the call site `await` the fetch directly under both target's event loops without a target-specific trampoline. The downside is `load_path` and `load_expr_imports` become async too, but they were already in a single call tree with no real recursion-vs-async incompatibility."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Defer `package://` URI resolution to a follow-up"
      rationale =
        "Apple Pkl's `package://` scheme resolves through `pkg.pkl-lang.org`'s registry protocol: fetch package metadata JSON, locate the zipball URL, fetch + extract the zipball, then look up the path fragment inside. That's a separate slice in its own right (zip unpacker, path-fragment routing, signature checking). Shipping the recognition + clear diagnostic now keeps imports honest: `import \"package://...\"` no longer falls through to the filesystem reader (which would emit `failed to read package://...` — meaningless), and the diagnostic points at the workaround (use the raw https URL of the .pkl file)."
    }
    new Decision {
      date = "2026-05-16"
      summary = "WASM target prints the unsupported message instead of falling back to JS"
      rationale =
        "WASM doesn't have a native HTTP client today; the bundled WASI variant of fetch is still in flux upstream. mizchi/x ships a `NotSupported` stub on WASM, and propagating that to the CLI as a clear message lets users see what's missing rather than fighting an opaque error. When WASI sockets stabilise, the WASM stub extends to wrap a WASI-backed fetcher."
    }
  }
}

local pkspecPolish = new Scenario {
  id = "PKL-139"
  name = "parser and evaluator polish for pkspec"
  description =
    "Running pkspec's `pkl/Test.pkl` through pkl-mbt surfaced five drive-by parser / evaluator gaps that have nothing to do with one big subsystem but together blocked the file from evaluating. They are bundled here so a single slice unblocks the empirical pkspec round-trip: (1) `@ModuleInfo { ... }` brace-bodied annotations skip the `{ ... }` payload the same way `@Deprecated(\"...\")` skips parens — Apple Pkl's module / class metadata uses the brace form. (2) `typealias Foo =\\n  String(...)` allows the RHS to start on the next line; `parse_typealias_decl` now uses `skip_trivia` after the `=` so newlines are consumed. (3) Postfix dot-chains break across newlines (`xs\\n  .toList()\\n  .map(...)`); `parse_postfix_expr` peeks past trivia and, when the first significant follow-up token is `.` / `?.`, advances the cursor before continuing. (4) `module.foo` is Apple Pkl's self-reference to the current module's `foo` binding; the parser emits `Identifier(\"module\")` and the evaluator short-circuits `MemberAccess(Identifier(\"module\"), name)` to `resolve_binding_value(name, ...)`. (5) The stdlib constructor functions `List(...)`, `Set(...)`, `Map(k1, v1, k2, v2, ...)`, and `Pair(a, b)` are recognised before the generic call-path runs: `List` and `Set` produce `ListingValue` (Set dedupes), `Map` builds a `MappingValue`, `Pair` collapses to a 2-element `ListingValue` until PKL-119 introduces a dedicated `PairValue`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-001"; "PKL-002"; "PKL-138" }
  tags { "parser"; "evaluator"; "stdlib"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Bundle five independent gaps into one slice rather than five mini-slices"
      rationale =
        "The gaps were found by a single empirical exercise (`moon run cmd/main -- eval pkspec/pkl/Test.pkl`) and each one in isolation gates the next: if `@ModuleInfo` isn't skipped, the module never parses; if the typealias RHS doesn't accept newlines, the type system never sees the constraints; if the dot-chain doesn't follow newlines, the body bindings fail; if `module.foo` isn't a self-reference, `output { value.defaults = module.defaults }` errors; if `List(...)` isn't a constructor, every cross-reference check in Test.pkl falls over. Splitting them into individual tickets would require five separate Roadmap entries that each only make sense in the context of the others. The bundle is small enough (one parser arm and four eval arms per gap) to stay reviewable in one commit."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Skip brace-bodied annotations rather than capture metadata"
      rationale =
        "Apple Pkl's `@ModuleInfo { ... }` carries metadata (min Pkl version, doc, etc.) that the runtime doesn't enforce inside an evaluator — it's primarily for tooling (`pkldoc`, codegen). pkl-mbt doesn't carry annotation metadata into the AST yet (PKL-128 is the slice that would). Skipping the body is the conservative move: it unblocks the file without storing data that nothing consumes. When the annotation surface lands, the skipper extends to a captured `AnnotationDecl` AST node."
    }
    new Decision {
      date = "2026-05-16"
      summary =
        "`Pair(a, b)` collapses to a 2-element ListingValue rather than blocking on PairValue"
      rationale =
        "Apple Pkl's `Pair` is a structurally distinct stdlib type with `.first` / `.second` accessors. pkl-mbt doesn't have `PairValue` yet (PKL-119 is the future slice that splits Set / Pair / Map / IntSeq into dedicated variants). Until then, returning a 2-element `ListingValue` keeps the constructor call passing without introducing a half-baked third variant. Downstream code that depends on `.first` / `.second` will still error, but the construction itself no longer fails parser-side — which is what unblocks the pkspec evaluation path that just passes Pair values through unchanged."
    }
  }
}

local newBodyInference = new Scenario {
  id = "PKL-138"
  name = "new body inference from first token and binding annotation"
  description =
    "Apple Pkl writes `tests: Listing<Test> = new { ... }` and `m: Mapping<K, V> = new { ... }` without an explicit `Listing` / `Mapping` qualifier on `new`. The parser previously dispatched `new { ... }` (empty type prefix) unconditionally to `parse_object_body`, so bare-expression bodies parsed as zero members (the property-decl loop skipped them) and empty bodies came back as `ObjectValue([])` that failed every Listing / Mapping method. The new `parse_inferred_new_body` helper peeks the first significant token inside the brace: `[` → mapping body, `}` / `local` / `when` / `for` / property-decl / `hidden ident` / `fixed ident` → object body, anything else (literal / `(` / unary / `new` / identifier without property suffix) → listing body. For the empty-body case the parser still produces `ObjectLiteral([])`; the evaluator's `coerce_value_to_annotated_type` helper then projects it to `ListingValue([])` / `MappingValue([])` when the binding's type annotation requires it. Coercion runs at every binding eval site (`resolve_binding_value`, module-level binding loop, `eval_object_members`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-005" }
  tags { "parser"; "evaluator"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Peek-based dispatch in the parser, type-driven coercion in the evaluator"
      rationale =
        "An alternative is to parse `new { ... }` into a single FlexibleLiteral variant that captures both bare expressions and object members, then disambiguate at typecheck / eval time. That preserves more information but requires touching every consumer of `ObjectLiteral` / `ListingLiteral` / `MappingLiteral`. The peek approach covers all non-empty cases at parse time (the body shape is unambiguous when the first item is concrete), and only the empty body needs the type-driven fallback. Two narrow integration points (parser peek + eval coercion) rather than threading a new AST variant through every stage."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Coerce only empty `ObjectValue([])` to `ListingValue([])` / `MappingValue([])`"
      rationale =
        "A non-empty `ObjectValue` with a `Listing<T>` annotation is a real type mismatch — the body had real members (`name = ...`), so it can't be a listing. Limiting coercion to empty values keeps the diagnostic surface honest: legitimate type errors still surface, only the parse-time ambiguity around `new {}` gets smoothed over. The coercion runs before the constraint / annotation check so the post-coerced value is what gets validated, mirroring upstream's semantics where `new {}` is a polymorphic empty literal."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Include `Set<T>` in the coercion table, folding to `ListingValue([])`"
      rationale =
        "`Set` doesn't have a dedicated value variant yet (PKL-119 is the future slice that splits Set / Pair / Map / IntSeq), so coerce empty `new {}` annotated as `Set<T>` to `ListingValue([])` for now. The runtime behaviour matches how pkl-mbt already collapses Listing / List into a single variant. When PKL-119 ships, the table extends to a dedicated `SetValue([])` arm."
    }
  }
}

local whenConditionalProperty = new Scenario {
  id = "PKL-136"
  name = "when conditional property in Listing / Mapping bodies"
  description =
    "Apple Pkl's `when (cond) { ... } [else { ... }]` form is recognised inside Listing and Mapping bodies as well as object bodies. The parser wraps each block in a new `WhenSpread(ConditionalExpr(cond, then_body, else_body))` Expr variant whose branches reuse `ListingLiteral` / `MappingLiteral` (matching the surrounding context). The evaluator's `ListingLiteral` and `MappingLiteral` arms recognise `WhenSpread` during element / entry iteration and spread the selected branch's contents into the parent collection instead of attaching it as a nested value. Object body `when` was already wired in an earlier slice via the synthetic `@when` ObjectMember; the new variant is additive. A drive-by parser fix in `parse_object_expr` recognises `new Listing<T> { ... }` / `new List<T> { ... }` / `new Mapping<K, V> { ... }` as listing / mapping bodies — previously the generic-tagged forms fell into the `TypedObjectLiteral` arm and silently parsed the body as object members, dropping everything inside."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-001"; "PKL-002" }
  tags { "parser"; "evaluator"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Introduce a single `WhenSpread(Expr)` variant rather than per-collection wrappers"
      rationale =
        "An alternative is per-collection sum types (`enum ListingBodyItem { Element; When }`, `enum MappingBodyItem { Entry; When }`), which models the body more precisely but requires churning every push-site of `Array[Expr]` / `Array[MappingEntry]`. The `WhenSpread(Expr)` wrapper rides on the existing `Array[Expr]` / `Array[MappingEntry]` shapes by letting the wrapped Expr be a `ConditionalExpr` whose branches are `ListingLiteral` / `MappingLiteral`. The evaluator pattern-matches `WhenSpread` during iteration, evaluates the inner conditional, then unpacks the resulting `ListingValue` / `MappingValue` and spreads. Two arms in eval + two in the parser, no shape refactoring."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Reuse `ConditionalExpr` inside `WhenSpread` rather than a dedicated when-AST node"
      rationale =
        "`when (cond) { then } else { else }` is operationally a `ConditionalExpr` whose branches happen to be collection literals. The evaluator already handles `ConditionalExpr` — we just need the outer marker (`WhenSpread`) to tell the listing / mapping iteration arm to spread the result. Defining a separate `WhenExpr(Expr, Expr, Expr)` node would duplicate the conditional evaluation path. The mismatch with the object-body `@when` machinery (which uses a synthetic ObjectMember name as the marker) is intentional: object members already have a `String` discriminator (the name), so the marker fits there; listing elements / mapping keys don't, so the marker has to be an Expr variant."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Fix `new Listing<T> { ... }` parsing in this slice"
      rationale =
        "pkspec's `specRef = new Listing<String> { when (s.id != null) { s.id } }` uses the typed listing form. Without the parser fix the body silently parses as object members and the `when` block never reaches the listing evaluator. The fix is mechanical (`type_name.has_prefix(\"Listing<\")` → `parse_listing_body`) and unblocking it inside PKL-136 keeps the slice useful end-to-end; if pulled out to a separate ticket the slice ships a feature that doesn't actually work on the pkspec call sites that motivated it."
    }
  }
}

local listingMappingFunctional = new Scenario {
  id = "PKL-135"
  name = "Listing and Mapping functional methods"
  description =
    "Higher-order predicate / search / flatten methods on `Listing` and `Mapping` resolve and run end-to-end. `Listing` gains `flatMap`, `count`, `every`, `any`, `none`, `find`, `findOrNull`, `findLast`, `findLastOrNull`; `Mapping` gains `every`, `any`, `none`, `count` whose predicates take `(Key, Value) -> Boolean` (matching upstream's signature). Each method is wired through `is_listing_method_name` / `is_mapping_method_name` plus `eval_listing_method` / `eval_mapping_method`, reusing `apply_function_value` to invoke the user lambda per element. `find` raises a diagnostic when no element matches (mirroring Apple Pkl's behaviour), `findOrNull` and `findLastOrNull` return `NullValue` instead. `flatMap` accepts callbacks returning Listing only — the `Collection<Result>` union (List / Listing / Set) is collapsed onto `ListingValue` today, so the constraint is the runtime shape of the result rather than the declared type."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-134" }
  tags { "stdlib"; "evaluator"; "typechecker"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Skip `noneMatch` — Apple Pkl spells it `none`"
      rationale =
        "PKL-135's roadmap text mentioned `noneMatch` as a synonym, but Apple Pkl's stdlib only defines `none(predicate) -> Boolean`. The Java Stream API uses `noneMatch`; introducing the alias here would create a Pkl-incorrect surface. Implementing only `none` keeps the surface byte-aligned with Apple Pkl. If someone later wants the Stream-API spelling it can be added as a one-line alias arm."
    }
    new Decision {
      date = "2026-05-16"
      summary = "`find` raises a diagnostic when no match, `findOrNull` returns null"
      rationale =
        "Apple Pkl's `find` throws if no element matches; the `OrNull` variant exists precisely to avoid the throw. pkl-mbt mirrors that split by pushing a diagnostic and returning `None` (which aborts the evaluation) when `find` runs through the whole collection without a hit, and by returning `NullValue` for the `OrNull` variants. Collapsing both into a silent `NullValue` would diverge from upstream and hide bugs."
    }
    new Decision {
      date = "2026-05-16"
      summary = "`flatMap` rejects non-Listing callback results"
      rationale =
        "Upstream `flatMap` accepts a `Collection<Result>` (List | Listing | Set). pkl-mbt collapses those into `ListingValue`, so we only need to recognise that variant. Anything else (Int, String, ObjectValue, ...) is almost certainly a user bug; raise a clear diagnostic rather than silently coercing. When PKL-119 splits Set / Pair into their own variants, the arm extends to recognise the new variants without changing the call-site grammar."
    }
  }
}

local equalityTypecheckOperandMatch = new Scenario {
  id = "PKL-113"
  name = "equality typecheck operand match"
  description =
    "The typechecker rejects `==` and `!=` when the operand types are statically distinct. Today's typechecker returned BoolType unconditionally, so `5 == \"hi\"` and `true != 3` typechecked clean and only failed at runtime (or rather, silently returned `false`). The new pass routes through a dedicated `equality_compatible(left, right)` helper that admits the wider compatibility relation Apple Pkl exhibits for equality: numeric mix (Int vs Float, e.g. `1 == 1.0` is `true` in upstream), nullable / non-null match (`name: String? = null; name == null`), same-name `ClassType` pairs, structural `ObjectType` / `ListingType` / `MappingType` matches, and any pair where either side is `UnknownType` or a free `TypeVariable(_)`. `ConstrainedType` / `DefaultedType` wrappers are stripped via `equality_unwrap_type` before the case match so `Int(isPositive) == 5` still compares as `Int == Int`. `UnionType` flows through the existing fan-out: a union accepts the other side if any of its options does. The helper is symmetric — both `5 == \"hi\"` and `\"hi\" == 5` raise `operator == expects operands of matching types`, and the same wording is reused for `!=`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-004" }
  tags { "typechecker"; "equality" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Use a dedicated `equality_compatible` helper rather than reusing `type_accepts`"
      rationale =
        "`type_accepts(expected, actual)` is one-directional: it answers `does an actual fit where an expected was declared?`. Equality is symmetric and admits Int / Float as compatible operands, which `type_accepts` deliberately rejects (assigning an Int into a Float-typed binding is a type error). Bolting Int / Float symmetry onto `type_accepts` would weaken assignment checks elsewhere. A separate helper keeps the two concepts cleanly factored — `type_accepts` for assignment / argument flow, `equality_compatible` for the symmetric equality relation."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Mirror Apple Pkl's `1 == 1.0 == true` rather than rejecting Int / Float pairs"
      rationale =
        "The upstream snippet at `third_party/apple-pkl/.../basic/float.pcf` evaluates `1 == 1.0` to `true`. Rejecting Int / Float at the typecheck layer would diverge from the established surface — users who write `n: Int = 5; n == 5.0` would suddenly need explicit conversions even though the runtime does the right thing. The helper therefore lists `(IntType, FloatType)` and its symmetric pair as compatible, leaving Int / Float as a numeric-mix admission analogous to `LessThan` / `GreaterThan`."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Accept any `ObjectType` / `ListingType` / `MappingType` pair instead of requiring per-element match"
      rationale =
        "Per-element structural equality is the runtime concern (`Object.equals` walks the members at runtime). At the typecheck layer rejecting `{ a = 1 } == { b = 2 }` would surface as a noisy error in valid programs (`map` / `filter` outputs comparing against literals, fixture-style equality checks). The compatibility relation therefore accepts any same-kind structural pair — false positives at this layer mean runtime evaluates to `false`, which matches Apple Pkl's behaviour."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Leave the evaluator untouched"
      rationale =
        "The evaluator already returns `false` for cross-type equality (`IntValue(5) == StringValue(\"hi\")` flows through the catch-all `_ => None` branch which surfaces a diagnostic). PKL-113 just lifts that runtime rejection into the static layer; the evaluator's `Int == Float` mixing (via `eval_float_binary` after widening the Int to Double) already matches the upstream `1 == 1.0 == true` semantics."
    }
  }
}

local callSiteGenericInference = new Scenario {
  id = "PKL-110"
  name = "call-site generic inference"
  description =
    "The typechecker propagates concrete types through generic function calls and class literals. Each `ClassDecl.type_parameters` / `FunctionDecl.type_parameters` entry binds to a new `TypeVariable(name)` variant in the typecheck `Type` enum (previously `UnknownType`). At every call site (`infer_lambda_application` and `infer_function_type_call`) the typechecker walks parameter / argument pairs through `unify_for_substitution`, building a `TypeSubstitution` table that records `TypeVariable(\"T\") := <concrete>` bindings. `substitute_type` then rewrites the inferred return type, the parameter cache entries, and the declared return annotation so the call's result has the concrete type — `identity(7)` typechecks as `Int`, so `identity(7) + 1` succeeds while `identity(\"hi\") + 1` rejects with `operator + expects Int operands`. The class literal path in `apply_type_annotation` does the symmetric move: when the expected `ClassType` still carries TypeVariable members and the inferred `ObjectType` carries concrete member types, `substitute_class_type_variables` unifies and rewrites the class type before returning, so downstream field accesses (`intBox.value`) resolve to the substituted member type. `type_accepts` treats `TypeVariable(_)` on either side as accept-any during the structural pass so unification can run without false rejection; the substitution table is the diagnostic surface. Generic class declarations whose body uses are exhausted at scope exit (e.g. a function body that references T but is never called) still typecheck — the variable simply stays free and renders as its parameter name."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-089"; "PKL-090" }
  tags { "typechecker"; "generics"; "inference" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Promote type parameters to a real `TypeVariable(String)` variant instead of overloading `UnknownType`"
      rationale =
        "PKL-089 / PKL-090 deliberately bound T to `UnknownType` because the substitution machinery was deferred. Now that the machinery exists, `UnknownType` is too coarse: it means 'I don't know this type — accept anything', while a free `T` means 'this site is a parameter — rewrite me at the call site'. Conflating them would either leak `UnknownType` into substituted return types (silently accepting nonsense) or require call-side flags to distinguish them. A dedicated variant is cheaper and lets `render_type` print the original parameter name (`T`) instead of `Unknown`, which is the form Pkl users wrote."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Collect substitutions in a separate pass over parameter / argument pairs"
      rationale =
        "Hindley-Milner-style unification with constraint generation is the textbook approach. A separate accumulating pass keeps the diagnostic surface clean: `type_accepts` still drives argument rejection, `unify_for_substitution` does not raise diagnostics on conflict (it just records the first binding), and `substitute_type` runs at well-defined boundaries (return-from-call, after-class-literal-annotation). This split lets the substitution pass remain non-recursive at the top level — every signature reduces to a finite walk over the parameter list."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Apply class-type substitution inside `apply_type_annotation` rather than at the `TypedObjectLiteral` site"
      rationale =
        "`apply_type_annotation` is the single funnel for `binding: ClassType = new ClassType { ... }`, `binding = new ClassType { ... }`, and `binding: ClassType` (no body). Doing substitution at the funnel guarantees every path benefits — including imports and re-amends that route through the same annotation resolver. Doing it at `TypedObjectLiteral` would miss the `binding: Box<Int> = someBox` annotation form once user-facing generic syntax expands."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Leave the evaluator untouched"
      rationale =
        "Substitution is a typechecker-side phenomenon: at runtime, `new Box { value = 5 }` has always carried `value = IntValue(5)` regardless of T's static binding. The new variant lives in `typecheck.mbt` only, and the evaluator's PKL-090 short-circuit (`eval_type_name_is_type_parameter`) still applies — it never relied on the typechecker's representation of T."
    }
  }
}

local pklTestExamples = new Scenario {
  id = "PKL-100"
  name = "pkl test examples and golden diff"
  description =
    "The native CLI `test` subcommand walks the module-level `examples` member alongside the existing `facts` walker. Each example is rendered through the PCF envelope (`examples { [\"label\"] { ... } }`) and the entire envelope is byte-diffed against a sibling `<file>-expected.pcf` golden file. A passing diff prints `PASS examples (N examples)`; a mismatch prints `FAIL examples diff against <path>` and contributes to the non-zero exit. The `--overwrite` CLI flag regenerates the golden file from the current rendering (printing `OVERWRITE <path>`), matching Apple Pkl's golden-file workflow. Modules without an `examples` member skip the diff entirely so facts-only fixtures keep working unchanged."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-095" }
  tags { "cli"; "pkl-test"; "examples" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Diff the entire `examples` envelope, not per-example sections"
      rationale =
        "A structured per-example golden format would buy granular diff reporting at the cost of inventing a sectioning convention (Apple Pkl uses a custom delimiter scheme). Diffing the whole envelope keeps the implementation portable across renderer formats and the golden file readable as plain PCF. Per-example diff reporting is a follow-up once the envelope baseline is stable."
    }
    new Decision {
      date = "2026-05-15"
      summary = "`--overwrite` flag instead of an environment variable"
      rationale =
        "Apple Pkl uses `--overwrite` to regenerate goldens; matching the flag name keeps the workflow muscle-memory portable. The flag is parsed centrally with the other CLI flags so future subcommands can opt in to the same regeneration channel without inventing parallel flag names."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Compose with the existing facts walker rather than replace it"
      rationale =
        "PKL-095's facts walker is a working contract used by existing fixtures; `examples` is additive. Running both walkers sequentially on the same module keeps the existing fixtures' `PASS addition (N assertions)` lines intact while letting new fixtures add examples on top. Both contribute to the same non-zero exit path so failures of either kind block CI."
    }
  }
}

local cliFormat = new Scenario {
  id = "PKL-099"
  name = "cli format subcommand"
  description =
    "`moon run cmd/main -- format <file>` parses and evaluates the source through the existing `AnalysisSession`, then re-emits the resolved module via the PCF renderer. Whitespace and indentation collapse to the renderer's canonical form (`name = \"hawk\"`, two-space indent inside blocks, separator after `=`). Parse failures and evaluation failures short-circuit with the diagnostic surface used by the other CLI subcommands. The first cut deliberately operates on the evaluated module value rather than the CST, so default values from class declarations and amend chains land in the output; a trivia-preserving idempotent formatter (`render_cst_with_comments`) is a follow-up that reuses the existing CST infrastructure."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-070" }
  tags { "cli"; "renderer"; "format" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Format via the evaluated module + PCF renderer instead of CST round-trip"
      rationale =
        "The PCF renderer already produces byte-for-byte canonical output (matched against Apple Pkl gold on 25 fixtures). Routing `format` through it requires zero new code on the emit side. The trade-off is that comments and original layout are dropped — that's a known limitation, made explicit in the spec description, and the CST infrastructure already exists to upgrade later."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Fail the command on parse / evaluation errors"
      rationale =
        "A formatter that silently emits the original text on failure would hide bugs and break editor save-on-format flows. Failing loudly with the diagnostic surface mirrors what `pkl format` does upstream and lets editors surface the underlying issue."
    }
  }
}

local genericFunctionTypeParameters = new Scenario {
  id = "PKL-090"
  name = "generic function type parameters"
  description =
    "`function identity<T>(x: T): T = x` and `function pair_first<A, B>(a: A, b: B): A = a` parse, typecheck, and evaluate. The parser captures the optional `<T1, T2, ...>` list immediately after the function name on `FunctionDecl.type_parameters`. The module-level `collect_declared_types_with_imports` flattens each function's parameters into the shared `type_env` as `UnknownType` bindings so body uses of `T` resolve without the 'unknown type annotation' diagnostic. The evaluator gains a `eval_type_name_is_type_parameter` short-circuit on both the callable-argument and callable-return validators: when the declared `type_name` matches any class or function type parameter, runtime annotation rejection is skipped wholesale (the parameter accepts any value). Call-site inference of T from the argument type stays deferred — `identity(42)` evaluates to `IntValue(42)` because the body is a literal pass-through, not because the typechecker propagated `Int` through `T`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-089" }
  tags { "typechecker"; "evaluator"; "generics"; "callable" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Flatten function parameters into the module-level `type_env`"
      rationale =
        "Pkl exposes no nested function definitions in user-visible syntax, so all function declarations share a single module scope. A flat injection costs nothing compared with threading a per-function scope through every typechecker helper that touches a body. Name collisions across functions collapse to a single `UnknownType` binding, which is correct under the deferred-inference model — both T's are 'tolerated unknown' until call-site inference arrives."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Short-circuit runtime annotation validators on type parameter names"
      rationale =
        "The runtime callable-argument and callable-return validators reject when `eval_value_accepts_type_annotation` says no. Without an instantiation-time binding, `T` simply is not a concrete type — saying 'accept anything' (matching the deferred-inference posture) is more honest than rejecting all calls to a generic function. The check walks all declarations once per call, which is fine at our declaration counts and cacheable later."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer call-site inference of T to a follow-up slice"
      rationale =
        "True generic inference (propagating the argument type into the body and the return) needs a substitution table that the typechecker can thread through every expression node. That is a substantial refactor and is not on the critical path for fixtures that just need to declare generic functions and have them parse / typecheck / evaluate."
    }
  }
}

local genericClassDeclarations = new Scenario {
  id = "PKL-089"
  name = "generic class declarations"
  description =
    "`class Box<T> { value: T }` and `class Pair<A, B> { first: A; second: B }` parse, typecheck, and evaluate. The parser recognizes the optional `<T1, T2, ...>` list immediately after the class name and stores the parameter names on `ClassDecl.type_parameters`. The typechecker injects each parameter into a class-scoped `type_env` as a binding to `UnknownType`, so body uses of `T` route through the existing unknown-but-tolerated annotation path rather than failing as 'unknown type annotation'. Parent-name lookup (`extends`) and method-body validation also receive the scoped env so a parameter visible in a property type stays visible on a method signature. The evaluator is unchanged: type parameters are a typechecker-only construct in this slice, so instantiating `new Box { value = 5 }` produces an `ObjectValue` whose `value` member carries the actual runtime value. Instantiation-time T-binding (where the typechecker would propagate `Int` through `b.value` after `new Box { value = 5 }`) stays deferred — that lands together with PKL-090's call-site inference."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-040" }
  tags { "typechecker"; "generics"; "class" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Bind type parameters to `UnknownType` rather than introducing a real `TypeVariable` variant"
      rationale =
        "A faithful `TypeVariable` representation would require propagation rules (substitution at call sites, unification at instantiation, variance tracking) that span the entire typechecker. None of those rules ship in this slice — the goal is for fixtures that declare a generic class to parse and typecheck without false rejection. `UnknownType` already serves as the 'tolerated but not constrained' fallback, so binding `T` to it lets every existing branch keep working without new code paths. When PKL-090 lands call-site inference, the upgrade path is to swap `UnknownType` for a real type variable variant — but doing that today, without inference, would be dead code."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Inject the parameter scope into a single helper at `class_decl_to_members`"
      rationale =
        "Class properties, methods, parent-name lookup, and method-body validation all reach for the type environment. Inserting the parameters once at `class_decl_to_members` and threading the scoped env through every downstream call keeps the change local. The alternative — passing `type_parameters` as a parameter through each callee — would touch every helper signature without buying additional flexibility."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Keep the evaluator unchanged"
      rationale =
        "Pkl's value model is structural: an `ObjectValue` carries member values regardless of the declared type parameters. There is no runtime artifact that holds 'Box of Int' versus 'Box of String'. Touching the evaluator would either invent a phantom value variant or layer runtime type tags onto every object — both are larger architectural moves that this slice declines."
    }
  }
}

local floatNumericsAndConstraints = new Scenario {
  id = "PKL-092"
  name = "Float numerics and constraint predicates"
  description =
    "Float numeric values flow through the entire stack. The lexer recognizes `<digits>.<digits>` as a Float token (Duration / DataSize `Int.<unit>` shorthand stays Int because `.identifier` is not promoted), the parser produces a new `FloatLiteral(Double)` Expr, and the evaluator carries the new `FloatValue(Double)` variant. Arithmetic widens automatically: `Int + Float` and `Float + Float` produce Float, comparisons (`<`, `<=`, `>`, `>=`, `==`, `!=`) admit any Int / Float mix, and `Int / Int` widens to Float to match Apple Pkl's `5 / 2 == 2.5` semantics. `IntDivide` / `Modulo` / `Power` keep their Int-only contract since their semantics are integer-domain. The typechecker gains a sibling `FloatType` and the `Number` annotation expands to `UnionType([IntType, FloatType])` so existing narrowing logic (union members, is-guards) keeps working. All four renderers (PCF / JSON / YAML / Properties) project Floats via a `render_float_text` helper that appends `.0` when the Double's shortest-round-trip form would otherwise look like an Int. The constraint cascade extends `pkl_constrained_int_predicates` to accept `Int(...)` / `Float(...)` / `Number(...)` as the host annotation, and a new `pkl_constraint_predicate_accepts_float` evaluator runs the existing Int-threshold predicates against Double values (widening thresholds to Double). `Float(isPositive)`, `Float(isBetween(0, 10))`, `Number(isPositive)`, and the negated / custom variants therefore fire on Float values; the rejection message format matches the Int side (`type annotation <name> constraint <p> rejects <v>`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-078" }
  tags { "evaluator"; "typechecker"; "renderer"; "constraint"; "float" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Bring Float numerics into the stack alongside the constraint cascade"
      rationale =
        "The slice description nominally focuses on Float constraint predicates, but the only way to exercise them honestly is to first have FloatValue / FloatType / Float arithmetic in place — predicate evaluation needs a Float value to land on. Pulling the numeric base into the same slice keeps the cascade tests meaningful; splitting the base off would have left the constraint side untestable until the numerics shipped, which inverts the dependency."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Reuse the Int-threshold predicate encoding for Float values"
      rationale =
        "Apple Pkl's numeric predicates take a number argument (`isBetween(0, 10)` works for both Int and Float). Encoding the threshold as Int and widening it to Double at comparison time keeps a single source of truth for `isPositive` / `isBetween` / `isGreaterThan` / `isLessThan` — the alternative (parallel `ConstraintFloatPredicate` enum) would duplicate the parsing + custom-factory dispatch without adding semantic surface."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Emit `.0` suffix for integral Floats so round-tripping preserves the type"
      rationale =
        "`Double::to_string()` renders `42.0` as `42` in MoonBit, which would round-trip through the parser as an Int and silently change the value's type. Appending `.0` when the shortest-round-trip form has no decimal point keeps Float / Int distinguishable on the wire, matching Apple Pkl's projection."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Keep IntDivide / Modulo / Power Int-only for this slice"
      rationale =
        "Their semantics are integer-domain by name (`Int.~/`, `Int.%`, `Int.**`). Apple Pkl exposes the floating counterparts through `math.pow` / `math.div` etc. rather than reusing the operator surface, so widening these three would diverge from upstream and complicate the typechecker's promotion table."
    }
  }
}

local readSandboxedBuiltin = new Scenario {
  id = "PKL-098"
  name = "read built-in with sandbox-bounded env: scheme"
  description =
    "`read(uri)` is recognized at the CallExpr layer ahead of the generic call path. The argument must evaluate to a String; the scheme prefix (text before the first `:`) selects the dispatch. Today the sandbox policy is explicit and conservative: only `env:` is on the allow-list. `read(\"env:NAME\")` consults the host environment via `moonbitlang/core/env.get_env_var`, returning the value as a `StringValue` on success and surfacing `read: env variable <NAME> is not set` as a diagnostic when the variable is missing. The remaining Apple Pkl schemes (`prop:`, `file:`, `https:`, `package:`) all surface `read: scheme <s>: is not allowed by the sandbox policy` rather than silently failing — the diagnostic names the offending scheme so the failure mode points at the policy boundary, not at the call site. URIs without a scheme prefix surface `read: missing URI scheme in \"<uri>\"`. The `read?(uri)` null-returning variant requires parser support for the `?`-suffixed call form and stays deferred to a follow-up slice. Built-in honors user shadowing (`read = (uri) -> uri` takes precedence), mirroring how `Bytes` / `Regex` / `throw` / `trace` honor shadows."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-084" }
  tags { "stdlib"; "io"; "sandbox" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Default-deny sandbox: only allow `env:` until each additional scheme has an explicit policy"
      rationale =
        "The original Roadmap entry for `read()` flagged the sandbox boundary as a precondition for shipping. The simplest honest policy is default-deny: every scheme except the one we have written rules for surfaces a diagnostic naming the rejection. Picking `env:` first matches the canonical fixture pattern (Apple Pkl's own snippets read env variables more than file paths) and keeps the surface area manageable — adding `prop:` and `file:` later only needs an allow-list extension, not a re-architecture. Crucially, the rejection diagnostic must name the offending scheme: an opaque `unsupported uri` message would push the failure away from the policy boundary."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Hook `read` at the CallExpr layer, like `throw` / `trace`"
      rationale =
        "`read` is a top-level identifier in Apple Pkl's base scope, not behind an `import`. Placing it next to `throw` / `trace` keeps the shadow-aware dispatch logic localized and avoids touching the import resolver. The helper `eval_read_uri` is split out as a standalone function so the scheme dispatch table (and future allow-list extensions) reads as a flat match rather than nested CallExpr branches."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer the `read?(uri)` null-returning variant to a parser-extension slice"
      rationale =
        "Apple Pkl's `read?(uri)` is special syntax — a `?`-suffixed call form distinct from a regular nullable member access. Wiring it in would touch the parser, not just the evaluator, and the slice description for this entry deliberately limits scope to the sandbox-aware `read` path. The null-returning variant is straightforward once the parse form lands; the gating decision here is the policy boundary, not the diagnostic-vs-null choice."
    }
  }
}

local traceAndThrowBuiltins = new Scenario {
  id = "PKL-084"
  name = "trace and throw built-ins"
  description =
    "`throw(message)` recognized as a builtin call ahead of the generic call path. The argument must evaluate to a String; on success it pushes a diagnostic carrying the message verbatim and aborts evaluation (no value returned), letting the existing diagnostic surface reuse the `test.catch` capture path. Anything other than a String surfaces `throw expects a String argument`, and wrong arity surfaces `throw expects exactly one argument`. `trace(value)` recognized as a sibling builtin that evaluates the argument and returns it verbatim; the stderr-stamp side of Apple Pkl's `trace` is deferred to a follow-up slice because the only observable channel for it lives in the CLI layer and would balloon this slice into renderer / diagnostic territory. Both builtins honor user shadowing (`throw = (s) -> s` takes precedence) so the same identifier remains free for user-defined helpers, mirroring how `Bytes` / `Regex` honor shadows."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "stdlib"; "diagnostics" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Split `read` off into its own slice; ship `throw` + `trace` first"
      rationale =
        "The original PKL-084 bundled `read(uri)` with `throw` and `trace`, but `read` is a sandbox boundary, not just an stdlib call — it introduces external state (env / prop / file) and forces an allow-list policy decision before any implementation can ship without a footgun. `throw` and `trace` carry no such dependency: they are pure value-side builtins whose semantics are fully specified inside the evaluator. Shipping them first delivers the diagnostic-style escape hatch fixtures expect (`throw(\"...\")` aborts; `trace(x)` is a transparent inspection wrapper) while leaving the `read` sandbox question to a dedicated slice."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Recognize `throw` / `trace` at the call-expression layer, not in stdlib source"
      rationale =
        "`pkl:math` and the minimal `pkl:reflect` stub live as Pkl source strings in `builtin_stdlib_source`, but those are import-resolved modules. `throw` and `trace` are top-level identifiers in Apple Pkl's base scope, not behind an `import`. The closest existing pattern is `Bytes` / `Regex`, which are recognized at the `CallExpr` layer with explicit shadowing checks; placing `throw` / `trace` next to them keeps the dispatch logic localized and makes user shadowing work without touching the import resolver."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer the stderr side of `trace` to a follow-up slice"
      rationale =
        "Apple Pkl's `trace` writes a diagnostic line to stderr and returns the value. The value-side semantics ship today because they are testable without touching the CLI; the stderr side requires plumbing a diagnostic channel through the evaluator and the CLI's print path, which is a renderer-surface decision rather than a builtin-semantics decision. Tag the gap explicitly in the source comment so the next slice picks it up deliberately."
    }
  }
}

local pklReflectMinimal = new Scenario {
  id = "PKL-080"
  name = "minimal pkl:reflect support"
  description =
    "`builtin_stdlib_source` resolves `pkl:reflect` to a thin Pkl-source stub that exposes the most-cited type mirror constants as string-tagged placeholders (`anyType`, `booleanType`, `intType`, `floatType`, `numberType`, `stringType`, `durationType`, `dataSizeType`, `bytesType`, `pairType`, `listType`, `setType`, `mapType`, `listingType`, `mappingType`, `objectType`, `dynamicType`, `typedType`, `moduleType`, `unknownType`, `nothingType`), all tagged with the `pkl.base#<name>` prefix that is internal to this stub. The factory bindings `Class`, `Module`, `TypeAlias`, `Property`, and `DeclaredType` are lambdas: each accepts a string identifier (rather than a class value, which the value model cannot yet round-trip) and returns an Object container exposing `reflectee` (for the first four) or `referent` (for `DeclaredType`). Fixtures that only read mirror constants or assert `reflect.Class(name).reflectee == name` now parse, typecheck, and evaluate; upstream `reflect.pkl` fixtures that need a real `ClassValue`, runtime member introspection, or `isSubclassOf` remain out of scope and are picked up by follow-up slices once the value model grows."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-040" }
  tags { "stdlib"; "pkl-reflect" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Stub `pkl:reflect` as a Pkl-source module, mirroring the `pkl:math` / `pkl:test` pattern"
      rationale =
        "Existing stdlib stubs (`pkl:math` exposing Int helpers, `pkl:test` exposing `catch = null`) live as Pkl source strings in `builtin_stdlib_source`; the evaluator already imports and binds them through the regular import path. Adding `pkl:reflect` as a sibling entry keeps the implementation contained to one file and avoids touching the import resolver or value model. The alternative — hooking `reflect.Class(...)` as a special-cased builtin call — would need a new value variant and a privileged call path before any user-visible behaviour shipped."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Factory inputs are strings, not class values"
      rationale =
        "Upstream `reflect.Class(Foo)` passes the class itself; our value model has no `ClassValue` variant and the slice graph for one (typecheck integration + runtime member surface) is a major chunk of work that would block this slice indefinitely. Falling back to a string identifier loses static linkage between the call site and the declared class, but keeps the runtime model honest: a stub returning `new { reflectee = name }` is a faithful container for a name-keyed mirror, not a misleading fake-class wrapper. A follow-up slice can lift the API to `ClassValue` once the variant exists."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Omit `isSubclassOf` from the minimal stub"
      rationale =
        "Without a real subclass relation table, the only honest implementation is `(other) -> name == other.reflectee` — which silently misreports `Boolean.isSubclassOf(Any)` as `false`. A follow-up slice that introduces a base-type lattice (Any > Number > Int, Object > Typed > Dynamic, etc.) is the right place to add this; emitting it as a misleading stub now would let fixtures pass for the wrong reason. Tag the gap explicitly in the source comment so the next slice picks it up deliberately."
    }
  }
}

local upstreamJsonGoldDiff = new Scenario {
  id = "PKL-097"
  name = "diff JSON evaluation output against apple/pkl gold files"
  description =
    "`scripts/upstream-smoke.sh` gains a `JSON_GOLD_FIXTURES` list and an `eval_json_matches_gold` helper that runs the native CLI with `eval -f json`, byte-diffs the output against `LanguageSnippetTests/output/<dir>/<name>.json`, and prints `upstream json eval ok: <label> (gold match)` on success. The CLI's new `extract_output_value` helper unwraps a top-level `output { value = ... }` member before the renderer dispatches, mirroring the `output.value`-on-renderer invocation Apple Pkl uses for its renderer-test fixtures. Fixtures that route their data through `output.value` therefore render only the inner subtree, so `api/jsonRenderer1.json.pkl` matches the gold byte-for-byte. The remaining upstream JSON-renderer fixtures (`jsonRenderer2.json.pkl` / `3.json.pkl` / `6.json.pkl`) all need converters, Float numerics, or stdlib types (List / Set / Map / Pair / IntSeq / Dynamic) outside the implemented slice; those stay off the list and are picked up incrementally as the related slices land."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-071"; "PKL-072"; "PKL-096" }
  tags { "compatibility"; "upstream"; "renderer" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Honor `output.value` in the CLI rather than wiring the full Apple Pkl `output { renderer }` driver"
      rationale =
        "A complete `output {}` driver requires class-name tagging on every ObjectValue (so the CLI can read `output.renderer`'s class to pick a format), plus runtime support for `output.renderer = new JsonRenderer { converters { ... } }` with path / type-keyed converter lambdas. That is several slices of work. The `extract_output_value` helper isolates the smallest piece — `output.value` extraction — that lets a JSON-renderer fixture line up with its gold when the user passes `-f json` explicitly. The `-f` flag remains the source of truth for renderer choice; honoring `output.renderer` lands as a follow-up once class-name tagging exists."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Curate the JSON gold list explicitly, like the PCF list"
      rationale =
        "Same gating logic as PKL-096: an explicit list is auditable and a regression makes the script fail noisily, while an auto-discovery sweep would silently mask regressions. Starting with one entry (`api/jsonRenderer1.json`) keeps the diff infrastructure honest — anyone adding a fixture has to first verify it gold-matches manually, and the script catches drift afterwards."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Document the deferred fixtures in the script and the spec, not as TODOs in code"
      rationale =
        "The three deferred fixtures (`jsonRenderer2/3/6`) each fail for different concrete reasons (converters, Float, missing stdlib types). Listing them as TODO comments in the script would rot every time we add a feature; tracking them as `dependsOn` notes in the spec narrative keeps the slice graph the source of truth and the script as a pure executable contract."
    }
  }
}

local upstreamFixtureSweep = new Scenario {
  id = "PKL-096"
  name = "evaluate broader upstream Pkl fixtures with gold byte-diff"
  description =
    "`scripts/upstream-smoke.sh` carries an explicit list of `LanguageSnippetTests/input/<dir>/<name>.pkl` fixtures whose `pkl eval` output already matches the upstream gold `.pcf` file byte-for-byte. The script iterates the list, runs the fixture through the native CLI, diffs against `LanguageSnippetTests/output/<dir>/<name>.pcf`, and prints `upstream eval ok: <label> (gold match)` on success or a unified diff plus non-zero exit on any mismatch. The `parse_ok` and `eval_contains` paths from the original script remain so parser-only fixtures and the project-specific diagnostic-text fixture (`classes/constraints8.pkl`) keep their checks. The list lifts coverage from 7 hand-coded fixtures to 25 (`basic` 12, `classes` 3, `modules` 8, `objects` 1, `types` 1) and the trailing `upstream-smoke: <N> gold-match fixtures passed` summary lets the pkspec contract assert the total count instead of every individual line."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075"; "PKL-077"; "PKL-085" }
  tags { "compatibility"; "upstream"; "renderer" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Curate the passing list manually rather than auto-discovering at runtime"
      rationale =
        "Auto-iterating every `.pkl` under `input/` and skipping mismatches would silently mask real regressions: a fixture that flips from passing to failing (because of a renderer change or an evaluator bug) would just drop off the list with no diagnostic. An explicit list inverts that: the script fails on any mismatch, and a fixture cannot rejoin the list without a deliberate edit. New passes are surfaced by re-running the discovery sweep manually before each compatibility slice — that's the gating decision the slice description demands."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Cover modules / classes / objects / types alongside basic/, not just `basic/`"
      rationale =
        "The slice description says `bulk of input/basic`, but the discovery sweep showed only 12 of 97 basic/ fixtures pass byte-for-byte today (the rest depend on `amends \"pkl:test\"` shorthand, Float numerics, generators, or `pkl:reflect`). The same sweep across `classes/`, `modules/`, `objects/`, and `types/` adds 13 more byte-for-byte matches that exercise complementary surface (class methods, amend chains, implicit receivers, union narrowing). Adding them now increases compatibility coverage without expanding the slice cost."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Print a tally line and assert it in the pkspec contract"
      rationale =
        "The previous pkspec contract listed every individual `upstream eval ok: <label>` it expected to see; that meant every additional fixture required a contract-side update that read like noise. The trailing `upstream-smoke: <N> gold-match fixtures passed` line lets the contract assert the total count plus a small representative sample, so adding a fixture only changes one number and a few example lines instead of an enumerated list. The script still exits non-zero on the first individual mismatch so the contract failure points to the offending fixture."
    }
  }
}

local bytesLiteralAndMethods = new Scenario {
  id = "PKL-083"
  name = "Bytes literal and Bytes methods"
  description =
    "`Bytes(<Listing of Int>)` is recognized as a constructor form ahead of the generic call path; each Listing element must be an Int in 0..=255 and the resulting `BytesValue` wraps a MoonBit `Bytes` instance. `Bytes.fromBase64(\"<base64>\")` is the static-style decoder counterpart, surfacing malformed base64 input as a diagnostic rather than a raise. The `.length` and `.base64` properties expose the byte count and the base64 encoding of the underlying bytes; `.getOrNull(i)` returns the byte at index `i` (as `IntValue` 0..=255) or `null` when out of range; `.toList()` materializes the bytes back into a `Listing<Int>` so existing list helpers keep working. `String.toBytes()` joins the dispatch table on the String side, encoding the input as UTF-8 via `moonbitlang/core/encoding/utf8`. The PCF renderer round-trips a `BytesValue` back through the constructor (`Bytes(new Listing { 65; 66; 67 })`) so the parser can re-evaluate the literal verbatim; JSON / YAML / Properties project the bytes as their base64 encoding (a quoted string), matching the projection shape used by Apple Pkl for opaque stdlib values."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-077" }
  tags { "evaluator"; "renderer"; "bytes"; "stdlib" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Pull in moonbitlang/core/encoding/{base64,utf8} instead of hand-rolling the codecs"
      rationale =
        "Both base64 and UTF-8 codecs ship in MoonBit core (`moonbitlang/core/encoding/base64` and `moonbitlang/core/encoding/utf8`). Reimplementing either would double the Bytes-related code without buying compatibility — they already match the upstream Apple Pkl semantics. Adding the imports keeps the slice focused on Pkl-side wiring (value variant, constructor intercepts, method / property dispatch, renderer surface) and inherits the codec semantics from the maintained core packages."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Validate byte values 0..=255 at construction, not at access"
      rationale =
        "Out-of-range bytes are a programmer error that almost always originates from the Listing literal that built the Bytes — surfacing the rejection at the constructor (with the offending value in the diagnostic) points to the right line. Validating at access would push the failure to wherever the value happens to be read first, which loses the source location and lets the bad Bytes value flow through other operations (renderers, comparisons) before failing."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Round-trip PCF through the Listing constructor; project base64 in non-PCF formats"
      rationale =
        "PCF is the only output format that flows back into our parser, so the Listing-of-Int constructor is the only round-trip-safe form (the parser already understands `Bytes(<Listing>)` because of the constructor intercept). JSON / YAML / Properties do not have a native bytes type and base64 is the upstream-compatible representation — the same opaque-value pattern we use for Duration / DataSize / Regex. The two shapes intentionally differ because the round-trip target differs."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Provide `Bytes.fromBase64` instead of overloading the `Bytes(...)` constructor"
      rationale =
        "Overloading `Bytes(\"<base64>\")` to mean \"decode this string\" would conflict with the future `Bytes(<other-shape>)` overload Apple Pkl supports (e.g. raw byte literal syntax, sequence of hex pairs). Keeping the decoder under the explicit `Bytes.fromBase64` name leaves the bare `Bytes(...)` constructor unambiguous as the Listing-of-Int form, and matches the static-method spelling Apple Pkl uses for analogous decoders elsewhere in the stdlib."
    }
  }
}

local cliPklTestRunner = new Scenario {
  id = "PKL-095"
  name = "CLI test runner integrates pkl:test facts"
  description =
    "`pkl test <file.pkl>` evaluates the file the same way `eval` does, then walks a top-level `facts: Mapping<String, Listing<Boolean>>` member: each entry is one fact, each Listing element is one assertion, and the fact passes only when every assertion is `BoolValue(true)`. The runner prints one `PASS <name> (N assertions)` or `FAIL <name>: assertion #i of N did not evaluate to true` line per fact, then a trailing `<passed> passed, <failed> failed` summary, and exits non-zero on any failure. Modules without a `facts` member print only the summary (zero passed, zero failed) and exit zero — matching the `moon test` behaviour for empty test files. The minimal slice intentionally requires the explicit typed `facts` shape rather than the `amends \"pkl:test\"` shorthand because the shorthand needs the full `pkl:test` module to flow through the import system; that lift stays a follow-up."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-058" }
  tags { "cli"; "pkl-test" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Require the explicit `facts: Mapping<String, Listing<Boolean>>` shape, not `amends \"pkl:test\"`"
      rationale =
        "`amends \"pkl:test\"` relies on the import resolver loading the upstream `pkl:test` module so the `facts { [\"...\"] { ... } }` shorthand picks up its declared shape. Our resolver currently short-circuits `pkl:` URIs to a stub, so the shorthand collapses to an empty mapping when actually evaluated. The slice scope draws the line at the explicit type so the runner can ship today; the shorthand support is a strictly larger lift that needs the full `pkl:test` module to flow through the resolver."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Walk the evaluated value rather than re-parsing the source"
      rationale =
        "Routing through `eval_path` reuses every constraint, typecheck, and renderer behaviour the rest of the CLI depends on, so a fact like `xs.map((x) -> x.length) == [3, 4, 5]` evaluates with the same semantics as a regular eval. A separate parser would have to re-implement the assertion grammar and would silently drift from the rest of the evaluator."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Report per-fact pass/fail with the failing assertion index, short-circuiting within a fact"
      rationale =
        "A fact bundles a small group of related assertions; once one fails the rest of the same fact are no longer evidence — they could trivially pass with a stale value. Naming the first failing assertion's 1-based index plus the total assertion count gives enough information to find the offending line without burying the user in cascading diagnostics. Per-fact (rather than per-assertion) granularity also matches the upstream `pkl test` output shape."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Use stdout assertions in the pkspec contracts rather than exit-code checks"
      rationale =
        "`moon run cmd/main --target native -- ...` swallows the inner binary's exit code (it returns moon's own exit code, not the binary's). Asserting on stdout — `PASS <name>`, `FAIL <name>`, and the trailing summary — captures the same information through the only channel the test harness can observe through the wrapper, and the binary itself still exits non-zero so direct invocations behave correctly for users. Lifting the exit-code assertion is a strictly larger CLI-runner change."
    }
  }
}

local cliFormatFlag = new Scenario {
  id = "PKL-094"
  name = "CLI --format flag for eval"
  description =
    "The `pkl eval` subcommand accepts both the short `-f` and the long `--format` flag and dispatches to the matching renderer. The format string is validated against the closed set `pcf` / `json` / `yaml` / `properties` before evaluation begins; an unrecognised format fails fast with `unsupported format: <text>`. Inside the dispatch, `pcf` has its own explicit arm rather than acting as the unmatched fallback, so adding a future renderer surfaces as a missing-arm warning at compile time. The default format remains `pcf` when neither flag is present, matching the existing CLI contract and the upstream `pkl eval` default. Both short and long forms are tested via the pkspec contracts: `cli eval --format long form` exercises `--format json`, `cli eval --format pcf` exercises the explicit `pcf` arm, and the existing `cli eval json` / `cli eval yaml` / `cli eval properties` tests stay on the short form to cover the original surface."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-072"; "PKL-073"; "PKL-074" }
  tags { "cli"; "renderer" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Promote pcf into the dispatch match instead of leaving it as the else fallback"
      rationale =
        "The previous chain ran `if json ... else if yaml ... else if properties ... else pcf`, which silently absorbed any new format token that slipped past the up-front validation. Making `pcf` an explicit `match` arm fails the compile when a new format is added without a matching renderer hookup, which keeps the validation list and the dispatch list in sync by construction."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Test both short and long forms via separate pkspec scenarios"
      rationale =
        "The flag-parsing loop in `cmd/main/main.mbt` treats `-f` and `--format` symmetrically — they share a single branch in the argument scanner — but the contract surface should still exercise both spellings independently so a future refactor that collapses the parsing path cannot regress one form without the other. Two new scenarios (`cli eval --format long form`, `cli eval --format pcf`) cover the long form and the explicit `pcf` dispatch; the existing three short-form scenarios keep their coverage of the short flag."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Keep `pcf` as the default rather than requiring an explicit flag"
      rationale =
        "Upstream `pkl eval path.pkl` (no flag) emits PCF. Changing the default here would silently break existing automation that relies on PCF-shaped output. The slice only adds explicit `pcf` dispatch and the long-form flag; the flag-less behavior stays identical to the previous release."
    }
  }
}

local collectionElementConstraints = new Scenario {
  id = "PKL-093"
  name = "Listing and Mapping element constraint propagation"
  description =
    "`pkl_constrained_type_annotation_has_supported_constraint` recurses into the `Listing<T>` and `Mapping<K, V>` wrappers so element-level constraint annotations register as supported. The value-rejection cascade gains a collection branch after the Int / String branches: for a `Listing<T>` annotation on a `ListingValue`, every element re-enters the cascade with `T` as both display and source name; for a `Mapping<K, V>` annotation on a `MappingValue`, each entry's key is checked against `K` and each entry's value against `V`. The first rejecting element produces the diagnostic and short-circuits the cascade so error messages name a single failing predicate rather than a list. Nested wrappers (`Listing<Listing<Int(isPositive)>>`, `Mapping<String, Listing<Int(isBetween(0, 9))>>`) compose naturally because each recursion uses the same entry point; depth is capped at 8 to keep cycle-like aliases bounded."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-091"; "PKL-075" }
  tags { "evaluator"; "typechecker"; "constraint"; "collection" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Recurse through the existing entry points rather than threading a separate per-element checker"
      rationale =
        "The constrained-type cascade is already the value-side authority for Int and String predicates. Routing the per-element check back through `pkl_constrained_type_annotation_value_rejection_message_from_source` means any constraint family that lands later (Float, user-defined factories, future types) inherits collection support for free without touching the collection plumbing. The depth bound on the same path keeps recursive aliases (`typealias R = Listing<R>`) from looping the runtime."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Short-circuit on the first rejecting element instead of reporting every failure at once"
      rationale =
        "Apple Pkl reports the first failing constraint and aborts — listing every failure would multiply the diagnostic count on common typos (missing constraint, wrong predicate). Short-circuiting matches that behavior and keeps the diagnostic vocabulary identical to the scalar path; `length rejects` reads the same whether it fired on a top-level value or the third element of a Listing."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Reuse `generic_argument_text` / `split_top_level_generic_arguments` from the typechecker"
      rationale =
        "Both helpers already balance angle-bracket and paren nesting correctly for `Listing<Pair<Int, Int>>` / `Mapping<String, Listing<Int>>` shapes. Reusing them keeps a single source of truth for the collection-type grammar and avoids a parallel parser that would drift the moment one side learns a new wrapper type."
    }
  }
}

local stringConstraintPredicates = new Scenario {
  id = "PKL-091"
  name = "String constraint predicates"
  description =
    "`String(...)` annotations recognise three predicate shapes — length comparisons (`length > 0`, `length >= 1`, etc., plus `<` / `<=` / `==` / `!=`), `length.NAME(...)` method calls that reuse the Int predicate grammar (`length.isBetween(1, 64)`, `length.isPositive`, `length.isGreaterThan(N)`, `length.isLessThan(N)`), and full-input regex matches (`matches(Regex(\"<pattern>\"))`). Negation via the `!` prefix wraps any of these. Predicates run as part of the same constrained-type-annotation rejection cascade as the Int predicates: `pkl_constrained_type_annotation_has_supported_constraint` returns true when a String constraint is present, the runtime value-rejection path dispatches on String values, and the typecheck literal-expression path dispatches on String literals. Diagnostics keep the constraint name verbatim (`length > 0`, `length.isBetween`, `matches`, `!matches`, etc.) so the rejection message reads back to the original source shape."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-077"; "PKL-081" }
  tags { "evaluator"; "typechecker"; "constraint"; "string" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror the Int constraint cascade rather than introducing a parallel pipeline"
      rationale =
        "The Int constraint cascade already covers the three integration points a new constraint family needs (`has_supported_constraint` gate, runtime value rejection, typecheck literal rejection). Mirroring its shape — a `ConstraintStringPredicate` enum plus `_predicates(type_name)` / `_rejection_message_from_source` helpers — keeps the surface area small and lets a future Float or collection-element constraint follow the same template. The dispatch point inside `pkl_constrained_type_annotation_value_rejection_message_from_source` adds a String branch after the existing Int branch, so non-String constrained types are unaffected."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Parse the constraint text rather than retyping the constraint as an Expr"
      rationale =
        "Constraint text arrives as the raw source between `String(` and `)`. Retyping it through the parser would mean threading a parser dependency into the constraint module and recompiling the constraint on every value check. Parsing the three documented shapes textually — operator-based comparison, `length.`-prefixed method call delegating back to the Int parser, and `matches(Regex(\"...\"))` literal — is enough to cover the slice scope and keeps the constraint module self-contained."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Reuse the moonbitlang/regexp engine that PKL-081 added rather than caching compiled patterns"
      rationale =
        "Patterns inside constraint text are short-lived: the same constrained type is matched against many values, but the regex source is fixed. Compiling on each `matches(...)` predicate evaluation is wasteful but never quadratic — caching the compiled regex would need a constraint-level value store and only matters once a workload uses thousands of constrained values per second. Defer caching until profiling justifies it; for now the predicate compiles inside `pkl_string_predicate_accepts` and treats a malformed pattern as a deterministic rejection so the constraint cascade still produces a stable diagnostic."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Anchor `matches(Regex(...))` to the entire string, matching `Regex.matches`"
      rationale =
        "`String(matches(Regex(\"...\")))` says \"the entire value matches this regex\", not \"the regex matches somewhere in the value\". PKL-081 made the same choice for `Regex.matches`, so anchoring here keeps the two surfaces consistent — `String(matches(Regex(p)))` accepts iff `Regex(p).matches(value)` returns true. Substring matches stay reachable via the unanchored regex (`Regex(\".*pattern.*\")`) without changing the predicate semantics."
    }
  }
}

local regexLiteralAndMethods = new Scenario {
  id = "PKL-081"
  name = "Regex literal and Regex methods"
  description =
    "`Regex(\"<pattern>\")` is recognized as a constructor form before the generic call path runs; the call's single String argument is captured verbatim as a `RegexValue(String)` carrying the pattern. The `.pattern` property exposes the original source pattern as a `String`. Five Regex methods dispatch through the same MemberAccess / SafeMemberAccess sites as the other stdlib value methods: `.matches(input)` returns true only when the regex covers the entire input (anchored on both ends), `.find(input)` returns the first match's text or `null`, `.findAll(input)` returns a `Listing<String>` of every non-overlapping match, `.replace(input, repl)` substitutes the first match, and `.replaceAll(input, repl)` substitutes every non-overlapping match. Compilation is deferred to the first method call so a Regex value can be constructed even if its pattern is later unused; an invalid pattern reports a diagnostic at method-call time. The PCF renderer round-trips a `RegexValue(p)` back as `Regex(\"<escaped-p>\")`; JSON / YAML / Properties project the pattern as a plain string."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-077" }
  tags { "evaluator"; "renderer"; "regex"; "stdlib" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Pull in moonbitlang/regexp instead of writing a pure-MoonBit regex engine"
      rationale =
        "Apple Pkl's regex grammar is the standard PCRE-compatible flavor; reimplementing it for this slice would dwarf every other stdlib slice combined and gain nothing for compatibility. `moonbitlang/regexp` 0.3.5 is a maintained MoonBit-native package with PCRE-style features (character classes, anchors, alternation, repetition, capture groups). Adding it as a dep keeps the slice focused on Pkl-side wiring (value variant, method dispatch, renderer surface) and lets the regex semantics inherit a well-tested implementation."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Compile the pattern lazily at method-call time, not at constructor time"
      rationale =
        "Compiling `Regex(\"<pat>\")` eagerly forces the entire program to fail at construction even when the regex is dead code (e.g. a typealias body that's never instantiated). Lazy compilation localizes the failure to the actual `.matches` / `.find` / etc. call, which both matches user intuition and lets a Regex value participate in renderers (PCF / JSON / YAML / Properties) without ever invoking the engine."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Anchor `.matches` to the whole input rather than searching for a substring match"
      rationale =
        "Apple Pkl's `String.matches(regex)` returns true iff the entire input matches; `.find` / `.findAll` cover the unanchored substring case. Mirroring that split here keeps the Regex API consistent with the existing String API (`.contains` / `.startsWith` / `.endsWith` for unanchored checks, `.matches` for full-input). The implementation checks the match's `before` and `after` views are both empty to distinguish a full match from a partial one."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Project Regex as the pattern string in JSON / YAML / Properties; round-trip as Regex(\"...\") in PCF"
      rationale =
        "JSON / YAML / Properties have no native regex type, so the only deterministic projection is the source pattern as a quoted string — matching the same shape we use for Duration / DataSize. PCF, on the other hand, is the format that flows back into the parser; emitting `Regex(\"<escaped-pattern>\")` lets the same Regex value re-evaluate to itself, which is the property the rest of the renderer surface relies on."
    }
  }
}

local typeAliasedCallableArgumentEvaluation = new Scenario {
  id = "PKL-069"
  name = "evaluate typealiased Pkl callable argument annotations"
  description =
    "Function, lambda, and class method calls resolve typealiased parameter annotations through the alias chain at runtime, so a parameter declared `x: Small` with `typealias Small = Int(isBetween(0, 10))` triggers the same predicate cascade as `x: Int(isBetween(0, 10))`. Built-in and user-defined constrained predicates fire alike, and the diagnostic preserves the original alias name (`Small`) while running the resolved constraint against the argument value."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-066"; "PKL-068" }
  tags { "evaluator"; "callable"; "typealias" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror the return-side alias resolution on the argument side"
      rationale =
        "`eval_callable_return_rejection_message` already resolves a return-type alias via `eval_resolved_type_alias` before running the predicate cascade. The argument side was bypassing alias resolution entirely — it called the non-`_from_source` predicate variants on the raw type name, which silently ignored anything that wasn't an inline constrained type. Switching the argument path to the same `_from_source` predicate variants closes the bypass and reuses the existing typealias chain walker."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Reuse the typealias bindings collected from the program's declarations"
      rationale =
        "`eval_type_alias_bindings(declarations)` is the same input used by the return-side path. Computing it inside the argument-rejection helper keeps the call sites unchanged: every dispatcher (lambda application, function call, class method call) already passes `declarations`, so no new threading is needed."
    }
  }
}

local hiddenAndLocalMembers = new Scenario {
  id = "PKL-087"
  name = "hidden and local object members"
  description =
    "Object-body members declared with the `hidden` modifier or the `local` keyword are kept inside the evaluated `ObjectValue` (so `lookup_member` still resolves bare-name reads against them) but are skipped by every renderer (PCF / JSON / YAML / Properties). Module-level `hidden` bindings get the same render-side filter; module-level `local` already routed through `parse_local_decl`, which marks the binding `exported: false` so the renderer never sees it in the first place. The render filter is a single `visible_members` projection applied at the entry of each renderer's member loop, keyed off a reserved `@hidden$` name prefix that the lexer rejects as an identifier character so it cannot collide with user-declared properties."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-070"; "PKL-071"; "PKL-072"; "PKL-073"; "PKL-074" }
  tags { "evaluator"; "renderer"; "object" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mark hidden members via a name-prefix marker instead of widening ValueMember"
      rationale =
        "Adding a `hidden : Bool` field to `ValueMember` would force updating ~334 struct-literal constructions in the test suite (the source uses shorthand field-name punning that MoonBit cannot extend with a default). A reserved name prefix (`@hidden$`) achieves the same goal — distinguishing renderable from non-renderable members — without touching the struct shape, and the lexer's rejection of `@` / `$` in identifiers guarantees the prefix cannot collide with anything in user source."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Resolve bare-name reads against either the bare or prefixed form in `lookup_member`"
      rationale =
        "Apple Pkl's `hidden` keeps the member reachable from outside the object (renderers drop it; member access still resolves it). The bare-name lookup must therefore match the prefixed entry transparently. Extending `lookup_member` to try both forms keeps the visibility contract intact without forcing every caller to know about the prefix."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Split visibility-consumption between module-level and object-body parsers"
      rationale =
        "Module-level `local` is a binding-declaration keyword that routes through `parse_local_decl` and produces `exported: false` bindings. Reusing the object-body visibility consumer at module level would swallow that keyword before `parse_local_decl` could see it, breaking 16 existing tests. The split — `consume_member_visibility_modifiers` for object bodies (handles both `hidden` text and `local` keyword) and `consume_module_visibility_modifiers` for module level (handles only `hidden` text) — keeps the keyword's existing role intact."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Treat `local` and `hidden` identically on the render side"
      rationale =
        "Apple Pkl's `hidden` keeps the member reachable via member access; `local` is supposed to be scoped to the declaring body and unreachable from outside. Our evaluator currently lacks sibling-visibility for object-body members (the existing tests of sibling references show `unbound identifier`), so the stricter `local` scoping isn't observable yet. Producing identical render-filtering for both modifiers ships the renderer contract now and leaves the stricter scoping for a follow-up slice that bundles sibling visibility."
    }
  }
}

local objectBodyForGenerators = new Scenario {
  id = "PKL-085"
  name = "evaluate object body for-generators"
  description =
    "`for (var in source) { ... }` and `for (var1, var2 in source) { ... }` inside an object body iterate the source (Listing or Mapping) and splice each iteration's members into the surrounding object. For Listings, the single-variable form binds the element; the two-variable form binds (index, element). For Mappings, the two-variable form binds (key, value). Per-iteration members are merged via `merge_value_members`, so later iterations overwrite earlier writes to the same name (matching Apple Pkl's `for`-as-property-generator semantics). The construct is encoded as a synthetic `@for` ObjectMember whose value is a new `ForGenerator(var1, var2, source, body)` `Expr` variant; `eval_object_members` recognises the reserved name and spreads the resulting `ObjectValue`'s members into the parent. Composes with `when`-conditionals inside the body — the @when spread per iteration contributes (or skips) members according to the condition."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075"; "PKL-086" }
  tags { "evaluator"; "object" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Promote `for` and `in` to reserved keywords"
      rationale =
        "Apple Pkl marks both as reserved words — they can never be property names. Adding them to `keyword_or_identifier` lets `parse_object_body_members` dispatch on the keyword's syntax kind directly and lets the binding-form parser look for `in_kw` as the source separator. The upstream parser suite (802 fixtures) still passes after the change, so no fixture uses `for` or `in` as an identifier."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Add a dedicated `ForGenerator` `Expr` variant instead of reusing a wrapper expression"
      rationale =
        "The for-generator's payload — loop variable name(s), source expression, and body members — does not fit into any existing `Expr` shape (the body is an `Array[ObjectMember]`, not an `Expr`). Encoding it as `(var1, var2_opt, source, body)` in a new variant keeps the surface explicit at every parser / evaluator / typechecker site. The typechecker treats the variant as `UnknownType` because for-generators only appear inside object bodies via the synthetic `@for` member, never as a free-standing expression."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Merge per-iteration members across iterations rather than appending duplicates"
      rationale =
        "Apple Pkl's `for`-as-property-generator semantics are last-write-wins per name — writing `result = x` inside the body for each iteration yields one `result` member set to the final iteration's value, not three duplicates. Our regular object-body evaluation keeps duplicate names (the renderer / amend chain resolves them downstream), but per-iteration spreading is a stronger contract; using `merge_value_members` between iterations matches the user's mental model and prevents the resulting `ObjectValue` from growing without bound for large sources."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Custom in-place skipper for binding-side type annotations"
      rationale =
        "Apple Pkl allows `for (n: Int in source)` and `for (n: Listing<Pair<Int, Int>> in source)`. Reusing `parse_type_annotation` here doesn't work because its `parse_type_text` greedily consumes tokens until `=` / `{` / `}` / `,`, which swallows the `in` keyword and the source expression. A small custom loop that stops at `,` / `in` / `)` while balancing parens / brackets / angles keeps the typed-binding contract intact without weakening the existing type-annotation parser."
    }
  }
}

local objectBodyWhenConditionals = new Scenario {
  id = "PKL-086"
  name = "evaluate object body when-conditionals"
  description =
    "`when (cond) { ... } else { ... }` inside an object body picks the then-branch when the condition evaluates to `true` and the else-branch otherwise; the picked branch's members are spliced into the surrounding object body alongside any sibling properties. `else` is optional — a false condition without an `else` contributes no members. The condition expression sees the enclosing module's bindings (so `when (stage == \"prod\")` works), and each branch may declare multiple members. The construct is desugared at parse time into a synthetic `@when` object member whose value is a `ConditionalExpr` between the two branch `ObjectLiteral`s; `eval_object_members` recognises the reserved name and spreads the resulting `ObjectValue`'s members into the parent."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "evaluator"; "object" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Encode `when` as a synthetic `@when` ObjectMember rather than changing the ObjectMember shape"
      rationale =
        "Promoting `ObjectMember` from a struct to an enum (with separate `Property` and `WhenBranch` variants) would ripple through every place that constructs or inspects object members — parser, evaluator, typechecker, renderers, four separate match arms. Encoding `when` as a reserved-named ObjectMember whose value is a `ConditionalExpr` between two `ObjectLiteral`s keeps the change local: the parser emits one extra branch in `parse_object_body_members`, and the evaluator spreads on the reserved name. `@` is rejected as an identifier character by the lexer, so the reserved name cannot collide with anything in user source."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Spread branch members at evaluation time rather than at parse time"
      rationale =
        "Apple Pkl evaluates the condition at module-evaluation time and the branches see the surrounding object's bindings (forward references, class defaults, amend chains). Spreading at parse time would require copying the branch's `ObjectMember`s into the surrounding array, which loses the source position for diagnostics and forces the parser to know about evaluation order. Spreading at evaluation time, after `eval_expr_with_bindings` resolves the conditional, keeps the parser oblivious to runtime semantics and lets the existing scoping machinery (`eval_object_members` already iterates in order with forward-reference support) handle the resolution."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Promote `when` from an identifier to a reserved keyword"
      rationale =
        "Apple Pkl marks `when` as a reserved word — it can never be a property name. Adding `when` to `keyword_or_identifier` matches that contract and lets `parse_object_body_members` dispatch on the keyword's syntax kind directly. The upstream parser suite (802 fixtures) and smoke tests still pass, so no existing fixture uses `when` as an identifier."
    }
  }
}

local nullCoalescingAndLet = new Scenario {
  id = "PKL-088"
  name = "null-coalescing operator and let expressions"
  description =
    "The `??` operator picks the right-hand value when the left evaluates to `NullValue`, and is right-associative so `a ?? b ?? fallback` short-circuits left-to-right. `let (name = value) body` introduces a single scoped binding, with the body able to reference outer bindings and inner let-expressions able to shadow the outer name. The two compose: `let (fallback = ...) raw ?? fallback`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "evaluator"; "expressions" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Desugar `let (name = value) body` into `((name) -> body)(value)` at parse time"
      rationale =
        "Pkl's let-expression is just a single-parameter lambda applied to one value — same scoping rules, same closure capture, same return-validation. Desugaring at the parser level means the rest of the evaluator continues to operate on the existing `LambdaExpr` + `CallExpr` machinery (closure capture, parameter rejection, return validation) without a new AST node or eval arm. The CST node keeps the `let_decl` kind so the source-mapped diagnostic surface stays intact."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Lean on the existing `NullCoalesce` binary operator rather than synthesizing a new short-circuit form"
      rationale =
        "The lexer / parser / typechecker / evaluator already wire `??` through `BinaryOp::NullCoalesce` (it lit up the moment the existing slice landed), with `NullCoalesce` evaluating the right-hand side only when the left produces `NullValue`. PKL-088 ships the spec contract that pins down the behavior — right-associativity, short-circuit semantics, type-of-result — without changing the implementation."
    }
  }
}

local pklMathExpansion = new Scenario {
  id = "PKL-079"
  name = "expand pkl:math beyond maxInt32"
  description =
    "`pkl:math` exposes Int range constants (`maxInt32`, `minInt32`, `maxInt`, `minInt`) and Int-side helpers (`abs(x)`, `min(a, b)`, `max(a, b)`). The helpers are declared as top-level lambda bindings inside the synthetic `pkl:math` source so they round-trip through the regular `exported: true` path and become members of the imported module's `ObjectValue` — `import \"pkl:math\" as math; math.max(a, b)` evaluates without further dispatch work. `maxInt` / `minInt` track the 32-bit `Int` representation; once a 64-bit slot exists they expand to match the Java-derived Apple Pkl bounds."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-007"; "PKL-078" }
  tags { "stdlib"; "pkl-math" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Declare helpers as lambda bindings, not `function` declarations"
      rationale =
        "Our parser marks `function name(...) = body` declarations with `exported: false`, which keeps them out of the imported module's `ObjectValue`. Apple Pkl's `pkl:math` exposes these helpers as plain functions on the module, so to match the reachable-from-an-import contract we declare them as `name = (...) -> body` instead. The semantics are identical (both forms produce a `FunctionValue`), but the binding flag flips the lambda form into the exported set."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Track `maxInt` / `minInt` against the implemented Int width"
      rationale =
        "Apple Pkl's `Int` is 64-bit (Java `long`), so its `maxInt` / `minInt` are `+/-2^63`. Our `IntValue` carries a 32-bit MoonBit `Int`. Reporting Apple Pkl's 64-bit limits here would mean lying about what literals will actually round-trip through evaluation (anything beyond 32-bit overflows during parsing today). The constants therefore expose the implementation-actual range; PKL-092 / a follow-up Int-64 slice will widen them once the value model supports the bigger slot."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Defer Float-bearing math (`sqrt` / `pow` / `log` / `exp` / `ceil` / `floor` / `round`) to PKL-092"
      rationale =
        "Apple Pkl's `pkl:math` exposes `sqrt(Float)`, `pow(Float, Float)`, `log(Float)`, etc. None of these can be implemented honestly against `IntValue` alone — `sqrt(4) = 2` happens to be integer but `sqrt(2)` cannot be represented. Float-bearing math arrives with `FloatValue` in PKL-092, alongside the Float constraint predicates."
    }
  }
}

local pklBaseInt = new Scenario {
  id = "PKL-078"
  name = "expose pkl:base Int operations"
  description =
    "Int properties (`abs`, `isEven`, `isOdd`) and methods (`toString()`, `toString(radix)`, `toChar()`) dispatch against `IntValue` receivers via the same `MemberAccess` / `CallExpr` interception as the Listing / Mapping / String builtins. `toString(radix)` accepts radices 2..36 and writes a leading `-` for negative inputs. `toChar()` projects a Unicode code point (0..0x10FFFF) to a single-character `StringValue`. Int builtins compose with String / Listing pipelines, so `xs.map((n) -> n.toString(16)).join(\",\")` returns a hex-CSV `StringValue`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-077" }
  tags { "stdlib"; "pkl-base"; "numeric" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Implement radix conversion in-tree rather than via a third-party crate"
      rationale =
        "MoonBit's `Int` type does not expose a built-in radix-aware `toString`. Pulling in a numeric-formatting library for one method would balloon the dependency surface; implementing the loop ourselves (a 20-line helper that walks the digit table) keeps the slice focused. The radix bound (2..36) matches Java's `Integer.toString(int, int radix)` and Apple Pkl's `Int.toString(radix: Int(isBetween(2, 36)))` constraint."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer `toFloat()` and Float-side projections until a real `Float` value lands"
      rationale =
        "Apple Pkl's Int surface includes `toFloat(): Float`, and the Roadmap entry called for matching Float-side projections. Our value model has no `FloatValue` yet — numeric literals like `1.23` currently fail to evaluate. Implementing `toFloat` against `IntValue` alone would mean returning an `IntValue` again (since there's no other slot), which is misleading. The Float surface arrives with PKL-092, at which point `toFloat()` slots in alongside the new value variant."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Reject `toChar` code points outside the Unicode range explicitly"
      rationale =
        "Apple Pkl's `Int.toChar()` errors when the receiver is outside `0..0x10FFFF`. Our `Char::unsafe_to_char` would happily accept any 32-bit input, but a code point above `0x10FFFF` is not a valid Unicode scalar and the resulting `StringValue` would be ill-formed. The explicit bound check matches Apple Pkl's behavior and protects downstream renderers (JSON / YAML / Properties string-escape paths) from surrogate-pair leakage."
    }
  }
}

local pklBaseString = new Scenario {
  id = "PKL-077"
  name = "expose pkl:base String operations"
  description =
    "String properties (`length`, `isEmpty`) and methods (`toUpperCase()`, `toLowerCase()`, `contains(s)`, `startsWith(p)`, `endsWith(s)`, `indexOf(s)`, `replaceAll(old, new)`, `replaceFirst(old, new)`, `take(n)`, `drop(n)`, `split(sep)`, `padStart(width, padStr)`, `padEnd(width, padStr)`) dispatch against `StringValue` receivers via the same `MemberAccess` / `CallExpr` interception as the Listing / Mapping builtins. `indexOf` returns `-1` for missing substrings (matching Apple Pkl rather than returning null). `split` projects to `Listing<String>`, so `s.split(\",\").map(...).join(...)` pipelines through the Listing builtins. `take` and `drop` saturate at the string bounds. All operations are code-unit-based (matching Apple Pkl's Java-string-derived semantics)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-076" }
  tags { "stdlib"; "pkl-base"; "string" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Map `indexOf` absent result to `-1`, not `null`"
      rationale =
        "Apple Pkl's `String.indexOf` returns `Int` with `-1` for absent substrings; a separate `indexOfOrNull` returns the nullable form. Mirroring that convention here keeps Pkl source ported from upstream working without rewriting `if (idx == -1)` checks into null guards. The MoonBit primitive (`String::find`) returns `Int?`, so the wrapper applies the `-1` fallback at the dispatch boundary."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Accept `padChar` as a single-character String, not a `Char` value"
      rationale =
        "Apple Pkl's `padStart` / `padEnd` take a `Char` parameter, but our value model has no separate `Char` type — character literals evaluate to `StringValue` of length one. Accepting a String and using its full content as the pad sequence is a strict superset of the Apple Pkl behavior for single-character pads and avoids forcing a `Char` value into the model for one builtin. If a future slice introduces `Char`, the pad parameter narrows naturally."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer regex-bearing String operations (`matches`, `replaceAllMapped`) to PKL-081"
      rationale =
        "Apple Pkl's String surface includes regex-bearing operations (`matches(Regex)`, `replaceAllMapped(Regex, (MatchResult) -> String)`). The regex slice (PKL-081) brings its own value type and constraint integration; folding those into this slice would force premature design choices. PKL-077 ships the non-regex slice — toUpperCase / split / replaceAll etc. — and PKL-081 will extend it without touching the dispatcher."
    }
  }
}

local pklBaseMapping = new Scenario {
  id = "PKL-076"
  name = "expose pkl:base Mapping operations"
  description =
    "Mapping properties (`length`, `isEmpty`, `keys`, `values`) and methods (`containsKey(k)`, `getOrNull(k)`, `fold(init, op)`) dispatch against `MappingValue` receivers via the same `MemberAccess` / `CallExpr` interception as the Listing builtins. `keys` and `values` project to `ListingValue` in declaration order (Apple Pkl returns `Set<K>` for `keys`, but our value model has no separate Set yet — the deviation is documented in the decisions). `getOrNull(k)` returns `NullValue` when the key is missing. `fold` invokes a 3-argument callback `(acc, key, value)` per entry via the shared `apply_function_value` helper. Listing builtins continue to dispatch on Listing receivers, so `m.values.filter(...).fold(...)` pipelines through both surfaces correctly."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075" }
  tags { "stdlib"; "pkl-base"; "mapping" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Project `keys` as `Listing<K>` until a real `Set` value lands"
      rationale =
        "Apple Pkl's `Mapping.keys` returns `Set<K>`, which has its own equality / iteration semantics. Our value model represents `Set(...)` literals as `ListingValue` already, so synthesizing a separate `SetValue` just for `keys` would mean either retrofitting Set throughout the evaluator now (large slice) or returning a one-off type the rest of the code can't manipulate. Returning `Listing<K>` matches what `Set(...)` becomes after evaluation today, and the contract upgrades naturally when a real `Set` lands."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Fold callback receives `(acc, key, value)` triple"
      rationale =
        "Apple Pkl's `Mapping.fold` exposes both the entry key and value to the accumulator. Reusing the `apply_function_value` helper with a 3-element argument array keeps the per-call validation / return checking consistent with Listing's `fold`, and means the only Mapping-specific code is the per-entry iteration shape."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer `entries -> Listing<Pair>` projection to a later slice"
      rationale =
        "Apple Pkl's `Mapping.entries` returns a `Listing<Pair<K,V>>`. We do not have a `Pair` value type yet (it depends on the broader `pkl:base` class surface in PKL-080). Implementing `entries` ahead of `Pair` would force an ad-hoc representation we'd need to migrate later, so this slice ships `keys` / `values` instead and `entries` arrives with Pair / reflect."
    }
  }
}

local pklBaseListing = new Scenario {
  id = "PKL-075"
  name = "expose pkl:base Listing operations"
  description =
    "Listing properties (`length`, `isEmpty`, `first`, `last`, `distinct`) and methods (`contains(x)`, `reverse()`, `take(n)`, `drop(n)`, `join(sep)`, `map(fn)`, `filter(p)`, `fold(init, op)`) dispatch against `ListingValue` receivers in the evaluator. Property-style access (`xs.length`) is handled in the `MemberAccess` arm; method calls (`xs.contains(1)`) are handled in the `CallExpr(MemberAccess(...), args)` arm before falling through to the regular callable path. Higher-order methods (`map` / `filter` / `fold`) accept a `FunctionValue` callback and invoke it per element via a shared `apply_function_value` helper that mirrors `eval_lambda_application` for already-evaluated arguments. Chained calls (`xs.filter(p).map(f).fold(0, g)`) work because each step re-evaluates its receiver as a `ListingValue`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009"; "PKL-066" }
  tags { "stdlib"; "pkl-base"; "listing" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Dispatch builtins on the receiver shape, not via a synthetic class binding"
      rationale =
        "Apple Pkl exposes Listing operations through a `pkl:base.Listing<T>` class. Our class lookup is keyed off typed-object class names, and `ListingValue` is not represented as a typed object — synthesizing one just to satisfy the dispatcher would balloon the surface (constructor flow, amend rules, etc.). Intercepting `MemberAccess` / `CallExpr` for `ListingValue` receivers keeps the evaluator changes local and leaves the class system unchanged for PKL-089 generics work later."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Share `apply_function_value` between Listing higher-order builtins"
      rationale =
        "`map` / `filter` / `fold` all need to invoke a `FunctionValue` against already-evaluated element values, which differs from the existing `eval_lambda_application` (Expr-based arguments). Extracting `apply_function_value` once means each Listing builtin's body stays focused on its iteration shape and the per-call rejection / return validation lives in one place. The helper is reusable by Mapping (PKL-076) and String (PKL-077) builtins once those land."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Saturate `take` / `drop` instead of erroring on out-of-range counts"
      rationale =
        "Apple Pkl's `Listing.take(n)` and `.drop(n)` clamp `n` to the listing's bounds rather than raising — `xs.take(100)` on a 3-element listing returns the whole listing, and `xs.drop(100)` returns the empty listing. Mirroring that policy keeps user-facing behavior intuitive and avoids leaking an internal index-bounds error from data-shape variation."
    }
  }
}

local propertiesRenderer = new Scenario {
  id = "PKL-074"
  name = "render Pkl values as Java Properties"
  description =
    "The CLI `eval -f properties` (or `--format properties`) flag emits a Java Properties document matching Apple Pkl's `pkl eval -f properties` shape: ObjectValue and MappingValue members flatten into dotted keys (`a.b.c`), Mapping keys are coerced to strings, scalar values emit as unquoted `key = value` lines with property-style escaping for `\\`, `\\n`, `\\t`, `\\r`, `\\f`, leading space, `:`, `=`, `!`, and `#`. ListingValue renders as a compact JSON-style single-line value (`[1,2,3]`), with the JSON `:` separators property-escaped to `\\:`. NullValue leaves are omitted (mirroring Apple Pkl's `omitNullProperties = true` default), empty Object / Mapping leaves are dropped entirely, and empty Listings emit `key = []`. Top-level non-mapping values produce an empty document."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-072"; "PKL-073" }
  tags { "renderer"; "properties"; "cli" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror Apple Pkl's dotted-flatten Properties projection"
      rationale =
        "Apple Pkl's Properties renderer commits to a deterministic projection: nested Object / Mapping flatten into dot-joined keys, ListingValue stays as a single inline JSON-style scalar (so the line count matches the leaf count, not the listing length), and NullValue leaves are dropped by default. Mirroring that projection now means existing Pkl configurations ported here serialize to .properties without divergence, and adding `omitNullProperties = false` / `restrictCharset = true` / converters later remains an opaque extension instead of a re-architecting."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Apply property-style escaping symmetrically to keys and values"
      rationale =
        "Java Properties readers strip leading whitespace and use `=`, `:`, ` ` (space), `!`, `#`, and `\\` as syntactic delimiters. Apple Pkl's renderer escapes all of those in both keys and values (with a slight asymmetry: leading space is escaped in values, every space is escaped in keys, trailing space is left alone in values). Following that scheme here keeps round-trip behavior intact for any conforming Java Properties parser."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer `restrictCharset = true` Unicode escaping to a stdlib slice"
      rationale =
        "Apple Pkl's `restrictCharset = true` mode emits `\\uXXXX` escapes for every non-ASCII code point so the resulting file is safe for legacy ISO-8859-1 .properties readers. That knob lives on the `PropertiesRenderer` stdlib class, which arrives as part of PKL-079 stdlib expansion. Until then, the default `restrictCharset = false` behavior — pass Unicode through verbatim — is enough for modern JVM consumers."
    }
  }
}

local yamlRenderer = new Scenario {
  id = "PKL-073"
  name = "render Pkl values as YAML"
  description =
    "The CLI `eval -f yaml` (or `--format yaml`) flag emits a YAML document matching Apple Pkl's `pkl eval -f yaml` block-style shape: ObjectValue and MappingValue project to block mappings (Mapping keys are coerced to strings, indented two spaces per level), ListingValue projects to block sequences at the parent column with `- value` entries, and empty composites use the `[]` / `{}` flow form. String scalars stay bare when they parse as plain YAML, switch to single-quoted with `''` escapes for leading indicators / numeric-or-keyword shapes / inline `: ` / ` #` / trailing whitespace, and switch to double-quoted with `\\n`, `\\t`, `\\r`, `\\\\`, `\\\"`, and `\\uXXXX` escapes when the value contains control characters or a backslash. The default `eval` output stays PCF."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-072" }
  tags { "renderer"; "yaml"; "cli" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror Apple Pkl's block-style YAML projection rules"
      rationale =
        "Apple Pkl's YAML renderer commits to a deterministic block-style projection (sequences emit `- item` at the parent column, mappings emit `key: value` with two-space indentation, empties use the flow `[]` / `{}` form). Mirroring that projection now means existing Pkl configurations ported here serialize to YAML without divergence, and adding `indentWidth` / `omitNullProperties` / converters later remains an opaque extension instead of a re-architecting."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Reuse the JSON `-f` CLI flag rather than the `output { renderer }` block"
      rationale =
        "PKL-072 wires `eval -f json` through a CLI flag because the `output { renderer = new JsonRenderer { ... } }` shape depends on stdlib classes (`JsonRenderer`, `YamlRenderer`) that we have not implemented yet — that lives in PKL-079 stdlib expansion. Reusing the same flag for YAML keeps the CLI surface uniform; once the stdlib renderer classes land, the `output { renderer }` path simply re-invokes the same internal `render_value_as_yaml` entry point."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Use double-quoted form for control-character strings instead of block scalars"
      rationale =
        "Apple Pkl uses `|`, `|-`, and `|+` block scalars for multiline / control-character strings to keep YAML output human-readable. That projection is non-trivial (indentation indicators, chomping indicators, leading-whitespace handling) and is best implemented as its own slice. Until then, double-quoted strings with the JSON-style `\\n` / `\\t` / `\\uXXXX` escapes produce equivalent YAML — slightly less readable but still spec-compliant and round-trippable through any YAML 1.1 parser."
    }
  }
}

