local userDefinedConstrainedCallableArgumentEvaluation = new Scenario {
  id = "PKL-066"
  name = "evaluate user-defined constrained Pkl callable arguments"
  description =
    "Function, lambda, and class method calls enforce user-defined numeric predicate factories on parameter annotations at runtime, matching the existing built-in numeric predicate behavior."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-065"; "PKL-056" }
  tags { "evaluator"; "callable" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Extend argument validation to user-defined constraint predicates"
      rationale =
        "Return validation now applies built-in and user-defined predicates, but callable and method parameter checks only run the built-in predicate machinery. Extending the parameter validation to call the user-defined predicate helper closes the symmetry gap."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Share a callable argument rejection helper"
      rationale =
        "Both eval_lambda_application and eval_class_method_call needed to combine the built-in and user-defined predicate checks. A shared eval_callable_argument_rejection_message helper keeps the message format aligned with the existing argument diagnostics and avoids duplicating the predicate cascade."
    }
  }
}

local constrainedCallableReturnBodyTypechecking = new Scenario {
  id = "PKL-067"
  name = "typecheck constrained Pkl callable return bodies"
  description =
    "Function, lambda, and class method declarations whose body is a literal that violates the declared constrained return annotation are rejected by the typechecker, mirroring the existing constrained binding behavior for built-in and user-defined numeric predicates."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-065"; "PKL-066" }
  tags { "typechecker"; "callable" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Lift literal-body return checks into the typechecker"
      rationale =
        "Constrained value bindings already use push_constrained_type_annotation_expr_diagnostic and the user-defined variant to flag literal violations at typecheck time. Callable return bodies currently only run the runtime check, leaving a static-analysis gap when the body is a known literal."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Walk declarations once at typecheck entry"
      rationale =
        "Function and class method bodies are visited from different paths in the inference flow, so a dedicated post-typecheck walker that visits all declarations once keeps the rule centralized and avoids threading declarations through every infer_call path."
    }
  }
}

local typeAliasedCallableReturnEvaluation = new Scenario {
  id = "PKL-068"
  name = "evaluate typealiased Pkl callable return annotations"
  description =
    "Function, lambda, and class method return annotations whose declared type name is a typealias resolve through the alias chain at runtime, accepting alias targets such as Int when the alias is declared as typealias Small = Int."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-065"; "PKL-039" }
  tags { "evaluator"; "callable"; "typealias" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Resolve callable return aliases before runtime base-type validation"
      rationale =
        "eval_value_accepts_type_annotation rejects typealiased return annotations because it only matches the literal alias name against the value type. Value bindings already resolve aliases through the type alias environment, and the same resolution should happen for callable returns so user code can name the return through a typealias."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Preserve the alias display name in diagnostics"
      rationale =
        "The constraint rejection helpers accept separate display and source names, so the runtime can resolve the alias to drive the base-type and constraint checks while still surfacing the alias in the user-facing diagnostic for parity with constrained value binding messages."
    }
  }
}

local pcfRendererPrimitives = new Scenario {
  id = "PKL-070"
  name = "render Pkl values as PCF primitives"
  description =
    "Module rendering as the canonical Pkl Configuration Format (PCF) emits Int, Boolean, String, and Null values with the same lexical form Apple Pkl uses, so module bindings reparse to the same value graph and the basic LanguageSnippetTests fixtures match the upstream gold output byte-for-byte."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "renderer"; "pcf" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Lock the existing CLI renderer in as the PCF baseline"
      rationale =
        "The CLI `eval` command already emits PCF-shaped output for Int, Boolean, String, and Null primitives, and the basic upstream parens / import1 fixtures match the gold .pcf files byte-for-byte. PKL-070 locks that contract with explicit unit tests, a round-trip test, and a doc comment on render_value identifying it as the PCF entry point so future JSON / YAML renderers (PKL-072..074) land alongside without ambiguity."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer Float values to a dedicated slice"
      rationale =
        "Float values, literals, and the matching FloatType are not yet in the AST, evaluator, or typechecker. Adding them would inflate PKL-070 well beyond a renderer slice, so Float rendering is queued as a follow-up alongside Float constraint predicates (PKL-092)."
    }
  }
}

local pcfRendererObjects = new Scenario {
  id = "PKL-071"
  name = "render Pkl objects and listings as PCF"
  description =
    "PCF rendering emits nested objects, listings, and mappings with the brace / element conventions Apple Pkl uses, including 2-space indentation, type-tag-free `new { ... }` wrappers for non-scalar listing / mapping values, and the empty `{}` form. The basic, modules, and classes upstream fixtures match the gold `.pcf` output byte-for-byte."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-070" }
  tags { "renderer"; "pcf" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Drop the explicit type tag from nested PCF blocks"
      rationale =
        "Apple Pkl PCF emits `new { ... }` (no `Listing` / `Mapping` / `Dynamic` tag) for non-scalar values that appear as listing elements or mapping keys / values, and `name { ... }` for typed and untyped block-valued properties. Re-introducing the tags broke byte-for-byte parity with the upstream gold outputs."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Treat module top-level as ObjectValue with a flat layout"
      rationale =
        "The CLI evaluation result is always an ObjectValue at the module boundary, so render_value treats ObjectValue at the entry point as a module (no enclosing braces, no indentation, members on their own lines) and dispatches every nested value through the inline path. This keeps the top-level layout indistinguishable from `pkl eval` and lets render_value still produce a self-contained value for non-module callers such as pkl:test.catch."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Skip the listing / mapping round-trip test"
      rationale =
        "PCF rendering drops the `Listing` / `Mapping` tag and uses Pkl's listing / mapping shorthand syntax for elements, which this evaluator's parser does not yet accept. The round-trip unit test stays on the object-member subset until the parser slice that accepts the shorthand lands; byte-for-byte parity with upstream gold output is enforced via the upstream smoke check instead."
    }
  }
}

local jsonRenderer = new Scenario {
  id = "PKL-072"
  name = "render Pkl values as JSON"
  description =
    "The CLI `eval -f json` (or `--format json`) flag emits a JSON document matching Apple Pkl's `pkl eval -f json` shape: ObjectValue and MappingValue project to JSON objects (Mapping keys are coerced to strings), ListingValue projects to JSON arrays, IntValue / BoolValue / NullValue use the JSON scalar form, and StringValue applies the standard `\"`, `\\`, control-character (`\\b`, `\\f`, `\\n`, `\\r`, `\\t`, `\\uXXXX`) escapes. Indentation is fixed at two spaces. The default `eval` output remains PCF."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-071" }
  tags { "renderer"; "json"; "cli" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror the `pkl eval -f json` projection rules"
      rationale =
        "Apple Pkl's JSON output has specific rules for ObjectValue / MappingValue / ListingValue, Mapping key coercion, and JSON string escapes. Mirroring them at this stage means existing Pkl configs ported here can serialize to JSON without divergence; re-deriving the rules from scratch later would invite per-feature drift."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Wire JSON through a CLI flag rather than an `output { renderer }` block"
      rationale =
        "Apple Pkl primarily selects renderers via the module-level `output { renderer = new JsonRenderer { ... } }` block, which depends on the stdlib `JsonRenderer` class and `output { value }` projection. Those are independent slices (PKL-079 stdlib expansion). A `-f json` CLI flag covers the common `pkl eval -f json` workflow without blocking on stdlib work, and the renderer code itself is decoupled so the `output { ... }` path can call it later."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Coerce Mapping keys via PCF inline form for composite keys"
      rationale =
        "Apple Pkl forbids non-string JSON object keys; for scalar keys (Int, Bool, Null) the upstream renderer formats them as the corresponding scalar string (`\"1\"`, `\"true\"`, `\"null\"`). For composite keys the upstream behavior is implementation-defined and rarely used, so we reuse the PCF inline form to keep the output deterministic and readable, instead of failing."
    }
  }
}

local durationAndDataSizeLiterals = new Scenario {
  id = "PKL-082"
  name = "Duration and DataSize literals with arithmetic comparison and unit conversion"
  description =
    "Member access on an Int literal whose name is a recognised Duration unit (`ns` / `us` / `ms` / `s` / `min` / `h` / `d`) produces a `DurationValue(Int, String)` carrying the original magnitude and unit; the matching DataSize units (`b` / `kb` / `kib` / `mb` / `mib` / `gb` / `gib` / `tb` / `tib` / `pb` / `pib`) produce a `DataSizeValue`. Same-unit `+` / `-` operate on the raw magnitudes and preserve the unit; mixed-unit `+` / `-` and comparison (`<` / `<=` / `>` / `>=` / `==` / `!=`) normalize to the smaller of the two units by stepping along the unit ladder one factor at a time so the running magnitude never overflows Int32. `.value` and `.unit` accessors expose the underlying Int and unit name; `.toUnit(name)` re-expresses the value in another aligned unit (e.g. `1.h.toUnit(\"min\") == 60.min`). Unary negation flips the sign while keeping the unit. The PCF renderer emits the values back as the `<n>.<unit>` literal; JSON / YAML / Properties project them as the same lexical form coerced to a string."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "evaluator"; "renderer"; "duration"; "datasize" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Restrict the slice to Int magnitudes and document the Float gap"
      rationale =
        "Apple Pkl tracks the magnitude as a `Number` (Int or Float) and switches to Float on the first fractional-result mixed-unit operation (e.g. `2.s + 3.min` yields `3.033333333333333.min`). The MoonBit value model has no `FloatValue` yet (that lands with PKL-092), so this slice ships Int-only magnitudes. Same-unit arithmetic is exact; mixed-unit arithmetic rounds toward the smaller unit by integer division when the step is non-aligned (notably the binary↔decimal DataSize crossings `kb ↔ kib`). The decision is documented in the slice scope so callers know which operations are reliable and which are deferred."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Pick the smaller of two units as the result of mixed-unit arithmetic"
      rationale =
        "The natural alternative — normalize to the base unit (ns / b) — overflows Int32 immediately: `1.s` is already 1e9 ns and `1.h` is 3.6e12 ns. Picking the smaller of the two operand units keeps the multiplier small (`min → s` is 60, `gb → mb` is 1000) and matches the way most user input flows (people add minutes to a base of seconds, not seconds to a base of nanoseconds). The result type stays exact for aligned-unit ladders (ns..d for Duration; the decimal-only and binary-only paths for DataSize)."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Walk the unit ladder step-by-step instead of multiplying through a flat factor"
      rationale =
        "A flat `factor_in_ns(from) * magnitude / factor_in_ns(to)` table already overflows Int32 once `from` is `min` or coarser (1 min = 6e10 ns). Walking the unit ladder one step at a time — `h → min × 60`, `min → s × 60`, `s → ms × 1000`, etc. — keeps every intermediate value as small as possible and lets us defer Int64 to the PKL-092 Float slice. The DataSize side reuses a single-step `byte_factor` lookup capped at `gib` (~1.07e9 b, the last value that fits in Int32); `tb` and coarser construct fine but a `-1` sentinel from `datasize_byte_factor` makes the mixed-unit path bail rather than silently corrupt the result."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Render to PCF as the literal form, project JSON / YAML / Properties as the same string"
      rationale =
        "Apple Pkl rounds the PCF projection of a Duration / DataSize to its original literal form (`5.min`, `3.kib`); reusing that exact lexical shape lets the value round-trip through the parser cleanly. JSON / YAML / Properties do not have a native Duration / DataSize type, so the upstream renderer also emits them as quoted strings (e.g. `\"5.min\"`); matching that shape keeps the output deterministic without requiring a dedicated `pkl:base` projection table this slice."
    }
  }
}

local floatPowerAndDivisionSemantics = new Scenario {
  id = "PKL-111"
  name = "Float Power IntDivide and Modulo semantics"
  description =
    "Apple Pkl's `**` / `~/` / `%` operators accept Float operands and produce results that match the JVM evaluator's golden output. `**` (Power) widens to Float on any Float operand: `2.0 ** 3 = 8.0`, `2.3 ** 4.0 ≈ 27.984099999999998` (Apple's exact bit pattern). `~/` (IntDivide) always returns an Int even when both operands are Float, using truncation toward zero: `5.0 ~/ 3.0 = 1`, `5 ~/ 3.0 = 1`, `5.1 ~/ 3.1 = 1`. `%` (Modulo) widens to Float on any Float operand and computes the truncated remainder `a - b * trunc(a / b)`: `5.5 % 6.5 = 5.5`, `5 % 6.5 = 5.0`. The evaluator routes these through `eval_float_binary`'s extended branches, using `@math.pow` from `moonbitlang/core/math` for exponentiation and a local `double_trunc` helper that round-trips through Int64 for truncation. Division-by-zero on `~/` and `%` against a zero divisor surfaces the same `division by zero` diagnostic as the Int-side path. The typechecker mirrors the runtime rule: when both operands are numeric and at least one is Float, the result is Float for `**` / `%` and Int for `~/`; Int × Int keeps the existing Int-only result type."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-092" }
  tags { "evaluator"; "typechecker"; "float"; "operator" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Match Apple Pkl exactly rather than route through a `pkl:math` stdlib wrapper"
      rationale =
        "The roadmap entry posed two paths: widen the operators in-place or surface them as `math.pow` / `math.floorDiv` / `math.remainder` stdlib calls. The upstream golden output in `third_party/apple-pkl/.../basic/float.pcf` is unambiguous — Apple just widens the operators directly. Routing through `pkl:math` would require additional fixtures and naming decisions; widening in `eval_float_binary` matches the upstream test data and keeps the change local to the binary-operator dispatch."
    }
    new Decision {
      date = "2026-05-15"
      summary = "`~/` returns Int even on Float operands"
      rationale =
        "Apple Pkl's golden output for `5.0 ~/ 3.0` and `5.1 ~/ 3.1` is `1` (the bare integer, not `1.0`). The natural reading is that `~/` is `truncating-divide-to-Int` regardless of operand type. Following the upstream output keeps `intResult: Int = 5.0 ~/ 3.0` typechecking on the Int side instead of forcing call-sites to wrap with `.toInt()`."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Compute `%` as `a - b * trunc(a / b)` instead of `a.mod(b)` to dodge ambiguous Float remainder semantics"
      rationale =
        "Apple Pkl's `5.5 % 6.5 = 5.5` matches truncated (toward-zero) remainder, not floored modulo (which would give `5.5` for the same case but differ on negatives). Encoding the formula explicitly avoids depending on the stdlib's Double remainder convention and makes the Float / Int sign behavior explicit at the call site."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Import `moonbitlang/core/math` for `pow` rather than implementing it locally"
      rationale =
        "The stdlib `pow` is a thin libm wrapper; reimplementing it would either duplicate the libm call or invent a Taylor-series variant whose precision drifts from libm on the standard test inputs. The dependency is already transitively available, so importing it costs nothing at link time."
    }
  }
}

local floatThresholdConstraints = new Scenario {
  id = "PKL-112"
  name = "Float-threshold constraint predicates"
  description =
    "Numeric constraint predicates (`isBetween`, `isGreaterThan`, `isLessThan`, plus the user-defined comparison factories) accept Float literals as thresholds. `Float(isBetween(0.5, 1.5))` now parses and runs without losing precision — previously the threshold parser only accepted Int text, so `0.5` failed to parse and the predicate was silently dropped. The `ConstraintIntPredicate` enum keeps its name (still scoped to the numeric host `Int` / `Float` / `Number`) but its arguments are encoded as `Double` instead of `Int`. The text parser `pkl_parse_constraint_double_text` accepts an optional leading `-`, a digit-run integer part, and an optional `.<digits>` fractional part; the existing `pkl_parse_constraint_int_text` stays in place for `String(length OP N)` paths where `length` is always Int. Int-side value comparison flows through `pkl_constraint_predicate_accepts_float(predicate, value.to_double())` so `Int(isBetween(0, 10))` keeps working uniformly with `Float(isBetween(0.5, 1.5))`. The `length.is*` reuse of the numeric grammar truncates the Double threshold back to Int with `Double::to_int` — `length.isBetween(2.5, 3.5)` therefore behaves like `length.isBetween(2, 3)`, matching Apple Pkl's truncation toward zero. Rejection messages format the Double via the existing `\\{value}` interpolation, so `Float(isLessThan(1.5))` rejecting `2.0` surfaces as `rejects 2` (the MoonBit `Double::to_string` strips the trailing `.0` for integral Doubles, which the existing PKL-092 fixtures already documented for `rejects -0.5`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-092" }
  tags { "typechecker"; "constraint"; "float" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Lift the predicate enum's Int arguments to Double across the board"
      rationale =
        "The alternative was to keep `ConstraintIntPredicate` Int-shaped and bolt on a parallel `ConstraintFloatPredicate` enum with the same variant set. That would double the maintenance surface (every variant added in the future needs both copies, every negation / dispatch lookup needs both arms). Promoting the Int arguments to Double once unifies the dispatch — Int values widen via `to_double` at the top of `pkl_constraint_predicate_accepts`, and the Float path drops its previous `lower.to_double()` widenings since both sides are already Double."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Keep `pkl_parse_constraint_int_text` for the String length predicate path"
      rationale =
        "`String(length > N)` and `String(length.isBetween(0, 10))` always carry Int thresholds — `length` is itself an Int. Routing those through the Double parser would force a `.to_int` round-trip at every length comparison and risk silently truncating thresholds the user meant to fail. Leaving the Int parser in place keeps the existing String constraint grammar bit-for-bit identical."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Truncate Double thresholds back to Int when they flow into `length.isBetween` style predicates"
      rationale =
        "The numeric predicate parser is shared between the `Float(isBetween(...))` host and the `String(length.isBetween(...))` host. The String host's downstream variant `StringLengthIsBetween` still takes Int because `length` is Int. Truncation via `Double::to_int` matches Apple Pkl's `length.isBetween(2.5, 3.5)` reading (round toward zero, identical to writing `length.isBetween(2, 3)`); the alternative (rejecting Float thresholds for length) would require a separate Int-only parser variant and a third error message."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Hand-roll the Double text parser instead of leaning on `@strconv.parse_double`"
      rationale =
        "The constraint-text parser sits next to `pkl_parse_constraint_int_text` and follows the same hand-rolled walk style. Pulling in `moonbitlang/core/strconv` for the Double form would add a dependency for one helper, and the surface here is small (`-?<digits>(\\.<digits>)?`) — exponent notation is parser-level (PKL-128) and not reached from constraint text. The hand-rolled walk also returns `None` on trailing garbage, which lets the predicate parser fall through cleanly instead of catching a strconv exception."
    }
  }
}

local isOperatorRuntime = new Scenario {
  id = "PKL-114"
  name = "is operator runtime evaluation"
  description =
    "The `is` operator evaluates at runtime: `5 is Int` returns `true`, `1.5 is Float` returns `true`, `5 is Number` and `1.5 is Number` both return `true`, `\"x\" is Int` returns `false`, and `if (x is Int) ...` actually branches on the runtime type of `x` instead of failing with `operator is is parser-only`. The new `value_is_type(value, type_name)` helper in `eval.mbt` mirrors the surface that the typechecker's `type_from_annotation` accepts: union (`String | Int`), nullable (`Float?`), constrained (`Int(isPositive)` strips the predicate and falls back on the base type), and generic (`Listing<Int>` / `Mapping<String, Int>` route to `ListingValue` / `MappingValue` without inspecting elements). User-defined class names fall through to `false` for now — class-instance dispatch needs class tags on `ObjectValue`, which is out of scope for this slice. The typechecker's is-guard narrowing was already generic enough for `Float / Number / TypeVariable` paths via the existing `UnionType` / `NullableType` recursion (PKL-092 widened `Number` to `UnionType([IntType, FloatType])` and PKL-110 made `TypeVariable(_)` accept-any in `type_accepts`), so the scope reduces to the evaluator side."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-092"; "PKL-110" }
  tags { "evaluator"; "is-operator"; "narrowing" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Drop the parser-only stub and add a value-classification helper on the evaluator side"
      rationale =
        "The `Is | As | Pipe => parser-only` branch was a stub from the earliest evaluator that signalled 'parsed but not interpretable'. With the typechecker's `Number = UnionType([IntType, FloatType])` and `TypeVariable(_)` accept-any in place, the typecheck side already routes is-guards through the structural narrowing pass for every type the surface admits. The missing piece was the evaluator's runtime classification — `value_is_type` covers the same shape and lets `if (x is Int) ...` finally branch instead of erroring."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Reuse `pkl_constraint_trim` / `split_top_level_union_choices` / `generic_argument_text` / `pkl_constrained_type_base_name` instead of forking a new parser"
      rationale =
        "The type-annotation text the parser stores in the `is` right operand has the same grammar the typechecker already parses for `Listing<T>` / `Mapping<K, V>` / `Float?` / `Int(isPositive)`. Reusing the existing helpers keeps the classification rules in lock-step — when the parser surface grows (e.g. PKL-128 scientific notation, triple-quoted strings) only one set of helpers needs to update."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Leave user-defined class names returning `false` from `value_is_type` for now"
      rationale =
        "Class-instance dispatch needs `ObjectValue` to carry a class tag (the typechecker has `ClassType(name, _)` but the evaluator's `ObjectValue([members])` does not). Tagging is a separate slice (the design touches `new <ClassName> { ... }` instantiation, amends, and renderer round-trips). Returning `false` for unknown class names is the conservative choice — `if (x is Box) ...` always takes the else branch, preserving sound runtime behaviour."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Leave `As` and `Pipe` on the parser-only stub"
      rationale =
        "`As` (type coercion) and `Pipe` (`|>` operator) are independent slices in the roadmap (PKL-128 parser surface expansion covers `|>`). PKL-114's scope is the `is` operator; mixing `as` runtime evaluation in would muddle the slice boundary. The error message stays the same for those two, so authoring still gets a clear `parser-only` hint when they reach for them."
    }
  }
}

local genericTypealiasInstantiation = new Scenario {
  id = "PKL-115"
  name = "generic typealias instantiation"
  description =
    "`typealias Box<T> = Listing<T>` parses and binds T in the target text. At an instantiation site like `Box<Int>`, the typechecker looks up the alias binding for `Box`, matches its declared type parameters against the provided arguments, substitutes the parameter names in the recorded target text, and re-evaluates the resulting type. `b: Box<Int> = new Listing { 1; 2; 3 }` typechecks (the target rewrites to `Listing<Int>`), `b: Box<Int> = new Listing { \"a\"; \"b\" }` rejects (Int-element listing expected, String elements found). Multi-parameter aliases (`typealias Pair<K, V> = Mapping<K, V>`) work the same way — parameters substitute positionally. The substitution pass is textual (`is_typealias_identifier_start` / `_continue` walks the target string and replaces full identifier tokens that match a parameter name); generic alias bindings carry the original `TypeAliasDecl` on a new `alias_decl: TypeAliasDecl?` field on `TypeBinding` so the use-site rewriter does not need to re-walk the declarations array. Non-generic aliases keep `alias_decl = None` and the previous resolution path unchanged."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-110" }
  tags { "parser"; "typechecker"; "typealias"; "generics" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Substitute textually in the alias target instead of representing parameters as a new Type variant"
      rationale =
        "Two designs were on the table. (A) Add a new `TypeAlias(name, parameters, target_type)` variant to the Type enum and substitute at use sites via the Type tree. (B) Keep the alias target as a String on `TypeAliasDecl` and substitute textually before re-running `type_from_annotation`. (B) is much smaller — the Type enum and every consumer of it stays untouched, the substitution is a 20-line tokenizer that walks identifier characters, and the resolution path that `Box<Int>` takes is `try_generic_alias_substitution → type_from_annotation`, which reuses every existing case (union / nullable / constrained / generic). (A) would have given better introspection (`render_type` could show `Box<Int>` instead of the substituted form) but at the cost of touching every Type-walking pass."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Inject declared type parameters as scoped TypeVariables when resolving the alias at definition time"
      rationale =
        "Without this, `typealias Box<T> = Listing<T>` fails to resolve at definition time — `T` is unknown in the surrounding `type_env`, so `type_from_alias_target_annotation` returns `None` and the typechecker emits `unknown type annotation Listing<T>`. Scoping `T` as `TypeVariable(\"T\")` for the duration of the alias's target resolution mirrors how PKL-090 / PKL-110 already handle generic class / function declarations (parameters bind to TypeVariable inside the body). The resulting binding's `typ` is `ListingType([TypeVariable(\"T\")])` — an unresolved generic, never observed by user code because every use site re-runs through `try_generic_alias_substitution` which produces a fully concrete type."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Carry the decl on TypeBinding rather than maintain a parallel alias table"
      rationale =
        "The alternative was to thread `Array[Declaration]` through every call to `type_from_annotation` so the alias resolver could re-walk declarations at use time. That would have grown the signature of ~20 functions for a single new dependency. Embedding the decl on the binding itself keeps `type_from_annotation`'s signature stable; bindings that were never aliases (the vast majority) carry `alias_decl = None` and pay no cost. The trade-off is that all `TypeBinding` construction sites had to update (13 callers, mechanical), which sed handled in one shot."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Tokenize identifiers manually rather than reach for the regex module"
      rationale =
        "`@regexp` is available (constraints.mbt uses it), but a regex like `\\bT\\b` over the target text is a recipe for substitution interference when type parameter names share prefixes (`T` vs `TList`). The character-class identifier walk (`is_typealias_identifier_start` / `_continue` + iterate) gives us full identifier boundaries by construction. The walker is ~25 lines and matches Pkl's identifier grammar precisely — `T` does not replace inside `TList` even if both are referenced in the same target text."
    }
  }
}

local typeParameterBounds = new Scenario {
  id = "PKL-116"
  name = "type parameter bounds"
  description =
    "`class Box<T : Number>` and `function pick<T : Number>(x: T): T` constrain T to a supertype. The parser collects the `: <bound>` suffix per type parameter and stores it as a parallel `type_parameter_bounds: Array[String?]` on `ClassDecl` and `FunctionDecl`. `collect_declared_types` resolves each bound text against the surrounding `type_env` and stores the resulting Type on the new `bound: Type?` field of `TypeBinding`. At call sites, `unify_for_substitution` consults `binding.bound` when it records `T := <actual>`; if the bound is set and `type_accepts(bound, actual)` returns false, a diagnostic surfaces as `type parameter T bound <bound> rejects <actual>` (with Number rendered as `Int|Float` since the union form is canonical). Unbounded parameters keep `bound = None` and the existing accept-any behaviour. Class type literal sites flow through the same path via `substitute_class_type_variables`, which now threads `type_env` and `diagnostics` so bound failures inside `new Container { value = \"x\" }` (where `Container<T : Number>`) reach the user."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-089"; "PKL-110" }
  tags { "parser"; "typechecker"; "generics"; "bounds" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Carry the resolved bound on `TypeBinding` rather than re-walking declarations at use sites"
      rationale =
        "Same trade-off as PKL-115's `alias_decl`: threading `Array[Declaration]` through every typecheck signature would touch ~20 functions. Storing the resolved `bound: Type?` on the `TypeBinding` that already exists for each type parameter is local — the binding is constructed once during `collect_declared_types`, then `unify_for_substitution` reads it during call-site unification. The trade-off is that all `TypeBinding` construction sites had to grow another field; sed handled the 13 update again in one shot."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Render the bound through `render_type` instead of preserving the original `: <text>` literal"
      rationale =
        "The bound was authored as the text `Number`, but it lives on `TypeBinding` as `UnionType([IntType, FloatType])` after resolution. Reporting `bound Int|Float rejects String` keeps the diagnostic faithful to the typechecker's internal representation; preserving the user-authored text would diverge once the bound is built from a typealias or a union literal. Tests and authoring docs reflect this trade — when a bound is `Number`, the diagnostic surfaces as `Int|Float`."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Apply bound check on every unify_for_substitution descent, not only at the top level"
      rationale =
        "Nested TypeVariable references (`function f<T : Number>(xs: Listing<T>) = ...`) need the same bound enforcement when the call site supplies `Listing<String>`. The unifier already recurses into Listing / Mapping / FunctionType / ClassType shapes — adding the bound check inside the `(TypeVariable(name), _) =>` arm guarantees it fires at every nested instantiation site without a separate top-level pass."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer typealias parameter bounds to a later slice"
      rationale =
        "`typealias Box<T : Number> = ...` would also be useful, but PKL-115 introduced generic typealias substitution only days ago and its substitution path is textual rather than Type-based. Adding bound checks there means either re-resolving the typealias target inside `try_generic_alias_substitution` (a string-level operation) or rewiring the path to operate on Types. Both are bigger changes than the class / function bound work; the typealias case can land as a follow-up once the substitution path settles."
    }
    new Decision {
      date = "2026-05-15"
      summary = "The `<T : Bound>` suffix is a pkl-mbt extension over upstream Apple Pkl"
      rationale =
        "Apple Pkl's type parameter grammar admits only `in T` / `out T` variance modifiers plus an identifier — there is no `: Bound` suffix on the upstream side. PKL-116 adds the bound suffix as a pkl-mbt extension so generic functions and classes can statically reject calls like `pick(\"hi\")` against `function pick<T : Number>(x: T)`. Side effect: the upstream Pkl formatter does not recognise the suffix, so the CLI fixture `fixtures/cli_type_parameter_bounds.pkl` intentionally uses the unbounded form to keep `pkf run fmt` clean across the tree. The bounded form is exercised end-to-end through the unit tests in `pkl_test.mbt`."
    }
  }
}

local pklAnyType = new Scenario {
  id = "PKL-133"
  name = "Any top type"
  description =
    "`Any` is Pkl's top type — every value flows through it. The Type enum gains a dedicated `AnyType` variant (distinct from `UnknownType`, which signals parser / inference fallback). `builtin_type_from_annotation(\"Any\")` returns `AnyType`. `type_accepts` short-circuits to `true` whenever either side is `AnyType`, mirroring the relation `Any` plays in Pkl's type lattice: a concrete value flows into `Any`, and a value of `Any` flows back into any concrete annotation that expects it. `equality_compatible` accepts the same pattern so `x: Any = 5; res = x == 5` typechecks without a matching-types diagnostic. `render_type` emits `Any` so error messages preserve the user-facing name; collapsing into `UnknownType` would hide the difference from `Unknown`. The change is parser-transparent — no new tokens, no new AST nodes — and lights up `Any?`, `Mapping<String, Any>`, and `bodyJson: Any?` annotations across pkspec's schema without touching the evaluator at all."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-004" }
  tags { "typechecker"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Introduce a dedicated `AnyType` variant instead of aliasing to `UnknownType`"
      rationale =
        "`UnknownType` was already accept-any in `type_accepts`, so reusing it would have lit up the existing tests. But the two carry distinct semantics: `UnknownType` is `we couldn't determine the type` (parse / inference failure); `AnyType` is `the user wrote Any explicitly`. Renderer output and future error messages should distinguish them (`expected Int, got Unknown` reads as a bug; `expected Int, got Any` reads as a typed-Any flow that needs a cast). Keeping the variants separate preserves the diagnostic surface."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Symmetric `(_, AnyType)` accept-any to mirror Pkl's top-type semantics"
      rationale =
        "Apple Pkl's `Any` accepts any value (variance: covariant) and a value typed as `Any` can be assigned to any annotation (variance: contravariant under the user-facing model, even though the typechecker doesn't track variance). Both arms of `type_accepts` short-circuit to keep the relation symmetric. `as` (PKL-128) will eventually require a downcast, but until then accepting unconditional flow on both sides reflects what works in upstream when the user writes `Any` explicitly."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Wire `Any` into `equality_compatible` alongside `type_accepts`"
      rationale =
        "Without it, `x: Any = 5; res = x == 5` would surface as `operator == expects operands of matching types` once PKL-113 landed. The equality relation already had wildcards for `UnknownType` and `TypeVariable`; adding `AnyType` to the same list keeps the symmetric matching contract consistent. The alternative (treating `Any` differently across `type_accepts` vs `equality_compatible`) would make `x == y` and `x = y` diverge in surprising ways."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Evaluator stays untouched"
      rationale =
        "`AnyType` is a typechecker-side concept; at runtime every value is already self-describing (`IntValue`, `StringValue`, `ObjectValue`, etc.). The fixture exercises `Any = 5`, `Any = \"hello\"`, `Any = true`, and `Mapping<String, Any> = new Mapping { ... }` and the rendered output is identical to what the concrete annotations produce — same path through `eval_property_binding`, same renderer."
    }
  }
}

local listingMappingStdlibCore = new Scenario {
  id = "PKL-134"
  name = "Listing and Mapping stdlib core methods"
  description =
    "The read-only conversion / shape methods on `Listing` and `Mapping` resolve as expected. `Listing.toList()` returns the same elements (pkl-mbt collapses Listing / List into one Value variant); `Listing.toMap()` returns the empty Mapping (Pair-based projections are deferred to PKL-119). `Mapping.toMap()` is the identity, `Mapping.toList()` projects the values. `length`, `isEmpty`, `keys`, `values` were already wired by earlier slices and stay green. Type annotation `List<T>` resolves to `ListingType([T])` via a new alias in `builtin_type_from_annotation` and `generic_argument_text(..., \"List\")` — the typechecker treats Listing / List as the same shape until PKL-119 introduces dedicated value variants. The method dispatch routes through `is_listing_method_name` / `is_mapping_method_name` + the existing `eval_listing_method` / `eval_mapping_method`, so the call-site grammar (`xs.toList()`) follows the same path as `xs.contains(v)`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075" }
  tags { "stdlib"; "evaluator"; "typechecker"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Collapse `Listing.toList()` and `Mapping.toMap()` into runtime identity"
      rationale =
        "Apple Pkl distinguishes the builder type `Listing` from the immutable indexed `List`, and the keyed-builder `Mapping` from the immutable `Map`. pkl-mbt has a single `ListingValue` and `MappingValue` variant for now (PKL-119 is the deferred slice that splits Set / Pair / Map / IntSeq into dedicated variants). Until that split happens, `toList` / `toMap` are runtime identities — they return the same Value with the same elements. The cost is that downstream methods that rely on a distinct List shape (e.g. `take`, `drop`) operate on a `Listing` and a `List` identically, which matches pkf / pkspec's use sites today (shape inspection chains) and surfaces no observable difference."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Add `List<T>` as an alias for `Listing<T>` in `type_from_annotation`"
      rationale =
        "Without this, pkspec's `local testNames: List<String> = tests.toList().map((t) -> t.name)` triggers `unknown type annotation List<String>`. The simplest fix is a dedicated lookup arm for `List` (both the bare name and the generic form) that produces the same `ListingType`. When PKL-119 introduces a `ListValue` variant, the alias can be replaced with a distinct binding — the call site stays the same."
    }
    new Decision {
      date = "2026-05-16"
      summary = "`Mapping.toList()` projects values rather than Pairs"
      rationale =
        "Apple Pkl's `Mapping.toList()` produces a `List<Pair<K, V>>`. pkl-mbt doesn't have `PairValue` yet (PKL-119 again), so the projection has to pick something representable. Values-only projection is what most pkspec chains end up doing (`m.values.toList()` is the idiomatic form), and emitting Pairs would either require a synthetic `ObjectValue` wrapper that downstream methods can't pattern-match, or block the slice entirely. Once Pair lands, the projection becomes a List<Pair>. Documented here so the future change is bounded."
    }
    new Decision {
      date = "2026-05-16"
      summary =
        "Defer functional methods (`map` / `filter` / `flatMap` / `count` / `every` / `distinct`) to PKL-135"
      rationale =
        "The roadmap entry splits `Listing.toList()` (this slice) from the higher-order functional layer (PKL-135). The split keeps each slice tight: PKL-134 is purely dispatch + identity; PKL-135 introduces lambda-binding evaluation per element, which is a different mechanic. Several functional methods (`map`, `filter`, `fold`, `contains`, `take`, `drop`, `join`, `reverse`) are already wired — they were drive-by additions during PKL-075 — so PKL-135's scope narrows to the methods that remain unimplemented (`every`, `count`, `distinct` on Mapping, `flatMap`, `find`, `none`)."
    }
  }
}

local floatMagnitudeUnits = new Scenario {
  id = "PKL-121"
  name = "Float magnitude Duration and DataSize literals"
  description =
    "`1.5.s`, `2.5.gib`, `0.5.h` and other Float-magnitude unit literals parse and evaluate to Duration / DataSize values whose magnitude is `Double`. The `DurationValue` / `DataSizeValue` variants were widened from `Int` to `Double` so both Int and Float magnitudes round-trip through the same Value, and the conversion helpers (`duration_in_unit`, `datasize_in_unit`) now compute in Double. Int-magnitude call sites promote on the way in. The `.value` property projects back to `IntValue` when the magnitude is integral and `FloatValue` otherwise so existing Int-magnitude observations stay byte-identical."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-082"; "PKL-092" }
  tags { "parser"; "evaluator"; "duration"; "datasize"; "float" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary =
        "Widen DurationValue / DataSizeValue magnitudes to Double rather than introduce Float variants"
      rationale =
        "Adding `FloatDurationValue` / `FloatDataSizeValue` variants would double the surface for every pattern match against the existing variants (render, equality, unit conversion, comparison, arithmetic). Widening the existing variant's magnitude field from `Int` to `Double` lets every Int-magnitude consumer keep working as long as it accepts the magnitude as `Double` and promotes through `.to_double()` at construction time. The render path already handles `Double` projection."
    }
    new Decision {
      date = "2026-05-16"
      summary = "`.value` projects back to IntValue when magnitude is integral"
      rationale =
        "Pre-PKL-121, `5.min.value` returned `IntValue(5)`. Promoting unconditionally to `FloatValue(5.0)` would break every observation that pattern-matches on the `.value` shape (renderers, arithmetic, constraint checks). The `magnitude_as_value` helper projects to `IntValue` when the magnitude has no fractional component and to `FloatValue` otherwise, so the common path stays byte-identical."
    }
  }
}

local upstreamFixtureSweepExpansionScenario = new Scenario {
  id = "PKL-109"
  name = "upstream fixture sweep expansion"
  description =
    "`scripts/upstream-smoke.sh` gains seven additional fixtures whose `pkl eval` output now matches the upstream `LanguageSnippetTests/output/<dir>/<name>.pcf` gold byte-for-byte: `annotation/annotation1`, `api/jsonRendererEmptyComposites`, `api/moduleOutput2`, `basic/minPklVersion`, `basic/moduleRefLibrary`, `generators/propertyGenerators`, `listings/cacheStealingTypeCheck`. Total gold-match coverage rises from 25 to 32 fixtures across 7 upstream subtrees (`annotation`, `api`, `basic`, `classes`, `generators`, `listings`, `modules`, `objects`, `types`). The promoted fixtures were discovered by walking the candidate subtrees (`api/`, `annotation/`, `generators/`, `lambdas/`, `listings/`, `mappings/`, `methods/`, `objects/`, `types/`) and gating on `diff -q gold actual` byte-equality; new failures still fall outside the curated list and surface as a non-zero exit when the script runs."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-096" }
  tags { "compatibility"; "upstream" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Promote per-fixture rather than per-subtree"
      rationale =
        "A subtree-level promotion (`api/*`, `generators/*`, …) would force every fixture in the subtree to pass gold-match before any of them count, which the upstream corpus's distribution makes infeasible — most subtrees have at least one fixture that exercises a stdlib gap (List / Set / Pair / IntSeq, glob imports, package URIs) outside the implemented slice. Promoting per-fixture keeps the curated list honest: every entry has been manually probed against the gold output and the script's byte-diff gates regressions immediately. New failures in promoted fixtures fail the smoke check; new passes in unpromoted fixtures are silent until a future sweep finds them."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Re-run the same probe loop after each significant evaluator / typechecker slice"
      rationale =
        "PKL-109 is intentionally rolling — each subsequent slice that lifts a stdlib gap (PKL-119 Set/Pair/Map variants, PKL-124 renderer stdlib modules, PKL-127 renderer converters) is expected to unlock more upstream fixtures. The probe loop is a 30-line bash one-liner that iterates the candidate subtrees and diffs against gold; running it after every couple of feature slices and promoting any new passes keeps the upstream coverage growing without a dedicated investigation pass per fixture."
    }
  }
}

local pairValueVariantScenario = new Scenario {
  id = "PKL-119a"
  name = "Pair Value variant"
  description =
    "Pair gets a dedicated value model. `Value` gains a `PairValue(Value, Value)` variant; the `Pair(first, second)` constructor returns it directly instead of the PKL-139 stop-gap `ListingValue` of size 2. Member access on the dedicated variant resolves `.first` and `.second` to the carried values; any other property name surfaces `Cannot find property \\`<name>\\` in object of type \\`Pair\\`.`, matching Apple Pkl's wording for typed containers. Renderer projection: PCF round-trips through `Pair(a, b)` (so the eval output is parser-readable), JSON / YAML / Properties / plist project as a 2-element sequence (`[a, b]` / sequence items / `<array>` of two elements). The typechecker gains `PairType(Type, Type)` alongside `ListingType` / `MappingType` so `Pair<A, B>` annotations stay distinct from `Listing<A | B>` — the same separation pkl-mbt's library consumers need to preserve embedder types. `Pair<A, B>` annotation lands through the `generic_argument_text` intercept; bare `Pair` (no generic arguments) is intentionally NOT a builtin so user-defined `class Pair` declarations still shadow per the existing generic-class-with-two-type-parameters test."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075"; "PKL-139" }
  tags { "evaluator"; "typechecker"; "stdlib" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Split PKL-119 (Set / Pair / Map / IntSeq) into sub-slices"
      rationale =
        "PKL-119 originally bundled all four stdlib value variants. Each variant touches the same broad surface (Value enum, eval constructors, member access, every renderer, typechecker Type enum, annotation parsing) but for different upstream types with different operation sets; bundling them produces a >1000-line diff and forces all four to land together. Splitting into PKL-119a (Pair) / PKL-119b (IntSeq) / PKL-119c (Set) / PKL-119d (Map) keeps each slice tight (one variant, one TYPE alias, the matching renderer arms) and lets the gold-match probe sweep land alongside each one. Pair leads the chain because it's the smallest blast radius — 2-arity, no operations, just member access."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Bare `Pair` (no type arguments) is not a builtin type alias"
      rationale =
        "An earlier draft added `\"Pair\" => Some(PairType(UnknownType, UnknownType))` to `builtin_type_from_annotation` so unparameterised reads still typechecked. That arm shadowed user-defined `class Pair<A, B> { ... }` declarations and broke the existing `generic class declaration with two type parameters` test. The fix is to keep only the parameterised form (`Pair<A, B>`) as a typechecker hook, intercepted in `type_from_annotation` via `generic_argument_text`; the bare name flows through the standard env lookup so local class shadows still win. Test added (`PKL-119a: user-defined class Pair shadows the builtin generic`) to pin this contract."
    }
  }
}

local intSeqValueVariantScenario = new Scenario {
  id = "PKL-119b"
  name = "IntSeq Value variant"
  description =
    "IntSeq joins the dedicated stdlib value variants. `Value` gains `IntSeqValue(Int, Int, Int)` carrying start / end / step; `IntSeq(start, end)` constructs one with step = 1 and `.step(newValue)` returns a new IntSeq with the step replaced (zero is rejected). Bare property reads `.start` / `.end` / `.step` return the carrier slots as Int values; method calls `.toList()` / `.toListing()` materialize into a `ListingValue` of Ints (the two share the materialization path until PKL-119c/d split List / Map out), `.map(f)` projects each materialized element through the lambda, and `.fold(initial, op)` reduces left-to-right. PCF round-trips through `IntSeq(s, e)` (or `IntSeq(s, e).step(n)` when step != 1) so the rendered output is parser-readable; JSON / YAML / Properties / plist materialize to a sequence of Int elements. The typechecker gains `IntSeqType` (parameter-free since elements are always Int); `IntSeq` annotations resolve directly, `IntSeq(start, end)` call sites infer to `IntSeqType` with both arguments expected to accept `Int`, and `infer_call_expr` intercepts method-form calls so `.toList()`/`.toListing()` return `Listing<Int>`, `.map(f)` returns a Listing of the lambda's return type, `.fold(initial, op)` returns the initial type, and `.step(n)` returns IntSeqType. Empty IntSeq (e.g. ascending `IntSeq(5, 0)` or descending without `step(-1)`) materializes to an empty Listing; full upstream equality semantics (empty sequences are equal regardless of endpoints, step-aware element-set equality) remains a follow-up — the structural `derive(Eq)` lined up well enough for the contracts we have today."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-119a" }
  tags { "evaluator"; "typechecker"; "stdlib" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Lazy carrier rather than eager materialization"
      rationale =
        "An eager `IntSeqValue(Array[Value])` would have collapsed PCF round-tripping (Apple Pkl renders `IntSeq(0, 1000000)` as the constructor form, not a 1M-element listing) and would have allocated a 1M-slot Array for any range bound, regardless of whether the elements were ever consumed. Storing the three Int slots keeps construction O(1); materialization happens at `.toList()` / `.toListing()` / `.map` / `.fold` / non-PCF renderer projection time, which are the places the elements actually need to exist."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Method-call inference intercepted in `infer_call_expr`, not modelled as method signatures"
      rationale =
        "Listing's own collection methods are still typecheck-silent (`xs.map((x) -> x)` typechecks as `member access expects Object` but evaluates fine). Adding a full method-signature table for IntSeq would have either set a precedent we'd need to backfill for Listing / Mapping or introduced a one-off table that lived in a different place from the runtime dispatcher. The lightweight intercept in `infer_call_expr` produces the right return type for the common surface (`.toList` / `.toListing` / `.map` / `.fold` / `.step(n)`) without that broader refactor — when the collection-method-signature work lands (the bigger PKL-110-style slice), the intercept moves into it."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Structural Eq instead of upstream sequence-equality"
      rationale =
        "Apple Pkl's `IntSeq.equals` treats every empty sequence as equal regardless of start / end, and equates two non-empty IntSeqs when they produce the same Int list. Mirroring that would require a custom equality function (overriding the `derive(Eq)`) that materialized both operands inside `eval_binary` whenever `==` saw `IntSeqValue` on either side. Today's slice keeps the structural Eq the variant inherits via `derive(Eq)` — same-shape IntSeqs compare equal, different-shape ones don't. The upstream `basic/intseq.pkl` fixture is therefore deferred; it gets promoted alongside the dedicated equality function in a follow-up."
    }
  }
}

local pklRawStringInterpolationScenario = new Scenario {
  id = "PKL-148ao"
  name = "raw string interpolation plus raw escape decoding plus unicode escape plus heredoc backslash"
  description =
    "Apple Pkl's raw string literal supports an `\\<N #>(expr)` interpolation marker — the same `\\(...)` shape as a non-raw string but prefixed with `N` `#`s, where `N` matches the leading hash count of the raw delimiter. Inside a raw string the same N-hash escape re-enables every standard escape: `\\#t` → tab, `\\##n` → newline, `\\#u{1F920}` → 🤠. PKL-148an landed the delimiter strip + verbatim text path; this slice closes the interpolation + escape loop. Four coupled changes. (1) Lexer learns to skip an entire `\\<N #>(...)` argument when scanning for the close delimiter — without it a `\"##` inside a nested raw string (e.g. `#\"a\\#(##\"b\"##)c\"#`) mis-terminates the outer literal. `is_raw_interp_marker` + `skip_raw_interp_arg` + `skip_nested_string_at` walk balanced `(...)` while recognising every nested string shape (single-line / heredoc, raw / non-raw, arbitrary hash count). (2) Parser's `assemble_string_parts` is parameterised on `hash_count`: 0 routes to the non-raw walker (looks for `\\(`, runs `decode_string_escapes` on literal segments), > 0 routes to the raw walker (looks for `\\<N #>(`, keeps literal segments verbatim, but decodes `\\<N #>X` inline by feeding the equivalent non-raw escape through `decode_string_escapes`). (3) `decode_string_escapes` gains a `\\u{HHHH}` arm — hex digits up to the matching `}`, emitted as a single code point. This was missing entirely (`\\u` fell through to the catch-all that wrote `u` literally), so non-raw `\"\\u{1F920}\"` and raw `\"\\#u{1F920}\"` both gain support in one place. (4) PCF heredoc render now escapes each content line via `escape_string_heredoc` (`\\` → `\\\\`, `\\t` → literal `\\t`, `\\r` → literal `\\r`); previously a heredoc string containing a literal `\\` round-tripped as a single backslash and broke gold-match for any multi-line value with escape-significant chars. +2 fixtures (basic/rawString, basic/stringMultiline — the latter benefits from the unicode escape arm), 145 → 147; basic category 57.0% → 59.3%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148an" }
  tags { "parser"; "lexer"; "strings"; "renderer"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Parameterise the interpolation walker on `hash_count` rather than forking raw / non-raw paths"
      rationale =
        "The non-raw `\\(expr)` walker and the raw `\\<N #>(expr)` walker differ in two narrow ways: the escape character run length (0 hashes for non-raw, N for raw) and the literal-segment decoder (full escape decode for non-raw, verbatim for raw with an inline `\\<N #>X` re-decode). Doing both in one function keeps the marker-detection + balanced-paren walk + segment-parsing logic shared — duplicating the entire walker for raw would have meant two places to fix the same bug class (e.g. a nested string inside a balanced `(...)` arg). The `decode` closure + `is_raw` flag is enough to specialise the two leaf behaviours."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Decode raw `\\<N #>X` escapes inline by routing through `decode_string_escapes`"
      rationale =
        "The naive approach — implementing every Apple-Pkl escape (`\\n`, `\\t`, `\\r`, `\\\"`, `\\\\`, `\\u{...}`) twice (once in `decode_string_escapes` for non-raw, once in a raw-specific decoder) — would invite the two decoders to drift. Reconstructing the equivalent non-raw escape (`\\#t` → `\\t`) and feeding it through `decode_string_escapes` keeps escape coverage in one helper, including the new `\\u{HHHH}` arm. The hash-count probe is local to the raw branch; the non-raw branch's existing semantics are untouched."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Lexer carries its own string-skipping logic instead of delegating to the parser"
      rationale =
        "The interpolation argument needs to be walked at both lexing (to determine where the outer string ends) and parsing (to slice the segment for `parse_source`). A parser-only walker would still leave the lexer mis-terminating the outer token, surfacing as a downstream `unsupported expression` with no way to attribute the failure to the string content. Mirroring the walker in the lexer (with a shared shape — `is_raw_interp_marker` / `skip_raw_interp_arg` / `skip_nested_string_at` mirror the parser's `skip_string_at` flow) costs ~100 lines but keeps the token boundaries correct and the parser's segment slice trustworthy. Refactoring them to a shared module is possible but would require pulling string-shape constants out of both — deferred."
    }
    new Decision {
      date = "2026-05-18"
      summary = "PCF heredoc render escapes backslash + tab + CR but NOT double-quote"
      rationale =
        "A heredoc's close delimiter is `\"\"\"`, so a single `\"` inside the body parses back verbatim (no risk of premature close from a lone `\"`). But the standard escape interpretation still runs in Apple Pkl's heredoc lexer — `\\\\` decodes to a literal `\\`, `\\t` decodes to tab — so a heredoc containing a literal `\\` character must round-trip as `\\\\`, not as a single `\\` (which the re-parse would interpret as the start of an escape). Skipping `\"` keeps the heredoc form readable; escaping `\\` / `\\t` / `\\r` preserves the value's exact byte content."
    }
  }
}

local pklRawStringLiteralScenario = new Scenario {
  id = "PKL-148an"
  name = "raw string literal with arbitrary hash count for single-line and heredoc forms"
  description =
    "Apple Pkl's raw string literal — `#\"...\"#` (single-line) or `#\"\"\"...\"\"\"#` (heredoc), with an arbitrary number of leading `#`s that the closing delimiter must match — passes the inner text through verbatim. `\\` escape sequences (`\\n`, `\\t`, `\\\\`) are NOT interpreted, `\\(...)` is NOT an interpolation marker, and only the matching `\\<N #>(...)` form (which this slice does not yet implement) re-enables interpolation. pkl-mbt's lexer previously fell off the `#` character into the regular token path; the parser then surfaced every raw literal as `unsupported expression`. The fix has two halves. (1) The lexer counts the leading `#` run, requires a `\"` (or `\"\"\"`) immediately after, and scans for a matching `\"<N #>` (or `\"\"\"<N #>`) close. Newlines terminate single-line raw strings the same way the non-raw form would. (2) `parse_string_literal_text` detects a `#` prefix on the captured token, computes the hash count, strips the prefix / suffix, and emits the inner text as a verbatim `StringLiteral` — no escape decoding, no interpolation walk. Heredoc indent stripping still applies via `strip_heredoc_indent`, matching Apple Pkl's non-raw heredoc behaviour. No PCF count change — `basic/rawString` stalls on res28 which uses `\\#(...)` interpolation inside a `#\"...\"#` raw, and the api/* fixtures that use raw strings (api/baseModule, api/jsonParser1/2, api/regex, api/string, api/stringUnicode, api/set, api/mapping, api/listing, api/stringMultiline*, etc.) each have additional snippetTest framework / stdlib surface needs before they flip. But the parse-error class shrinks substantially: 17 fixtures drop out of the `unsupported expression` set (43 → 26), unblocking diagnosis of the next layer of failures."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148al" }
  tags { "parser"; "lexer"; "strings"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Support arbitrary leading `#` count in the lexer rather than hard-coding the single-hash form"
      rationale =
        "Apple Pkl's fixture suite (basic/rawString res25-res34) exercises 1- to 5-hash forms (`#`, `##`, `###`, `####`, `#####`). Hard-coding the single-hash case would parse only res1-res24 and surface `unsupported expression` for every multi-hash literal — and the api/* renderer fixtures use multi-hash forms heavily inside their gold output. Implementing the count once is the same code volume as the single-hash case (one loop counting leading `#`s, two loops scanning the close with the captured count) and avoids a follow-up slice that would touch the same lexer arm."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Defer the `\\<N #>(expr)` interpolation arm to a follow-up slice"
      rationale =
        "Raw interpolation is the higher-effort half of the feature — the segment walker has to recognise an N-hash escape inside the raw text, walk the balanced `(...)` group, route the segment through `parse_source` (same shape as the non-raw `\\(...)` case), and concatenate the parts into a `StringConcat` Expr. Doing it in this slice would gate the lexer fix behind a much larger parser change; staging the lexer + verbatim parser landing first lets the next slice focus purely on the interpolation walker without bisecting blame across two unrelated changes. The flip-blocking fixtures (basic/rawString res28-res31, api/regex, etc.) all depend on the interpolation arm; landing it as PKL-148ap (or similar) is straightforward once the lexer surface is in."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Raw heredoc indent stripping reuses `strip_heredoc_indent` rather than a dedicated path"
      rationale =
        "Apple Pkl's `#\"\"\"...\"\"\"#` shape leaves the leading-newline trim and the close-delimiter-indent dedent untouched — the raw flag only disables escape / interpolation interpretation, not the structural indent processing. Reusing the existing helper keeps the indent semantics identical to non-raw heredocs (basic/stringMultiline gold-match) so the raw form behaves predictably under the same source-shape rules without a per-shape divergence."
    }
  }
}

local pklPcfHeredocAndDynamicOrderingScenario = new Scenario {
  id = "PKL-148al"
  name = "PCF triple-quoted heredoc form plus Dynamic property-before-element projection"
  description =
    "Apple Pkl's PCF renderer has two output conventions that pkl-mbt was missing. (1) A StringValue containing at least one `\\n` at a block position (property value, mapping entry value, listing element) renders as a triple-quoted heredoc — `lastName = \"\"\"<newline><indent>line1<newline><indent>line2<newline><indent>\"\"\"` — with content lines and the closing `\"\"\"` sitting at one consistent indent that depends on whether the heredoc is a property value (indent + 2 from the name) or a bare element (same as the element's own indent). Inline contexts (`List(\"a\\nb\")`, `Pair(\"x\\ny\", 2)`) keep the single-line `\\n`-escaped form. Empty content lines preserve the indent verbatim (Apple Pkl emits `<indent>\\n`, not a bare `\\n`). (2) A Dynamic-shape body's PCF projection groups every named property before every bare element / mapping subscript entry, regardless of source order — `barnOwl { name = \"barn owl\"; \"surfing\"; age = 42; \"fire making\" }` projects as `barnOwl { name = ...; age = ...; \"surfing\"; \"fire making\" }`, not source-order. The fix lives entirely in eval.mbt's PCF renderer: a new `render_pcf_string_heredoc(s, indent, buf)` helper plus a `string_split_newline` walker, gated by an `indent > 0 && value is StringValue(s) && s.contains(\"\\n\")` check inside `render_pcf_inline`; matching `field.value is StringValue(s) && s.contains(\"\\n\")` arms in `render_pcf_object_member` and `render_pcf_mapping_entry` so property / mapping values pick up the same heredoc form with `indent + 2`; and a partition step at the head of `render_pcf_block_body`'s ObjectValue arm that splits `visible_members` into a named bucket and an `@element$` / `@subscript$` bucket, emitting named first. +1 fixture (`api/pcfRenderer1`), 144 → 145; api category 7.4% → 8.4%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148ak" }
  tags { "renderer"; "pcf"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Heredoc form keyed on `indent > 0 && StringValue contains \"\\n\"` rather than a per-call-site flag"
      rationale =
        "Plumbing a `block_position` bool through every render call site (PairValue, SetValue, ListValue inline elements; ListingValue / ObjectValue block elements; mapping entries; property values) would double-touch every existing render path for a single new rule. The `indent` parameter is already 0 in inline contexts (Pair / List / Set elements pass 0 down to nested values) and > 0 in block contexts (ListingValue block elements pass indent+2). Keying the heredoc decision on `indent > 0` lets `render_pcf_inline` route the new branch without a new parameter, and the property / mapping-entry sites pick up the same shape by adding a sibling arm that matches the same predicate before falling through to `render_pcf_scalar`."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Content indent argument is the value-position indent, not the heredoc body indent"
      rationale =
        "Apple Pkl emits property heredocs with content at name-indent + 2 (`lastName = \"\"\"` → content at 6 spaces when name is at 4) but bare-element heredocs with content at the element's own indent (the element's `\"\"\"` and content lines sit at the same column). The caller already knows which case it is — `render_pcf_object_member` has the name's indent and passes `indent + 2`; `render_pcf_inline` has the element's indent and passes `indent` verbatim. `render_pcf_string_heredoc` itself is dumb: it writes the opening `\"\"\"` inline, then a newline + indent + content for each segment, then a final newline + indent + closing `\"\"\"`. Keeping the helper indent-agnostic means the per-call-site arithmetic stays localised and easy to audit."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Property / element ordering partitioned at render-time, not at construction-time"
      rationale =
        "Apple Pkl's projection convention sorts properties before elements only at output; the underlying member order matters for source-order semantics (later members shadow earlier ones, the `@element$<offset>` sentinel encodes the original source byte offset so re-emit round-trips). Reshuffling at `eval_object_members` would change the stored shape and risk breaking the offset-based element-sentinel naming. Doing the partition inside `render_pcf_block_body`'s ObjectValue arm keeps the eval-side representation unchanged and matches what the renderer already does for other PCF-specific shapes (`@subscript$` decode, `@element$` strip)."
    }
  }
}

local pklDeferredPropertyErrorSentinelRoutingScenario = new Scenario {
  id = "PKL-148ak"
  name = "deferred property error sentinel hides from output and fires on bare identifier reads"
  description =
    "Apple Pkl evaluates class-default property bodies lazily: a typed local whose RHS violates the annotation (`local p2: Int = \"foo\"`) doesn't fail the surrounding class — the rejection is deferred and only raised when the property is actually read, so `test.catch(() -> p2)` captures the diagnostic message verbatim while siblings that never touch `p2` evaluate cleanly. pkl-mbt's `defer_property_errors` mode (PKL-148u) already stamps a `@error$<stored>` sentinel next to each rejected member, but the wiring was one-sided. The sentinel had no invisibility marker, so the PCF renderer projected entries like `@error$@local$p2 = \"Expected value of type \\`Int\\`, but got type \\`String\\`. Value: \\\"foo\\\"\"` next to the legitimate `res*` members. And `local` member hoisting only pushed the bare name + (type-invalid) value into the per-field `local_env`; an Identifier reference to `p2` from a sibling — including the lambda body of `test.catch(() -> p2)` — read the value silently with no diagnostic, so `test.catch` reported `Expected an exception, but none was thrown.` instead of the gold message. Three coordinated changes. (1) Moved the `@error$` prefix out of `eval.mbt` into `parser.mbt` (`error_member_prefix` / `error_member_name` / `is_error_member_name`) and extended `is_invisible_member_name` to include it, so every existing renderer / equality / iteration site picks up the filter without per-site touch-ups. (2) `eval_object_members`'s hoisting loop now recognises `@error$<stored>` entries and re-emits them as `@error$<bare>` env bindings (with whatever inner visibility prefix stripped), so the sentinel sits in env alongside the bare-name value. (3) `eval_expr_with_bindings`'s Identifier arm checks `lookup_value(env, error_member_name(name))` first; when present it pushes the message and returns None, mirroring the `lookup_pending_error_message` short-circuit that the member-access arm already runs. Lambdas closed over the env (including the `test.catch(() -> p2)` body) see the same intercept. +1 fixture (`basic/localTypedClassMember`), 143 → 144; basic category 55.8% → 57.0%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148aj" }
  tags { "evaluator"; "diagnostics"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "`@error$` prefix relocated to parser.mbt so `is_invisible_member_name` gates the renderer in one place"
      rationale =
        "The deferred-rejection sentinel had been defined as a string literal inside `pending_error_member_name` in eval.mbt; the renderer's `visible_members` filter checked `is_invisible_member_name`, which only knew about `@hidden$` and `@local$`. Adding the `@error$` check directly inside the eval-side helper would have required every renderer / equality / iteration site to consult two predicates. Moving the constant + predicate into parser.mbt and folding it into the existing invisible set means a single edit to `is_invisible_member_name` cascades to every caller — including paths I'd otherwise have to remember to update (PCF mapping render, structural equality walks, deep-equality member iteration)."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Hoist the sentinel into env under `@error$<bare>` rather than wrapping the bare-name value in a throwing marker"
      rationale =
        "The alternative — wrapping the type-invalid value in a sentinel Value variant (e.g. `ErrorValue(message)`) — would touch every Value pattern match in the cascade and require equality / coercion to decide what an ErrorValue means in their context. The two-entry shape (`<bare>` → invalid value, `@error$<bare>` → message) keeps the existing value variants untouched and matches the on-disk member shape, so the env intercept reads identically to the `lookup_pending_error_message` short-circuit that the member-access path already uses. Lambdas close over env naturally — `test.catch(() -> p2)` sees the intercept without any extra plumbing through the Lambda value."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Identifier intercept fires before `resolve_binding_value` rather than inside it"
      rationale =
        "`resolve_binding_value` is the shared resolution path for module-level bindings, lexical bindings, and synth class mirrors. Pushing the `@error$` lookup inside would cost a probe on every name lookup project-wide for a slice that only fires in `defer_property_errors=true` bodies. Doing the check inline at the Identifier arm — where env is already in hand — keeps the cost local to the affected slice; non-deferred bodies pay one extra `lookup_value(env, ...)` per identifier, which is a linear-in-env walk that the hot path was already doing for the primary lookup anyway."
    }
  }
}

local pklObjectBodyMemberHeaderDispatchScenario = new Scenario {
  id = "PKL-148aj"
  name = "object body member header dispatch absorbs const and other modifier prefixes"
  description =
    "Apple Pkl's object-body grammar lets any modifier keyword (`const`, `fixed`, `abstract`, ...) interleave with the `local` / `hidden` visibility prefix before the member's name — `const local function biz() = baz` and the simpler `const qux = 99` are both legal. pkl-mbt had two missing pieces in the parser. (1) `consume_member_visibility_modifiers` only consumed `local` / `hidden`; when the leading token was `const` the loop exited with VisibleMember, `skip_member_header` consumed `const`, and the parser then sat on `local function biz()` with no further visibility pass — the body-member dispatcher fell through to the bare-expression branch and lost the function. (2) `parse_inferred_new_body` disambiguates between an object body and a listing body by looking at the first significant token after `{`; only `hidden` and `fixed` (plus `local NAME = EXPR` blocks via `skip_local_decls_from`) routed to `parse_object_body`. A leading `const` (or `abstract`, etc.) failed every check and routed the entire body through `parse_listing_body`, dropping every named member silently — the rendered output of `const baz = 15; foo { const local bar = baz; … }` was `baz = 15; foo {}`. The fix collapses the two parser passes into a single `consume_member_header` that handles annotations + visibility + modifier-text idents in one loop, and adds a `skip_member_prefix_from` helper that walks past trivia + annotations + visibility + modifier idents so `parse_inferred_new_body` can ask `at_property_decl_from` on the token *after* the prefix run. +1 fixture (`basic/constModifier4`), 142 → 143; basic category 54.7% → 55.8%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148ai" }
  tags { "parser"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Collapse `consume_member_visibility_modifiers` + `skip_member_header` into one `consume_member_header` loop"
      rationale =
        "Calling the two passes in sequence assumed `local` / `hidden` always physically led the modifier run. Apple Pkl allows `const local`, `abstract local`, etc., so the visibility latch has to survive past arbitrary modifier prefixes. Doing both jobs in one loop — push to `pending_modifiers` when the token is a modifier ident, set the visibility enum when the token is `local_kw` / `hidden`, drain annotations when the token is `@` — removes the ordering dependency and lets later modifier-vs-visibility insertions (e.g. a future `nullable` modifier) extend the same loop instead of growing a new pass."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Object-vs-listing disambiguation peeks through the full member prefix"
      rationale =
        "Hard-coding `hidden` and `fixed` as the only modifier idents that route to `parse_object_body` was a band-aid for the original two-modifier surface; the upstream grammar treats every modifier symmetrically, and Apple Pkl's `const baz = 15` body sample is precisely the failure mode it produces. `skip_member_prefix_from` walks the same shape as `consume_member_header` (annotations + visibility + modifier idents) so the disambiguator's at-property-decl check sees the actual member shape rather than the modifier ident — keeping a single source of truth for what counts as a member prefix."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Peek-only helper rather than reusing the advancing parser pass"
      rationale =
        "The disambiguator runs *before* `parse_object_body` / `parse_listing_body` claims the `{` — it has to read tokens without advancing the parser cursor, because mis-dispatching to the listing form has to be recoverable. `skip_member_prefix_from` takes a start index and returns the next significant index, mirroring `skip_local_decls_from`'s shape; reusing the advancing `consume_member_header` here would require save / restore of `pos` + `pending_modifiers` + `pending_annotations`, which is the kind of state shuffling that bites later when annotations grow side effects."
    }
  }
}

local pklLiteralTypeUnionAndStringAffixPredicatesScenario = new Scenario {
  id = "PKL-148ai"
  name = "string literal type union plus startsWith endsWith contains string constraints"
  description =
    "Apple Pkl's `\"<text>\"` is a singleton type whose only inhabitant is the literal string itself; it can appear inside a union (`Null|Boolean|\"Pigeon\"`) to narrow the acceptable set of string values. The same surface also exposes `String.startsWith(\"X\")` / `endsWith(\"X\")` / `contains(\"X\")` as constraint predicates (with `!`-prefixed negations). pkl-mbt's `eval_value_accepts_type_annotation` had no string-literal arm — the union choice `\"Pigeon\"` failed the head check, the cascade fell through to the value-mismatch path, and the `List<Null|Boolean|\"Pigeon\">` element `\"Pigeon\"` was rejected. The constraint side missed three predicates: `endsWith`, `startsWith`, `contains` (plus negations) — `String(endsWith(\"A\"))` parsed but no `pkl_string_constraint_predicate` arm produced a recogniser, so the let-typed binding `str: String(endsWith(\"A\")) = \"Pigeon\".reverse()` accepted `\"noegiP\"` and `test.catch` saw `Expected an exception, but none was thrown.` instead of the gold `Type constraint \\\\`endsWith(\\\\\"A\\\\\")\\\\` violated. Value: \\\\\"noegiP\\\\\"`. The fix has two parts. (1) `eval_value_accepts_type_annotation` checks for a leading-and-trailing `\"` on the type name; if both present, the inner text is the literal payload — a StringValue equal to the payload satisfies the singleton, anything else rejects. The PKL-148ag unresolvable gate already special-cases the `\"`-prefix head so the rejection cascade quotes the original union surface instead of `Cannot find type \\\\`\"Pigeon\"\\\\`.` (2) `ConstraintStringPredicate` gains `StringStartsWith` / `StringEndsWith` / `StringContains` plus their `Not`-prefixed twins; `pkl_string_constraint_predicate` recognises the bare and `this.`-prefixed forms with quoted-string arguments; `pkl_string_constraint_name` renders the verbatim source (`endsWith(\"A\")`) so the diagnostic lines up byte-for-byte; `pkl_string_predicate_accepts` dispatches through `value.has_prefix` / `value.has_suffix` / `value.find` for the three positive forms. +1 fixture (`basic/letTyped`), 141 → 142; basic category 53.5% → 54.7%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148ah" }
  tags { "evaluator"; "constraints"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "String-literal singleton arm lives in `eval_value_accepts_type_annotation` rather than a dedicated `eval_literal_type_*` helper"
      rationale =
        "All other type-annotation acceptance (Int, String, Listing, user classes, generics, nullable, constrained) already routes through `eval_value_accepts_type_annotation`. Splitting literal types into a parallel helper would force every caller (cascade entry, union choice walk, etc.) to consult both — easy to forget, easy to drift. The new arm sits inside the existing cascade so the union walk in `eval_callable_argument_type_rejection_message` automatically picks it up, and the recursive shape (constraint strip → optional strip → literal head check) flows through without extra wiring."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Add `endsWith` / `startsWith` / `contains` (plus negations) as a single slice"
      rationale =
        "All three follow the identical surface shape (bare or `this.`-prefixed, quoted-string argument, verbatim diagnostic name) and Apple Pkl's stdlib pairs them at the same level. Splitting `endsWith` out for the immediate `basic/letTyped` flip and deferring the other two would force the cascade to grow twice in the same place, with two rounds of recogniser-and-acceptance-and-name boilerplate. Folding them into one variant family keeps the constraint cascade flat."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Literal-type comparison uses byte equality on the inner payload"
      rationale =
        "Apple Pkl's `\"Pigeon\"` literal type matches only the exact string content (the Java implementation compares via `String.equals`). pkl-mbt's StringValue stores the raw text; `==` on MoonBit String mirrors the same semantic. Unicode normalisation, case folding, or trimming would diverge from upstream — the literal-type fixtures are precisely about exact-match. No deviation needed."
    }
  }
}

local pklModuleSelfRefAndAmendModuleParentFallbackScenario = new Scenario {
  id = "PKL-148ah"
  name = "module self-ref partial visibility plus amend parent member fallback"
  description =
    "Apple Pkl's `module.<self>.<sibling>` reference, where `<self>` is the binding currently being evaluated, reads the in-progress partial object (siblings already computed in source order) instead of cycling — and `module.X` inside an `amends` / `extends` child resolves to the parent module's member when the child doesn't shadow it. pkl-mbt's `resolve_binding_value` short-circuit treated both as `cyclic property reference foo` / `Cannot find property a` respectively: the cyclic detector fired because the inflight binding was on the stack with no live snapshot in env, and `module.X` only consulted `find_binding(child_bindings, ...)` which doesn't carry parent-only names in amends mode. The fix has two parts. (1) `eval_object_members` pushes `{ name: <top_of_stack>, value: ObjectValue(values_snapshot) }` into per-field `local_env` so the in-flight object is exposed under the binding name being resolved; lookup_value's last-match-wins ordering means `module.foo.b` resolves through the snapshot ahead of the cycle path. (2) The `module.X` short-circuit (in MemberAccess) falls back to `lookup_value(cache, \"super\")` and reads X from the parent ObjectValue when the primary `resolve_binding_value` returns None — the `super = ObjectValue(parent_members)` pushed by `eval_program` (PKL-148ac) for amends / extends modules carries the parent surface. +2 fixtures (`basic/moduleRef1`, `basic/moduleRef2`), 139 → 141; basic category 51.2% → 53.5%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148ag" }
  tags { "evaluator"; "modules"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Snapshot copy of `values` rather than holding a live reference"
      rationale =
        "Pushing `ObjectValue(values)` directly into local_env would expose the live accumulator — every subsequent push to `values` would mutate the snapshot retroactively. The fix takes a copy so the partial value at field K reflects siblings 0..K-1 only, matching Apple Pkl's source-order visibility semantic. The cost is O(K) per field; trivial against the typical body size."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Late-binding (parent's `aa = module.a` re-eval against child's `a`) deferred to a later slice"
      rationale =
        "`basic/moduleRef3` (`extends \"moduleRefLibrary.pkl\"` + `const a = 44`) still expects `aa = 44`, but the parent's `aa` was eagerly computed in `eval_module_relation` against the parent's own `a = 42` before `super` was pushed. Re-evaluating parent members in the child's scope requires plumbing the parent's parsed Bindings through resolve_import (which currently only returns the evaluated Value); that's a deeper refactor and rides as its own slice instead of being bolted into this one."
    }
    new Decision {
      date = "2026-05-18"
      summary = "`super` fallback uses `lookup_member` (bare match) not `find_member_exact`"
      rationale =
        "Parent members surface under bare names in `parent_members` (the renderable surface), not under `@local$X` / `@hidden$X` prefixes. `lookup_member`'s name-strip handling makes the bare match natural; `find_member_exact` would require duplicating the prefix-aware lookup. The two helpers are interchangeable here because `super`'s ObjectValue carries the post-merge member shape."
    }
  }
}

local pklObjectBodyLocalFunctionScenario = new Scenario {
  id = "PKL-148ag"
  name = "object-body local function and unknown-type diagnostic"
  description =
    "Apple Pkl lets an object body declare `local function f(...) = body` whose lexical scope covers every sibling member: `foo { local function f1(x: Int): Int = x + 1; res1 = f1(42) }` resolves `f1` to the in-body lambda. pkl-mbt's `parse_object_body_members` consumed the `local` visibility modifier but then dispatched on `at_property_decl()` / bare-expression — the leading `function` keyword (lexed as the bare identifier `function`) fell through to `parse_expr` and surfaced as `Cannot find property \\\\`function\\\\`.` at eval time. The fix adds a dedicated arm before the property-decl check: when the next significant token's text is `function`, reuse `parse_function_decl` to consume the full method shape (parameters, optional return type, body) and lower it to `ObjectMember { name = local_member_name(decl.name), value = LambdaExpr(params, body, return_type) }`. `eval_object_members` already strips the `@local$` prefix when hoisting prior members into the per-field eval env, so a sibling `f(arg)` resolves the bare name and `eval_callable_call`'s fallback path applies the FunctionValue. The same slice closes a related diagnostic gap: when a parameter / return annotation names a type that doesn't resolve to a stdlib class, user class, typealias, or in-scope type parameter, Apple Pkl emits `Cannot find type \\\\`<name>\\\\`.` — not the mismatched-value wording. A new `eval_type_name_is_unresolvable` helper runs the same `resolve → split-union → strip-constraint → strip-generic-head → strip-optional` cascade as the accept path, and the rejection-message functions short-circuit through it before crafting the value-mismatch message. +6 fixtures (`basic/localMethodInAmendingModule`, `basic/localMethodTyped`, `basic/localMethodTyped2`, `basic/localMethodTyped5`, `basic/localMethodTyped6`, `basic/localMethodUntyped`), 133 → 139; basic category 44.2% → 51.2%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148af" }
  tags { "parser"; "evaluator"; "diagnostics"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Lower object-body `local function` to a `@local$f = LambdaExpr(...)` ObjectMember instead of teaching ObjectMember to carry FunctionDecl"
      rationale =
        "ObjectMember carries an `Expr` value; FunctionDecl is its own structure (parameters / return_type / body / annotations). Adding a `MethodMember(FunctionDecl)` variant would ripple through every evaluator dispatcher that pattern-matches on ObjectMember.value. Lowering to LambdaExpr at parse time piggybacks on the existing prefix-strip logic in `eval_object_members` (`@local$f` hoists as bare `f` in the per-field env) and the existing `eval_callable_call` fallback that accepts any Identifier resolving to a FunctionValue — so the slice fits behind the parser surface with zero evaluator changes for the call-site path."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Add a dedicated `eval_type_name_is_unresolvable` helper rather than threading the resolvability check through the union-walk loop"
      rationale =
        "The union-acceptance walk and the unresolvability gate ask different questions about the same shape: the former is `any choice accepts <value>`, the latter is `every choice fails to name a known type`. Folding them would tangle the loop with two early-exit conditions and a four-way state (accepted / value-rejected / unknown / known-but-rejected). A separate helper keeps each loop single-purpose; the cost is one extra pass over the choices on the rejection path, which is cold."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Restrict the unresolvability gate to callable parameter / return paths (not class-property defaults)"
      rationale =
        "Class-property defaults already short-circuit on unknown annotations earlier in the cascade (the `if !is_stdlib_class_name(head) && !(eval_lookup_class_decl is Some(_))` guard returns None without a diagnostic). Adding the gate there would change behaviour for fixtures that currently rely on the silent skip. Only the callable rejection paths surface a value-mismatch message that needs the unknown-type wording substitution — keeping the change scoped avoids opening a second front of diagnostic churn."
    }
  }
}

local pklTypeRejectionWalksCollectionElementsScenario = new Scenario {
  id = "PKL-148af"
  name = "callable arg type rejection walks collection elements"
  description =
    "Apple Pkl's callable parameter type check walks the element type for `List<X>` / `Listing<X>` / `Set<X>` / `Map<K, V>` / `Mapping<K, V>` arguments even when the head accepts: `f3(List(\"foo\", 42))` against `x: List<String>` rejects element `42` with `\"Expected value of type \\\\`String\\\\`, but got type \\\\`Int\\\\`. Value: 42\"`. pkl-mbt's `eval_callable_argument_type_rejection_message` accepted the head (`List` matched `eval_value_accepts_type_annotation` for ListValue) and returned None — so the element-type mismatch never surfaced; only constraint-side element walks (PKL-148ae) actually fired the per-element cascade. The fix folds the element / entry walk into the type-rejection arm right after `union_accepted`: strip the resolved type's outer constraint via `pkl_constrained_type_base_name`, then try `Listing` / `List` / `Set` and `Mapping` / `Map` prefixes via `generic_argument_text`. For matching collection values, recurse into `eval_callable_argument_type_rejection_message` per element / per (key, value) entry; the first violation surfaces and the rest are silenced (Apple Pkl's fail-fast diag order). +1 fixture (`basic/localTypedModuleMember`), 132 → 133; basic category 43.0% → 44.2%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148ae" }
  tags { "evaluator"; "constraints"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Recurse through `eval_callable_argument_type_rejection_message` per element"
      rationale =
        "A separate `walk_collection_elements` helper would have duplicated the type-name normalisation cascade (typealias → union → constraint strip → generic head). Folding the walk into the existing function lets nested containers (`List<List<String>>`) flow through the same code path without ad-hoc plumbing — the recursive call lands on the inner type and the cascade re-runs from the top."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Fail-fast on first violation rather than collecting every offending element"
      rationale =
        "Apple Pkl's snippet tests capture a single diagnostic string per `test.catch(...)`; collecting all per-element diagnostics would either change the wording (multi-line) or pick an arbitrary one. First-violation matches upstream's diag ordering and keeps the cascade O(n) in the common case where a single bad element fails the check."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Walk Set elements through the List branch (no dedicated SetValue case)"
      rationale =
        "`SetValue(elements)` already shares the `Array[Value]` shape with `ListValue` / `ListingValue`; matching it in the same arm and recursing through the element type keeps the dispatch flat. A dedicated `Set<X>` arm would re-do the same per-element walk against the same inner type — no benefit, and adds another match leg to keep in sync when the inner cascade evolves."
    }
  }
}

local pklConstraintCascadeListMapOptionalScenario = new Scenario {
  id = "PKL-148ae"
  name = "constraint cascade extends to List Map Optional element walks"
  description =
    "Apple Pkl's class-method parameter / return constraint cascade walks element-level predicates for `List<X(...)>`, `Map<K(...), V(...)>`, and the inner type of `T(...)?` nullable wrappers — and the return-side diagnostic shape mirrors the parameter side without the `<call-site label> return` prefix. pkl-mbt missed four pieces that together blocked `methods/methodParameterConstraints2` (7 lines of DIFF). (1) `eval_callable_return_rejection_message` was prepending `\\\\{label} return ` to the constraint message; Apple Pkl emits the bare message (matches the parameter-side already aligned by PKL-148o). (2) `pkl_collection_element_rejection_message_from_source` only matched `Listing<X>` / `Mapping<K, V>` source names — `List<X>` and `Map<K, V>` arguments / returns fell through with no element check. The helper now strips the top-level `(<...>)` constraint via `pkl_constrained_type_base_name` and then tries `Listing`, `List`, `Mapping`, and `Map` prefixes in turn; the List branch also walks `SetValue` so the same cascade catches `Set<X(...)>`. (3) Nullable-wrapped constrained types (`String(!isEmpty)?` / `Int(isPositive)?`) had their constraint cascade silently bypassed because `pkl_constrained_type_base_name` returns None when the source ends with `?`. The cascade now strips a trailing `?` recursively (NullValue passes; non-null values dispatch through the inner type). (4) `isEmpty` / `!isEmpty` on `String` weren't in the predicate set — only `length.isEmpty` / `length.isPositive` forms were recognised. Two new variants `StringIsEmpty` / `NotStringIsEmpty` join the set with bare `isEmpty` / `!isEmpty` (also matches `this.isEmpty`) so the constraint name renders verbatim. +1 fixture (`methods/methodParameterConstraints2`), 131 → 132; methods category 60.0% → 80.0%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148ad" }
  tags { "evaluator"; "constraints"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Strip trailing `?` recursively in the constraint cascade entry"
      rationale =
        "An alternative would have been to update every callsite that builds a type name to drop the `?` before calling the cascade. That would scatter the unwrap logic across 6+ callers (callable arg / return, class property, runtime constraint, etc.) and miss future ones. Centralising the strip in `pkl_constrained_type_annotation_value_rejection_message_from_source` keeps it one rule with one NullValue short-circuit — the recursive call then dispatches through Int / Float / String / Listing / Mapping naturally."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Use `pkl_constrained_type_base_name` to strip the outer constraint before generic argument extraction"
      rationale =
        "`generic_argument_text(name, prefix)` requires `name.has_suffix(\">\")`. A source like `List<String(!isEmpty)>(!isEmpty)` ends with `)` so the function silently returned None and the element walk never fired. Stripping via the existing `pkl_constrained_type_base_name` helper produces `List<String(!isEmpty)>` which then passes the generic-argument check. The same helper is already used for the outer host predicate (`pkl_constrained_listing_rejection_message_from_source`), so the strip behaviour is consistent across the file."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Add `StringIsEmpty` / `NotStringIsEmpty` instead of folding into `StringLengthCompare(Equal, 0)`"
      rationale =
        "Apple Pkl's diagnostic wording uses `isEmpty` / `!isEmpty` verbatim — not `length == 0` / `!(length == 0)`. Reusing `StringLengthCompare` would force the diag-name renderer to special-case the threshold-zero shape, which is fragile when other length-with-0 cases (`length > 0` / `length >= 0`) shouldn't render as `isEmpty`. A dedicated predicate keeps the rendering one-to-one with the surface form."
    }
  }
}

local pklAtPrefixLocalDepImportScenario = new Scenario {
  id = "PKL-148ad"
  name = "at-prefix local dep import resolution"
  description =
    "Apple Pkl's `import \"@<dep>/<rest>\"` resolves the `<dep>` short-name through the nearest ancestor `PklProject.deps.json` file. For local-type deps (`type: \"local\"`, `path: \"../packageWithSpaces/\"`) the importer combines the PklProject directory with the entry's `path` and the import's remainder to land on a regular file. pkl-mbt's `resolve_import_path` had no `@`-prefix arm, so the loader joined `<from_dir>/@<dep>/<rest>` as if it were a relative path and the read failed with `Cannot find module`. The fix adds `resolve_at_prefix_dep` in the CLI loader: walk `from` upward looking for `PklProject.deps.json`, JSON-parse it via `@json.parse`, scan `resolvedDependencies` for an entry whose key path-tail (`package://host/<dep>@<v>` → `<dep>`) matches the import's `<dep>`, and when the entry is `local`-type combine the PklProject directory with `dep.path + rest` to produce the absolute path. The resolution is then registered in the sandbox cache (reusing the triple-dot registry from PKL-148r), and `analysis.mbt`'s resolve_import_path consults the same cache for `@`-prefix URIs so the IO-free eval-side lookup lands on the same file. Remote-type deps (`type: \"remote\"`) return None — package download (`pkl download-package` equivalent) is parked in PKL-129 and the fixture-side coverage stays None. +1 fixture (`projects/project7/spacesInImport`), 130 → 131; projects category 36.8% → 42.1%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148r" }
  tags { "loader"; "sandbox"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Reuse the triple-dot sandbox cache instead of a parallel `@`-prefix registry"
      rationale =
        "Both triple-dot (`import \".../...\"`) and at-prefix (`import \"@<dep>/...\"`) resolutions share the same shape: `(from, uri) → absolute_path` cached by the CLI loader and looked up by the analysis layer. A dedicated registry would duplicate the storage struct, the `register_*` / `lookup_*` API, and the analysis-side consult site. Reusing `register_triple_dot_resolution` / `lookup_triple_dot_resolution` keeps the cache singleton; the function names trail the original use case but the shape is generic — a follow-up rename to `register_loader_resolution` would not change behaviour."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Defer remote-type dependency handling to PKL-129 (`package://` download)"
      rationale =
        "Remote-type deps require fetching a zipball from `package://host/...`, verifying SHA-256, and unpacking it under a cache dir. That work is the PKL-129 slice (`package://` URI parse + metadata probe + zipball-URL extraction already landed in PKL-129b1; DEFLATE+SHA-256+cache loop is still parked). Returning None for `type: \"remote\"` here keeps the at-prefix loader cohesive (local deps work end-to-end) without dragging in the network / crypto surface; the existing `Cannot find module` diagnostic surfaces for remote-only fixtures (`projects/project4/main` and friends) until PKL-129 closes."
    }
    new Decision {
      date = "2026-05-18"
      summary = "JSON-parse `PklProject.deps.json` instead of hand-scanning"
      rationale =
        "The `.deps.json` shape is well-defined (`resolvedDependencies` map keyed by `package://...@<major>`). `@json.parse` is already a dependency for `pkl:json.Parser.parse`, so adding the import in `cmd/mpkl/moon.pkg` reuses the existing parser and tolerates whitespace / escapes / ordering variation. Hand-scanning a few specific keys would be fragile against Apple Pkl's future additions to the file schema."
    }
  }
}

local pklModuleLevelSuperDispatchScenario = new Scenario {
  id = "PKL-148ac"
  name = "module-level super dispatch for extends"
  description =
    "Apple Pkl's `module B extends A` rebinds `super` to the parent module's evaluated members at the module-level — so `super.X` (property access) and `super.X(...)` (method call) inside the child's bindings / hidden properties / functions dispatch through the parent's binding cache, not just through a class-scoped `@current_class` marker. pkl-mbt's `eval_super_method_call` checked `@current_class` first and bailed with `super.<m> used outside a class body` when called from module top-level; the bare `super.X` property read hit `Cannot find property \\`super\\`.` because `Identifier(\"super\")` had no env / cache entry. The fix is two-step: (1) at the start of `eval_program`, when `program.module_relation` is set, eagerly run `eval_module_relation` to materialise the parent's members and push `super = ObjectValue(parent_members)` into the cache (not env) so module-level `LambdaExpr → FunctionValue` evaluations capture it via `capture_value_bindings(env, cache)`, and so class-default evaluation (PKL-148aa) which pushes its own class-scoped `super` later still wins via the last-pushed-wins lookup. (2) `eval_super_method_call` falls back when `@current_class` is missing: look up `method_name` in the super-bound `ObjectValue` (trying both the bare and `hidden_member_name(...)` keys — module functions are stored under the hidden prefix), and when it resolves to a `FunctionValue`, hand it to `apply_function_value` with the evaluated arguments. The parent module's FunctionValues already captured the parent's env / cache when they were constructed, so `super.say(msg)` evaluates `prefix + msg` against the parent's `prefix`. +3 fixtures (`modules/supercalls2`, `modules/amendModule4`, `modules/extendModule1`); 127 → 130; modules category 61.9% → 76.2%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148ab" }
  tags { "evaluator"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Push module-level `super` into cache, not env"
      rationale =
        "PKL-148aa pushed a class-scoped `super = ObjectValue(parent_class_members)` into a fresh `defaults_cache` while evaluating class defaults. If module-level `super` lived in env, `resolve_binding_value` (which checks env first) would always return the module-level `super` and shadow the class-scoped one — regressing `classes/supercallsInLet`. Pushing into the shared cache lets PKL-148aa's later push to `defaults_cache` (a copy of cache + class super) win via last-pushed-wins lookup, while module-level functions still capture the module-level `super` via `capture_value_bindings(env, cache)` since they're built before any class-default evaluation runs."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Fallback inside `eval_super_method_call` instead of forking a new dispatch fn"
      rationale =
        "A separate `eval_super_module_method_call` would duplicate the argument-evaluation, parameter-arity, and FunctionValue dispatch logic. Folding the fallback into the `@current_class` arm keeps the diagnostic wording aligned (the existing `super.<m> used outside a class body` only fires when neither path applies) and lets future cases (e.g. module-level `super.X.Y` chains) extend a single dispatcher."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Look up under both bare and `hidden_member_name(...)` keys"
      rationale =
        "Module-level function declarations are stored under the `@hidden$` prefix (via `hidden_member_name`) so they don't render in the output; importers reach them via `lookup_member` which is hidden-aware. A `super.say(...)` lookup needs the same treatment — try the bare name first (for non-hidden bindings like `prefix`) and fall back to the hidden form for functions."
    }
  }
}

local pklClassMethodsLexicalScopeScenario = new Scenario {
  id = "PKL-148ab"
  name = "class methods bare-name resolution in class default body"
  description =
    "Apple Pkl's `class Foo { local function f() = \"original\"; x = f() }` calls `f()` bare from a property default — resolution walks the class's own lexical method set (no `this` dispatch needed, `local` modifier doesn't alter the bare-name reachability inside the declaring class). pkl-mbt parsed class methods into `ClassDecl.methods` but never injected them as Identifier-resolvable bindings, so `f()` fell through `Cannot find property \\`f\\`.`. `eval_class_default_members` now collects the class's own methods alongside the parent's recursive `base_values`, then pushes each method as a `FunctionValue` into the same `defaults_cache` it threads into `eval_object_members_with_options`. Each `FunctionValue.captured_env` references the live `defaults_cache` (no copy), so when one method calls another mutual-recursively, the lookup at call time sees every sibling pushed before the call. Lexical (not virtual) scoping: the recursive `eval_class_default_members(\"Foo1\", ...)` pushes Foo1's methods during Foo1's defaults evaluation, then back at Foo2's layer pushes Foo2's methods — so `Foo1.x = f()` always resolves to Foo1's `f` (Apple Pkl's expected behaviour), and a Foo2-defined property would resolve to Foo2's `f`. +3 fixtures (`basic/localMethodOverride1` / `localMethodOverride2` / `localMethodTyped4`), 124 → 127; basic category 39.5% → 43.0%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148aa" }
  tags { "evaluator"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Share `defaults_cache` (no copy) as each FunctionValue's captured_env"
      rationale =
        "Method A calling method B requires B to be reachable from A's captured environment. A two-pass approach — push placeholders first, then walk and replace each FunctionValue's captured_env — would need mutation through the FunctionValue tuple, which MoonBit can't express without rebuilding the value. Sharing the live `defaults_cache` array exploits that `apply_function_value`'s `copy_value_bindings(captured_env)` snapshots at call time, AFTER every method has been pushed. The snapshot then includes every sibling. The cost is a captured reference to the cache from each FunctionValue; the cache itself is scoped to this `eval_class_default_members` call so it does not outlive the class layer."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Lexical-only scoping — each class layer pushes only its own methods, not inherited ones"
      rationale =
        "Apple Pkl's `class Foo1 { local function f() = \"original\"; x = f() }` keeps `f` resolution lexical: `x = f()` defined inside Foo1's body sees Foo1's `f`, even when invoked through `new Foo2 {}.x` where Foo2 declares its own `f`. The recursive `eval_class_default_members(\"Foo1\", ...)` call (from Foo2's level) pushes Foo1's methods during Foo1's defaults evaluation, so `x = f()` lands on Foo1's `FunctionValue`. Back at Foo2's layer, only Foo2's methods are pushed — Foo2's own defaults (if any) would see Foo2's `f`. This matches Apple's local-function lexical scoping (and works for non-local class methods too: same name, same arena)."
    }
  }
}

local pklSuperPropertyInClassDefaultScenario = new Scenario {
  id = "PKL-148aa"
  name = "super property access in class default body"
  description =
    "Apple Pkl's `class D extends C { result = let (x = \"d\") super.value + x }` resolves `super.value` against the parent class C's already-evaluated property defaults. pkl-mbt only pushed a `super` binding into the cache inside `AmendExpr` evaluation (the `(target) { ... }` form) and inside `eval_class_method_call` via the `@current_class` marker for `eval_super_method_call`. Class default bodies that referenced `super.X` as a property access — not a method call — fell through to `resolve_binding_value(\"super\", ...)` which has no entry and surfaced `Cannot find property \\`super\\`.`. `eval_class_default_members` now copies the cache before evaluating the class's own defaults and pushes `{ name: \"super\", value: ObjectValue(base_values) }` when the parent contributed any members. `base_values` is the parent's recursively-evaluated default set (including the grand-parent chain), so a property read like `super.value` lands on the parent's value without disturbing the method-call path (`super.foo()` still goes through `CallExpr(MemberAccess(Identifier(\"super\"), _), _) → eval_super_method_call` and uses `@current_class`). Lambda-captured cases work too: the `let (x = \"d\") body` desugar to `CallExpr(LambdaExpr([x], body), [\"d\"])` captures the cache (which now includes `super`) via `capture_value_bindings`, so the body sees `super` even after the lambda hop. +1 fixture (`classes/supercallsInLet`), 123 → 124; classes category 52.9% → 55.9%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148y" }
  tags { "evaluator"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Push `super` only when `base_values` is non-empty"
      rationale =
        "A class with no parent (`class A {}`) has empty `base_values`, so pushing `super = ObjectValue([])` would resolve `super.X` lookups in unrelated places to `Cannot find property X in object of type Dynamic.` instead of the existing `Cannot find property super.` (the right diagnostic — `super` truly isn't bound here). The empty-base short-circuit keeps the no-parent diagnostic unchanged while wiring the meaningful case."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Use `copy_value_bindings(cache)` instead of mutating the caller's cache"
      rationale =
        "The caller's cache is reused across sibling property evaluations (and across the merge-with-base step). Mutating it in place would leak `super` into the merged ValueMember bindings for subsequent class-default evaluations of unrelated classes (the cache is threaded through `eval_object_members_with_options` and shared with caller stacks). Copying keeps the `super` binding scoped to this class's defaults; the cost is one array clone per `new <ClassWithParent>` evaluation, negligible against the existing per-property work."
    }
  }
}

local pklListingAmendGeneratorToleranceScenario = new Scenario {
  id = "PKL-148y"
  name = "listing amend body tolerates when for spread generator members"
  description =
    "Apple Pkl accepts `(listing) { when (cond) {...}; for (...) {...}; ...x; [N] = value }` — generator members (when / for / spread) inside a listing-amend body splice their payload into the running listing before subsequent `[N]` subscripts apply. pkl-mbt's `eval_listing_subscript_amend` only handled `@subscript$<offset>` sentinels and bailed with `object amendment expects Object` on anything else; `listings2/wrongIndex` exercises this exact shape (`when (false) {0}` followed by `[3] = \"barn owl\"`). The fix extends the per-member loop: when the member is `@when` / `@for` / `@spread` / `@element$<offset>`, evaluate the value and splice the resulting ListingValue / ListValue / SetValue elements onto the end of `result`; NullValue and other empty shapes contribute nothing. Subsequent `@subscript$<offset>` entries see the grown listing, so out-of-range diagnostics still surface against the post-generator length. +1 fixture (`listings2/wrongIndex`), 122 → 123; listings2 category 10.0% → 20.0%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148x" }
  tags { "evaluator"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Splice generator payloads in-order during the per-member loop instead of two-phase evaluation"
      rationale =
        "Apple Pkl's amend-time semantics evaluate generators and subscripts in source order; a `when` block earlier in the body can grow the listing so a later `[N]` lands in-bounds. A two-phase approach (run all generators first, then run all subscripts) would diverge from upstream when the same body mixes both shapes with cross-dependencies. The single-pass splice keeps `result` as the running listing and matches the source-order eval."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Silently swallow non-listing generator payloads instead of surfacing a diagnostic"
      rationale =
        "A `when (false) {0}` evaluates the false branch which produces an empty listing (or no value at all). Pushing a diagnostic for `Some(_)` payloads that aren't list-shaped would noise every fixture using `when` inside listing amend; Apple Pkl tolerates these by treating them as empty. The fix mirrors that — only `None` (genuine eval failure) propagates as a return-None."
    }
  }
}

local pklDynamicShapeViaSentinelsScenario = new Scenario {
  id = "PKL-148x"
  name = "Dynamic value shape via element and subscript sentinel members"
  description =
    "Apple Pkl's `new {}` accepts mixed-shape bodies: named properties (`name = value`), unnamed listing-style elements (bare `value`), and mapping-style entries (`[key] = value`) coexist on the same ObjectValue (Dynamic shape). pkl-mbt's ObjectValue carries only `Array[ValueMember]` (name → value), so unnamed elements were dropped at parse time (`skip_unknown_member`) and `[key] = value` couldn't be represented even after PKL-148w wired the parse side for AmendExpr. The Dynamic shape lands via sentinel member names that ride inside the existing `Array[ValueMember]` storage — no Value enum change. Parser captures bare expressions in an object body as `ObjectMember { name = \"@element$<offset>\" }` (offset disambiguates multiple unnamed entries) and `[key] = value` as `ObjectMember { name = \"@subscript$<offset>\", value = CallExpr(Identifier(\"@__index_entry\"), [key, value]) }` (the same encoding PKL-148w introduced for AmendExpr). Eval-side `eval_object_members` evaluates each sentinel and stores the result as a ValueMember keeping the sentinel name; `@subscript$` payloads decode the CallExpr and produce a synthetic `ObjectValue([@key, @value])` so the (key, value) pair survives as a Value. Renderer's `render_pcf_object_member` projects `@element$` listing-style (`render_pcf_inline` so nested Dynamic objects pick up the `new ` prefix) and `@subscript$` as `[key] = value` (or `[key] { body }` for block values). The `@spread` arm in `eval_object_members` was extended to lower ListingValue / ListValue / SetValue payloads into `@element$spread<i>` entries and MappingValue / MapValue payloads into `@subscript$spread<i>` entries, so `new { ...listing }` and `new { ...mapping }` now flatten into the parent Dynamic. `parse_inferred_new_body` routes a body whose first significant token is `...` through the object-body parser (the Dynamic shape now absorbs every payload shape, so the listing-only route is no longer needed). +2 fixtures (`generators/spreadSyntaxTyped`, `generators/forGeneratorNestedReference2`), 120 → 122; generators category 9.5% → 19.0%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148w" }
  tags { "parser"; "evaluator"; "renderer"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Implement Dynamic shape via sentinel member names rather than a new Value variant (`DynamicValue { named, elements, entries }`)"
      rationale =
        "A new Value variant would force every consumer of the Value enum (renderers across PCF / JSON / YAML / Properties / plist, equality, operator dispatch, coercion, mbti surface, ~30 sites) to handle the new shape. The sentinel-name approach piggybacks on the existing `Array[ValueMember]` storage and the established `@hidden$` / `@local$` / `@error$` / `@spread` / `@when` / `@for` / `@subscript$` family — only one site (the PCF object-member renderer) needs to learn the new prefixes; all other code paths treat sentinel-named members as ordinary entries (`visible_members` keeps them visible, equality compares by name+value). The downside is rendering-order coupling (insertion order = render order) and inability to merge / dedupe sentinel slots — both acceptable for Dynamic where order matters anyway."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Route `{ ...x }` (triple-dot prefix) through the object-body parser, not the listing-body parser"
      rationale =
        "Before PKL-148x the listing-body parser was the only spread-aware path; the object-body parser's @spread arm only accepted ObjectValue. With the Dynamic shape, the object-body @spread arm now absorbs every payload shape (Object merges, Listing / Set lower to @element$, Mapping / Map lower to @subscript$, Null silently skipped). Routing `{ ...x }` through the object body lets the spread resolve to whatever the runtime payload happens to be — fixing `spreadSyntaxTyped` (`new { ...dynamicObj }` merges members) without breaking `spreadSyntaxNullable` (`b { ...?listing }` lowers to `@element$` entries that render listing-style)."
    }
  }
}

local pklListingSubscriptAmendScenario = new Scenario {
  id = "PKL-148w"
  name = "subscript amend on Listing with out-of-range diagnostic"
  description =
    "Apple Pkl accepts `(listing) { [N] = newValue }` as a subscript-amend syntax: when N is in `[0, length)` the element is replaced, when out of range the runtime emits `Element index \\`<n>\\` is out of range \\`0\\`..\\`<upper>\\`.`. pkl-mbt's parser routed every `(target) {...}` body through `parse_object_body_members` which had no `[` arm, so the bracketed entry was silently dropped (`skip_unknown_member`) and the AmendExpr arm bailed with the generic `object amendment expects Object`. The parser now captures each `[key] = value` (and `[key] { body }`) inside an object body as `ObjectMember { name = \"@subscript$<offset>\", value = CallExpr(Identifier(\"@__index_entry\"), [key, value]) }` — a synthetic encoding that round-trips through the existing AST shapes (no new variant needed). The AmendExpr evaluator gains a `ListingValue` / `ListValue` arm that dispatches the `@subscript$*` members through `eval_listing_subscript_amend`: evaluate each key, range-check, replace the element, and surface Apple Pkl's wording on out-of-range. Members without the subscript prefix fall back to the generic diagnostic for now; mixing `[N] = ...` with `name = ...` on a Listing base is deferred until a gold fixture surfaces the need. +1 fixture (`listings/wrongIndex`), 119 → 120; listings category 18.8% → 25.0%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148v" }
  tags { "parser"; "evaluator"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Encode subscript-amend entries as `@subscript$<offset>` ObjectMembers with a `CallExpr(Identifier(\"@__index_entry\"), [key, value])` payload instead of adding a new AST variant"
      rationale =
        "Adding an `IndexEntry(key, value)` Expr variant would touch every `match expr` site (12+ across the codebase) and the `derive(Eq, Debug)` machinery. The synthetic-CallExpr encoding lives entirely inside existing AST shapes — `@subscript$<offset>` is unique enough to avoid name collisions with user properties (`@` is the same prefix family as `@hidden$` / `@local$` / `@error$` / `@spread`), and the evaluator's pattern-match on `CallExpr(Identifier(\"@__index_entry\"), args)` reads as a one-line decode. The offset suffix disambiguates multiple subscript entries inside the same body."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Drop the `Collection: <pcf>` suffix from the listing-out-of-range diagnostic so the wording matches `listings/wrongIndex` gold"
      rationale =
        "The existing `Element index N is out of range 0..M. Collection: <pcf>` form was introduced by PKL-148h's gold-match alignment for `SubscriptAccess` (`x[3]`). The amend-side path (`(x) { [3] = ... }`) uses the SAME `errorMessages.properties#elementIndexOutOfRange` template in upstream but renders WITHOUT the `Collection:` suffix — `listings/wrongIndex` gold cuts the diagnostic at the period after `\\`<upper>\\``. The subscript-amend helper emits the cut form to match gold byte-for-byte; the subscript-access path keeps the suffix it already aligned to (different gold fixture)."
    }
  }
}

local pklClassParentTypealiasResolutionScenario = new Scenario {
  id = "PKL-148v"
  name = "class parent typealias resolved through alias chain"
  description =
    "Apple Pkl walks the type-alias chain when looking up the parent class for default inheritance — `class Baz extends Bar` where `typealias Bar = Foo` resolves to `Foo`'s declarations for the default-property surface, so `new Baz {}.value` reads through to the `value: Int = 42` declared on `Foo`. pkl-mbt's `eval_class_default_members` recursed on `class_binding.parent_name` directly through `lookup_class_binding`; since `Bar` is a typealias not a class binding, the lookup returned None and `Baz` lost every inherited property. The fix is a one-spot alias resolve: when the parent_name is set, run it through `eval_resolved_type_alias` before the recursive class-default lookup. +1 fixture (`types/typeAlias2`), 118 → 119; types category 29.4% → 35.3%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148u" }
  tags { "evaluator"; "typecheck"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Resolve the typealias chain at the parent-name recursion site rather than rewriting `ClassBinding.parent_name` at collection time"
      rationale =
        "Rewriting the field at `collect_class_bindings` time would require threading the alias bindings into the collector (which currently has no access to declarations beyond the class kind), and would make the on-disk shape diverge from the source AST. Resolving in-place at the recursion site keeps the AST canonical and the alias lookup local — same pattern as PKL-148r's analysis-side resolver consult. Other consumers of `parent_name` (constraint inheritance, reflect mirror, virtual-method dispatch) keep the source spelling for now; they'll be migrated in the same shape as gold fixtures surface the need."
    }
  }
}

local pklLazyClassDefaultTypeRejectionScenario = new Scenario {
  id = "PKL-148u"
  name = "structural type rejection with lazy per-property class-default semantics"
  description =
    "Apple Pkl rejects a value whose runtime type doesn't satisfy the declared annotation independently of any constraint predicate — `res: String = 42` (or the aliased `res: Simple = 42` where `typealias Simple = String`) emits `Expected value of type \\`String\\`, but got type \\`Int\\`. Value: 42`. pkl-mbt's binding-level and class-default checks were only running the CONSTRAINT cascade (`pkl_constrained_type_annotation_value_is_valid`) which silently accepts when the source type has no predicate, so the entire `typeAlias1`-shape gold cluster fell through with `Expected an exception, but none was thrown`. The fix has two parts: (1) a new `eval_resolved_annotation_structural_rejection_message` helper that resolves type aliases, splits top-level unions (`Int|Boolean`), strips each choice's `(...)` constraint and outermost `<...>` generic head, recurses element-wise for `List<T>` / `Listing<T>` / `Set<T>` / `Map<K,V>` / `Mapping<K,V>`, and produces the rejection diagnostic using the RESOLVED type name (not the source alias). The helper only fires for stdlib type names or known user classes so partially-implemented surfaces stay silent. (2) An `eval_object_members_with_options(... defer_property_errors~)` variant that captures each class-default property's diagnostics into a per-property buffer; failures are stored as a sentinel `@error$<name>` member on the resulting ObjectValue instead of bubbling to the outer diagnostics array. The ObjectValue access path (`MemberAccess` arm in `eval_expr_with_bindings`) consults `lookup_pending_error_message` first; when a sentinel matches, it raises THAT property's diagnostic and short-circuits. The net effect: `test.catch(() -> bad.res13)` catches `res13`'s rejection; `test.catch(() -> bad.res14)` independently catches `res14`'s — even though `bad = new Bad {}` is cached after first construction. The callable-argument and binding-level diagnostics also align with Apple Pkl's wording (use resolved name, strip trailing `?` so `Nullable = Duration?` shows as `Duration`). +2 fixtures (`types/typeAlias1`, `modules/typedModuleMethods1`), 116 → 118; types category 23.5% → 29.4%, modules 57.1% → 61.9%, TOTAL 29.7% → 30.2%."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148t" }
  tags { "evaluator"; "typecheck"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Encode per-property class-default failures as `@error$<name>` sentinels instead of materialising a `ThunkValue` variant or a side-table of pending errors"
      rationale =
        "A `ThunkValue` variant would force every consumer of the `Value` enum (renderers, equality, operator dispatch, mbti surface) to handle the new shape — a multi-day refactor for a single Apple-Pkl correctness gap. A side-table keyed on `(object_id, property_name)` would need either weak references or explicit lifetime management. The sentinel-member approach lives inside the existing `Array[ValueMember]` storage, is invisible to renderers (the `@error$` prefix is already filtered out alongside `@hidden$` / `@local$` by `visible_members`), and only one access site (`MemberAccess` on `ObjectValue`) needs the `lookup_pending_error_message` consult. The downside — a phantom `name: NullValue` member when the original eval returned None — is masked by the same intercept (the sentinel wins) and doesn't leak into renders."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Apply the deferred-error encoding only inside `eval_class_default_members` (via `defer_property_errors=true`); user-body literals and module bindings keep eager rejection"
      rationale =
        "Apple Pkl's lazy class-default semantics only apply to the CLASS BODY where each property's RHS evaluates independently on access. User-body amends (`new Person { name = 42 }`) and module-level bindings (`res2: Parameterized = List(42)`) are checked eagerly upstream and surface their diagnostics at construction time. Reusing the same flag across both would erase the PKL-148i literal-rejection wording for `new Person { name = 42 }` and silently accept module-level type mismatches until next access. Keeping the lazy variant strictly to class defaults preserves all three behaviours."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Quote the RESOLVED type name (with trailing `?` stripped) in rejection diagnostics, not the source alias"
      rationale =
        "Apple Pkl's `typeMismatch` template renders the resolved type — `String` for `Simple = String`, `Int|Boolean` for `Union = Int|Boolean`, `Duration` for `Nullable = Duration?`. Quoting the source alias (our previous behaviour) made the diagnostic less informative (the user has to chase the alias chain to see what the rejected value should have been) and broke gold-match for every typealias-using fixture. The strip-trailing-`?` rule matches the gold's `Duration` vs `Duration?` distinction; the union shape is preserved as-is so `Int|Boolean` lands verbatim."
    }
  }
}

local pklTypeAliasNormalisationScenario = new Scenario {
  id = "PKL-148t"
  name = "callable return / argument type checks resolve aliases generics and unions"
  description =
    "Apple Pkl's function-parameter and function-return type checks resolve type aliases (`typealias Parameterized = List<String>`), strip the outermost generic head before the value-side acceptance check, and split top-level unions (`typealias Union = Int|Boolean`) into alternative choices. pkl-mbt's `eval_callable_return_rejection_message` was running the resolved alias through `eval_value_accepts_type_annotation` directly — `List<String>` didn't match any arm (which key on bare names like `List`), so functions declared with aliased generic return types (`function l(l: List<String(!isEmpty)>): List<String(!isEmpty)> = l`) wrongly rejected every valid return value. The argument-side check had the generic-head strip but lacked union splitting. Both sites now share the same shape: split on top-level `|` via `split_top_level_union_choices`, strip each choice's `(...)` constraint, strip its outermost `<...>` generic head, then accept if any choice matches either the builtin acceptance set or the user-class annotation cascade. PKL-148t also addresses a separate `qux = qux(...)` shadow case: when a property binding's RHS self-references the same name but a sibling module-level `function` shares it, `resolve_binding_value` now falls through to the function-shaped binding before surfacing the cycle diagnostic (the property `qux` and function `qux` live in different namespaces in Apple Pkl's lexical model). +1 fixture (`methods/methodParameterConstraints1`), 115 → 116; methods category 40% → 60%. The remaining typeAlias* fixtures stay gated on per-property lazy class instantiation (each `test.catch(() -> bad.res13)` should isolate that one property's check rather than re-evaluating all 12 properties on `new Bad {}`) — separate slice."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148s" }
  tags { "evaluator"; "typecheck"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Reuse `typecheck.mbt:split_top_level_union_choices` from the eval-side check instead of duplicating the splitter"
      rationale =
        "The typecheck layer already has a `<>`-and-`()` aware top-level `|` splitter for static union acceptance; reusing it from eval avoids two parallel implementations that could drift on edge cases like `List<Int|String>|Set<Bytes>`. The two layers live in the same package so direct call is free."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Fall through to the function-shaped sibling binding before surfacing `cyclic property reference X`"
      rationale =
        "Apple Pkl's `qux = qux(...)` form is idiomatic — function namespace and property namespace are distinct, and the RHS `qux` resolves through the function namespace first. Our `all_eval_bindings` synthesises both into one `Array[Binding]` (functions first, then properties), and `find_binding` returns the LAST match (property), causing the cyclic. The fallback only fires when (a) the currently-resolving binding is non-function, and (b) a sibling LambdaExpr-valued binding exists with the same name — both conditions keep the change scoped so a real cycle on a function-only binding still surfaces the diagnostic."
    }
  }
}

local pklSpreadMemberScenario = new Scenario {
  id = "PKL-148s"
  name = "spread members in object listing and mapping bodies"
  description =
    "Apple Pkl's `...x` / `...?x` spread member splices the payload into the surrounding body — into listing elements when the parent is a Listing, mapping entries when the parent is a Mapping, properties when the parent is an Object. pkl-mbt's body parsers were dropping the construct entirely (the `else` arm of `parse_object_body_members` / `parse_listing_body` routed the dots through `skip_unknown_member`), so any fixture using spread reported `unsupported expression`. Implemented in two halves: the parser gains `at_triple_dot` / `parse_spread_payload` helpers and a spread arm in each of the three body parsers (object body pushes `ObjectMember { name = \"@spread\" }`; listing body and mapping body wrap the payload in the existing `WhenSpread(...)` construct so the eval-side spread-flatten path already covers them). The evaluator's `eval_object_members` gains an `@spread` arm alongside the existing `@when` / `@for` sentinels (splices ObjectValue members; silently skips `NullValue`; diagnoses other shapes), and the ListingLiteral / MappingLiteral arms gain a `Some(NullValue) => ()` clause so the nullable spread `...?x` against null is a no-op (the required form `...x` against null would ideally surface a diagnostic, but treating both alike unblocks `spreadSyntaxNullable` without demanding an AST-level required-vs-optional distinction that none of the current gold fixtures exercise). +1 fixture (`generators/spreadSyntaxNullable`), 114 → 115. The deeper Dynamic-shape work (a single value variant that holds both named members and unnamed elements simultaneously, needed to flip `spreadSyntaxDynamic` / `spreadSyntaxListing` / `spreadSyntaxTyped`) stays deferred under the super-late-bind cluster."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148r" }
  tags { "parser"; "evaluator"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Encode object-body spread as a reserved-name `ObjectMember { name = \"@spread\" }` instead of adding a dedicated `SpreadMember` AST variant"
      rationale =
        "The `@when` / `@for` sentinels already use the reserved-name pattern in `eval_object_members` to splice body generators into the parent — `@spread` slots into the same dispatch with a one-arm extension and avoids an AST-wide churn that would have to land in every consumer of `ObjectMember`. The listing and mapping arms use the pre-existing `WhenSpread(...)` synthetic-entry encoding for the same reason: keep the AST stable and route through the spread-flatten paths that already work for `when` blocks."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Treat `...x` against null silently (same as `...?x`) instead of surfacing a required-vs-optional diagnostic"
      rationale =
        "Apple Pkl distinguishes `...x` (required, throws on null) from `...?x` (optional, silent skip on null), but none of the currently-gating gold fixtures exercise the required-spread-on-null path — `spreadSyntaxNullable` only uses `...?x`. Carrying the required-vs-optional bit through the AST would require either a new ObjectMember field (touches every consumer) or a separate AST variant, both more invasive than this slice's deliverable. The pragmatic uniform-silent-skip stance lands the foundation without forcing the wider refactor."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Keep the `parse_inferred_new_body` dispatch routing `{ ...x }` to listing rather than to object body"
      rationale =
        "A first attempt routed `{ ...x }` through the object-body parser so `spreadSyntaxTyped`'s `new { ...barnOwlDynamic }` could merge Dynamic members directly. That broke `spreadSyntaxNullable` whose `d { ...?c }` payload is a Listing — the object-body path can't accept ListingValue spread without a unified Dynamic value variant. Keeping the listing route preserves the +1 fixture; the typed-spread case (`spreadSyntaxTyped`) stays gated on the deferred Dynamic-shape refactor."
    }
  }
}

local pklTripleDotImportResolverScenario = new Scenario {
  id = "PKL-148r"
  name = "triple-dot import resolves through ancestor directories"
  description =
    "Apple Pkl's `import \".../X/Y.pkl\"` form searches the parent directories of the importing module to find the first ancestor that contains the remainder path. The upstream test corpus uses this prefix 51 times (e.g. `import \".../input-helper/api/annotationConverter.pkl\"` from `input/api/pcfRenderer9.pkl`), and pkl-mbt was bailing on all of them with `Cannot find module` because `resolve_import_path` only handled bare-relative paths. Implemented in two halves: the CLI loader (`cmd/mpkl/main.mbt:resolve_import_path`) walks ancestor dirs via `@fs.path_exists` and registers the resolution into a sandbox-level `(from, uri) -> resolved` map; the IO-free analysis-layer resolver (`analysis.mbt:resolve_import_path`) consults the registry to map the same `(from, uri)` pair back to the absolute path the CLI loaded under, so the cache key agrees end-to-end. Three fixtures flip: `classes/constraints14` (custom constraint pulling in a helper file), `errors/const/constLocalAmendModule` (amend chain across the `input-helper` tree), `modules/amendModule6` (`amends \".../input-helper/modules/Birds.pkl\"`). The other 22+ with-gold triple-dot fixtures still need orthogonal work — `pkl:shell`, `pkl:yaml` parser flags, jsonnet renderer, `pkl:reflect.Module.imports`, `ConvertProperty` annotation framework, package registry resolution — so the resolver itself is the foundation and the rest land as their own slices. +3 gold-match fixtures, 111 → 114."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148q" }
  tags { "cli"; "imports"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Split the resolver across CLI (FS) and analysis (registry lookup) instead of duplicating the ancestor walk in both"
      rationale =
        "The CLI loader is the only layer with FS access (the library surface deliberately stays IO-free so embedders in wasm sandboxes can depend on it). Doing the ancestor walk twice — once via `@fs.path_exists` at load time, once via the session source store at eval time — risked subtle drift if the walk order diverged. Caching the CLI's authoritative resolution into a sandbox-level `Map[String, String]` (keyed `\"<from>\\n<uri>\"`) gives the analysis layer a single, deterministic lookup that's guaranteed to agree with the path the CLI loaded the source under, without re-implementing the walk or pulling FS into the library."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Fall through to the bare uri (and the existing `Cannot find module` diagnostic) when no ancestor matches"
      rationale =
        "Returning the original `.../X` string preserves the diagnostic surface for the case where the triple-dot resolution legitimately has no answer (file genuinely absent). The alternative — synthesising a `not-found` path string — would produce noisy diagnostics like `Cannot find module \\`<concocted-prefix>/X\\``. Returning the original keeps the message readable and matches what the user typed."
    }
  }
}

local pklOutputTextByteExactScenario = new Scenario {
  id = "PKL-148q"
  name = "output.text emitted verbatim and upstream smoke diff goes bytewise"
  description =
    "Apple Pkl writes `output.text` to stdout verbatim — the string itself decides whether a trailing newline is present, so `output { text = \"some string\" }` produces exactly `some string` with no `\\n`. pkl-mbt's CLI was calling `println(text)` in the `output.text` short-circuit, which always appended `\\n` and skewed the byte count for `api/moduleOutput` (whose gold ends without `\\n`). The fix routes the text bypass through `@fs.write_string_to_file(\"/dev/stdout\", text)` — `/dev/stdout` is a kernel-provided alias for fd 1 on both macOS and Linux, so the existing `moonbitlang/x/fs` API gives us a no-newline write without adding a new dep just for one CLI slot; the `try / catch` falls back to `println` if the open ever fails on an unusual host. The smoke script's PCF diff path was simultaneously hardened: `eval_matches_gold` previously captured CLI stdout into a shell variable via `$(...)` (which strips trailing newlines) and re-emitted it through `printf '%s\\n'` (which forces exactly one trailing `\\n`), so any disagreement on the final byte was silently masked. Replacing that with `mpkl eval ... > tmpfile; diff -u gold tmpfile` makes the comparison byte-exact, which is the only shape that catches `api/moduleOutput`-style mismatches and matches the contract documented in the README (\"byte-for-byte against upstream\"). +1 gold-match fixture (`api/moduleOutput`), 110 → 111."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148p" }
  tags { "cli"; "smoke"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-18"
      summary = "Route `output.text` through `@fs.write_string_to_file(\"/dev/stdout\", text)` instead of pulling in `mizchi/x/raw_fd` or shipping a bespoke `extern \"C\" fputs` stub"
      rationale =
        "MoonBit core only exposes `%println` (always appends `\\n`); adding raw_fd or libc FFI for a single CLI slot would inflate the dep tree and require per-target plumbing (native+js+wasm). `@fs.write_string_to_file` is already a dep, works on every target we ship to, and writing to `/dev/stdout` is the canonical Unix path for fd-1 emit. The `try / catch` keeps println as a graceful fallback on hosts where `/dev/stdout` isn't available (unlikely in our supported envs, but cheap insurance)."
    }
    new Decision {
      date = "2026-05-18"
      summary = "Switch `eval_matches_gold` from `printf '%s\\n' \"$actual\"` wrapping to `mpkl eval > tmpfile; diff -u gold tmpfile`"
      rationale =
        "The shell-mediated `$(...)` + `printf '%s\\n'` shape silently normalised the CLI's trailing newline regardless of whether the gold file had one. That masked `api/moduleOutput`-shaped mismatches and meant our smoke gate wasn't enforcing the byte-for-byte contract the README advertises. A temp-file bytewise diff matches the contract; the existing PCF gold files all already terminate with `\\n` so no regressions (verified by re-running the script against the 110 prior-passing fixtures)."
    }
  }
}

local pklShebangPreambleScenario = new Scenario {
  id = "PKL-148p"
  name = "shebang preamble at module start consumed as trivia"
  description =
    "Apple Pkl tolerates a `#!...` shebang as the first line of a `.pkl` source — `pkl eval` strips it silently and parses the rest of the module, so `#!/usr/bin/env pkl eval` + `foo = 1` evaluates to the same `foo = 1` PCF as the body alone. pkl-mbt's lexer had no `#` branch, so the leading `#!` surfaced as `unsupported expression` and `syntax/shebang.pkl` failed before the body parsed. The fix is a tiny lexer-level branch in `Lexer::next_token`: when `pos == 0` and the first two bytes are `#!`, consume the line up to (not including) the next `\\n` and emit it as a `comment()` trivia token — the existing trivia handling in the parser then skips it the same way it skips a `//` line comment. The `pos == 0` guard keeps a stray `#!` later in the source from being silently swallowed (Apple Pkl only treats the preamble shebang specially). +1 gold-match fixture (`syntax/shebang`), 109 → 110."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148o" }
  tags { "lexer"; "parser"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Emit shebang as a `comment()` trivia token instead of stripping bytes from the source string"
      rationale =
        "The parser's `byte_offset` tracker increments by each consumed token's text length, so silently skipping bytes inside `tokenize` (without emitting a token) would skew every subsequent diagnostic position by the length of the shebang line. Routing the shebang through the existing `comment()` token kind preserves byte-offset accounting and reuses the trivia-skip logic that already handles `//` / `/* */`."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Guard the shebang branch on `start == 0` so a `#` later in the source stays unrecognized"
      rationale =
        "Apple Pkl only honours the shebang as the very first bytes of the module. A `#!` appearing after any other token would be a syntax error upstream — the lexer should reflect that. Without the `start == 0` guard, a stray `#!` mid-module would silently swallow the rest of its line and produce confusing downstream errors."
    }
  }
}

local pklCatchOrNullAndBareConstraintScenario = new Scenario {
  id = "PKL-148o"
  name = "catchOrNull wiring catch no-throw wording bare callable constraint diagnostic"
  description =
    "Three Apple-Pkl alignment fixes that share a code path (`pkl:test.catch` / `catchOrNull` plus the callable-parameter constraint diagnostic). (1) `module.catchOrNull(() -> ...)` / `test.catchOrNull(() -> ...)` wasn't wired into the CallExpr intercept — the snippetTest examples blocks lean on `catchOrNull(...) == null` to project Boolean throw-vs-no-throw, but pkl-mbt's eval surfaced `Cannot find property catchOrNull`. (2) `catch(fun)` on a non-throwing lambda returned the rendered value as a string instead of throwing — Apple Pkl's `TestNodes.catchMethod.eval` raises `expectedAnException` (`Expected an exception, but none was thrown.`) when the lambda exits normally. (3) The callable-parameter constraint check (`function add(n: Int(isPositive)) = n`, `class X { function int(int: Int(isPositive)) = int }`, etc.) wrapped its bare upstream message (`Type constraint isPositive violated. Value: -1`) with a `<label> argument N` prefix at all three eval entry points (`eval_lambda_application`, `apply_function_value`, class-method dispatch in `eval_member_access_call`), producing `function f argument 1 Type constraint isPositive violated. Value: -1` — Apple Pkl emits the bare form per its `errorMessages.properties#typeConstraintViolated` entry. New shared `pkl_test_catch_form_kind` predicate plus a `PklTestCatchOutcome` enum split keeps the binding-time intercept's catch / catchOrNull dispatch clean, the prefix wrapper is dropped at every eval call site (the typecheck-side wording in `typecheck.mbt` is unaffected), and four affected unit tests get their expected messages updated to the upstream-aligned bare form. No gold-match flip from this slice alone — the `basic/as*` and `methods/methodParameterConstraints2` fixtures that exercise these paths still need the broader per-element constraint deferral (`Set(...) as Set<Listing<Int>>` element access) and runtime constraint expression eval for lambdas with closures (`length > n` against a captured `n`), both deferred to PKL-148m (the super-late-bind cluster)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148n" }
  tags { "evaluator"; "diagnostics"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Drop the `<label> argument N` prefix at every eval-time callable parameter constraint call site"
      rationale =
        "Apple Pkl's runtime emits the bare `Type constraint X violated. Value: V` per the `typeConstraintViolated` template — no `function f argument 1 ...` prefix. Our four affected unit tests had encoded the wrong (prefixed) form, so passing them was not evidence the message lined up with upstream. The typecheck-side prefix in `typecheck.mbt` is a separate code path serving the static analysis surface (it carries the call-site context for IDE diagnostics, not snippetTest round-trips) — that path stays as-is. The eval-side change unblocks the constraint-emitting half of fixtures like `lambdas/typedLambdas` (res4 now matches gold), though the runtime constraint expression eval for lambdas-with-closure (res6's `length > n` against a captured `n`) is the remaining blocker for full gold-match."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Split binding-time intercept dispatch by detecting `catch` vs `catchOrNull` form, instead of branching inside the shared body"
      rationale =
        "The pre-existing binding-time intercept passed every catch-shaped expression through `eval_pkl_test_catch_binding_value`, which had to decide whether to throw or return the value on no-throw. Mixing the two into one helper would require either a Boolean knob (ugly) or hard-coding the throw branch (wrong for catchOrNull). Adding the `PklTestCatchFormKind` enum + `pkl_test_catch_form_kind` predicate keeps each helper single-purpose; the call-expr-time intercept dispatches by callee match, and the binding-time intercept dispatches by AST shape, both routing into the same shared `eval_pkl_test_catch_outcome` core that returns a tagged ThrewOutcome / NoThrowOutcome."
    }
  }
}

local pklAsCastAndLocalInListingScenario = new Scenario {
  id = "PKL-148n"
  name = "as cast accepts generic-wrapped heads and local bindings inside listing bodies"
  description =
    "Two infrastructure changes for the asAndPipeRuntime (PKL-150) work cluster, both gating the upstream `basic/as*` fixtures. (1) The `as` operator (Apple Pkl's runtime type cast) ran its acceptance check on the raw type-name string, so `Set(...) as Set<Listing<Int>>` rejected upfront with `Expected value of type `Set<Listing<Int>>`, but got type `Set`.` even though the outer Set shape was correct — Apple Pkl's runtime treats `as` as shape-preserving at the outermost head, with per-element constraint mismatches surfacing only when the inner values are read. Mirrors PKL-148l's generic-head strip (`pkl_constrained_type_base_name` then `name.find(\"<\")`) so the cast check matches Apple Pkl semantics, and also threads `value_satisfies_user_class_annotation` so `value as MyClass<T>` round-trips. (2) `local NAME = EXPR` declarations interleaved with element expressions inside a Listing body (e.g., `examples { [\"set of listing\"] { local s1 = Set(...) as Set<Listing<Int>>; s1.first[0]; module.catchOrNull(() -> s1.first) == null } }` from `basic/as3`) were silently dropped by `parse_listing_body` (the catch-all `skip_unknown_member` ate the entire declaration), so any element after a local rendered as nothing. The parser now captures each body item as either an Element or a LocalBinding and desugars the chain into nested `let` expressions wrapped by `WhenSpread` (each `local` opens a fresh CallExpr(LambdaExpr, …) whose body is the recursively-desugared remainder; the resulting ListingValue spreads back into the parent so the binding stays transparent at render time). `parse_inferred_new_body` also gained a look-ahead helper (`skip_local_decls_from`) so an inferred body that leads with `local …` is dispatched to the listing parser when subsequent items are bare expressions, instead of always picking the object-body branch. Coverage counter doesn't move on this slice alone — the affected fixtures (`basic/as`, `basic/as2`, `basic/as3`) need follow-up work on `pkl:test.catch` / `catchOrNull` (currently the non-throw branch returns the value uncasted) and on per-element constraint deferral. The PKL-152 (`anyTypeCoercion`) roadmap entry is also retired here — `Any` already accepts every runtime value via `eval_value_accepts_type_annotation`'s `(\"Any\", _) => true` arm (PKL-148e), so no separate slice is needed."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148m" }
  tags { "evaluator"; "parser"; "operator"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "`as` strips both `(...)` constraint and `<...>` generic head before the acceptance check, matching PKL-148l's callable-parameter normalisation"
      rationale =
        "`Set(...) as Set<Listing<Int>>` should accept any SetValue without iterating the elements — Apple Pkl's runtime `as` is shape-preserving at the outermost head, with inner-element checks deferred to access time. Reusing the same two-step strip (`pkl_constrained_type_base_name` then `name.find(\"<\")`) keeps the behaviour aligned across `as`, callable parameter rejection, and class-property acceptance. The surface name is preserved in the diagnostic so `Expected value of type `Set<Listing<Int>>`, but got type `Set`. Value: …` still quotes the full annotation if the head itself doesn't match."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Listing-body local bindings desugar to nested `let` chains wrapped in `WhenSpread` rather than adding a new Expr variant"
      rationale =
        "A new `LocalBindingMarker` Expr variant would touch every exhaustive `match expr` pattern across analysis / typecheck / codegen / format / lint (~13 sites). The `let (NAME = VALUE) BODY` form already desugars to `CallExpr(LambdaExpr([{NAME}], BODY, None), [VALUE])` and the listing evaluator already recognises `WhenSpread(inner)` as a flatten-into-parent marker (used by `when` blocks). Wrapping the binding chain as `WhenSpread(CallExpr(LambdaExpr(...), [value]))` reuses both existing machineries, so the parser's `build_listing_body` is the only new code — every downstream consumer treats the produced AST as normal."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Retire the PKL-152 (`anyTypeCoercion`) scenario without a dedicated slice"
      rationale =
        "The roadmap entry described a one-arm fix in `eval_value_accepts_type_annotation` to make `Any` accept every runtime value, citing `methods/methodParameterTypes2` as the unblocked fixture. Both are already in: PKL-148e's `(\"Any\", _) => true` arm covers the runtime side, and `methods/methodParameterTypes2` already gold-matches without change. Carrying the draft forward would just churn the roadmap."
    }
  }
}

local pklLocalDeclModifierScenario = new Scenario {
  id = "PKL-148m"
  name = "local modifier on class / function / typealias declarations"
  description =
    "A `local` modifier in front of a `class`, `function`, or `typealias` declaration was silently dropped at parse time — the whole member routed through `skip_unknown_member`, so `local class C { ... }` / `local function f(...): ... = ...` / `local typealias T = Int(this > N)` never reached the declaration list. The downstream symptom was either `Cannot find property ...` on a later reference (`local function` / `local typealias` resolved to nothing) or a stamped-empty ObjectValue (`local class C` was unknown so `new C {}` couldn't pick up the defaults), AND silently bypassing a typealias's runtime constraint (`x: T = 5` against `local typealias T = Int(this > 100)` rendered `x = 5` instead of raising). Apple Pkl treats `local` here as a scope modifier — the declaration exists inside the module but is not exported when another module imports it; for pkl-mbt's primary single-module driver path the export-suppression aspect is a separate concern, so this slice records the declaration unchanged (parses the `local` token, then dispatches to the appropriate `parse_class_decl` / `parse_function_decl` / `parse_typealias_decl` exactly as the bare form would). Unblocks `types/typeAliasConstraint1` (`local typealias OneCharacterString = String(length == 1)` paired with a `local class ClassWithLengthProperty` whose default `characters: List<OneCharacterString> = List(\"a\", \"b\")` couldn't be reached), plus a fan of fixtures that lean on `local function` declarations or `local class` defaults. Lifts gold-match from 103 to 109 PCF (`basic/localMethodTyped3`, `basic/localModuleMemberOverride1`, `modules/amendModule5`, `types/typeAliasConstraint1`, `implementation/equality`, `implementation/inequality`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148l" }
  tags { "parser"; "evaluator"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "`local class` / `local function` / `local typealias` parse as their non-local counterparts; export suppression is deferred"
      rationale =
        "Apple Pkl uses `local` here purely as a visibility modifier (the declaration is invisible to importers but still resolvable in-module). pkl-mbt's primary driver path is single-module evaluation, so registering the declaration without tracking the export flag is enough to make every in-module reference resolve correctly and every typealias constraint fire. The alternative — wiring a `is_local: Bool` field through ClassDecl / FunctionDecl / TypeAliasDecl and every consumer — costs ~70 construction-site touches for a behavior (cross-module export filtering) that no current gold fixture exercises. When a cross-module fixture lands that actually depends on the export side, we add the flag then."
    }
  }
}

local pklCallableParamTypeRejectionScenario = new Scenario {
  id = "PKL-148l"
  name = "Callable parameter basic-type rejection fires before body evaluation"
  description =
    "Apple Pkl rejects a function/method call whose argument doesn't satisfy the parameter's basic type annotation before the body runs, with the bare diagnostic `Expected value of type `<T>`, but got type `<U>`. Value: <pcf>` — the same wording the return-side annotation already uses. pkl-mbt only ran a constraint-shaped check (`Int(isBetween(0, 10))`) on parameters, so a basic-type mismatch like `x.sum(1.1, 2)` against `sum(a: Int, b: Int): Int = a + b` slipped past the parameter gate and only failed inside the body (sometimes returning a Float, sometimes bubbling `operator + expects Int operands`). A new `eval_callable_argument_type_rejection_message` mirrors the return-side acceptance pipeline (resolve type alias → strip the trailing `(...)` constraint → strip any `<...>` generic suffix → fall through `eval_value_accepts_type_annotation` + `value_satisfies_user_class_annotation`) and emits the bare message (no `<label> argument N` prefix, matching Apple Pkl's exact wording). The check runs at all three callable entry points — `eval_lambda_application`, `apply_function_value`, and the class-method dispatch in `eval_member_access_call` — before the existing constraint check, so the constraint cascade still wraps with `<label> argument N <message>` while the basic-type rejection projects the wording byte-for-byte. Generic-head stripping is necessary so `List<Set<String(this==\"one\")>(thisisSet)>(thisisList)`-shaped annotations from `types/ThisInTypeConstraint` collapse to `List` and accept the `ListValue` argument without false-positive. Lifts gold-match from 102 to 103 PCF (`methods/methodParameterTypes1`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148k" }
  tags { "evaluator"; "typecheck"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Basic-type parameter check emits the bare Apple Pkl wording with no `<label> argument N` prefix"
      rationale =
        "The constraint-check call sites already wrap their message with `<label> argument N <message>` (`method add argument 1 Type constraint `isBetween(0, 10)` violated. Value: 11`), which matches how Apple Pkl prefixes constraint failures. Basic-type rejection however lands on the *same* wording as the return-side annotation rejection (`Expected value of type `Int`, but got type `Float`. Value: 1.1`) with no prefix at all — `test.catch(() -> x.sum(1.1, 2))` round-trips it through as a bare string. Keeping the two helpers separate (`_type_` vs the existing constraint helper) means each call site emits the right prefix shape without the wrapping logic having to inspect the message form."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Strip both trailing constraint `(...)` and generic `<...>` from the annotation head before the acceptance check"
      rationale =
        "`pkl_constrained_type_base_name` only strips the constraint paren suffix, so `List<Set<...>>(thisisList)` collapses to `List<Set<...>>` — which `eval_value_accepts_type_annotation` doesn't recognize, false-positive-rejecting valid `ListValue` arguments in `types/ThisInTypeConstraint`. The existing default-synthesizer at `synthesize_default_for_type` already uses `name.find(\"<\")` to strip the generic suffix; this helper mirrors that pattern. The original `source` is preserved for the diagnostic so the user sees the full annotation in `Expected value of type `<source>`, …`, while the acceptance check runs against the bare head — matching Apple Pkl's runtime, which only looks at the outermost type."
    }
  }
}

local pklMappingDupKeyAndPipeDiagnosticScenario = new Scenario {
  id = "PKL-148k"
  name = "Mapping literal duplicate scalar key detection and pipe operator diagnostic"
  description =
    "Two tiny Apple-Pkl-shaped diagnostics that travel through `test.catch(...)` and project the failure as a String. `new Mapping { [\"barn owl\"] = 1; [\"bar\" + \"n owl\"] = 3 }` must reject with `Duplicate definition of member `\"barn owl\"`.` even though the two key expressions are different string-concat compositions: the check fires at MappingLiteral eval time, after each key is resolved, and quotes the first colliding key through `render_pcf_value_inline`. The check is restricted to scalar key shapes (String / Int / Float / Bool / Null / Duration / DataSize / Regex / Bytes) — composite-key equality (ObjectValue / ListingValue / MappingValue) collapses without class identity, so the same gate would false-positive on `mappings/mapping1`'s `[new Dynamic {...}]` / `[new Person {...}]` keys that share identical visible members. The composite-key case lands alongside the class-aware ObjectValue refactor (PKL-148l). Pipe-operator (`|>`) projects the dedicated Apple Pkl diagnostic when the RHS isn't callable (`module.catch(() -> 42 |> 21)` → `Operator `|>` is not defined for operand types `Int` and `Int`. Left operand : 42 Right operand: 21`) instead of bubbling the desugared `CallExpr`'s generic `call expects Function`; the right operand is evaluated first so the diagnostic captures the actual runtime type / inline-PCF render. Lifts gold-match from 100 to 102 PCF (`mappings/duplicateComputedKey`, `mappings2/duplicateComputedKey`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148j" }
  tags { "evaluator"; "diagnostics"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Mapping duplicate-key check is gated on scalar key shapes"
      rationale =
        "A naive `existing.key == k` check against every key would false-positive on `mappings/mapping1`'s composite keys (`[new Dynamic { name = \"Pigeon\"; age = 42 }]` and `[new Person { name = \"Pigeon\"; age = 42 }]` are different in Apple Pkl because the class identity differs, but both project to identical structural ObjectValue today). Restricting the duplicate check to scalar primitives keeps `mappings/duplicateComputedKey` working while leaving the composite case deferred until ObjectValue gains a class tag (PKL-148l)."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Pipe operator evaluates the RHS before the LHS to capture the non-callable diagnostic"
      rationale =
        "`x |> f` previously desugared straight into `CallExpr(f, [x])`, so the non-callable failure surfaced as the generic `call expects Function` and lost the pipe-operator context that `test.catch(() -> 42 |> 21)` round-trips into a string. Evaluating the RHS first, checking for `FunctionValue`, and routing the call through `CallExpr` only on a match preserves the existing fast path while letting the non-callable branch emit Apple Pkl's full `Operator `|>` is not defined for operand types `Int` and `Int`. Left operand : 42 Right operand: 21` (renders both operands inline through `render_pcf_value_inline`)."
    }
  }
}

local pklLocalMemberVisibilityScenario = new Scenario {
  id = "PKL-148j"
  name = "local and hidden member visibility split with Collection default"
  description =
    "External member access on an ObjectValue must hide `local` declarations (Apple Pkl's `foo.x` where `foo` declares `local x = 2` raises `Cannot find property `x` in object of type `Dynamic`.`) while still resolving `hidden`-modifier properties (`new Box { value = 42 }.marker` returns the hidden default). pkl-mbt previously collapsed both modifiers onto the single `@hidden$` storage prefix, so the visibility distinction was lost — `lookup_member` resolved both forms, and any `lookup_visible_member` filter would either expose locals or hide hidden properties. This slice splits the prefix: `local` declarations are stored under a dedicated `@local$` marker, `hidden` keeps `@hidden$`; `lookup_visible_member` filters only `@local$`, so external `.X` access correctly rejects locals while passing hidden through. A combined `is_invisible_member_name` predicate (either prefix) drives every renderer / analysis / typecheck filter so locals still stay out of PCF output. `strip_member_visibility_prefix` projects either prefix back to the bare name for binding-cache seeding and sibling-env hoisting (handles both 8-char `@hidden$` and 7-char `@local$` lengths). Module-level function declarations are still stored under `@hidden$` and remain reachable via `Base.func` — the external access falls back to a `FunctionValue`-only `lookup_member` after `lookup_visible_member` misses, matching Apple Pkl's cross-module function-export semantics. The Apple Pkl diagnostic wording (`in object of type `Dynamic`.`) replaces the bare `Cannot find property `X`.` form for ObjectValue member-access failures. Also fills the auto-default for `Collection<T>` / `List<T>` typed properties (Apple Pkl renders both as `List()`; the helper had Listing / Mapping / Set / Map but missed those two). Lifts gold-match from 96 to 98 PCF (`basic/localProperty2`, `basic/propertyDefaults`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148i" }
  tags { "evaluator"; "parser"; "renderer"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Two storage prefixes — `@hidden$` for `hidden`, `@local$` for `local`"
      rationale =
        "Apple Pkl's `hidden` and `local` modifiers behave differently for external member access: `hidden` keeps the property reachable via `.X` (it just hides from rendering), `local` blocks external access entirely. A single prefix can't encode that distinction without an extra side-table; splitting into two prefixes keeps the existing `lookup_member` / renderer call sites' shape (still string-prefix checks) and lets `lookup_visible_member` filter only `@local$`. The cost is updating every renderer-filter site from `is_hidden_member_name` to `is_invisible_member_name` (combined predicate); the alternative — adding a `local: Bool` field to `ValueMember` — would have touched 70+ struct-construction sites instead."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Module-level function export still resolves via FunctionValue-only fallback"
      rationale =
        "`function f(...) = ...` at module scope is stamped as `@hidden$f` so `Base.f(...)` works across import boundaries while `f` stays out of the rendered envelope. After `lookup_visible_member` misses, a follow-up `lookup_member` resolves the hidden slot only when it's a `FunctionValue` — keeps cross-module function access working without exposing arbitrary `hidden`-tagged scalars under a different visibility contract."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Collection / List auto-default routes to ListValue"
      rationale =
        "Apple Pkl renders both `coll: Collection<Person>` (no initializer) and `list: List<Person>` as `List()`. The `synthesize_default_for_type` helper covered Listing / Mapping / Set / Map but had no arm for Collection or List, so `basic/propertyDefaults` dropped the `coll` and `list` lines entirely. Adding both arms (route to `ListValue([])`) matches the gold and keeps the dedicated `ListValue` variant introduced in PKL-148h consistent across construction + default paths."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Amend merge uses strict storage-name matching to keep local and visible namespaces independent"
      rationale =
        "`merge_value_members` previously called `lookup_member` to find an amend body's override against the base — that lookup accepts either the bare or prefixed form, so `local l` in a base and visible `l` in an amend body collided on the same slot. Apple Pkl treats them as different namespaces: `(foo3) { l = \"override\" }` where `foo3` declares `local l = \"original\"` keeps the local at its old value AND adds a fresh visible `l` member. `find_member_exact` resolves only the literal storage name; using it in both merge passes keeps `@local$l` and bare `l` as independent slots, unblocking `basic/localPropertyOverride1` / `localPropertyOverride2`."
    }
  }
}

local pklAmendTimeLiteralTypeRejectionScenario = new Scenario {
  id = "PKL-148i"
  name = "literal-valued class property assignments enforce declared type"
  description =
    "Apple Pkl rejects `new Person { name = 42 }` with `Expected value of type `String`, but got type `Int`. Value: 42` when `Person.name: String`. pkl-mbt's TypedObjectLiteral loop only ran predicate-style constraint checks (`Int(x > 0)` and friends) — bare type annotations silently kept the wrong-shape value. This slice adds `eval_class_property_type_rejection_message` which resolves the declared annotation through type aliases, normalises generic heads (`Listing<X>` → `Listing`, `Mapping<K,V>` → `Mapping`, etc.), and emits Apple Pkl's exact diagnostic text when neither `eval_value_accepts_type_annotation` nor `value_satisfies_user_class_annotation` matches. The check fires only for literal-valued AST nodes (`IntLiteral`, `FloatLiteral`, `StringLiteral`, `BoolLiteral`, `NullLiteral`); free-form expression bodies are deferred until the upstream forward-binding leak (locals from a sibling object literal can resolve into a later body's identifier lookups, e.g. `a8`'s `local x = 1` reaching `c7`'s `age = x`) is fixed separately. `eval_class_property_annotation_with_depth` now walks the parent chain when a subclass declares the property without its own annotation (Person3 → Person.name), so `class Person3 extends Person { name = \"Pigeon\" }` still inherits the parent's `String` annotation for the rejection. Lifts gold-match from 82 to 96 PCF: 1 fixture (`classes/wrongType5`) is unblocked by the new check; 13 (`errors/baseModule`, `listings2/listing1`, `mappings2/mapping1`, `parser/constraintsTrailingComma`, `parser/trailingCommas`, the `projects/` cluster — `badLocalProject/dog`, `notAProject/@child/theChild`, `notAProject/goodImport`, `packageWithSpaces/module with spaces`, `project6/children/{a,b,c}` — and `types/helpers/someModule`) ride along as free promotions surfaced by the same exhaustive probe pass."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148h" }
  tags { "evaluator"; "typechecker"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Type check restricted to literal value expressions, not free-form bodies"
      rationale =
        "Running the bare-type check across every property-assignment exposed a pre-existing forward-binding leak: `a8 = new Dynamic { foo = x; local x = 1 }` populates `x = 1` in a way that re-resolves inside a later sibling like `c7 = new Person { age = x; local x = 40; street = y; local y = \"X\" }`. The rendered output already silently records `age = 1` (wrong), but the gold-match for `objects/equality` does not pivot on that property so the regression was invisible. Adding the type-check then surfaced the leak as `Expected value of type \\`String\\`, but got type \\`Int\\`. Value: 1` on `street`, breaking 32 lines of `objects/equality` output. Gating the check on `IntLiteral` / `FloatLiteral` / `StringLiteral` / `BoolLiteral` / `NullLiteral` keeps the wrongType5-style assignments rejecting while leaving the leak's behavioural surface unchanged. The free-form expression case lands once the leak itself is fixed."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Subclass without explicit annotation inherits the parent's annotation"
      rationale =
        "`eval_class_property_annotation_with_depth` previously stopped at the first matching property declaration even when its `type_name` was `None` (e.g. `class Person3 extends Person { name = \"Pigeon\" }` where Person declares `name: String`). That short-circuit dropped the inherited annotation, so amend overrides like `new Person3 { name = 42 }` skipped the rejection. Walking the parent chain when the local declaration's annotation is `None` matches Apple Pkl's semantics for `wrongType5` res3 without changing any other path's behaviour."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Class-aware ObjectValue tagging via hidden marker is the wrong shape — defer to ObjectValue enum refactor"
      rationale =
        "A prototype of this slice stamped a hidden `__class = StringValue(class_name)` member onto each TypedObjectLiteral so AmendExpr could re-fire the host class's constraints downstream (covering `constraints11/12` res4-6's `(res3) { y = 0 }` against `Int(this > x)`). The marker broke 14 structural-equality unit tests that asserted exact `ObjectValue([...])` shape — the additional member changes the array. The right fix is a dedicated `ObjectValue(class_name: String?, members: Array[ValueMember])` variant change (~418 call sites), tracked in PKL-148j."
    }
  }
}

local pklListValueSplitScenario = new Scenario {
  id = "PKL-148h"
  name = "ListValue split from ListingValue for List constructor PCF round-trip"
  description =
    "Apple Pkl distinguishes `List<T>` (immutable indexed collection, constructor `List(...)`, PCF `List(elem, ...)`) from `Listing<T>` (CST-typed builder, `new Listing { ... }`, PCF `new { elem; ... }` block). pkl-mbt previously collapsed both into `ListingValue`, which meant `List(1, 2, 3)` rendered as `new { 1; 2; 3 }` — silent rendering divergence on every fixture that uses `List`. This slice splits the variant: `List(...)` and `.toList()` now produce a dedicated `ListValue(Array[Value])` that renders through `render_pcf_scalar` as `List(elem, ...)`; `.toListing()` and the existing `new Listing { ... }` literal path stay on `ListingValue`. Listing-method dispatch (`.filter`, `.map`, `.length`, `.startsWith`, `.flatMap`, `.toSet`, subscript, `+`) accepts both variants via pattern alternation — the dispatcher's element-walking logic is identical. The Apple-Pkl `module.catch(() -> list[i])` diagnostic text is also brought into shape (`Element index `i` is out of range `0`..`N`. Collection: List(...)`) so out-of-bounds string projections round-trip. Lifts gold-match from 72 to 82 PCF (`api/pair`, `basic/list`, `classes/inheritance1`, `classes/inheritance2`, `listings/listing1`, `mappings/mapping1`, `methods/methodParameterTypes2`, `modules/lists`, `modules/typedModuleProperties1`, `types/ThisInTypeConstraint`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148g" }
  tags { "evaluator"; "renderer"; "stdlib"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "ListValue variant carries the List(...) constructor form distinct from Listing"
      rationale =
        "Collapsing List and Listing into one variant forced the PCF renderer to pick a single shape — `new { ... }` was the previous default, which silently broke every `List(...)` literal's gold output. A dedicated `ListValue(Array[Value])` variant lets `render_pcf_scalar` emit `List(elem, ...)` (parallel to `Set(...)` and `Map(...)`) while keeping `ListingValue` on the block form. MoonBit's derived `==` now also distinguishes the two at runtime, matching Apple Pkl's `List != Listing` semantics."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Method dispatch shares the element-walking surface across List / Listing"
      rationale =
        "Apple Pkl's `.filter` / `.map` / `.length` / `.startsWith` / `.flatMap` work on both List and Listing — the element-walking logic is the same; only the receiver's type tag differs. Routing both `ListingValue(es)` and `ListValue(es)` into `eval_listing_method` via pattern alternation avoids duplicating the dispatcher. `.toList()` tags as `ListValue`, `.toListing()` as `ListingValue`; the receiver-variant-preserving thread for `.map` / `.filter` results stays out of scope for this slice (currently both project as `ListingValue` regardless of receiver, deferred until the upstream fixtures that exercise the distinction land)."
    }
    new Decision {
      date = "2026-05-17"
      summary = "`List + List` / `List + Set` preserves the List variant; `Set + List` widens to Set"
      rationale =
        "Apple Pkl's `Collection + Collection` dispatch is left-biased: the LHS variant decides the result shape. `List + List` appends and stays a `ListValue`, `List + Set` appends with no dedup (still a List), `Set + List` unions and stays a Set, `List + Listing` widens to Listing (left-side asymmetric — matches upstream's `Listing` super-type position in the join lattice). Eight dispatch arms cover the cross-product."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Subscript out-of-bounds diagnostic uses Apple Pkl's `Element index ... is out of range ... Collection: ...` wording"
      rationale =
        "`module.catch(() -> list[-1])` projects the runtime error as a String. Apple Pkl's wording embeds the rendered receiver inside the message (`Collection: List(1, \"two\", 3)`). Rendering the receiver through `render_pcf_value_inline` and templating the index range gives byte-exact gold match for the `basic/list` `subscript` block; the same template fires for Listing receivers (the tag inside the message follows the receiver's PCF render)."
    }
  }
}

local pklLambdaIdentityAndVirtualDispatchScenario = new Scenario {
  id = "PKL-148g"
  name = "lambda identity equality virtual method dispatch and this.X access"
  description =
    "Closes the next batch of upstream silent-mismatch fixtures. FunctionValue carries an identity stamp (fresh `Int` id generated when a `LambdaExpr` is evaluated or a function declaration is loaded) so structural-only payloads no longer collide under MoonBit's derived `==` — Apple Pkl's identity-based lambda equality (`(() -> 1) == (() -> 1)` is false; `local f = ...; f == f` is true) now round-trips. Sibling class methods are seeded parent-first so the derived class's same-named override wins under `lookup_value`'s last-match rule, fixing virtual dispatch when a method body references another method that's overridden in the subclass. Module-level `local const x = ...` (and any `local <modifier>* x` combination) is parsed as a hidden binding; the modifier keywords were previously stealing the slot for the binding name and the actual identifier was being parsed as a separate property. `this.X` inside an object body short-circuits to `resolve_binding_value` when `X` is in the implicit-receiver scope (siblings / enclosing bindings), letting `bar = this.baz + 1` and `super.X`-free fixtures resolve their cross-references; value-derived properties (`this.abs` on an Int receiver, used by `Int(abs < 100)` after the constraint runtime's implicit-this rewrite) still flow through the standard MemberAccess path. Lifts gold-match from 67 to 72 PCF (`classes/functions1`, `classes/functions4`, `lambdas/equality`, `lambdas/inequality`, `objects/this1`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148f" }
  tags { "evaluator"; "equality"; "dispatch"; "scope"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "FunctionValue carries a fresh identity stamp per LambdaExpr evaluation"
      rationale =
        "Apple Pkl's `==` on functions is identity-based: two distinct lambda literals never equate, but the same bound lambda equates with itself. MoonBit's derived `derive(Eq)` would equate `(() -> 1)` and `(() -> 1)` structurally. Adding an `Int` id to the FunctionValue payload (fresh-counter on LambdaExpr / function-decl evaluation, preserved when re-wrapping via `.apply` / `.applyToList` / `.getClass`) gives identity without re-implementing the equality dispatcher — the derived `Eq` now compares structure plus id."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Sibling class method seeding walks parent → derived so overrides win"
      rationale =
        "`lookup_value` returns the last-match in the binding cache. The previous push order (derived first, then parent) inverted the priority: a class method override in the subclass was shadowed by the parent's same-named method. Collecting the inheritance chain bottom-up and pushing parent → derived restores virtual dispatch — derived `Y.a` lands after parent `X.a` in the cache and wins the lookup."
    }
    new Decision {
      date = "2026-05-17"
      summary = "`local <modifier>* name` consumes optional modifiers after `local`"
      rationale =
        "`parse_local_decl` consumed `local` then expected an identifier name; for `local const x = ...` the next identifier was `const` (a soft keyword), so the binding name became `const` and `x = 1` was parsed as a separate property. Apple Pkl accepts any combination of `local` plus a modifier keyword (`const`, `hidden`, `fixed`, `open`, `external`, `abstract`); swallowing them between `local` and the name fixes the property-name capture for the common `local const` form."
    }
    new Decision {
      date = "2026-05-17"
      summary = "`this.X` short-circuits to sibling-binding lookup only when X is in scope"
      rationale =
        "`this` is the implicit receiver of an object body — `bar = this.baz + 1` should resolve `baz` the same as bare `baz`. Routing `MemberAccess(Identifier(\"this\"), X)` to `resolve_binding_value` mirrors the existing `module.X` shortcut. But the runtime constraint helper rewrites bare `abs` inside `Int(abs < 100)` as `this.abs`, and `abs` isn't a binding — it's a property on the Int receiver. Gating the shortcut on `X is in bindings / env / cache` keeps both forms working: `this.sibling_prop` hits the lazy resolver, `this.abs` falls through to the standard MemberAccess dispatch."
    }
  }
}

local pklUnorderedEqualityAndTypedDefaultsScenario = new Scenario {
  id = "PKL-148f"
  name = "unordered equality plus typed-property default synthesis"
  description =
    "Tightens upstream equality and unblocks the typed-default fixture cluster. SetValue equality now compares as a multiset (was order-sensitive via derived `==`), ObjectValue equality compares by visible-member content ignoring property order and hidden members, and MapValue / MappingValue follow the same bag-of-entries pattern — `Set(1, \"two\", 3) == Set(\"two\", 3, 1)` and `{foo=1; bar=2} == {bar=2; foo=1}` now round-trip. IntSeq equality no longer materialises the entire range (`IntSeq(math.minInt, math.maxInt)` was OOM-ing on the materialise path); length is computed in Int64 to survive the full 32-bit span. The no-arg property surface on String / Int / Float / Listing also accepts the method-call form (`str.reverse()`, `n.abs()`, `x.isNaN()`, `list.toSet()`) since Apple Pkl exposes both shapes; Float gains its own `eval_float_property` for `abs` / `isPositive` / `isNonZero` / `isFinite` / `isNaN` / `isInfinite` / `sign`. Module-level `hidden h = ...` is now resolvable by bare name through `find_binding`'s hidden-prefix-aware lookup. Typed properties declared without `=` synthesise a type-directed default — user classes project to `new T {}` with class defaults applied, nullable types and `Null` project to `null`, string-literal types project to the literal, `Listing` / `Mapping` / `Set` / `Map` default to their empty form, and `*A|B` picks the starred branch. `extends \"parent.pkl\"` now exposes the parent module's class declarations to the child by bare name, and the analysis-side import resolver follows the extends chain so a downstream importer sees inherited classes too. Lifts gold-match from 60 to 67 PCF (`basic/intseq`, `basic/set`, `basic/typeResolution1`, `basic/typeResolution2`, `basic/typeResolution3`, `basic/typeResolution4`, `objects/closure`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148e" }
  tags { "evaluator"; "equality"; "scope"; "defaults"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Set / Object / Map equality dispatch through dedicated comparators"
      rationale =
        "MoonBit's derived `derive(Eq)` compares variant payloads positionally — for `SetValue(Array[Value])`, `ObjectValue(Array[ValueMember])`, and `MapValue(Array[ValueEntry])` that means insertion order leaks into equality, which contradicts Apple Pkl's set/object/map semantics. Dispatching `==`/`!=` on those variant pairs through `set_values_equal` / `object_values_equal` / `map_entries_equal` before the generic Equal/NotEqual arm keeps the derived `Eq` available for the other variants while fixing the surface behaviour. Hidden / `local` members are filtered out of the object compare so a body with `local _x = 1` matches the same body without it."
    }
    new Decision {
      date = "2026-05-17"
      summary = "IntSeq equality computed via Int64 length, not materialisation"
      rationale =
        "The old `intseq_value_equal` allocated both element arrays — `IntSeq(math.minInt, math.maxInt)` blew up the array-resize. Two arithmetic progressions are equal iff their lengths match and (when len >= 1) their starts match and (when len >= 2) their steps match. Computing length in Int64 sidesteps the 32-bit `MAX_INT - MIN_INT` overflow that briefly made the asymmetric case (`IntSeq(MIN, MAX) == IntSeq(MAX, MIN)`) come out true."
    }
    new Decision {
      date = "2026-05-17"
      summary = "No-arg property surface accepts the method-call form on String / Int / Float / Listing"
      rationale =
        "Apple Pkl projects `String.length`, `Int.abs`, `Float.isPositive`, `Listing.toSet` as both property reads (`str.reverse`) and zero-arg method calls (`str.reverse()`); the only difference is the trailing `()`. The method dispatchers used to reject the `()` form with `call expects Function`. Adding the same name set to each `is_*_method_name` predicate and routing them back to the property evaluator from the method dispatch keeps both shapes consistent without duplicating the property logic. `Float.isPositive` etc. previously had no `eval_float_property` at all — adding one parallels `eval_int_property` and unifies the Float dispatcher."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Typed-property defaults synthesised on `abstract_slot` bindings; extends imports class scope"
      rationale =
        "Apple Pkl materialises a type-directed default when a property has a type but no `=` (`p: Person` becomes `new Person {}` with class defaults applied). The PKL-140 abstract-slot path used to skip these bindings — fine for stdlib `external` props, but it dropped every snippetTest fixture's typed-only declarations. `synthesize_default_for_type` handles nullable / string-literal / structural-collection / starred-union / user-class cases; non-resolvable types still get skipped so genuinely abstract slots stay abstract. For `extends`, the parent's classes need to be in scope by bare name in the child (it's inheritance, not a namespaced import), and a downstream importer of the child also needs to see the inherited classes — the analysis-side resolver follows the extends chain when collecting class exports."
    }
  }
}

local pklForwardRefSuperAndApplyScenario = new Scenario {
  id = "PKL-148e"
  name = "object body forward refs amend super and Function apply surface"
  description =
    "Closes the next batch of upstream silent-mismatch fixtures. Object bodies now register every sibling member as a binding before evaluating any RHS, so `parent { x = 1 + y; y = 2 }` resolves `y` through the lazy `resolve_binding_value` path — cycle detection still uses the existing `stack` guard. Amend bodies expose `super` as the pre-amend ObjectValue, unlocking `(parent) { x = super.x + 100 }` for the simple-parent case (full Apple-Pkl super recursion against re-evaluated parents lands later). The `Function` value surface gains `.apply(args...)`, `.applyToList(list)`, `.toString()` / `.getClass()` plus the `(lambda).apply()` form, by intercepting MemberAccess(target, methodName) in `eval_callable_call` before the catch-all object-only lookup. Stdlib type identifiers (`Int`, `Float`, `String`, `Listing`, `Set`, `Map`, `Pair`, `IntSeq`, `Function`, etc.) project to a Class mirror just like user-declared classes, so `Int == Int`, `Int == 3.getClass()`, `Int != Float` round-trip. Bodyless `class Foo` is no longer eaten by the `skip_unknown_member` fallback that previously merged the following declaration into the current class node. `local` modifier on a class property now hoists via the hidden prefix and `push_receiver_method_bindings` strips it when seeding the method cache; sibling class methods are pushed as FunctionValues so `function compute() = b(c)` resolves `b` and `c` from the enclosing class. `let (x: Int = 42) body`'s typed binder threads through `parse_let_expr` already (no change required); the parser fix lands at `local name { body }` (was unsupported) and `.` immediately followed by a digit (leading-dot Float, used by `{1.2;.3;.4;.5}`). Heredoc dedent strips the newline immediately preceding the closing delimiter's indent line so `\"\"\"\\\\n hello\\\\n\"\"\"` reads as `\"hello\"` rather than `\"hello\\\\n\"`. The runtime type-acceptance widens: `Any` accepts every value (was rejecting), `List` / `Collection` accept ListingValue, `Set` accepts SetValue or ListingValue (until PKL-151's split), `Pair` / `IntSeq` route to their dedicated variants, and a user-declared class type accepts any ObjectValue (Apple Pkl checks the dynamic class on the instance; pkl-mbt's ObjectValue erases it). Lifts gold-match from 50 to 60 PCF (`api/moduleOutput`, `basic/identifier`, `basic/objectMember`, `classes/equality`, `classes/functions3`, `lambdas/lambda1`, `lambdas/lambda2`, `lambdas/lambda5`, `objects/super1`, `objects/super5`) and promotes `classes/constraints8` from substring to full gold-match."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148d" }
  tags { "evaluator"; "parser"; "scope"; "amend"; "stdlib"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Object body siblings pre-register as bindings for forward refs"
      rationale =
        "Apple Pkl evaluates `parent { x = 1 + y; y = 2 }` by reading the binder before the RHS — the binding order is positional but the lookup order is contents-first. Pre-registering every member as a Binding inside `eval_object_members` before the per-field eval loop hooks into the existing lazy resolver: `resolve_binding_value` already walks bindings on demand and the stack guard catches direct cycles. The alternative (multi-pass with explicit dependency analysis) would have added a parallel resolver."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Amend body super exposes the pre-amend ObjectValue, not late-bound parent"
      rationale =
        "Apple Pkl's super.X re-evaluates the parent's X with the amended this — full late binding requires re-running the parent's body against the current object's siblings. PKL-148e ships only the simple form (`super` = the evaluated parent ObjectValue), enough for super1 / super5 / class2a's super reads where the parent has no inter-property dependencies. super2 / super3 / super4 still need true late binding; they remain on the silent-mismatch list."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Function method dispatch intercept at eval_callable_call entry"
      rationale =
        "`.apply` / `.applyToList` / `.toString` / `.getClass` on a FunctionValue can't route through the regular method dispatcher because the receiver-type gate (`is_listing_method_name` / `is_string_method_name` / ...) doesn't include Function method names and the MemberAccess fallback rejects FunctionValue with `member access expects Object`. Intercepting at the top of `eval_callable_call` is the narrowest fix — the four method names are exhaustive for the Function class today, and the intercept fires before the regular evaluate-callee path so the lookup never sees the FunctionValue."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Sibling class methods are scope-visible; user-class annotations accept ObjectValue"
      rationale =
        "Apple Pkl treats `function f(...)` inside a class as scope-visible from sibling methods (no `this.` required); `push_sibling_class_methods` seeds the method cache with FunctionValue mirrors walking the parent chain, so an override in a subclass shadows the parent. For `param: Person` accepts `new {}` — Apple Pkl validates against the instance's dynamic class, but pkl-mbt's ObjectValue erases it; `value_satisfies_user_class_annotation` accepts any ObjectValue whose declared type matches a known user class, trading some tightness for upstream compatibility until ObjectValue carries a class tag."
    }
  }
}

local pklClassAsValueAndScopeScenario = new Scenario {
  id = "PKL-148d"
  name = "class-as-value reflect mirror plus lexical scope walk"
  description =
    "Adds class-as-value semantics — a bare class identifier (`Person`) projects to a `pkl:reflect.Class` mirror; member access on the mirror reports `Cannot find property \\\\\\\\\\\\\\`X\\\\\\\\\\\\\\` in object of type \\\\\\\\\\\\\\`Class\\\\\\\\\\\\\\`.` and call-form access reports `Cannot find method \\\\\\\\\\\\\\`X\\\\\\\\\\\\\\` in class \\\\\\\\\\\\\\`Class\\\\\\\\\\\\\\`.`. Lexical scope now wins over module-level bindings: `resolve_binding_value` checks `env` before the module's `bindings` / `cache`, and `eval_object_members` hoists each prior member (including `local` properties whose `@hidden$` prefix gets stripped during the hoist) into a per-field env so a nested `bar { x = 2; y = x + 3 }` resolves `x` to the inner `2` rather than the enclosing `foo.x = 1` or module-level `x = 0`. Amend operations now deep-merge ObjectValue members rather than wholesale-replacing them — `(x) { foo { bar { num1 = 11 } } }` keeps `foo.bar.num2` and `foo.baz` from the base. Constraint diagnostics that quote a class-typed value render with the host class name (`new Address { street = \"Garlic Blvd.\" }` rather than the multi-line PCF block form). Lifts gold-match from 43 to 50 PCF (`basic/localProperty1`, `basic/localPropertyOverride3`, `classes/class4`, `classes/constraints3`, `objects/configureObjectAssign`, `objects/implicitReceiver1`, `objects/implicitReceiver2`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148c" }
  tags { "evaluator"; "scope"; "amend"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "env wins over module bindings in resolve_binding_value"
      rationale =
        "Apple Pkl's lookup order is lexical-scope-first: an enclosing object body's properties shadow same-named module bindings. The pre-PKL-148d order (cache → bindings → env) made the module-level `x = 0` win even when `bar { x = 2; y = x + 3 }` was supposed to see `x = 2`. The reorder is local to `resolve_binding_value` so nothing else in the eval pipeline shifts."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Local members hoist into env with their bare name"
      rationale =
        "`local l = 2` stores the member as `@hidden$l` so the renderer skips it. For subsequent sibling expressions to see `l` (Apple Pkl's `local` is a fresh binding in the enclosing scope, not a hidden output), the hoist into env strips the `@hidden$` prefix. The renderer still hides the member at output time via the existing `visible_members` filter."
    }
    new Decision {
      date = "2026-05-17"
      summary = "merge_value_members deep-merges same-name ObjectValue members"
      rationale =
        "Apple Pkl's amend semantics traverse nested objects: `(x) { foo { bar { num1 = 11 } } }` preserves `x.foo.bar.num2` because the amend only overrides what's named, not the full subtree. Pre-PKL-148d the same-name override replaced the entire subtree, which made every multi-level amend lose siblings. Listing / Mapping / scalar overrides still replace outright — Apple Pkl's typed-collection amend is replacement, not append."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Class mirror diagnostic uses property/method wording by context"
      rationale =
        "Apple Pkl reports `Cannot find property X in object of type Class.` for `Person.foo` (read form) and `Cannot find method X in class Class.` for `Person.bar()` (call form). The wording differs because the surface chrome differs; routing the CallExpr's MemberAccess(class-identifier, name) arm separately keeps both messages exact without splitting Class-mirror logic across two value variants."
    }
  }
}

local pklRuntimeConstraintEvalScenario = new Scenario {
  id = "PKL-148c"
  name = "runtime evaluation of arbitrary constraint expressions"
  description =
    "Falls back to a generic runtime evaluator after the static predicate cascade (`isBetween`, `isPositive`, `length.isBetween`, `ThisCompare`, `!isEmpty`) returns no match for a class-property constraint. The fallback parses the constraint text by wrapping it as `__probe = (text)` through the regular parser, binds the candidate value as `this` plus the enclosing class's other property values into a fresh env, and rewrites bare `Identifier(name)` references inside the expression to `MemberAccess(Identifier(\"this\"), name)` when `name` is otherwise unresolved — Apple Pkl's constraint body uses implicit-receiver lookup, so `abs` in `Int(abs < 100)` resolves as `this.abs`, `street` in `Address(street.endsWith(\"St.\"))` resolves as `this.street`, and `min` in `Int(this >= min)` falls through to the sibling-property push. Diagnostic text is re-spaced through `pretty_constraint_text` because the existing `parse_type_text` strips trivia (so the captured form reads `this>=min` rather than Apple Pkl's `this >= min`). Also aligns the `if` condition diagnostic wording to `Expected value of type \\\\\\\\\\\\\\`Boolean\\\\\\\\\\\\\\`, but got type \\\\\\\\\\\\\\`X\\\\\\\\\\\\\\`. Value: V` (with a dedicated null branch). Lifts gold-match from 40 to 43 PCF (`basic/if`, `classes/constraints4`, `classes/constraints6`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148b" }
  tags { "evaluator"; "constraints"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Runtime constraint eval uses the host parser via a __probe wrapper"
      rationale =
        "Embedding a second mini-expression parser would diverge from Apple Pkl's surface (operator precedence, string escape rules, member-access chains, etc.). Wrapping the constraint text as `__probe = (text)` and pulling the parsed binding's value back out reuses the live parser at zero parser-maintenance cost; if the wrapped form fails to parse, the fallback silently returns None so the static cascade owns the diagnostic shape."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Implicit-receiver lookup is AST rewriting, not a runtime arm"
      rationale =
        "Adding a `this` fallback inside `eval_expr_with_bindings`'s `Identifier` arm would shift global semantics — every unresolved identifier in any expression would suddenly try a `this.` projection. Pre-rewriting the AST in `rewrite_implicit_this_in_expr` keeps the change scoped to the constraint pathway: only names that aren't already in `bindings` / `env` / `cache` get rewritten, and the rewrite happens once before eval, not on every Identifier reach."
    }
    new Decision {
      date = "2026-05-17"
      summary = "pretty_constraint_text re-inserts spaces around operators"
      rationale =
        "`parse_type_text` drops trivia, which means the captured constraint text reads `this>=min`. Re-rendering with `pretty_constraint_text` (which walks the text, skips string literals, and inserts spaces around `>=`, `<=`, `==`, `!=`, `>`, `<`, `&&`, `||`) reaches Apple Pkl's `this >= min` form. The alternative — preserving whitespace at parse time — would touch every `parse_type_*` caller (class properties, function parameters, method returns, type aliases, …) for a one-fixture-cluster win."
    }
  }
}

local pklBaseMethodSurfaceFollowupScenario = new Scenario {
  id = "PKL-148b"
  name = "pkl:base method surface second wave"
  description =
    "Follows the PKL-148 first wave with runtime support for `this <op> N` bare-comparison constraints (`Int(this > 0)` etc. via the new `ThisCompare` predicate variant), the `as` and `|>` operators (parser-only stops being parser-only — `as` does a runtime type assertion and `|>` desugars to a single-arg call), Duration / DataSize scalar arithmetic (`5.s * 3`, `2.gb / 4`, the symmetric Int/Float on either side), Set + Listing (and Listing + Set) concat that mirrors Apple Pkl's collection-union semantics, Int methods (`isBetween(a, b)`, `toFloat()`), Listing.isDistinctBy(keyFn), Listing-host constraints (`Listing<T>(!isEmpty)`), and construction-time enforcement of class-property constraints so `new P { l {} }.l` raises the violation at construction rather than only at the outer binding boundary. Lifts gold-match from 38 to 40 PCF (`classes/constraints1`, `classes/constraints2`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-148" }
  tags { "evaluator"; "stdlib"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "ThisCompare is a first-class constraint predicate"
      rationale =
        "`Int(this > 0)` is far enough off the named-predicate template (`isPositive`, `isGreaterThan(N)`, …) that it needs its own predicate variant. Storing the op + threshold + which side is `this` keeps both the accept check and the diagnostic rendering tight; the constraint name renders as the literal source (`this > 0`) so snippetTest fixtures match upstream wording."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Construction-time constraint enforcement on TypedObjectLiteral"
      rationale =
        "Apple Pkl raises class-property constraint violations the moment the value is built, not only when the outer binding is finalised. snippetTest's `new P { l {} }.l` would otherwise dodge the check entirely because the outer binding's expression is a `MemberAccess`, not a `TypedObjectLiteral`. The check is gated on provided members so default values that haven't been amended don't re-run."
    }
    new Decision {
      date = "2026-05-17"
      summary = "as does a runtime type assertion, not a static no-op"
      rationale =
        "The typechecker pass that would erase `as` to a no-op isn't always reachable (think dynamic Listing<Any> contents). Running the same `eval_value_accepts_type_annotation` check at runtime preserves Apple Pkl's diagnostic shape and keeps the operator from being a silent identity that can hide bugs."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Listing constraint host check runs before element cascade"
      rationale =
        "`Listing<String>(!isEmpty)` and `Listing<Int(isPositive)>` are different beasts — the host predicate fires against the Listing as a whole; the element predicate fires per element. The dispatch order matters: host check first, then element cascade, so an empty Listing fails `!isEmpty` rather than silently passing the no-elements case of the element cascade."
    }
  }
}

local pklBaseMethodSurfaceScenario = new Scenario {
  id = "PKL-148"
  name = "pkl:base method surface expansion first wave"
  description =
    "Fills in the pkl:base surface gaps that snippetTest fixtures lean on. Added: Bool methods (`xor` / `implies` / `and` / `or` / `toString`); Float methods (`toString` / `abs` / `round` / `floor` / `ceil`); Int property surface (`isPositive` / `isNonZero` / `isFinite` / `isNaN` / `isInfinite` / `sign` / `inv`); String property surface (`isNotEmpty` / `isBlank` / `isNotBlank` / `reverse` / `base64`); Listing property surface (`isNotEmpty` / `isDistinct` / `firstOrNull` / `lastOrNull` / `toList` / `toSet` / `toListing`); Listing methods (`getOrNull(idx)` / `startsWith(other)` / `endsWith(other)`); Mapping property surface (`isNotEmpty` / `entries` / `toMap` / `toMapping`); Set methods (`add(x)` / `every(p)` / `any(p)` / `none(p)` / `count(p)` / `firstOrNull` / `lastOrNull`); Map method (`containsValue(v)`); Pair member aliases (`.key` / `.value` mirror `.first` / `.second`). Binary `+` now concatenates ListingValue / SetValue / MappingValue / MapValue / StringValue pairs. `value.getClass()` synthesises a `pkl:reflect.Class` mirror exposing `simpleName` / `name`. Class-typed bindings (`p: Person = new {}`) now expand their declared default properties via `apply_class_defaults_for_type`. Constraint diagnostic wording was rewritten to Apple Pkl's canonical form (`Type constraint \\\\\\\\\\\\\\`isBetween(10, 20)\\\\\\\\\\\\\\` violated. Value: 11` and `Expected value of type \\\\\\\\\\\\\\`Int\\\\\\\\\\\\\\`, but got type \\\\\\\\\\\\\\`String\\\\\\\\\\\\\\`. Value: \\\\\\\"foo\\\\\\\"`) so snippetTest fixtures that capture the message via `test.catch(...)` match byte-for-byte. NonNull assertion wording aligned (`Expected a non-null value, but got \\\\\\\\\\\\\\`null\\\\\\\\\\\\\\`.`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075"; "PKL-147" }
  tags { "evaluator"; "stdlib"; "upstream"; "compat" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Constraint diagnostic wording matches Apple Pkl verbatim"
      rationale =
        "snippetTest fixtures stash the diagnostic via `test.catch(...)` and assert the rendered string is the exact upstream wording. Our pre-PKL-148 wording (`type annotation X member a constraint Y rejects Z`) was internal-style; switching to `Type constraint \\\\\\\\\\\\\\`Y\\\\\\\\\\\\\\` violated. Value: Z` unlocks the entire constraint-fixture cluster (`classes/constraints*.pkl`) — they're now either gold-match or one render-detail away."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Class defaults expand when a typed empty new {} is bound"
      rationale =
        "Apple Pkl applies class-default properties at binding time, not only inside a `new TypeName { ... }` typed-literal. The fixture `basic/fixedProperty2.pkl` writes `p: Person = new {}` and expects `p { name = \\\\\\\"The Person\\\\\\\" }` — without the binding-time default fill the rendered output was the empty `p {}`. `apply_class_defaults_for_type` runs at the binding-eval site so the path is symmetric to the typed-literal path."
    }
    new Decision {
      date = "2026-05-17"
      summary = "getClass() returns a synthetic reflect.Class mirror"
      rationale =
        "The fixture `api/any.pkl` exercises `value.getClass().simpleName` against every primitive variant. Building it as a `pkl:reflect.Class` mirror (with `__kind` marker, `reflectee`, `simpleName`, `name`) keeps the value compatible with the existing reflect-introspection path so downstream `.properties` / `.methods` / `.supertype` access surfaces don't need a parallel implementation."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Collection + operator semantics follow Apple Pkl"
      rationale =
        "`Listing + Listing` concatenates; `Set + Set` is union (right-biased for new elements); `Map + Map` / `Mapping + Mapping` are right-biased merges; `String + String` is concatenation. The arms are gated on the matching value variant before the generic equality / type-error path so a typo like `5 + \\\\\\\"x\\\\\\\"` still surfaces the standard `operator + expects Int operands` diagnostic."
    }
  }
}

local snippetTestHarnessScenario = new Scenario {
  id = "PKL-147"
  name = "snippetTest harness foundation"
  description =
    "Four small fixes that let upstream `LanguageSnippetTests/input/<dir>/<name>.pkl` fixtures whose body amends `snippetTest.pkl` produce shape-correct output. (1) `parse_mapping_entry` now dispatches the `[\"k\"] { body }` amend form through `parse_inferred_new_body` so a `Mapping<String, Listing<T>>` entry's body parses as a Listing (bare elements) instead of an ObjectLiteral that silently drops every non-property line — this alone unblocks every fixture whose body is a Listing of expressions. (2) The CallExpr dispatcher recognises `module.catch(() -> ...)` alongside `test.catch(() -> ...)` and reuses `eval_pkl_test_catch_binding_value` to materialise the no-throw / throw branches. (3) The lexer accepts `0x` / `0b` / `0o` integer prefixes plus `_` digit separators (`0xFF_FF`, `0b1010`, `1_000_000`) — without this the upstream `(0x110000).toChar()` test in `api/int.pkl` errored out at parse time. (4) The CLI's eval handler honours `output { text = \"…\" }` (verbatim string projection) and `output.renderer.omitNullProperties = true` (recursive null-property strip on the value tree). Method-coverage and diagnostic-message-wording gaps inside the snippetTest body bodies still keep most fixtures off the byte-match list; this slice is the harness foundation that PKL-148 / PKL-153 can build on."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-095"; "PKL-104"; "PKL-126"; "PKL-137" }
  tags { "parser"; "lexer"; "evaluator"; "cli" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "omitNullProperties pre-processes the value tree at the CLI boundary"
      rationale =
        "Threading the omit-null flag through every render function (`render_pcf_module` / `render_pcf_block_body` / `render_pcf_inline`) would touch ~30 call sites for one renderer flag. Pre-walking the value tree before render with `strip_null_object_properties` keeps the renderer pristine and the same pre-walk will work for future per-renderer flags (renderer.indent, renderer.extension) when they land."
    }
    new Decision {
      date = "2026-05-17"
      summary = "module.catch routes through the existing test.catch intercept"
      rationale =
        "`module.catch` and `test.catch` have identical semantics — the only difference is the receiver token (`module` is the self-module, `test` is the imported pkl:test alias). Reconstructing the call as `CallExpr(callee, arguments)` and dispatching through `eval_pkl_test_catch_binding_value` lets a single implementation cover both surfaces. When a real first-class `catch` member lands, both routes drop out together."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Hex / binary / octal int literals live in the lexer + parse_int_text"
      rationale =
        "Apple Pkl's lexer already recognises these prefixes; without them the upstream parser suite reports `expected ), got identifier` on `(0x110000)` because the lexer splits `0x110000` into `0` + identifier `x110000`. Underscores are accepted in every base for Apple Pkl parity (`1_000_000`, `0xFF_FF`)."
    }
    new Decision {
      date = "2026-05-17"
      summary = "output.text bypasses the renderer entirely"
      rationale =
        "When `output { text = \"…\" }` is set, Apple Pkl writes the string verbatim — no quotes, no PCF escaping, no module envelope. The CLI's `extract_output_text` is checked before `extract_output_value` so the bypass beats both format dispatch and renderer-class auto-detection."
    }
  }
}

local pklYamlParserScenario = new Scenario {
  id = "PKL-146"
  name = "pkl:yaml.Parser.parse implementation"
  description =
    "`pkl:yaml.Parser.parse(source)` decodes a YAML document into a Pkl `Value`. The evaluator's CallExpr dispatcher mirrors the PKL-144 / PKL-145 pkl:json path: the Parser stamps `hidden __kind = \"YamlParser\"` on its synthetic class, the dispatch checks `reflect_kind(receiver) is Some(\"YamlParser\")`, and the source string flows through `moonbit-community/yaml`'s `Yaml::load_from_string`. `yaml_to_value` projects each Yaml variant onto a Pkl Value: `Null` → `NullValue`; `Boolean` → `BoolValue`; `Integer(i)` → `IntValue` when `i` fits Int32 else `FloatValue` (no silent truncation); `Real(d)` → `IntValue` when integral + Int32-bounded else `FloatValue` (same disambiguation rule as the JSON path); `String` → `StringValue`; `Array` → `ListingValue` (recursive); `Map` → `ObjectValue` (default Dynamic mode) or `MappingValue` (`useMapping = true`); `BadValue` → `NullValue`. Multi-document YAML returns only the first document for now; the loader-side `Array[Yaml]` shape is preserved so multi-doc surface lands when a fixture demands it. Parser errors surface as `yaml.Parser.parse: <err>` diagnostics."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-145"; "PKL-144" }
  tags { "evaluator"; "stdlib"; "yaml" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Reuse moonbit-community/yaml@0.0.4 rather than hand-rolling a YAML parser"
      rationale =
        "YAML is bigger than JSON (indentation rules, multi-doc, anchors, tag handles) — hand-rolling a parser would dwarf the rest of pkl-mbt. `moonbit-community/yaml` exposes a `Yaml` enum that's a near-perfect projection target (Null / Boolean / Integer / Real / String / Array / Map plus the `BadValue` escape hatch) and builds on every MoonBit target. Cost: one extra entry in `moon.mod.json` deps."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Multi-document YAML returns the first document only"
      rationale =
        "Apple Pkl's `yaml.Parser.parse` returns a single value for single-document input; for multi-document `---`-separated streams it surfaces a `Listing<Value>` via a separate `parseAll` method. The loader-side `Array[Yaml]` shape is preserved (we just take `docs[0]`) so adding `parseAll` later is a method-name + arm addition, not a re-architecture. Single-doc covers every config / fixture pattern observed in pkspec / pkf today."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Int64 → Int32 numeric clamping uses FloatValue fallback"
      rationale =
        "`moonbit-community/yaml` exposes integers as `Int64`; pkl-mbt's `IntValue` carries Int32. Out-of-range Int64s could panic on `to_int` or silently wrap. The fallback to `FloatValue(i.to_double())` preserves the magnitude (Doubles cover the full Int64 range exactly for values up to 2^53) and lifts automatically when the value model promotes to Int64 (already a known follow-up for upstream `maxInt`)."
    }
  }
}

local hiddenClassPropertyScenario = new Scenario {
  id = "PKL-145"
  name = "hidden class property modifier"
  description =
    "The `hidden` member modifier now applies to class-property declarations, not just object-body members. `parse_class_property_decl` calls a new `take_pending_hidden` drainer that pulls the `hidden` token out of the `pending_modifiers` list `skip_member_header` populated, then wraps the stored property name with `hidden_member_name` (the same `@hidden$` prefix the object-body path uses). Lookups (`b.marker`) resolve through the bidirectional bare/prefixed `lookup_member` path; renderers skip the prefixed entry via `visible_members`. PKL-144's `pkl:json.Parser` synthetic source flips its `__kind = \"JsonParser\"` marker to a `hidden __kind` class property so the detection routes through the same `reflect_kind` helper that pkl:reflect mirrors use — replacing the shape-based fallback (`useMapping` slot present) with a structural marker check."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-098"; "PKL-144" }
  tags { "parser"; "evaluator"; "stdlib" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Drain via take_pending_hidden, mirroring take_pending_abstract"
      rationale =
        "PKL-117 introduced `pending_modifiers` + `take_pending_abstract` for the `abstract function` / `abstract class` path. The same drainer shape extends naturally to `hidden`: `skip_member_header` already populates the list for any token that `is_modifier_text` matches, so adding `take_pending_hidden` keeps the pull side narrow without touching the populate side. The drainer removes only `hidden` tokens (others like `const` / `external` stay for downstream consumers — none of those consume from `parse_class_property_decl` today, but the pattern stays composable)."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Switch pkl:json Parser detection from useMapping-shape to __kind marker"
      rationale =
        "PKL-144 detected the Parser by checking for a `useMapping: Boolean` slot — a shape-coincidence approach that worked because no other synthetic class shared the combination. Now that `hidden` on class properties survives lookup and renders cleanly, the marker-based detection (`reflect_kind(receiver) is Some(\"JsonParser\")`) is both more robust (no false positives if a future class re-uses `useMapping`) and consistent with the pkl:reflect Class / Module mirror dispatch path. The `useMapping` slot stays a public Parser property; only the detection key changes."
    }
  }
}

local pklJsonParserScenario = new Scenario {
  id = "PKL-144"
  name = "pkl:json.Parser.parse implementation"
  description =
    "`pkl:json.Parser.parse(source)` decodes a JSON document into a Pkl `Value`. The evaluator's CallExpr dispatcher intercepts `<receiver>.parse(s)` whenever the receiver is an ObjectValue carrying a `useMapping : Boolean` slot — the distinguishing shape of the pkl:json Parser mirror (no class-level hidden marker because `hidden` on a class property is not yet a recognised modifier; the `useMapping` slot is a sufficient discriminator across the synthetic stdlib). The source string flows through MoonBit core's `@json.parse`, then `json_to_value` projects the resulting `Json` enum onto Pkl Values: `Null` → `NullValue`; `True` / `False` → `BoolValue`; `Number` → `IntValue` when the magnitude fits an Int32 and is integral, else `FloatValue` (matches Apple Pkl's `42` → `Int`, `42.5` → `Float` rule); `String` → `StringValue`; `Array` → `ListingValue` (recursive); `Object` → `ObjectValue` when `useMapping = false` (Apple Pkl's Dynamic-mode default) or `MappingValue` when `useMapping = true`. Parser errors from `@json.parse` surface as `json.Parser.parse: <err>` diagnostics; non-String arguments / wrong arity get their own targeted wording."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-124" }
  tags { "evaluator"; "stdlib"; "json" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Detect Parser shape via the `useMapping : Boolean` slot, not a class-level kind marker"
      rationale =
        "The PKL-143 reflect work stamps a hidden `__kind` member inside lambda-returned `new { ... }` object literals, but `hidden` on a class property is not a recognised modifier in the parser today (`class Parser { hidden __kind: String = \"...\" }` would emit a visible `__kind` member, which leaks into renders). The `useMapping : Boolean` slot is already a load-bearing part of the Parser's public shape and no other synthetic stdlib class exposes both `.parse` and `useMapping`, so it's a stable enough discriminator. If a future synthetic class ends up with the same shape we add a real class-property `hidden` modifier (parser change) and switch the dispatch over."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Reuse moonbitlang/core/json rather than hand-rolling a parser"
      rationale =
        "MoonBit core ships a complete JSON parser (`@json.parse` returns the `Json` enum from builtin, builds on all four targets, error wording is reasonable). A hand-rolled parser would either repeat that work or risk subtle divergences (number-representation edge cases, escape sequences, surrogate handling). The cost is one extra import in moon.pkg — already in the standard library, no new dependency."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Number disambiguation: Int when integral and Int32-bounded, Float otherwise"
      rationale =
        "Apple Pkl projects `42` to a Pkl `Int` and `42.5` to a `Float`. `@json.parse` always returns `Double`; we widen to Int only when the value is structurally integral (`d.to_int().to_double() == d`) AND fits the Int32 range pkl-mbt's `IntValue` carries. Out-of-range integers (rare in config JSON but possible) fall back to Float to avoid silently truncating; a future slice promoting `IntValue` to Int64 also lifts that bound automatically."
    }
  }
}

local intSeqEqualityScenario = new Scenario {
  id = "PKL-119be"
  name = "IntSeq sequence equality"
  description =
    "Apple Pkl's `IntSeq` equality compares the *element sequence* the two operands produce, not their carrier shape. Empty IntSeqs are equal regardless of endpoints (`IntSeq(0, -1) == IntSeq(10, -10)`); non-empty IntSeqs are step-aware (`IntSeq(-10, 10).step(2) == IntSeq(-10, 11).step(2)` because both produce -10, -8, ..., 10). The PKL-119b stop-gap relied on the structural `derive(Eq)` the value variant inherits, which mis-answered both cases. `eval_binary` now intercepts `(IntSeqValue, IntSeqValue)` pairs before the generic equality fall-through and routes through `intseq_value_equal`, which materializes both operands and compares them element-by-element. Both-empty short-circuits via the length-mismatch check (zero == zero) plus the zero-iteration loop. Non-Equal binary ops on IntSeq operands aren't defined upstream and emit the standard `operator <op> not defined for IntSeq operands` diagnostic."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-119b" }
  tags { "evaluator"; "stdlib" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Materialize and compare element-by-element rather than implementing a closed-form check"
      rationale =
        "A closed-form check would walk the two ranges arithmetically without allocating Arrays, but the edge cases (mixed direction, mixed step sign, overflow at the boundary) are subtle enough that getting the formula right and reviewable costs more lines than the materialize-and-compare path. Materialization already exists for `.toList()` / `.map` / `.fold` / non-PCF renderers; reusing it keeps the equality logic a five-line function and lets a future closed-form check replace it without changing any caller. The 1M-element worst case is the same as those other materialization paths — already an accepted upper bound."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Non-Equal binary ops on IntSeq operands surface a `not defined` diagnostic"
      rationale =
        "Apple Pkl does not define `<`, `+`, etc. for IntSeq operands. The IntSeq-IntSeq match arm has to handle every op exhaustively (MoonBit can't easily fall through to the generic catch-all from inside a structural pattern), so the explicit per-op diagnostic mirrors the wording the surrounding arms use for Duration / DataSize on undefined ops."
    }
  }
}

local setValueVariantScenario = new Scenario {
  id = "PKL-119c"
  name = "Set Value variant"
  description =
    "Set joins the dedicated stdlib value variants. `Value` gains `SetValue(Array[Value])` and the `Set(a, b, c)` constructor returns it (duplicates dropped at construction via `contains_value`; insertion order preserved). Bare property reads (`.length` → Int; `.isEmpty` / `.isNotEmpty` → Boolean; `.first` / `.last` → element type with empty-set diagnostic; `.distinct` → identity SetValue) resolve through the member-access dispatcher; method calls (`.contains` → Boolean; `.toList` / `.toListing` → `Listing<element>`; `.toSet` → identity; `.map(f)` → `Listing<lambda return>`; `.filter(p)` → `Set<element>`; `.fold(initial, op)` → initial type; `.join(sep)` → String) dispatch through the dedicated `eval_set_method` evaluator. Renderer projection: PCF round-trips through `Set(a, b, c)` so the eval output is parser-readable; JSON / YAML / Properties / plist materialize as an array of the elements. Typechecker gains `SetType(Array[Type])` parallel to `ListingType`. `Set<T>` annotations land via `generic_argument_text`; bare `Set` resolves to `SetType([])` (accept-any element). `Set(a, b, c)` call sites infer to `SetType` carrying the element types, and `infer_call_expr` intercepts the method-form calls so each method returns the right shape. `type_accepts` adds a `(SetType, SetType)` arm with the same widening rules as `(ListingType, ListingType)` so `Set<Int>` annotations accept the inferred `SetType([IntType, IntType, IntType])` shape from the constructor."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-119a"; "PKL-119b" }
  tags { "evaluator"; "typechecker"; "stdlib" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Set.map returns Listing, not Set, matching Apple Pkl's `Set.map` signature"
      rationale =
        "Apple Pkl's `Set<T>.map(f: (T) -> R): Listing<R>` returns Listing even though uniqueness could be preserved trivially. The signature reflects that the mapped values may collide (different elements mapping to the same value), in which case downstream uniqueness becomes a separate `.toSet()` call. Mirroring the upstream signature keeps Set / Listing methods composable; `.filter`, which is `Set<T> -> Set<T>` upstream, keeps the Set type because the filter preserves uniqueness by construction."
    }
    new Decision {
      date = "2026-05-16"
      summary = "union / intersection / difference deferred to a follow-up"
      rationale =
        "The binary set operators carry slightly different semantics than the upstream `+` (concat-then-dedup) Listing operator, and threading them through `eval_binary` + the typechecker would either land alongside an `OperatorOverload`-style table (large refactor) or as ad-hoc method-call arms (mirror of Listing's `+`). Today's slice covers the read-only / projection / single-receiver method surface that pkspec / pkf use today; the binary operators get a dedicated slice when a fixture or upstream gold-match actually exercises them."
    }
  }
}

local reflectIntrospectionScenario = new Scenario {
  id = "PKL-143"
  name = "pkl:reflect class / module introspection"
  description =
    "`pkl:reflect` grows from a mirror-constant + factory stub into a usable introspection surface. The synthetic stdlib source stamps a hidden `__kind` marker (`\"Class\"` / `\"Module\"` / `\"TypeAlias\"`) on every factory-returned ObjectValue; the evaluator's `MemberAccess` arm checks for the marker before falling through to generic member lookup and dispatches to dedicated helpers (`reflect_class_properties` / `reflect_class_methods` / `reflect_class_supertype` / `reflect_module_classes`) that walk the surrounding module's `Array[Declaration]`. The same path handles the `isSubclassOf(other)` method call by tracing each receiver's `parent_name` chain against the argument's `reflectee` (with a 256-hop cap as a defensive cycle guard). The `__kind` marker is hidden via the existing `hidden_member_prefix` machinery, so it never reaches the renderer; the user-facing mirror still shows just `reflectee`. The slice deliberately keeps the factories taking a string identifier rather than a real `ClassValue` — that round-trip is the remaining gap once the value model grows a class-value variant. The `mpkl stdlib` probe table grows by five rows (properties / methods / supertype / isSubclassOf / classes) so the introspection surface is mechanically pinned alongside the existing mirror-constant probes."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-080" }
  tags { "evaluator"; "stdlib"; "reflect" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Hijack at MemberAccess rather than build a real ClassValue variant"
      rationale =
        "Apple Pkl's `pkl:reflect` expects to receive class values directly (`reflect.Class(MyClass)`); supporting that would require a new `ClassValue(ClassDecl)` Value variant plus a way to materialize a class declaration as a runtime value. That's a deep value-model change. The marker-based hijack reaches the same observable behaviour (`.properties` / `.methods` / `.supertype` / `.classes` / `.isSubclassOf` all work against named references) without touching the value-model API consumers depend on. When the real ClassValue variant eventually lands, the marker becomes redundant and the hijack arm collapses into a normal Value-arm match."
    }
    new Decision {
      date = "2026-05-17"
      summary = "isSubclassOf walks parent_name with a hop cap rather than building a class graph"
      rationale =
        "A real implementation would build a Map<String, ClassDecl> per module evaluation and cache parent-chain queries. For the typical project class hierarchy (single-digit depth), the 256-hop linear walk is unobservable and the cache would just be extra state to invalidate when source changes. The hop cap exists purely as a defensive bound against a malformed cyclic declaration; production code never reaches it."
    }
  }
}

local stdlibCoverageProbeScenario = new Scenario {
  id = "PKL-141"
  name = "mpkl stdlib coverage probe"
  description =
    "`mpkl stdlib` runs an in-process probe table — one minimal fixture per documented stdlib surface area — through `AnalysisSession` (so `import \"pkl:math\"` etc. resolve through the synthetic stdlib loader, not the import-less `eval_source` path), renders the result via the PCF renderer, and matches against an expected substring. Pass / fail lines surface as `[PASS] group :: name` or `[FAIL]` with the diagnostic message; the trailing `stdlib: N / N passed` summary terminates the run, and the exit code is non-zero when any probe fails. The probe table covers `pkl:base` (Listing / Mapping / String / Int builtins + dedicated `Pair` / `IntSeq` / `Set` / `Map` value variants + Renderer classes + `Duration` / `DataSize` / `Regex` / `Bytes` literals), `pkl:math` (Int constants + helpers + Float-side `sqrt` / `pow` / `pi`), `pkl:semver` (parse + compare + parseOrNull), `pkl:platform` (deterministic stub values), `pkl:test` (`catch` on the throw branch), `pkl:reflect` (mirror constants + factory containers), `pkl:json` / `pkl:yaml` (Parser shells), and `pkl:xml` / `pkl:protobuf` (Renderer shells). The contract gates the surface README.md advertises as `Full` / `Partial` / `Stub` — any regression that breaks a documented capability fails the smoke check before the README claim can drift."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-119d"; "PKL-124"; "PKL-123" }
  tags { "cli"; "stdlib"; "verification" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-17"
      summary = "Probe runs through AnalysisSession rather than eval_source"
      rationale =
        "`eval_source` plugs in a no-op import resolver — anything that `import \"pkl:math\"` fails with `Cannot find module \\`pkl:math\\`.`. The probe table needs the synthetic stdlib loader that `AnalysisSession::eval_path` wires up. Spinning up a fresh session per probe is O(milliseconds) and keeps the probes isolated (no cross-probe binding leakage)."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Substring matching on rendered PCF, not structural equality"
      rationale =
        "An exact-value comparison would require each probe to spell out the full `ObjectValue([ValueMember::{...}])` shape, which is verbose and brittle (renderer changes silently invalidate the probe even when the value is right). Matching against a substring of the PCF output (e.g. `v = 4.0`) keeps each probe a single-line claim while still catching wrong-value regressions; the renderer surface is itself pinned by the upstream-smoke gold-match contracts."
    }
    new Decision {
      date = "2026-05-17"
      summary = "Probe `pkl:test.catch` on the throw branch only"
      rationale =
        "Apple Pkl's `test.catch(() -> ...)` returns null on no-throw and the thrown-message string otherwise. pkl-mbt's synthetic `pkl:test` binds `catch = null`; the special-case dispatcher in eval.mbt only handles the throw branch (which is what `classes/constraints8.pkl` exercises upstream). The probe table is the place to document this — pinning the throw-side probe captures the contract pkl-mbt actually honors today, while the README's `pkl:test` row carries the `Partial` status so consumers know the no-throw branch isn't supported."
    }
  }
}

local codegenMoonbitBridgeScenario = new Scenario {
  id = "PKL-131"
  name = "pkl codegen bridge to MoonBit"
  description =
    "`moon run cmd/mpkl -- codegen <file.pkl>` lowers a parsed Pkl module into a MoonBit source skeleton so embedders can round-trip their schemas through both type systems. The `codegen_moonbit(program: Program): String` entry point walks `program.declarations`: each `ClassDeclaration` emits a `pub(all) struct ... derive(Eq, Show)` carrying one field per property; each `TypeAliasDeclaration` emits a `pub typealias <target> as <name>`; `FunctionDeclaration`s are intentionally skipped (no MoonBit data-shape analogue). Pkl type annotations flow through `pkl_type_to_moonbit`: scalars (`Int` → `Int`, `Float` → `Double`, `Boolean`/`Bool` → `Bool`, `String` → `String`, `Null` → `Unit`, `Bytes` → `Bytes`); generics recurse — `Listing<T>` / `List<T>` → `Array[T]`, `Mapping<K, V>` / `Map<K, V>` → `Map[K, V]`, `Set<T>` → `Array[T]` with a `/* Set */` comment (no ordered-unique container in moonbitlang/core yet), `Pair<A, B>` → tuple `(A, B)`, `IntSeq` → `Array[Int]` with `/* IntSeq */`, `Duration` / `DataSize` → `Double` with a unit comment; nullable `T?` carries through structurally; constraint suffixes (`Int(isPositive)`) strip to the base type because MoonBit doesn't model refinement types here; unrepresentable shapes (unions, `Any`, `Unknown`) fall back to `Unit /* TODO: ... */` so the generated file still parses and the embedder gets a `// TODO:` flag to grep for. The CLI subcommand reuses the same `print_diagnostics_with_source` path as `check` / `analyze` for parse errors, exits 1 on a non-clean parse, and otherwise prints the generated source verbatim (single trailing newline)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-080"; "PKL-110" }
  tags { "cli"; "codegen"; "typechecker" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "MoonBit-first target, skip Java / Kotlin / Swift / Go"
      rationale =
        "The original PKL-131 roadmap entry listed Java / Kotlin / Swift / Go alongside MoonBit. pkl-mbt is positioned as a MoonBit library, so the natural first consumer is the MoonBit codebase that embeds pkl-mbt itself. Single target keeps the slice tight (one type mapper, one emitter, one set of test cases) and matches the consumer that exists today. The other targets layer on as future slices once the mapping table proves out; the entry-point name `codegen_moonbit` (rather than a generic `codegen`) signals the explicit target rather than a polymorphic dispatcher pretending to handle all four."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Type annotations read from the parser, not the typechecker"
      rationale =
        "The full typechecker output (TypeMember / TypeEntry / ClassType / etc.) is richer — it carries inferred element types, generic parameter bounds, and union narrowing. But Pkl's declared `name: Type` annotations are already a structural surface; reading them via `parse_source` keeps codegen runnable on partially-typed modules (the embedder hasn't necessarily reached `TypeOk` yet) and avoids coupling to the typechecker's internal Type ADT. The string-level type mapping in `pkl_type_to_moonbit` handles the syntactic forms users actually write; PKL-110 / PKL-115 inferred shapes can layer in later if a fixture demands them."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Union / Any drop into Unit slots with TODO comments rather than fail-stop"
      rationale =
        "Three options for unrepresentable shapes: (a) hard-error (`pkl codegen` exits with `cannot lower union Int | String`), (b) emit a placeholder type like `@json.JsonValue` requiring a moonbitlang/x dependency, (c) drop into `Unit /* TODO: ... */`. Option (a) blocks any partial codegen — most real Pkl modules have at least one union somewhere. Option (b) ties codegen output to a specific JSON library the embedder may not use. Option (c) lets the file still parse, isolates the human-in-the-loop work to greppable TODO comments, and matches the existing pattern for `Set<T>` / `IntSeq` / `Duration` where the structural fallback is acceptable."
    }
  }
}

local packageRegistryProbeScenario = new Scenario {
  id = "PKL-129b1"
  name = "package registry probe and structured diagnostic"
  description =
    "The CLI accepts `package://<authority>/<path>@<version>[#<fragment>]` URIs and reports a structured diagnostic naming the package URI, the metadata URL (derived by direct scheme rewrite + drop the fragment), the optional fragment, and the `packageZipUrl` pulled out of the metadata JSON. The fetch path follows up to five 301 / 302 / 303 / 307 / 308 redirects so the `pkg.pkl-lang.org → CDN` hop the registry serves doesn't break the probe. `parse_package_uri` validates the shape (rejects authority-only URIs); `package_metadata_url` performs the rewrite; `extract_package_zip_url` substring-scans the metadata body for the `packageZipUrl` string (no full JSON parser stood up — the field is a simple unescaped URL string). On metadata fetch failure or missing field the diagnostic still surfaces the parsed pieces plus the workaround: download the zip manually (or with `pkl download-package`) and pass `--module-path <dir>`. The CLI exits with status 1 in either case. Full zipball download + DEFLATE unpack + cache + checksum verification land with PKL-129b2."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-129" }
  tags { "cli"; "parser"; "imports"; "sandbox"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Substring scan for `packageZipUrl` instead of a full JSON parser"
      rationale =
        "Adding a JSON parser (or threading the body through pkl's own evaluator) is a much larger lift than the slice needs. The metadata response is a single JSON object with `packageZipUrl` as a flat string field whose value (an HTTPS URL) never contains JSON-string escapes; a scan for `\"packageZipUrl\"` followed by `:` and the next quoted string is unambiguous. When PKL-129b2 lands the full registry resolution it'll need a structured JSON walk for `dependencies` / `packageZipChecksums` / `sourceCodeUrlScheme` — that's the natural slice to introduce a real parser; today's probe stays narrow."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Follow redirects in fetch_uri rather than just in the package-probe path"
      rationale =
        "The native `pkg.pkl-lang.org` host returns 301 redirects to a CDN before serving the JSON. Patching only the package-probe path would have left the existing https-import surface (PKL-129) silently broken for any URL that ever redirects (e.g. raw GitHub URLs after a tag move). Moving the 5-hop redirect loop into `fetch_uri` itself fixes both cases with one code path."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Split PKL-129b into PKL-129b1 / PKL-129b2"
      rationale =
        "The original PKL-129b bundled URI parse + metadata fetch + zipball extract + cache + checksum. The zip extraction needs a DEFLATE decoder that doesn't exist in `moonbitlang/core` today (and would itself be a several-hundred-line slice). Splitting into b1 (parse + diagnostic, this slice) and b2 (download + unpack + cache + checksum) lets the b1 diagnostic ship today and gives users an actionable workaround (`pkl download-package` + `--module-path`) while b2 either lands later or stays deferred if pkl-mbt consumers route through Apple Pkl's CLI for that part."
    }
  }
}

local mapValueVariantScenario = new Scenario {
  id = "PKL-119d"
  name = "Map Value variant for the immutable functional map"
  description =
    "Apple Pkl's `Map<K, V>` is the immutable functional map (built with `Map(k1, v1, k2, v2, ...)`), distinct from `Mapping<K, V>` (the object-style `new Mapping { ... }` form with constraints / defaults / amends). `Value` gains `MapValue(Array[ValueEntry])`; the `Map(...)` constructor returns it and later duplicate keys overwrite earlier entries (matching upstream functional-map semantics). Bare property reads — `.length` → Int; `.isEmpty` / `.isNotEmpty` → Boolean; `.keys` → SetValue of the keys; `.values` → ListingValue of values; `.entries` → ListingValue of PairValue carriers — flow through the member-access dispatcher. Methods (`.containsKey` / `.getOrNull(k)` / `.getOrThrow(k)` / `.toMap` / `.toMapping` / `.toList` / `.map((k, v) -> Pair<NewKey, NewValue>)` / `.filter((k, v) -> Boolean)` / `.fold(initial, (acc, k, v) -> NewAcc)`) dispatch through `eval_map_method`. Renderer projection: PCF round-trips through `Map(k, v, k, v, ...)` so eval output is parser-readable; JSON / YAML / Properties / plist project as the same object shape MappingValue uses (object / `<dict>` / `key.subkey = value`). Typechecker gains `MapType(Array[TypeEntry])` parallel to `MappingType`. `Map<K, V>` annotations land via `generic_argument_text`; bare `Map` resolves to `MapType([])`. `Map(...)` call sites infer to `MapType` carrying the entry-type pairs; `infer_call_expr` intercepts each method-call form so `.containsKey` → Boolean, `.getOrNull` → `value?`, `.getOrThrow` → value, `.toMap` → identity, `.toMapping` → MappingType, `.toList` → `Listing<Pair<K, V>>`, `.map` → `MapType([])` (richer return-type inference would need a Pair-shape narrowing hook), `.filter` → `Map<K, V>`, `.fold` → initial type. A new `(MapType, MapType)` arm in `type_accepts` mirrors `(MappingType, MappingType)`'s widening so `Map<String, Int>` annotations accept the constructor-inferred carrier shape."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-119a"; "PKL-119b"; "PKL-119c" }
  tags { "evaluator"; "typechecker"; "stdlib" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Carrier shape mirrors MappingValue (entries array, value-equality on keys)"
      rationale =
        "An alternative was to model Map's key lookup through a hash table for O(1) `.getOrNull` / `.containsKey`. Pkl's key types include user classes / Listing / Mapping / Pair / IntSeq / Set — any value type — so the hash function would need to traverse arbitrary value graphs. The entries-array shape mirrors the existing MappingValue carrier (where the same lookup pattern already runs) and reuses the `derive(Eq)` value comparison. For the data sizes actual Pkl modules use today (config / pkspec / pkf shapes) the O(n) lookup is unobservable; a hash backing can layer in as a separate slice when an embedder profile shows it matters."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Later duplicate keys overwrite earlier entries"
      rationale =
        "Apple Pkl's `Map(k, v, k, v, ...)` constructor explicitly overwrites earlier same-key entries with later values. The behaviour was missing from the PKL-139 stop-gap (it just pushed every entry, which produced visible duplicates in PCF output). PKL-119d's slice fixes this alongside the variant split so the carrier is always semantically valid (one entry per key) and downstream lookups don't have to defensively walk past stale entries."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Map.map return type stays MapType([]) at the typecheck layer"
      rationale =
        "Apple Pkl's `Map.map(f: (K, V) -> Pair<NewKey, NewValue>): Map<NewKey, NewValue>` requires inferring the lambda's return type as a Pair and then projecting the two element types into the new MapType carrier. The typechecker doesn't currently have a Pair-shape destructuring hook in `FunctionType(args, return_type)` — modelling it would require either a structural-return inspection during `infer_function_type_call` or a narrower per-method analyzer. Today's slice returns the open `MapType([])` so downstream `.containsKey` / `.length` still typecheck (the empty entry list accepts any narrowing); the precise key/value inference lands when collection-method signature inference matures more broadly."
    }
  }
}

local plistRendererScenario = new Scenario {
  id = "PKL-126a"
  name = "plist renderer"
  description =
    "The plist renderer emits Apple plist XML (PLIST 1.0 DTD) documents. The output starts with the standard XML 1.0 prolog and `<!DOCTYPE plist PUBLIC ...>` declaration, then wraps the rendered value in `<plist version=\"1.0\">`. Value projection mirrors upstream Apple Pkl: Int → `<integer>N</integer>`, Float → `<real>D</real>`, Bool → `<true/>` / `<false/>`, String → `<string>...</string>` with XML entity escaping (`&` `<` `>`), Object / Mapping → `<dict>` with `<key>` + value pairs, Listing → `<array>`, Duration / DataSize → `<string>N unit</string>` (space-separated form rather than the `.` form used by JSON / YAML for these values), Regex → `<string>pattern</string>`, Bytes → `<string>base64</string>`. Null entries are elided inside dicts (matching Apple's `omitNullProperties` default) and inside arrays (the upstream error-on-null-in-array surface lands with PKL-127's converter machinery, alongside the rest of the renderer-side error pipeline). `-f plist` selects the renderer at the CLI; `output { renderer = new PListRenderer {} }` selects it via the AST-driven detection that already powers `JsonRenderer` / `YamlRenderer`. `pListRenderer1.plist` from the upstream snippet tests now byte-matches the gold file and joins `scripts/upstream-smoke.sh`'s new `PLIST_GOLD_FIXTURES` list."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-124" }
  tags { "renderer"; "plist" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Split PKL-126 into plist / xml / protobuf sub-slices instead of bundling all three"
      rationale =
        "Apple Pkl's three remaining renderers have very different lifts: plist is structural XML (a few hundred lines, one slice), XML element-tree rendering needs `xml.Element` / `xml.Inline` annotation routing on top of the same XML primitives, and protobuf needs a `.proto` schema parser plus wire encoding. Bundling them into a single slice would either push protobuf onto the critical path of the smaller renderers or land a partial implementation. Splitting into PKL-126a / PKL-126b / PKL-126c lets each renderer land alongside its own fixture and upstream gold-match promotion without the others blocking."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Null-in-array elision (silent skip) rather than error-on-null"
      rationale =
        "Apple's `PListRenderer` documentation specifies an error when a `<array>` element resolves to null. Threading that error through `render_plist_value` would require either a `Result` return type at every recursion site or a sentinel `BadPlistValue` Value variant. PKL-127's converter machinery already needs an error-surface pipeline (`converters { [...] = ...converter raises... }`); the null-in-array error joins that pipeline rather than reimplementing the propagation at the renderer level. Skipping null silently keeps the rendered output structurally valid for the common case where a null reaches a list (typically from an over-broad `Listing<Person?>` annotation)."
    }
  }
}

local rendererStdlibModulesScenario = new Scenario {
  id = "PKL-124"
  name = "pkl:json / pkl:yaml / pkl:xml / pkl:protobuf stdlib modules"
  description =
    "The renderer-driver classes the `output { renderer = ... }` path looks up are now part of the typechecker's stdlib surface. `JsonRenderer`, `YamlRenderer`, `PcfRenderer`, `PropertiesRenderer`, and `PListRenderer` are seeded as unqualified `ClassType` entries in `builtin_type_from_annotation` because Apple Pkl re-exports them through the implicitly-imported `pkl:base`; references like `new JsonRenderer { indent = \"    \" }` typecheck without an explicit import. Four synthetic stdlib modules — `pkl:json`, `pkl:yaml`, `pkl:xml`, `pkl:protobuf` — are added to `builtin_stdlib_source` so `import \"pkl:json\" as json` succeeds and `new json.Parser { ... }` / `new xml.Renderer { ... }` / `new protobuf.Renderer { ... }` reach the qualified-type lookup. Each renderer class is declared with an empty (or default-only) member surface; field-level typing for `converters`, `extension`, etc. is deferred to PKL-127 where the converter machinery actually consumes those properties. Unknown renderer names still trip `Cannot find type` — the surface is opt-in, not a silent open-world fallback. The CLI's existing `renderer_format_from_class` mapping is unchanged; the format dispatch was already AST-driven and the typecheck visibility was the missing link."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-104" }
  tags { "stdlib"; "renderer" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary =
        "pkl:base renderer classes seeded in the builtin type table, not as a synthetic pkl:base module"
      rationale =
        "An alternative path is to add `pkl:base` to `builtin_stdlib_source` and walk its declarations through the normal import-typing pipeline. That would model the upstream relationship faithfully (renderers extend `ValueRenderer` which extends from a shared base) but requires a parser-visible `pkl:base` source for every class the user might reach for — strings, numbers, listings, mappings, and dozens of helpers — and the `infer_program` path would need to learn about implicit-import seeding. Wiring just the renderer class names into `builtin_type_from_annotation` keeps the slice narrow to what `output { renderer }` actually exercises today; the broader `pkl:base` synthesis can land as its own slice when an embedded use case requires the full stdlib type surface."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Renderer classes declared with empty member surface, not field-typed"
      rationale =
        "`JsonRenderer { indent: String = \"  \"; omitNullProperties: Boolean = true; converters: Mapping<Class | String, (unknown) -> unknown> }` is the upstream shape, but PKL-127 already tracks the converter machinery — landing fully-typed members here would either duplicate that work or block PKL-124 on it. The empty-member ClassType is permissive: `type_accepts(ClassType(name, []), ObjectType(actual))` iterates over zero expected members and always succeeds, so `new JsonRenderer { ... }` accepts any subset of property assignments while PKL-127 fleshes out the constrained surface."
    }
  }
}

local crossModuleFunctionExport = new Scenario {
  id = "PKL-118"
  name = "cross-module typecheck round-trip completeness"
  description =
    "Module-level `function name(params) = body` declarations now participate in cross-module lookup. An importing module reaches them as `<Import>.<name>` at both the eval layer (the call dispatches the lambda body against the supplied arguments) and the typecheck layer (the function's signature flows through the same `infer_expr_with_bindings` path as a local lambda, so argument type errors surface with the precision a local call would have). The implementation pushes each module-level function as a hidden-prefixed member on the module's `ObjectValue` (eval) and `ObjectType` (typecheck); `render_value`'s existing skip for `is_hidden_member_name` keeps the rendered output unchanged. `AnalysisSession::eval_path`, `eval_source`, and `typecheck_source` strip the hidden entries at their return boundary so the existing test corpus (which asserts on visible-binding equality) keeps passing — only the internal cross-module dispatch sees the full shape. Today's slice covers module-level functions only; imported class definitions, type aliases, and constraint annotations already flow through PKL-006 / PKL-137's earlier work and `qualify_imported_type` (`<Import>.<TypeName>`); a future tightening can layer in cross-module abstract-method coverage once an embedded use case exercises it."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-006" }
  tags { "typechecker"; "imports"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary =
        "Export module-level functions via hidden-prefixed members rather than a separate side channel"
      rationale =
        "Adding a parallel `Array[FunctionDecl]` channel to the import resolver (`resolve_import_functions` next to `resolve_import_classes`) would require plumbing the channel through every member-access call site so the dispatcher can fall back from the `ObjectValue` lookup to the function table. Pushing the function as a hidden-named member on the existing `ObjectValue` reuses the in-place `lookup_member` path (which already handles `is_hidden_member_name`-tagged entries bidirectionally) and stays narrow to the eval / typecheck output shape. The trade-off is that raw `eval_source` / `typecheck_source` would surface the hidden entries to test assertions, so the public entry points strip them at the return boundary — a five-line change per entry point versus a deep multi-file refactor."
    }
    new Decision {
      date = "2026-05-16"
      summary =
        "Filter only at public-API exit points; keep internal EvalResult / TypecheckResult unfiltered"
      rationale =
        "`AnalysisSession`'s ripple-cached `evals` query stores the full result so subsequent import lookups still see the cross-module function exports — the same cached value is consumed both by `eval_path` (which strips) and by the recursive `eval_module_path` that resolves another module's imports (which doesn't strip). Filtering at the cache layer would force a second lookup table to keep the unfiltered shape around for the next importer. Stripping at the boundary (`eval_path`, `eval_source`, `typecheck_source`) keeps the symmetry single-sourced: one filter per public entry, no parallel caches."
    }
    new Decision {
      date = "2026-05-16"
      summary =
        "Slice limited to functions; class / typealias precision already flows via PKL-006 / PKL-137"
      rationale =
        "The PKL-118 description originally enumerated functions, classes, type aliases, and constraint annotations as candidates for cross-module precision. Inspecting the codebase: classes already export through `qualify_imported_type` (`<Import>.<ClassName>`), type aliases through `type_exports_from_parse_result`'s typealias arm (PKL-137 work), and constraint annotations through the constraint-validation pass that already participates in the typecheck of `imported.MyClass`. The remaining concrete gap was module-level functions, which this slice closes. Inheriting abstract methods through an imported parent still stays deferred — a future slice can layer it on by extending `find_inherited_method` to traverse imported parents through the same hidden-prefixed channel."
    }
  }
}

local inheritanceDispatchHardeningScenario = new Scenario {
  id = "PKL-117"
  name = "inheritance dispatch hardening remaining"
  description =
    "The typechecker now enforces two structural inheritance rules on every locally-declared class. (1) Abstract method coverage: a concrete (non-`abstract`) class extending an ancestor chain that contains at least one `abstract function` must provide an override for every such method — through its own `methods` array or through some intermediate concrete ancestor between the abstract declaration and itself. Missing coverage surfaces as `Class \\`<name>\\` does not implement abstract method \\`<name>\\` inherited from \\`<parent>\\`.`. Abstract classes are exempt — they're explicitly allowed to leave abstract members for downstream concretisation. (2) Override-direction subtype rules: when a child class declares a method with the same name as one declared anywhere in its parent chain, the return type must be covariant (`child_return <: parent_return`) and each parameter type must be contravariant (`parent_param <: child_param`). Violations surface as `Method \\`<class>.<name>\\` return type \\`<child>\\` is not a subtype of \\`<parent>.<name>\\` return type \\`<parent_return>\\`.` and a parallel parameter form. Both checks walk only locally-declared parents; the imported-parent case still flows through PKL-118's cross-module typecheck round-trip work. The parser captures the `abstract` modifier on both class and function declarations via the same `pending_modifiers` buffer pattern PKL-128d uses for annotations, draining the flag at decl construction so the modifier never leaks between adjacent decls."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-040"; "PKL-117a" }
  tags { "typechecker"; "inheritance" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "AST-walking enforcement keyed on local declarations only"
      rationale =
        "Threading abstract-method metadata through the `TypeMember` shape would require updating ~60 construction sites across the codebase. Walking `Map[String, ClassDecl]` built once per program scopes the change tightly to the new validator. The trade-off is that abstract methods inherited through an imported parent stay deferred — a class extending an imported abstract base doesn't get the coverage check yet. PKL-118 (cross-module typecheck round-trip completeness) tracks that gap; today the local-only enforcement covers the common case where a project's class hierarchy lives in one module."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Pending-modifier buffer mirrors the PKL-128d annotation buffer"
      rationale =
        "An alternative is to thread an `abstract: Bool` parameter through every decl parser (`parse_class_decl` / `parse_function_decl`). The pending-buffer approach centralises the capture/drain contract: `skip_member_header` is the single owner that clears the list before each pass and fills it from `is_modifier_text` tokens; each decl parser pulls via `take_pending_abstract`. Decls that don't carry `abstract` simply leave the buffer in place, and the next header pass resets it before parsing the next member — so an `abstract` consumed for one declaration cannot bleed into the following one."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Override-direction check skips when either annotation is missing or unresolved"
      rationale =
        "Method signatures in Pkl don't require explicit type annotations; a body-only `function name() = \"animal\"` has no annotated return type to compare against. Pushing a diagnostic for every unannotated override would force every test fixture to spell out signatures even when the override is trivially compatible. Skipping the comparison when either side is missing keeps the rule advisory rather than viral, and the unannotated case still passes the abstract-method coverage check — only the subtype rule is conditional on annotation presence."
    }
  }
}

local diagnosticUpstreamAlignment = new Scenario {
  id = "PKL-108"
  name = "diagnostic message text upstream alignment"
  description =
    "First-line phrasing for the most common diagnostic families now matches Apple Pkl's wording verbatim: `Cannot find property \\`<name>\\`.`, `Cannot find property \\`<name>\\` in object of type \\`<Type>\\`.`, `Cannot find method \\`<name>\\` in object of type \\`<Type>\\`.`, `Cannot find type \\`<name>\\`.`, `Cannot find module \\`<uri>\\`.`. The alignment covers `unbound identifier`, `unknown member`, `unknown <Type> property / method` (Listing / Mapping / String / Int / Float / Duration / DataSize / Regex / Bytes), `unknown type annotation`, and `unresolved import` — both inside the evaluator and at the loader boundary that bails on missing imports before evaluation runs. Source-position arrows and value-trace blocks (the multi-line decoration around the first-line message in Apple Pkl's `.err` fixtures) stay deferred; pinning the first line is enough for an upstream-error-fixture sweep to diff against without false positives from prose differences."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-107" }
  tags { "diagnostics"; "compatibility" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary =
        "Align first-line phrasing only; leave source-position / value-trace decorations as a follow-up"
      rationale =
        "Apple Pkl error fixtures include caret-anchored source excerpts (`xx | foo`) and value-trace blocks (`(it: T) -> ...` with `│` blame lines) that depend on infrastructure we don't have yet — full source position propagation lands incrementally with PKL-107 and value tracing has no concrete slice yet. Pinning the first-line wording immediately is the highest-value chunk: a future fixture sweep can diff our output against `<fixture>.err`'s line 2 (the `Pkl Error` banner sits on line 1) and the byte-exact match becomes a regression test for the alignment as new error sites get added. The decorations can layer in without invalidating this work."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Loader bail message aligns with the evaluator's `Cannot find module` wording"
      rationale =
        "Our CLI loads transitive imports up-front via `load_path`, which bails through `fail()` (writes to stdout + `exit(1)`) before the evaluator runs. That meant a missing import surfaced as `failed to read <path>` rather than `Cannot find module <uri>` — even though the evaluator's `Cannot find module` arm exists for the cases where the loader can't run (synthetic / embedded use). Aligning the loader message keeps the contract single-source: every `missing module` failure prints the same first line regardless of which layer caught it."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Typed-property errors carry the host type for context"
      rationale =
        "Generic property misses use `Cannot find property \\`<name>\\`.` (no type qualifier — the receiver is dynamically typed at the failure site). When the receiver IS typed at miss time (`Listing`, `Mapping`, `String`, `Int`, `Float`, `Duration`, `DataSize`, `Regex`, `Bytes`), the diagnostic adds ` in object of type \\`<Type>\\`.` to match Apple Pkl's two-form distinction. This is a single edit per branch and aligns with Apple Pkl's behaviour: the bare form fires only when the typechecker hasn't constrained the receiver, the qualified form when it has."
    }
  }
}

local cliSandboxFlagsScenario = new Scenario {
  id = "PKL-106"
  name = "cli sandbox flags"
  description =
    "Three CLI flags configure the sandbox surface that `read` / `import` consult: `-p NAME=VALUE` (repeatable) populates the `prop:` resolver and lifts `read(\"prop:NAME\")` into the allow-list alongside `env:`; `--module-path <dir>` (repeatable) appends directories the loader searches when an unqualified import URI misses the working directory; `--allowed-modules <pipe-separated-prefixes>` overwrites a per-scheme allow-list that the loader enforces against import URIs. The allow-list applies only to URIs carrying a `scheme:` prefix (`pkl:`, `https:`, `package:`, etc.) — bare filesystem paths bypass the check so the entrypoint and locally-rooted imports don't have to be re-spelled into the pattern. Configuration is captured in module-level mutable state via `configure_sandbox_props` / `configure_sandbox_allowed_modules` / `configure_sandbox_module_paths`; the CLI installs the values once at startup before any evaluation runs, and the evaluator reads them through `sandbox_lookup_prop` / `sandbox_is_module_allowed` / `sandbox_module_paths`. Missing `prop:` reads surface `read: prop <NAME> is not set` (parallel to the existing `read: env variable <NAME> is not set`); disallowed module URIs surface `module <uri> is not allowed by --allowed-modules` at the loader boundary."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-098" }
  tags { "cli"; "sandbox" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary =
        "Module-level mutable sandbox state instead of threading SandboxConfig through every eval call"
      rationale =
        "The evaluator's deepest call paths (eval_expr_with_bindings, eval_module_path, eval_read_uri) are reached via dozens of intermediate frames. Plumbing a SandboxConfig argument through every one of them is a multi-hundred-line refactor that pays nothing back as long as the CLI is the only configurator. Module-level state mirrors how `env:` already reads from process-global state (host environment), so the precedent is already in the codebase. When an embedded use case demands per-evaluation isolation, the configurators can be swapped for a session-scoped struct without touching the read path."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Allow-list bypasses bare filesystem paths; only scheme-prefixed URIs are gated"
      rationale =
        "Apple Pkl's `--allowed-modules` is a per-scheme allow-list (`pkl:|file:|https:|package:`). Our CLI loads modules by bare filesystem path (no `file:` wrapper); applying the same allow-list literally would force every user to spell `file:` into the pattern just to load their own entrypoint, which is the opposite of useful. Bypassing bare paths keeps the surface honest: the allow-list governs trust-boundary crossings (`https:` / `package:` / `pkl:`) while local files stay subject to host filesystem permissions and the user's command-line intent."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Module-path fallback at FS-read time, not in resolve_import_path"
      rationale =
        "`resolve_import_path` is a pure string operation; teaching it to consult the filesystem would couple URI resolution to disk state and complicate the analysis layer. Falling back through `--module-path` only when the direct read misses keeps the resolver pure: the loader has full control of disk access and can iterate candidates without changing how downstream code interprets a path."
    }
  }
}

local analyzeLintSubcommand = new Scenario {
  id = "PKL-102"
  name = "pkl analyze lint subcommand"
  description =
    "`moon run cmd/mpkl -- analyze <file>` parses the module and runs a lint pass over the resulting `Program`. Four rules ship: `unused-local-binding` (a module-level `local` whose name never appears on any expression), `unused-import` (an import name never referenced), `unused-class-property` (a property of a class whose own name is never referenced — public schema classes are exempt to avoid noise), and `shadowed-identifier` (a binding whose name collides with an import / function / class / typealias at module scope). Findings render as `path: rule: message` one per line and the command exits non-zero when any finding surfaces, so editor integrations and CI can fail on lint regressions. Source positions become useful once PKL-107 propagates byte offsets into the AST; today's output is rule-driven."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "cli"; "lint"; "analyze" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Limit unused-class-property to classes whose own name is unreferenced"
      rationale =
        "Pkl class properties are typically the module's public schema — every property of a config-shaped class is intentionally `unused` by the module that declares it because the consumer is the caller / renderer. Linting every such property would flood the output. Restricting the rule to classes whose name itself is never referenced in the module catches the real failure mode (a private helper class left over after a refactor) without yelling about config schema. PKL-102's lint surface is intentionally tight; richer per-property visibility comes once Pkl gains a `local` modifier on class properties."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Substring scan for type-annotation references, not full type-expression parsing"
      rationale =
        "Type annotations in the AST today are stored as their raw textual form (`\"Listing<Box>\"`, `\"Box?\"`). The lint pass needs to spot references like `Box` inside `Listing<Box>` so that a class name used only as a generic argument doesn't get flagged as unused. A substring scan bounded by identifier-character boundaries (`[A-Za-z0-9_]`) is enough for the current surface and keeps the linter independent of the type-expression parser, which is being expanded incrementally by PKL-110 / PKL-115 / PKL-116. When the type-expression AST stabilises the scan can be swapped for a structured walk."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Single-rule per finding; no severity gradient"
      rationale =
        "The four ship-day rules are deterministic AST predicates with no false-positive nuance — every finding is actionable. Adding a severity field (info / warn / error) would force the CLI to gain `--max-severity` knobs and tempt the linter to ship rules that need configuration. Keeping output as `path: rule: message` with non-zero exit on any finding gives the simplest contract for CI integration; severity can land later as a `LintFinding` field once a rule needs it."
    }
  }
}

local annotationClassCapture = new Scenario {
  id = "PKL-128d"
  name = "annotation class capture"
  description =
    "Annotations preceding a `module` / `class` / `function` / `typealias` declaration are captured into the AST as `Annotation { class_name, body_kind, body_text }` records. Three body forms are recognised: bare (`@Deprecated`), parenthesised (`@Deprecated(\"...\")`), and braced (`@ModuleInfo { minPklVersion = \"...\" }`); the verbatim body text between the delimiters is preserved so a downstream tool (pkldoc / codegen) can re-parse the arguments without scanning back to the open token. The parser keeps a `pending_annotations` buffer on `Parser` that `skip_member_header` fills and each decl parser drains via `take_pending_annotations`; bindings / properties that don't capture annotations simply leave the buffer to be cleared by the next header pass. Evaluation is unaffected — annotations are pure metadata. The CLI's `parse` subcommand prints a one-line summary per captured annotation so pkldoc / codegen pipelines can consume the metadata without linking against the AST directly."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-001"; "PKL-128a"; "PKL-128b"; "PKL-128c" }
  tags { "parser"; "annotation"; "pkldoc"; "codegen" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Capture body as verbatim source text rather than a structured Expr tree"
      rationale =
        "Apple Pkl annotation bodies range from a single string literal (`@Deprecated(\"msg\")`) to an object literal with property assignments (`@ModuleInfo { minPklVersion = \"...\" }`). Parsing both forms into structured AST nodes means picking between two argument shapes (positional list vs. object members) and threading the existing expression parsers through the annotation path. Storing the body as verbatim text keeps the slice tight, defers the parsing cost until a consumer actually needs the values, and avoids carrying a second Expr-tree shape that the evaluator never sees. Downstream tooling (pkldoc, codegen) can call `parse_source` on the body text when it needs structured access."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Buffer annotations in `Parser.pending_annotations`, drain at decl construction"
      rationale =
        "An alternative is to thread an `annotations: Array[Annotation]` parameter through every decl parser (`parse_class_decl`, `parse_function_decl`, `parse_typealias_decl`, `parse_module_decl`). The pending-buffer approach centralises the capture/drain contract: `skip_member_header` is the single owner that clears the list and fills it from `@` tokens; each decl parser pulls via `take_pending_annotations` as its first step. Bindings / properties that don't carry annotations simply leave the buffer in place, and the next header pass resets it before parsing the next member — so a `@Deprecated` annotation on a local binding doesn't accidentally bleed into the following `class` declaration."
    }
    new Decision {
      date = "2026-05-16"
      summary =
        "Module-level annotations attach to Program.module_annotations, not the implicit module"
      rationale =
        "Apple Pkl files don't require an explicit `module` keyword; a file with no header still represents a module. Adding a `ModuleDeclaration` AST node just to hang annotations off would force every existing module consumer to thread the optional decl through. `Program` already aggregates module-level state (`module_name`, `module_relation`, etc.), so the new `module_annotations: Array[Annotation]` field slots in alongside. Annotations only attach when an explicit `module` keyword (or `amends` / `extends` header) is present — bare files leave the list empty."
    }
  }
}

local yamlBlockScalars = new Scenario {
  id = "PKL-125"
  name = "YAML literal block scalars"
  description =
    "Multiline String values render as YAML literal block scalars (`|`, `|-`, `|+`) in block contexts (mapping value position after `key:` and sequence item position after `- `). The chomping indicator follows the trailing-newline count: exactly one trailing `\\n` clips with `|`, zero strips with `|-`, two or more keep with `|+` (the natural newline after the last content line covers one of the kept newlines and `(trailing - 1)` bare newlines preserve the rest). Eligibility requires at least one internal newline (single-line strings stay inline), no control characters other than `\\n` / `\\t`, and no content line starting with whitespace (which would otherwise force an explicit `|N` indentation indicator). Ineligible strings fall back to the existing double-quoted form. Top-level scalar strings (no parent key / sequence) keep the double-quoted form for byte-identity with the pre-PKL-125 fixture baseline."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-073" }
  tags { "renderer"; "yaml"; "block-scalar" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Emit block scalar only in block contexts, not at top-level"
      rationale =
        "A bare top-level block scalar (no parent key) is legal YAML but produces a document that is awkward to round-trip and breaks the existing top-level-string test baseline at `pkl_test.mbt:556`. Block scalars are most readable when scoped under a key or a sequence dash, where the implicit indentation context is obvious. Top-level scalars stay double-quoted as before; the rendered output for `render_value_as_yaml(StringValue(\"a\\nb\"))` is unchanged."
    }
    new Decision {
      date = "2026-05-16"
      summary =
        "Reject strings whose lines start with whitespace instead of emitting `|N` indicators"
      rationale =
        "YAML supports `|2`, `|4`, etc. to override the auto-detected indentation when the first content line itself starts with spaces or tabs. Implementing the indicator + matching content indent is doable but doubles the code path and rarely improves readability over the double-quoted fallback for the few strings that actually need it. Falling back to double-quoted keeps the rendered output deterministic and avoids the per-line indent arithmetic; a follow-up can introduce `|N` if a fixture demands it."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Defer folded block scalars (`>`, `>-`, `>+`)"
      rationale =
        "Folded scalars collapse internal newlines into spaces, which is a semantic change to the rendered string. Apple Pkl's YAML renderer never elects folded form when the source string has literal newlines — picking `>` would mean rendering a string and then parsing it back to a different value. Keeping `|`-family only makes the round-trip identity straightforward; folded form belongs in a separate slice if/when a fixture needs human-readable long-line wrapping that the parser will fold."
    }
  }
}

local stringUnicodeMethods = new Scenario {
  id = "PKL-122"
  name = "String unicode and codepoint methods"
  description =
    "Surrogate-pair aware String access. `String.length` keeps the existing UTF-16 code-unit semantics (so the fixture baseline stays byte-identical), but three new properties surface the Unicode code-point view: `String.codePointCount: Int` (count of full code points), `String.codePoints: Listing<Int>` (code-point integers), `String.chars: Listing<String>` (single-character Strings split on code-point boundaries). `String.codePointAt(i: Int): Int` indexes the code-point stream; out-of-range pushes a diagnostic. All three iterate via MoonBit's `String::iter` which already yields full code-point `Char` values, so supplementary-plane characters (`🍣`, U+1F363) collapse to a single element instead of leaking the surrogate pair."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-077" }
  tags { "stdlib"; "string"; "unicode" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary =
        "Keep `String.length` as UTF-16 code units; add `codePointCount` as the Unicode view"
      rationale =
        "Switching `length` to code-point count is a behaviour change for every fixture that touches a non-BMP string — most observable today via `String.toBytes` and substring operations whose offsets are documented in UTF-16 units. The follow-up substring / indexing migration to code-point offsets is its own slice; landing both at once would conflate the API extension with a quiet semantic break. `codePointCount` is the explicit Unicode counterpart and leaves the existing baseline byte-identical."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Defer `String.normalize` and case-folding methods"
      rationale =
        "Both depend on Unicode tables (NFC/NFD/NFKC/NFKD normalization, case-folding maps) that aren't carried in MoonBit's `moonbitlang/core` today. Pulling a normalization table inline would dwarf this slice and require a separate vendoring discussion. The `chars` / `codePoints` / `codePointAt` surface covers what fixtures actually need first (iteration + indexing); normalization joins the roadmap as a follow-up."
    }
  }
}

local pklPlatformSemver = new Scenario {
  id = "PKL-123"
  name = "pkl:platform and pkl:semver stdlib modules"
  description =
    "`pkl:platform` is a synthetic stdlib module that exposes a read-only stub view of the host VM (`current.operatingSystem.name`, `current.operatingSystem.version`, `current.architecture.name`, `current.language.version`). The stub hard-codes `stub-os` / `stub-arch` so fixtures are deterministic across CI hosts; a future slice can swap in host-detected values via intrinsics without breaking the API shape. `pkl:semver` exposes the canonical `Version(major, minor, patch)` constructor plus `parse(s)` / `parseOrNull(s)` / `compare(a, b)` / `isLessThan` / `isGreaterThan` / `isEqualTo`. Both `parse` paths forward to `_pkl_semver_parse(_or_null)` intrinsics that decompose the SemVer 2.0 grammar (`MAJOR.MINOR.PATCH[-PRE][+BUILD]`) into a `{ major, minor, patch, preRelease, build }` ObjectValue. The comparison helpers forward through `_pkl_semver_compare`, which compares numeric core fields and then applies SemVer pre-release ordering (numeric identifiers numerically; alphanumeric lexicographically; numeric < alphanumeric; fewer identifiers < more; pre-release < release)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-080" }
  tags { "stdlib"; "platform"; "semver" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Hard-code platform stub values rather than detect host OS via intrinsics"
      rationale =
        "MoonBit's `@env` exposes env-vars but no host OS / arch detection. Adding an FFI shim per backend (js / native / wasm) would balloon the slice; the alternative — leaving the call returning `null` until a backend lands — would block fixtures from observing any deterministic value at all. Hard-coding `stub-os` / `stub-arch` keeps the API surface intact and gives fixtures stable assertions. A future slice can replace the constants with `_pkl_platform_os_name()` intrinsics without changing user-facing pkl code."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Implement SemVer parsing and comparison as MoonBit intrinsics, not pure pkl"
      rationale =
        "Parsing `1.0.0-alpha.1+build.42` in pure pkl would require a `String.toInt()` helper plus error-recovery logic for `parseOrNull`; the SemVer pre-release ordering rule (numeric < alphanumeric, fewer < more) is non-trivial enough that mirroring it twice (in pkl and in tests) would risk drift. Routing through `_pkl_semver_parse` / `_pkl_semver_compare` intrinsics keeps the spec-compliant logic in MoonBit where unit tests can target it directly, while the public surface (`semver.parse`, `semver.isLessThan`) remains identical to Apple Pkl's."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Represent Version as an anonymous ObjectValue, not a dedicated Value variant"
      rationale =
        "A dedicated `SemverValue` variant would buy nothing — every consumer (renderer, .field access, equality) already handles ObjectValue uniformly. The five-field shape `{ major, minor, patch, preRelease, build }` round-trips through the existing ObjectValue / ValueMember plumbing. The trade-off is type-checking: a typed `Version` class with property declarations would let the typechecker reject `v.banana`, but adding that requires either a real ClassValue or a synthetic class binding the import system doesn't have yet. Deferred to a follow-up."
    }
  }
}

local readNullable = new Scenario {
  id = "PKL-103"
  name = "nullable read form"
  description =
    "Apple Pkl's `read?(uri)` mirrors `read(uri)` but returns `null` instead of pushing a diagnostic when the URI scheme is rejected by the sandbox or the resource is missing. The parser recognises `?` followed by `(` after a primary expression and emits a new `NullSafeCallExpr(callee, args)` AST node; the evaluator handles the `read?` case by routing through `eval_read_uri` with a throwaway diagnostic sink — anything that would have surfaced an error becomes `NullValue` instead. The typechecker reports the result as `NullableType(StringType)` so downstream nullable chains see the right shape. A `?` not followed by `(` stays the existing unsupported-syntax fall-through."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-098" }
  tags { "parser"; "evaluator"; "read"; "nullable" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Introduce a generic `NullSafeCallExpr` even though only `read?` is wired"
      rationale =
        "Apple Pkl's `f?(...)` is a generic null-safe call form — `read?` is the only intrinsic that uses it today but the AST node generalises so future intrinsics (`import?`, `getProperty?`, etc.) can plug into the same dispatch arm without parser changes. Encoding the form as a separate Expr variant rather than overloading `CallExpr` with a flag keeps every existing CallExpr consumer untouched."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Reuse `eval_read_uri` with a throwaway diagnostic sink"
      rationale =
        "The non-nullable `read` path already encodes the sandbox policy and the env-var lookup. Routing `read?` through the same helper with a local `probe_diagnostics : Array[Diagnostic]` avoids duplicating the sandbox-rejection logic. Diagnostics raised during the probe are dropped (they're not user-visible — the user explicitly asked for the null-safe form) and the result is collapsed to `Some(NullValue)` on failure."
    }
  }
}

local pklMathFloatOps = new Scenario {
  id = "PKL-120"
  name = "pkl:math Float operations"
  description =
    "`pkl:math` exposes the Float-side helpers `sqrt`, `pow`, `log`, `exp`, `floor`, `ceil`, `round`, `sin`, `cos`, `tan`, `atan`, `atan2`, plus the constants `pi` and `e`. The synthetic `pkl:math` source forwards each public name to a `_pkl_math_<op>` intrinsic identifier; the CallExpr dispatcher in `eval.mbt` intercepts those names, evaluates the numeric arguments (Int promotes to Double), and computes the result via MoonBit's `math` module (or the `Double` intrinsics for `sqrt` / `floor` / `ceil` / `round`). Existing Int helpers (`maxInt32`, `minInt32`, `abs`, `min`, `max`) stay unchanged."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-092" }
  tags { "stdlib"; "pkl-math"; "float" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Forward through `_pkl_math_<op>` intrinsics rather than tagging FunctionValues"
      rationale =
        "An alternative is to add a `BuiltinFunctionValue(String)` Value variant that the runtime recognises directly. That would duplicate the existing FunctionValue dispatch path and require a new pattern in every place a callee is evaluated. Keeping the public surface as a regular Pkl lambda (`sqrt = (x) -> _pkl_math_sqrt(x)`) lets the existing FunctionValue / CallExpr machinery handle the dispatch; the intrinsic name is just one more case in the global identifier table that already holds `throw`, `read`, `trace`, `Regex`, `List`, `Set`, `Map`, `Pair`."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Reuse MoonBit's Double intrinsics for sqrt / floor / ceil / round"
      rationale =
        "`Double::sqrt` / `Double::floor` / `Double::ceil` / `Double::round` are method intrinsics on `Double`, not free functions in `@math`. Calling them as methods keeps each math op a one-liner without indirecting through a wrapper."
    }
  }
}

local superMethodCall = new Scenario {
  id = "PKL-117a"
  name = "super method call"
  description =
    "`super.method(args)` inside a subclass method body dispatches to the parent class's implementation while keeping the current `this`. `eval_class_method_call` pushes a synthetic `@current_class` marker onto the method cache when it enters a class body; `eval_super_method_call` reads that marker, looks up the class binding's `parent_name`, finds the named method on the parent, and invokes it with the same receiver members plus the freshly bound parameters. Errors surface cleanly when `super` is used outside a class body, when the current class has no parent, or when the parent class doesn't define the method. The abstract-method enforcement and override-direction type compatibility halves of PKL-117 remain on the original ticket — the dispatch slice unblocks the most common usage in pkspec adapters."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-040" }
  tags { "evaluator"; "inheritance" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary =
        "Encode the current class on the method cache via a synthetic `@current_class` marker"
      rationale =
        "Threading a `current_class : String?` argument through every eval call (and the recursive helper that follows) would touch dozens of signatures across `eval_expr_with_bindings`, `apply_function_value`, and the constraint check pipeline. Stashing the value on the method cache as a Value-typed entry under a key that can't collide with a user identifier (`@` prefix — the lexer keeps `@` as its own token) reuses an existing scope mechanism with one push at entry and one lookup inside `eval_super_method_call`."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Defer abstract enforcement and override-direction checks"
      rationale =
        "Both checks are typecheck-side: scanning all transitive parents for `body is None` abstract slots, and unifying override-direction subtype rules across method parameters / return types. Each is a non-trivial typecheck pass that's better landed when there are tests to anchor it. The dispatch slice covers the runtime path; the diagnostic for an abstract method without an override already fires at the call site (`method <name> has no body`)."
    }
  }
}

local constraintComposition = new Scenario {
  id = "PKL-128c"
  name = "constraint predicate composition"
  description =
    "Multi-argument constraint annotations like `Int(isPositive, isLessThan(10))` already split into per-predicate parts; this slice adds whitespace trimming so each part is dispatched with the surrounding spaces stripped (`pkl_int_constraint_predicate` no longer needs to defend against leading / trailing tabs). The lone-`&` predicate-composition form that some Pkl-adjacent dialects use isn't part of upstream Apple Pkl syntax — its formatter rejects `&` here — so this slice intentionally stops at the comma-separated form Apple Pkl supports."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-076" }
  tags { "parser"; "constraints" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Defer the lone-`&` composition operator"
      rationale =
        "Apple Pkl's official formatter rejects a bare `&` in constraint position (`Did you mean &&?`), and no upstream stdlib module uses the form. Implementing it on the pkl-mbt side would create a corpus pkl-mbt accepts but Apple Pkl rejects, which works against the round-trip goal. Comma-separated multi-args cover every composition case Apple Pkl actually supports; `&&` inside `this`-style expression predicates is a separate evaluator concern unrelated to splitting."
    }
  }
}

local scientificFloatAndHeredoc = new Scenario {
  id = "PKL-128b"
  name = "scientific Float and triple-quoted heredoc"
  description =
    "Two parser-surface extensions that landed together because they share the lexer's literal-token path. (1) Scientific-notation Float literals — `1e10`, `2.5e-3`, `4E+8`. The lexer extends the existing Int / Float scan with an optional `e` / `E` + sign + digit suffix; `parse_float_text` splits at the exponent, parses the mantissa, then multiplies by 10^exp. (2) Triple-quoted heredoc strings — `\"\"\"<newline>...<indent>\"\"\"`. The lexer captures the whole literal as one `string_token` (three opening `\"`, body, three closing `\"`); `strip_heredoc_indent` then drops the leading newline and dedents each body line by the closing delimiter's indentation. The existing escape decoder still runs on the dedented body so `\\n`, `\\t`, etc. continue to work. String interpolation (PKL-128a) operates on the same dedented body."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-001"; "PKL-128a" }
  tags { "parser"; "lexer"; "string"; "float" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Lex heredoc as one token, dedent at parse time"
      rationale =
        "An alternative is to emit one token per body line so the dedent happens in the lexer. That would scatter indent logic across two stages (lexer for split, parser for unwrap) and break the assumption that one source range corresponds to one token. Keeping the whole literal in one `string_token` mirrors the regular-string path; `strip_heredoc_indent` runs once in `parse_string_literal_text` and shares the escape / interpolation pipeline."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Compute `10^exp` with a multiply loop"
      rationale =
        "MoonBit's stdlib `Double::pow` would be one call, but pkl-mbt's parser is target-agnostic and doesn't currently depend on `moonbitlang/core/math.pow`. A bounded `exp_value`-step multiply loop keeps the parser zero-cost in deps. Scientific exponents in real-world Pkl never exceed a few hundred, so the loop is microseconds at worst."
    }
  }
}

local stringInterpolation = new Scenario {
  id = "PKL-128a"
  name = "string interpolation"
  description =
    "Apple Pkl's `\"... \\(expr) ...\"` string interpolation parses and evaluates. The lexer walks balanced parens (escape- and inner-string-aware) so the outer string's closing `\"` isn't confused with a `\"` inside a `\\(...)` segment. The parser's `parse_string_literal_text` helper splits the inner text at `\\(` boundaries, parses each segment via `parse_source`, and builds an `InterpolatedString(Array[Expr])` AST node — strings with no interpolation collapse back to a plain `StringLiteral` so the hot path stays untouched. The evaluator concatenates each part's `value_to_string_for_join` projection (the helper already used by `Listing.join`). The typechecker reports the result as `StringType` regardless of inner expression types but still walks each part so nested diagnostics surface."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-001"; "PKL-002" }
  tags { "parser"; "evaluator"; "string" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Split-time AST: store alternating segments rather than synthesising `+` chains"
      rationale =
        "An alternative encoding is to translate `\"hello \\(name)\"` into `\"hello \" + name.toString() + \"\"`. That reuses `+` and existing infix machinery, but pkl-mbt's `+` is Int / Float-only — wiring String concat through `+` would need a typechecker rule, an evaluator rule, and a renderer policy. `InterpolatedString(parts)` is an additive AST node that the eval / typecheck / render paths can handle on their own terms without affecting `+` overload resolution. Parser-side this also lets us collapse a no-interpolation string back to `StringLiteral` so the hot path is unchanged for the common case."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Re-enter the parser for each `\\(...)` segment via `parse_source`"
      rationale =
        "An interpolation segment can contain arbitrary Pkl: method calls, nested interpolations, lambdas, etc. Hand-rolling a separate parser for expression-position content would duplicate maintenance. Routing the segment text back through `parse_source` reuses every existing precedence / operator / call rule, including PKL-139 polish (dot-chain across newlines etc.). The cost is one extra `Parser::new` per segment — negligible against the rest of the eval pipeline."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Lexer tracks paren depth + inner-string state for `\\(...)` skipping"
      rationale =
        "The lexer used to close the outer string at the first `\"` it saw, which broke `\"\\(xs.join(\\\", \\\"))\"` — the `\"` inside the inner string call ended the outer prematurely. Walking balanced parens while tracking whether we're inside a nested string literal keeps the outer token intact. Other escapes (`\\n`, `\\t`, ...) still consume two characters as before."
    }
  }
}

local diagnosticSourcePosition = new Scenario {
  id = "PKL-107"
  name = "source position in diagnostics"
  description =
    "Every `Diagnostic` carries `start` / `end` byte offsets into the originating source. The parser sets the offset on every `add_error` site so syntax errors point at the failing token. The CLI's `print_diagnostics_with_source` projects the offset onto a `path:line:column: message` format that editors and IDEs can jump to. Sites that don't have a position yet (most typechecker / evaluator emissions) keep `start = -1`; those still render as just `message` — the migration is incremental. `Parser::current_offset` is now O(1) (cached on the parser struct, incremented by `bump`) instead of summing all preceding token texts on every emit. The helper `diag(message)` covers the common case of an unknown position; explicit `Diagnostic::{ message, start, end }` construction is the path for positioned diagnostics."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-004" }
  tags { "diagnostics"; "position" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Use byte offsets as the canonical position, project to line:column on demand"
      rationale =
        "Tracking `line:column` directly inside `Diagnostic` would require every emit site to know the current source layout, and the CST's natural unit is the byte offset. Storing the offset and projecting it via `offset_to_line_column(source, offset)` at print time keeps each diagnostic small and makes the source-walk a one-shot cost only when the CLI actually formats output. Editors can also use the raw offsets directly when consuming pkl-mbt as a library."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Migrate sites lazily; `-1` is a valid sentinel for unknown"
      rationale =
        "Threading positions through every typechecker / evaluator diagnostic would require carrying `start` / `end` on every `Expr` node. That's a larger refactor (PKL-107 follow-up). The minimum-viable slice wires parser sites only; the helper `diag(message)` returns `start = -1, end = -1` for the rest so the existing 259 emit sites compile without touching them. Future slices can promote sites incrementally — each one becomes more useful as it's positioned."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Cache `byte_offset` on the parser struct for O(1) reads"
      rationale =
        "The original `Parser::current_offset` summed token text lengths from index 0 every call. With ~30K tokens in a stdlib base.pkl and every diagnostic site calling current_offset, the cost would have compounded. Maintaining `byte_offset` incrementally on `bump` (and on the lone `self.pos = trivia_end` jump used by the multi-line dot-chain handler) keeps the diagnostic-emit path constant-time."
    }
  }
}

local rendererConverters = new Scenario {
  id = "PKL-105"
  name = "renderer converters"
  description =
    "`output { renderer = new JsonRenderer { converters { [\"path.to.field\"] = (value) -> ... } } }` rewrites the value at the named dotted path before the renderer serialises the module. Each converter is a `(value) -> newValue` lambda; `eval_program` collects the path-keyed converters from the post-eval result's `output.renderer.converters` MappingValue, then walks the value tree applying `apply_function_value(callback, [matched_node])` at each matching path. Both `ObjectValue` members and `MappingValue` entries with `StringValue` keys participate; unmatched paths are silently skipped (matching Apple Pkl's lenient behaviour). Class-keyed converters (`[\"MyClass\"] = ...`) are recognised but deferred — pkl-mbt's `ObjectValue` doesn't yet carry its source class. The `parse_object_member` brace-body parser now delegates to `parse_inferred_new_body` (mirroring the property-decl fix in PKL-137) so `converters { [\"k\"] = v }` parses as a mapping rather than an object body that silently drops bracket-keyed entries."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-104" }
  tags { "renderer"; "converter" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Apply converters in eval_program's post-processing pass rather than at render time"
      rationale =
        "An alternative is to thread converters into the renderers themselves (`render_value_as_json` etc.) so each format applies them just before serialising each node. That's the design Apple Pkl uses, but it requires every renderer to accept an `Array[(path, callback)]` parameter and an eval context to invoke the callback. Doing it once at the end of `eval_program` keeps the converters in the eval pipeline where `apply_function_value` is already in scope, and every renderer downstream sees the already-converted tree. The cost is that converters can't see the partially-rendered form of a node (they always see the source Value) — that's exactly Apple Pkl's contract."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Defer class-keyed converters until ObjectValue carries source class"
      rationale =
        "PKL-104 chose AST-side detection of the renderer class precisely because ObjectValue doesn't tag its source class. Class-keyed converters (`[\"MyClass\"] = ...`) need that tag to match values. Wiring class-keyed entries today would require visiting every TypedObjectLiteral eval site to attach the class name — a much bigger change. Apple Pkl's path-keyed form covers the common cases (single-field rewrites, format conversions) and unblocks the renderer.converters surface; class-keyed lands when PKL-119's variant split arrives or when an explicit class tag is added."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Walk `parse_object_member` brace bodies through `parse_inferred_new_body`"
      rationale =
        "Without this change, `converters { [\"k\"] = v }` inside `new JsonRenderer { ... }` parses as an empty ObjectLiteral — the object-body parser doesn't know about bracket-keyed entries. Delegating to the same inferred-body dispatcher PKL-137 uses for module-level property bodies fixes nested mappings (and listings) inside class amend bodies as a free side effect. The behaviour was already correct for module-level `tests { ... }` after PKL-137; this slice extends it to nested members."
    }
  }
}

local outputRendererDriver = new Scenario {
  id = "PKL-104"
  name = "output renderer driver"
  description =
    "The CLI's `eval` command picks its rendered format from the module's `output { renderer = new JsonRenderer { ... } }` block when the user did not pass `-f` / `--format`. The renderer's class name is read directly from the parsed AST — `parse_source(source).program.bindings` is walked for an `output` binding whose `ObjectLiteral` body has a `renderer` member; the renderer's `TypedObjectLiteral(class_name, _)` (or an `AmendExpr` peeling back to one) maps onto the existing format string (`JsonRenderer` → `\"json\"`, `YamlRenderer` → `\"yaml\"`, `PropertiesRenderer` → `\"properties\"`, `PcfRenderer` → `\"pcf\"`). The eval result's `ObjectValue` does not carry the source class, so this path stays AST-driven rather than tagging values. The `output` block itself is then stripped from the rendered envelope by `extract_output_value` (when there's no explicit `output.value` subtree) so the renderer doesn't echo its own configuration. An explicit `-f` flag still wins over the renderer-class detection so existing fixtures behave unchanged."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-097" }
  tags { "renderer"; "output"; "driver"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Read the renderer class from the parsed AST, not from a tagged ObjectValue"
      rationale =
        "A more general design tags every `ObjectValue` with its source class name so `new JsonRenderer {...}` survives the eval pipeline as a class-bound value. That would touch every `ObjectValue` pattern match across eval / typecheck / render — a substantial refactor. Reading the class straight from the parsed `TypedObjectLiteral` in the module's `output.renderer` slot is a tight, AST-local solution that lands the user-facing feature without the platform churn. When PKL-119 introduces dedicated value variants for Set / Pair / Map, an OO-aware tag may emerge organically; until then the simpler design pulls its weight."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Strip the `output` block from the rendered envelope"
      rationale =
        "Apple Pkl treats `output` as a module-level control block: it doesn't appear in the module's rendered output. The pre-existing `extract_output_value` only stripped the envelope when `output.value` was explicit; now it strips the `output` member whenever it's present (with no `output.value`), so `output { renderer = ... }` no longer round-trips its own configuration into the JSON / YAML / etc. output. The behaviour is consistent across renderers — every format sees the same `value` payload."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Explicit `-f` always wins"
      rationale =
        "Test fixtures and the upstream gold-diff workflow rely on `-f json` / `-f yaml` overriding the module's declared renderer. Honoring the `output.renderer` only when `-f` is absent keeps every existing test green while letting end users drop the flag once their module declares its target format."
    }
  }
}

local amendsBaseMerge = new Scenario {
  id = "PKL-137"
  name = "amends base module property and type merge"
  description =
    "`amends \"base.pkl\"` / `extends \"base.pkl\"` flows the base module's typealiases and class declarations into the child's unqualified type scope, in addition to the property values that PKL-006 already merged at eval time. (1) `infer_program` resolves `program.module_relation`, calls `resolve_import_types(relation.uri)`, and seeds the child's `type_env` with the base's `TypeExport`s so a bare `Test` annotation in the child resolves to the base's `class Test`. (2) `type_exports_from_parse_result` now exports `TypeAliasDeclaration`s alongside `ClassDeclaration`s. (3) `collect_declared_types_with_imports` falls back to `type_from_annotation` (not just `builtin_type_from_annotation`) so union / constrained / nullable alias targets resolve. (4) `type_from_annotation` strips a balanced outer paren wrapper before dispatch so target text like `(\"draft\" | \"review\" | \"approved\")` splits correctly. (5) `builtin_type_from_annotation` recognises a quoted string literal in type position as `StringType` so string-literal union types (`\"critical\" | \"major\" | \"minor\"`) resolve. (6) `type_accepts` admits an empty `ObjectType([])` against `ListingType(_)` / `MappingType(_)`. (7) `parse_property_decl` routes a brace-bodied amend (`tests { entry }`) through `parse_inferred_new_body` so the body shape follows the first significant token."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-006"; "PKL-118"; "PKL-138" }
  tags { "evaluator"; "typechecker"; "amends"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Inject relation type exports unqualified"
      rationale =
        "Apple Pkl's `amends` brings the base's names into the child's scope without a prefix, unlike `import \"base\" as base` which exposes them as `base.Foo`. Mirror that: the relation's TypeExports are pushed straight into the child's `type_env` with their original names. The `imported_type_bindings` path (qualified) keeps working for explicit `import` declarations."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Approximate string-literal types as `StringType`"
      rationale =
        "A full string-literal type would need a refined `StringLiteralType(String)` variant + narrowing in `type_accepts` + render adjustments. Collapsing each literal to `StringType` lets union typealiases (`\"critical\" | \"major\" | \"minor\"`) typecheck cleanly. A future slice can add the refined variant if call sites need it."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Empty `new {}` typecheck coercion mirrors PKL-138 eval coercion"
      rationale =
        "PKL-138 already coerced an empty `ObjectValue([])` to `ListingValue([])` / `MappingValue([])` at eval time. The typechecker had no matching rule, so `tests: Listing<Test> = new {}` typechecked as `Listing<Test> does not accept Object`. Adding the corresponding rule in `type_accepts` keeps the two phases in sync."
    }
  }
}

local stdlibModifiers = new Scenario {
  id = "PKL-140"
  name = "Apple Pkl stdlib declaration modifiers"
  description =
    "Parser and evaluator accept four Apple Pkl stdlib idioms that previously tripped `unsupported expression` / `missing expression body` / `expected type parameter, got in`. (1) `external` modifier on properties / classes / functions: already recognised by `is_modifier_text` and consumed by `skip_member_header`; the gap was the resulting property with no `=` body, which the parser now flags as an abstract slot. (2) Abstract property slots (`foo: Int?`): the parser sets a new `Binding.abstract_slot = true` field, stores a `NullLiteral` placeholder value, and both evaluator + typechecker skip the binding (eval: not pushed onto ObjectValue; typecheck: type recorded as the declared slot type, no validation against the placeholder). (3) Variance modifiers `<in T>` / `<out T>` on class / function / typealias type parameters: parser consumes the modifier before the identifier; pkl-mbt treats type parameters invariantly so the marker is purely a parse-side acknowledgement. (4) Function type annotations on properties (`comparator: (V, V) -> Boolean = ...`): new `parse_property_type_annotation` helper uses `stop_at_arrow=false` because property declarations end at `=` / `{`, making the arrow unambiguous. The same helper is wired into class-property declarations. (5) Declarations-only modules (`module pkl.math` with only `external` properties) now evaluate to the empty ObjectValue rather than `missing expression body`, mirroring Apple Pkl's stdlib loading model."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-001"; "PKL-002"; "PKL-116" }
  tags { "parser"; "evaluator"; "typechecker"; "stdlib" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary =
        "Promote abstract slots to a dedicated `Binding.abstract_slot` flag rather than a sentinel Expr"
      rationale =
        "An alternative is to overload `UnsupportedExpr` for the abstract case, but then every eval / typecheck arm has to disambiguate `legitimate abstract slot` from `parse failure`. A dedicated boolean keeps the two cases factored and lets the parser still emit `UnsupportedExpr` for actual parse errors."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Variance modifiers are parsed but not enforced"
      rationale =
        "Apple Pkl's variance semantics (`out T` covariant, `in T` contravariant) interact with the typechecker's subtype relation. pkl-mbt is fully invariant under the hood and the test suite doesn't exercise variance-dependent assignments yet. Accepting the modifier without enforcing it unblocks every stdlib class declaration immediately; correctness is a future slice once subtype-relation tests are in place."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Function type annotations only accept arrows in property position"
      rationale =
        "`parse_type_annotation` defaults to `stop_at_arrow=true` because lambda parameter type annotations (`(x: Int) -> x + 1`) need the arrow to terminate the type so the lambda body starts. Property declarations always end the type at `=` or `{`, so the arrow is unambiguous there. Splitting the helper into `parse_property_type_annotation` (arrow allowed) and `parse_type_annotation` (arrow stops) keeps each call site honest."
    }
  }
}

local httpsImports = new Scenario {
  id = "PKL-129"
  name = "URI imports via https with mizchi/x/http"
  description =
    "`import \"https://...\"` and the entry-point path resolve through `mizchi/x/http.get` running under a `moonbitlang/async` event loop. The CLI's `main` is now `async fn main`, so `load_path` can await the fetch directly — no `run_async_main` wrapper / Ref-capture dance. Both native and JS targets ship a working fetcher (mizchi/x supplies a socket-backed implementation on native and a `fetch`-backed one on JS, both behind the same `@http.get` surface). The WASM target prints a clear diagnostic — WASI support is the follow-up. `package://` URIs (Apple Pkl's registry protocol — zipball metadata + per-file path fragments) are recognised by the dispatcher but always raise; pointing the import at the raw GitHub URL is the workaround until that slice lands."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-006" }
  tags { "parser"; "imports"; "sandbox"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary =
        "Convert the CLI `main` to `async fn main` rather than wrapping each fetch in a sync trampoline"
      rationale =
        "The first cut used `@async.run_async_main(() => { ... })` to capture the fetch result into a `Ref` from a sync `fn main`. That works on native (the native event loop blocks until the closure returns), but on JS `run_async_main` only schedules — the result `Ref` is still `None` when control returns to the caller. Promoting `fn main` to `async fn main` lets the call site `await` the fetch directly under both target's event loops without a target-specific trampoline. The downside is `load_path` and `load_expr_imports` become async too, but they were already in a single call tree with no real recursion-vs-async incompatibility."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Defer `package://` URI resolution to a follow-up"
      rationale =
        "Apple Pkl's `package://` scheme resolves through `pkg.pkl-lang.org`'s registry protocol: fetch package metadata JSON, locate the zipball URL, fetch + extract the zipball, then look up the path fragment inside. That's a separate slice in its own right (zip unpacker, path-fragment routing, signature checking). Shipping the recognition + clear diagnostic now keeps imports honest: `import \"package://...\"` no longer falls through to the filesystem reader (which would emit `failed to read package://...` — meaningless), and the diagnostic points at the workaround (use the raw https URL of the .pkl file)."
    }
    new Decision {
      date = "2026-05-16"
      summary = "WASM target prints the unsupported message instead of falling back to JS"
      rationale =
        "WASM doesn't have a native HTTP client today; the bundled WASI variant of fetch is still in flux upstream. mizchi/x ships a `NotSupported` stub on WASM, and propagating that to the CLI as a clear message lets users see what's missing rather than fighting an opaque error. When WASI sockets stabilise, the WASM stub extends to wrap a WASI-backed fetcher."
    }
  }
}

local pkspecPolish = new Scenario {
  id = "PKL-139"
  name = "parser and evaluator polish for pkspec"
  description =
    "Running pkspec's `pkl/Test.pkl` through pkl-mbt surfaced five drive-by parser / evaluator gaps that have nothing to do with one big subsystem but together blocked the file from evaluating. They are bundled here so a single slice unblocks the empirical pkspec round-trip: (1) `@ModuleInfo { ... }` brace-bodied annotations skip the `{ ... }` payload the same way `@Deprecated(\"...\")` skips parens — Apple Pkl's module / class metadata uses the brace form. (2) `typealias Foo =\\n  String(...)` allows the RHS to start on the next line; `parse_typealias_decl` now uses `skip_trivia` after the `=` so newlines are consumed. (3) Postfix dot-chains break across newlines (`xs\\n  .toList()\\n  .map(...)`); `parse_postfix_expr` peeks past trivia and, when the first significant follow-up token is `.` / `?.`, advances the cursor before continuing. (4) `module.foo` is Apple Pkl's self-reference to the current module's `foo` binding; the parser emits `Identifier(\"module\")` and the evaluator short-circuits `MemberAccess(Identifier(\"module\"), name)` to `resolve_binding_value(name, ...)`. (5) The stdlib constructor functions `List(...)`, `Set(...)`, `Map(k1, v1, k2, v2, ...)`, and `Pair(a, b)` are recognised before the generic call-path runs: `List` and `Set` produce `ListingValue` (Set dedupes), `Map` builds a `MappingValue`, `Pair` collapses to a 2-element `ListingValue` until PKL-119 introduces a dedicated `PairValue`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-001"; "PKL-002"; "PKL-138" }
  tags { "parser"; "evaluator"; "stdlib"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Bundle five independent gaps into one slice rather than five mini-slices"
      rationale =
        "The gaps were found by a single empirical exercise (`moon run cmd/mpkl -- eval pkspec/pkl/Test.pkl`) and each one in isolation gates the next: if `@ModuleInfo` isn't skipped, the module never parses; if the typealias RHS doesn't accept newlines, the type system never sees the constraints; if the dot-chain doesn't follow newlines, the body bindings fail; if `module.foo` isn't a self-reference, `output { value.defaults = module.defaults }` errors; if `List(...)` isn't a constructor, every cross-reference check in Test.pkl falls over. Splitting them into individual tickets would require five separate Roadmap entries that each only make sense in the context of the others. The bundle is small enough (one parser arm and four eval arms per gap) to stay reviewable in one commit."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Skip brace-bodied annotations rather than capture metadata"
      rationale =
        "Apple Pkl's `@ModuleInfo { ... }` carries metadata (min Pkl version, doc, etc.) that the runtime doesn't enforce inside an evaluator — it's primarily for tooling (`pkldoc`, codegen). pkl-mbt doesn't carry annotation metadata into the AST yet (PKL-128 is the slice that would). Skipping the body is the conservative move: it unblocks the file without storing data that nothing consumes. When the annotation surface lands, the skipper extends to a captured `AnnotationDecl` AST node."
    }
    new Decision {
      date = "2026-05-16"
      summary =
        "`Pair(a, b)` collapses to a 2-element ListingValue rather than blocking on PairValue"
      rationale =
        "Apple Pkl's `Pair` is a structurally distinct stdlib type with `.first` / `.second` accessors. pkl-mbt doesn't have `PairValue` yet (PKL-119 is the future slice that splits Set / Pair / Map / IntSeq into dedicated variants). Until then, returning a 2-element `ListingValue` keeps the constructor call passing without introducing a half-baked third variant. Downstream code that depends on `.first` / `.second` will still error, but the construction itself no longer fails parser-side — which is what unblocks the pkspec evaluation path that just passes Pair values through unchanged."
    }
  }
}

local newBodyInference = new Scenario {
  id = "PKL-138"
  name = "new body inference from first token and binding annotation"
  description =
    "Apple Pkl writes `tests: Listing<Test> = new { ... }` and `m: Mapping<K, V> = new { ... }` without an explicit `Listing` / `Mapping` qualifier on `new`. The parser previously dispatched `new { ... }` (empty type prefix) unconditionally to `parse_object_body`, so bare-expression bodies parsed as zero members (the property-decl loop skipped them) and empty bodies came back as `ObjectValue([])` that failed every Listing / Mapping method. The new `parse_inferred_new_body` helper peeks the first significant token inside the brace: `[` → mapping body, `}` / `local` / `when` / `for` / property-decl / `hidden ident` / `fixed ident` → object body, anything else (literal / `(` / unary / `new` / identifier without property suffix) → listing body. For the empty-body case the parser still produces `ObjectLiteral([])`; the evaluator's `coerce_value_to_annotated_type` helper then projects it to `ListingValue([])` / `MappingValue([])` when the binding's type annotation requires it. Coercion runs at every binding eval site (`resolve_binding_value`, module-level binding loop, `eval_object_members`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-005" }
  tags { "parser"; "evaluator"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Peek-based dispatch in the parser, type-driven coercion in the evaluator"
      rationale =
        "An alternative is to parse `new { ... }` into a single FlexibleLiteral variant that captures both bare expressions and object members, then disambiguate at typecheck / eval time. That preserves more information but requires touching every consumer of `ObjectLiteral` / `ListingLiteral` / `MappingLiteral`. The peek approach covers all non-empty cases at parse time (the body shape is unambiguous when the first item is concrete), and only the empty body needs the type-driven fallback. Two narrow integration points (parser peek + eval coercion) rather than threading a new AST variant through every stage."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Coerce only empty `ObjectValue([])` to `ListingValue([])` / `MappingValue([])`"
      rationale =
        "A non-empty `ObjectValue` with a `Listing<T>` annotation is a real type mismatch — the body had real members (`name = ...`), so it can't be a listing. Limiting coercion to empty values keeps the diagnostic surface honest: legitimate type errors still surface, only the parse-time ambiguity around `new {}` gets smoothed over. The coercion runs before the constraint / annotation check so the post-coerced value is what gets validated, mirroring upstream's semantics where `new {}` is a polymorphic empty literal."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Include `Set<T>` in the coercion table, folding to `ListingValue([])`"
      rationale =
        "`Set` doesn't have a dedicated value variant yet (PKL-119 is the future slice that splits Set / Pair / Map / IntSeq), so coerce empty `new {}` annotated as `Set<T>` to `ListingValue([])` for now. The runtime behaviour matches how pkl-mbt already collapses Listing / List into a single variant. When PKL-119 ships, the table extends to a dedicated `SetValue([])` arm."
    }
  }
}

local whenConditionalProperty = new Scenario {
  id = "PKL-136"
  name = "when conditional property in Listing / Mapping bodies"
  description =
    "Apple Pkl's `when (cond) { ... } [else { ... }]` form is recognised inside Listing and Mapping bodies as well as object bodies. The parser wraps each block in a new `WhenSpread(ConditionalExpr(cond, then_body, else_body))` Expr variant whose branches reuse `ListingLiteral` / `MappingLiteral` (matching the surrounding context). The evaluator's `ListingLiteral` and `MappingLiteral` arms recognise `WhenSpread` during element / entry iteration and spread the selected branch's contents into the parent collection instead of attaching it as a nested value. Object body `when` was already wired in an earlier slice via the synthetic `@when` ObjectMember; the new variant is additive. A drive-by parser fix in `parse_object_expr` recognises `new Listing<T> { ... }` / `new List<T> { ... }` / `new Mapping<K, V> { ... }` as listing / mapping bodies — previously the generic-tagged forms fell into the `TypedObjectLiteral` arm and silently parsed the body as object members, dropping everything inside."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-001"; "PKL-002" }
  tags { "parser"; "evaluator"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Introduce a single `WhenSpread(Expr)` variant rather than per-collection wrappers"
      rationale =
        "An alternative is per-collection sum types (`enum ListingBodyItem { Element; When }`, `enum MappingBodyItem { Entry; When }`), which models the body more precisely but requires churning every push-site of `Array[Expr]` / `Array[MappingEntry]`. The `WhenSpread(Expr)` wrapper rides on the existing `Array[Expr]` / `Array[MappingEntry]` shapes by letting the wrapped Expr be a `ConditionalExpr` whose branches are `ListingLiteral` / `MappingLiteral`. The evaluator pattern-matches `WhenSpread` during iteration, evaluates the inner conditional, then unpacks the resulting `ListingValue` / `MappingValue` and spreads. Two arms in eval + two in the parser, no shape refactoring."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Reuse `ConditionalExpr` inside `WhenSpread` rather than a dedicated when-AST node"
      rationale =
        "`when (cond) { then } else { else }` is operationally a `ConditionalExpr` whose branches happen to be collection literals. The evaluator already handles `ConditionalExpr` — we just need the outer marker (`WhenSpread`) to tell the listing / mapping iteration arm to spread the result. Defining a separate `WhenExpr(Expr, Expr, Expr)` node would duplicate the conditional evaluation path. The mismatch with the object-body `@when` machinery (which uses a synthetic ObjectMember name as the marker) is intentional: object members already have a `String` discriminator (the name), so the marker fits there; listing elements / mapping keys don't, so the marker has to be an Expr variant."
    }
    new Decision {
      date = "2026-05-16"
      summary = "Fix `new Listing<T> { ... }` parsing in this slice"
      rationale =
        "pkspec's `specRef = new Listing<String> { when (s.id != null) { s.id } }` uses the typed listing form. Without the parser fix the body silently parses as object members and the `when` block never reaches the listing evaluator. The fix is mechanical (`type_name.has_prefix(\"Listing<\")` → `parse_listing_body`) and unblocking it inside PKL-136 keeps the slice useful end-to-end; if pulled out to a separate ticket the slice ships a feature that doesn't actually work on the pkspec call sites that motivated it."
    }
  }
}

local listingMappingFunctional = new Scenario {
  id = "PKL-135"
  name = "Listing and Mapping functional methods"
  description =
    "Higher-order predicate / search / flatten methods on `Listing` and `Mapping` resolve and run end-to-end. `Listing` gains `flatMap`, `count`, `every`, `any`, `none`, `find`, `findOrNull`, `findLast`, `findLastOrNull`; `Mapping` gains `every`, `any`, `none`, `count` whose predicates take `(Key, Value) -> Boolean` (matching upstream's signature). Each method is wired through `is_listing_method_name` / `is_mapping_method_name` plus `eval_listing_method` / `eval_mapping_method`, reusing `apply_function_value` to invoke the user lambda per element. `find` raises a diagnostic when no element matches (mirroring Apple Pkl's behaviour), `findOrNull` and `findLastOrNull` return `NullValue` instead. `flatMap` accepts callbacks returning Listing only — the `Collection<Result>` union (List / Listing / Set) is collapsed onto `ListingValue` today, so the constraint is the runtime shape of the result rather than the declared type."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-134" }
  tags { "stdlib"; "evaluator"; "typechecker"; "pkf-pkspec" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-16"
      summary = "Skip `noneMatch` — Apple Pkl spells it `none`"
      rationale =
        "PKL-135's roadmap text mentioned `noneMatch` as a synonym, but Apple Pkl's stdlib only defines `none(predicate) -> Boolean`. The Java Stream API uses `noneMatch`; introducing the alias here would create a Pkl-incorrect surface. Implementing only `none` keeps the surface byte-aligned with Apple Pkl. If someone later wants the Stream-API spelling it can be added as a one-line alias arm."
    }
    new Decision {
      date = "2026-05-16"
      summary = "`find` raises a diagnostic when no match, `findOrNull` returns null"
      rationale =
        "Apple Pkl's `find` throws if no element matches; the `OrNull` variant exists precisely to avoid the throw. pkl-mbt mirrors that split by pushing a diagnostic and returning `None` (which aborts the evaluation) when `find` runs through the whole collection without a hit, and by returning `NullValue` for the `OrNull` variants. Collapsing both into a silent `NullValue` would diverge from upstream and hide bugs."
    }
    new Decision {
      date = "2026-05-16"
      summary = "`flatMap` rejects non-Listing callback results"
      rationale =
        "Upstream `flatMap` accepts a `Collection<Result>` (List | Listing | Set). pkl-mbt collapses those into `ListingValue`, so we only need to recognise that variant. Anything else (Int, String, ObjectValue, ...) is almost certainly a user bug; raise a clear diagnostic rather than silently coercing. When PKL-119 splits Set / Pair into their own variants, the arm extends to recognise the new variants without changing the call-site grammar."
    }
  }
}

local equalityTypecheckOperandMatch = new Scenario {
  id = "PKL-113"
  name = "equality typecheck operand match"
  description =
    "The typechecker rejects `==` and `!=` when the operand types are statically distinct. Today's typechecker returned BoolType unconditionally, so `5 == \"hi\"` and `true != 3` typechecked clean and only failed at runtime (or rather, silently returned `false`). The new pass routes through a dedicated `equality_compatible(left, right)` helper that admits the wider compatibility relation Apple Pkl exhibits for equality: numeric mix (Int vs Float, e.g. `1 == 1.0` is `true` in upstream), nullable / non-null match (`name: String? = null; name == null`), same-name `ClassType` pairs, structural `ObjectType` / `ListingType` / `MappingType` matches, and any pair where either side is `UnknownType` or a free `TypeVariable(_)`. `ConstrainedType` / `DefaultedType` wrappers are stripped via `equality_unwrap_type` before the case match so `Int(isPositive) == 5` still compares as `Int == Int`. `UnionType` flows through the existing fan-out: a union accepts the other side if any of its options does. The helper is symmetric — both `5 == \"hi\"` and `\"hi\" == 5` raise `operator == expects operands of matching types`, and the same wording is reused for `!=`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-004" }
  tags { "typechecker"; "equality" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Use a dedicated `equality_compatible` helper rather than reusing `type_accepts`"
      rationale =
        "`type_accepts(expected, actual)` is one-directional: it answers `does an actual fit where an expected was declared?`. Equality is symmetric and admits Int / Float as compatible operands, which `type_accepts` deliberately rejects (assigning an Int into a Float-typed binding is a type error). Bolting Int / Float symmetry onto `type_accepts` would weaken assignment checks elsewhere. A separate helper keeps the two concepts cleanly factored — `type_accepts` for assignment / argument flow, `equality_compatible` for the symmetric equality relation."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Mirror Apple Pkl's `1 == 1.0 == true` rather than rejecting Int / Float pairs"
      rationale =
        "The upstream snippet at `third_party/apple-pkl/.../basic/float.pcf` evaluates `1 == 1.0` to `true`. Rejecting Int / Float at the typecheck layer would diverge from the established surface — users who write `n: Int = 5; n == 5.0` would suddenly need explicit conversions even though the runtime does the right thing. The helper therefore lists `(IntType, FloatType)` and its symmetric pair as compatible, leaving Int / Float as a numeric-mix admission analogous to `LessThan` / `GreaterThan`."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Accept any `ObjectType` / `ListingType` / `MappingType` pair instead of requiring per-element match"
      rationale =
        "Per-element structural equality is the runtime concern (`Object.equals` walks the members at runtime). At the typecheck layer rejecting `{ a = 1 } == { b = 2 }` would surface as a noisy error in valid programs (`map` / `filter` outputs comparing against literals, fixture-style equality checks). The compatibility relation therefore accepts any same-kind structural pair — false positives at this layer mean runtime evaluates to `false`, which matches Apple Pkl's behaviour."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Leave the evaluator untouched"
      rationale =
        "The evaluator already returns `false` for cross-type equality (`IntValue(5) == StringValue(\"hi\")` flows through the catch-all `_ => None` branch which surfaces a diagnostic). PKL-113 just lifts that runtime rejection into the static layer; the evaluator's `Int == Float` mixing (via `eval_float_binary` after widening the Int to Double) already matches the upstream `1 == 1.0 == true` semantics."
    }
  }
}

local callSiteGenericInference = new Scenario {
  id = "PKL-110"
  name = "call-site generic inference"
  description =
    "The typechecker propagates concrete types through generic function calls and class literals. Each `ClassDecl.type_parameters` / `FunctionDecl.type_parameters` entry binds to a new `TypeVariable(name)` variant in the typecheck `Type` enum (previously `UnknownType`). At every call site (`infer_lambda_application` and `infer_function_type_call`) the typechecker walks parameter / argument pairs through `unify_for_substitution`, building a `TypeSubstitution` table that records `TypeVariable(\"T\") := <concrete>` bindings. `substitute_type` then rewrites the inferred return type, the parameter cache entries, and the declared return annotation so the call's result has the concrete type — `identity(7)` typechecks as `Int`, so `identity(7) + 1` succeeds while `identity(\"hi\") + 1` rejects with `operator + expects Int operands`. The class literal path in `apply_type_annotation` does the symmetric move: when the expected `ClassType` still carries TypeVariable members and the inferred `ObjectType` carries concrete member types, `substitute_class_type_variables` unifies and rewrites the class type before returning, so downstream field accesses (`intBox.value`) resolve to the substituted member type. `type_accepts` treats `TypeVariable(_)` on either side as accept-any during the structural pass so unification can run without false rejection; the substitution table is the diagnostic surface. Generic class declarations whose body uses are exhausted at scope exit (e.g. a function body that references T but is never called) still typecheck — the variable simply stays free and renders as its parameter name."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-089"; "PKL-090" }
  tags { "typechecker"; "generics"; "inference" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Promote type parameters to a real `TypeVariable(String)` variant instead of overloading `UnknownType`"
      rationale =
        "PKL-089 / PKL-090 deliberately bound T to `UnknownType` because the substitution machinery was deferred. Now that the machinery exists, `UnknownType` is too coarse: it means 'I don't know this type — accept anything', while a free `T` means 'this site is a parameter — rewrite me at the call site'. Conflating them would either leak `UnknownType` into substituted return types (silently accepting nonsense) or require call-side flags to distinguish them. A dedicated variant is cheaper and lets `render_type` print the original parameter name (`T`) instead of `Unknown`, which is the form Pkl users wrote."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Collect substitutions in a separate pass over parameter / argument pairs"
      rationale =
        "Hindley-Milner-style unification with constraint generation is the textbook approach. A separate accumulating pass keeps the diagnostic surface clean: `type_accepts` still drives argument rejection, `unify_for_substitution` does not raise diagnostics on conflict (it just records the first binding), and `substitute_type` runs at well-defined boundaries (return-from-call, after-class-literal-annotation). This split lets the substitution pass remain non-recursive at the top level — every signature reduces to a finite walk over the parameter list."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Apply class-type substitution inside `apply_type_annotation` rather than at the `TypedObjectLiteral` site"
      rationale =
        "`apply_type_annotation` is the single funnel for `binding: ClassType = new ClassType { ... }`, `binding = new ClassType { ... }`, and `binding: ClassType` (no body). Doing substitution at the funnel guarantees every path benefits — including imports and re-amends that route through the same annotation resolver. Doing it at `TypedObjectLiteral` would miss the `binding: Box<Int> = someBox` annotation form once user-facing generic syntax expands."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Leave the evaluator untouched"
      rationale =
        "Substitution is a typechecker-side phenomenon: at runtime, `new Box { value = 5 }` has always carried `value = IntValue(5)` regardless of T's static binding. The new variant lives in `typecheck.mbt` only, and the evaluator's PKL-090 short-circuit (`eval_type_name_is_type_parameter`) still applies — it never relied on the typechecker's representation of T."
    }
  }
}

local pklTestExamples = new Scenario {
  id = "PKL-100"
  name = "pkl test examples and golden diff"
  description =
    "The native CLI `test` subcommand walks the module-level `examples` member alongside the existing `facts` walker. Each example is rendered through the PCF envelope (`examples { [\"label\"] { ... } }`) and the entire envelope is byte-diffed against a sibling `<file>-expected.pcf` golden file. A passing diff prints `PASS examples (N examples)`; a mismatch prints `FAIL examples diff against <path>` and contributes to the non-zero exit. The `--overwrite` CLI flag regenerates the golden file from the current rendering (printing `OVERWRITE <path>`), matching Apple Pkl's golden-file workflow. Modules without an `examples` member skip the diff entirely so facts-only fixtures keep working unchanged."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-095" }
  tags { "cli"; "pkl-test"; "examples" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Diff the entire `examples` envelope, not per-example sections"
      rationale =
        "A structured per-example golden format would buy granular diff reporting at the cost of inventing a sectioning convention (Apple Pkl uses a custom delimiter scheme). Diffing the whole envelope keeps the implementation portable across renderer formats and the golden file readable as plain PCF. Per-example diff reporting is a follow-up once the envelope baseline is stable."
    }
    new Decision {
      date = "2026-05-15"
      summary = "`--overwrite` flag instead of an environment variable"
      rationale =
        "Apple Pkl uses `--overwrite` to regenerate goldens; matching the flag name keeps the workflow muscle-memory portable. The flag is parsed centrally with the other CLI flags so future subcommands can opt in to the same regeneration channel without inventing parallel flag names."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Compose with the existing facts walker rather than replace it"
      rationale =
        "PKL-095's facts walker is a working contract used by existing fixtures; `examples` is additive. Running both walkers sequentially on the same module keeps the existing fixtures' `PASS addition (N assertions)` lines intact while letting new fixtures add examples on top. Both contribute to the same non-zero exit path so failures of either kind block CI."
    }
  }
}

local cliFormat = new Scenario {
  id = "PKL-099"
  name = "cli format subcommand"
  description =
    "`moon run cmd/mpkl -- format <file>` parses and evaluates the source through the existing `AnalysisSession`, then re-emits the resolved module via the PCF renderer. Whitespace and indentation collapse to the renderer's canonical form (`name = \"hawk\"`, two-space indent inside blocks, separator after `=`). Parse failures and evaluation failures short-circuit with the diagnostic surface used by the other CLI subcommands. The first cut deliberately operates on the evaluated module value rather than the CST, so default values from class declarations and amend chains land in the output; a trivia-preserving idempotent formatter (`render_cst_with_comments`) is a follow-up that reuses the existing CST infrastructure."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-070" }
  tags { "cli"; "renderer"; "format" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Format via the evaluated module + PCF renderer instead of CST round-trip"
      rationale =
        "The PCF renderer already produces byte-for-byte canonical output (matched against Apple Pkl gold on 25 fixtures). Routing `format` through it requires zero new code on the emit side. The trade-off is that comments and original layout are dropped — that's a known limitation, made explicit in the spec description, and the CST infrastructure already exists to upgrade later."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Fail the command on parse / evaluation errors"
      rationale =
        "A formatter that silently emits the original text on failure would hide bugs and break editor save-on-format flows. Failing loudly with the diagnostic surface mirrors what `pkl format` does upstream and lets editors surface the underlying issue."
    }
  }
}

local genericFunctionTypeParameters = new Scenario {
  id = "PKL-090"
  name = "generic function type parameters"
  description =
    "`function identity<T>(x: T): T = x` and `function pair_first<A, B>(a: A, b: B): A = a` parse, typecheck, and evaluate. The parser captures the optional `<T1, T2, ...>` list immediately after the function name on `FunctionDecl.type_parameters`. The module-level `collect_declared_types_with_imports` flattens each function's parameters into the shared `type_env` as `UnknownType` bindings so body uses of `T` resolve without the 'unknown type annotation' diagnostic. The evaluator gains a `eval_type_name_is_type_parameter` short-circuit on both the callable-argument and callable-return validators: when the declared `type_name` matches any class or function type parameter, runtime annotation rejection is skipped wholesale (the parameter accepts any value). Call-site inference of T from the argument type stays deferred — `identity(42)` evaluates to `IntValue(42)` because the body is a literal pass-through, not because the typechecker propagated `Int` through `T`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-089" }
  tags { "typechecker"; "evaluator"; "generics"; "callable" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Flatten function parameters into the module-level `type_env`"
      rationale =
        "Pkl exposes no nested function definitions in user-visible syntax, so all function declarations share a single module scope. A flat injection costs nothing compared with threading a per-function scope through every typechecker helper that touches a body. Name collisions across functions collapse to a single `UnknownType` binding, which is correct under the deferred-inference model — both T's are 'tolerated unknown' until call-site inference arrives."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Short-circuit runtime annotation validators on type parameter names"
      rationale =
        "The runtime callable-argument and callable-return validators reject when `eval_value_accepts_type_annotation` says no. Without an instantiation-time binding, `T` simply is not a concrete type — saying 'accept anything' (matching the deferred-inference posture) is more honest than rejecting all calls to a generic function. The check walks all declarations once per call, which is fine at our declaration counts and cacheable later."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer call-site inference of T to a follow-up slice"
      rationale =
        "True generic inference (propagating the argument type into the body and the return) needs a substitution table that the typechecker can thread through every expression node. That is a substantial refactor and is not on the critical path for fixtures that just need to declare generic functions and have them parse / typecheck / evaluate."
    }
  }
}

local genericClassDeclarations = new Scenario {
  id = "PKL-089"
  name = "generic class declarations"
  description =
    "`class Box<T> { value: T }` and `class Pair<A, B> { first: A; second: B }` parse, typecheck, and evaluate. The parser recognizes the optional `<T1, T2, ...>` list immediately after the class name and stores the parameter names on `ClassDecl.type_parameters`. The typechecker injects each parameter into a class-scoped `type_env` as a binding to `UnknownType`, so body uses of `T` route through the existing unknown-but-tolerated annotation path rather than failing as 'unknown type annotation'. Parent-name lookup (`extends`) and method-body validation also receive the scoped env so a parameter visible in a property type stays visible on a method signature. The evaluator is unchanged: type parameters are a typechecker-only construct in this slice, so instantiating `new Box { value = 5 }` produces an `ObjectValue` whose `value` member carries the actual runtime value. Instantiation-time T-binding (where the typechecker would propagate `Int` through `b.value` after `new Box { value = 5 }`) stays deferred — that lands together with PKL-090's call-site inference."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-040" }
  tags { "typechecker"; "generics"; "class" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Bind type parameters to `UnknownType` rather than introducing a real `TypeVariable` variant"
      rationale =
        "A faithful `TypeVariable` representation would require propagation rules (substitution at call sites, unification at instantiation, variance tracking) that span the entire typechecker. None of those rules ship in this slice — the goal is for fixtures that declare a generic class to parse and typecheck without false rejection. `UnknownType` already serves as the 'tolerated but not constrained' fallback, so binding `T` to it lets every existing branch keep working without new code paths. When PKL-090 lands call-site inference, the upgrade path is to swap `UnknownType` for a real type variable variant — but doing that today, without inference, would be dead code."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Inject the parameter scope into a single helper at `class_decl_to_members`"
      rationale =
        "Class properties, methods, parent-name lookup, and method-body validation all reach for the type environment. Inserting the parameters once at `class_decl_to_members` and threading the scoped env through every downstream call keeps the change local. The alternative — passing `type_parameters` as a parameter through each callee — would touch every helper signature without buying additional flexibility."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Keep the evaluator unchanged"
      rationale =
        "Pkl's value model is structural: an `ObjectValue` carries member values regardless of the declared type parameters. There is no runtime artifact that holds 'Box of Int' versus 'Box of String'. Touching the evaluator would either invent a phantom value variant or layer runtime type tags onto every object — both are larger architectural moves that this slice declines."
    }
  }
}

local floatNumericsAndConstraints = new Scenario {
  id = "PKL-092"
  name = "Float numerics and constraint predicates"
  description =
    "Float numeric values flow through the entire stack. The lexer recognizes `<digits>.<digits>` as a Float token (Duration / DataSize `Int.<unit>` shorthand stays Int because `.identifier` is not promoted), the parser produces a new `FloatLiteral(Double)` Expr, and the evaluator carries the new `FloatValue(Double)` variant. Arithmetic widens automatically: `Int + Float` and `Float + Float` produce Float, comparisons (`<`, `<=`, `>`, `>=`, `==`, `!=`) admit any Int / Float mix, and `Int / Int` widens to Float to match Apple Pkl's `5 / 2 == 2.5` semantics. `IntDivide` / `Modulo` / `Power` keep their Int-only contract since their semantics are integer-domain. The typechecker gains a sibling `FloatType` and the `Number` annotation expands to `UnionType([IntType, FloatType])` so existing narrowing logic (union members, is-guards) keeps working. All four renderers (PCF / JSON / YAML / Properties) project Floats via a `render_float_text` helper that appends `.0` when the Double's shortest-round-trip form would otherwise look like an Int. The constraint cascade extends `pkl_constrained_int_predicates` to accept `Int(...)` / `Float(...)` / `Number(...)` as the host annotation, and a new `pkl_constraint_predicate_accepts_float` evaluator runs the existing Int-threshold predicates against Double values (widening thresholds to Double). `Float(isPositive)`, `Float(isBetween(0, 10))`, `Number(isPositive)`, and the negated / custom variants therefore fire on Float values; the rejection message format matches the Int side (`type annotation <name> constraint <p> rejects <v>`)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-078" }
  tags { "evaluator"; "typechecker"; "renderer"; "constraint"; "float" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Bring Float numerics into the stack alongside the constraint cascade"
      rationale =
        "The slice description nominally focuses on Float constraint predicates, but the only way to exercise them honestly is to first have FloatValue / FloatType / Float arithmetic in place — predicate evaluation needs a Float value to land on. Pulling the numeric base into the same slice keeps the cascade tests meaningful; splitting the base off would have left the constraint side untestable until the numerics shipped, which inverts the dependency."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Reuse the Int-threshold predicate encoding for Float values"
      rationale =
        "Apple Pkl's numeric predicates take a number argument (`isBetween(0, 10)` works for both Int and Float). Encoding the threshold as Int and widening it to Double at comparison time keeps a single source of truth for `isPositive` / `isBetween` / `isGreaterThan` / `isLessThan` — the alternative (parallel `ConstraintFloatPredicate` enum) would duplicate the parsing + custom-factory dispatch without adding semantic surface."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Emit `.0` suffix for integral Floats so round-tripping preserves the type"
      rationale =
        "`Double::to_string()` renders `42.0` as `42` in MoonBit, which would round-trip through the parser as an Int and silently change the value's type. Appending `.0` when the shortest-round-trip form has no decimal point keeps Float / Int distinguishable on the wire, matching Apple Pkl's projection."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Keep IntDivide / Modulo / Power Int-only for this slice"
      rationale =
        "Their semantics are integer-domain by name (`Int.~/`, `Int.%`, `Int.**`). Apple Pkl exposes the floating counterparts through `math.pow` / `math.div` etc. rather than reusing the operator surface, so widening these three would diverge from upstream and complicate the typechecker's promotion table."
    }
  }
}

local readSandboxedBuiltin = new Scenario {
  id = "PKL-098"
  name = "read built-in with sandbox-bounded env: scheme"
  description =
    "`read(uri)` is recognized at the CallExpr layer ahead of the generic call path. The argument must evaluate to a String; the scheme prefix (text before the first `:`) selects the dispatch. Today the sandbox policy is explicit and conservative: only `env:` is on the allow-list. `read(\"env:NAME\")` consults the host environment via `moonbitlang/core/env.get_env_var`, returning the value as a `StringValue` on success and surfacing `read: env variable <NAME> is not set` as a diagnostic when the variable is missing. The remaining Apple Pkl schemes (`prop:`, `file:`, `https:`, `package:`) all surface `read: scheme <s>: is not allowed by the sandbox policy` rather than silently failing — the diagnostic names the offending scheme so the failure mode points at the policy boundary, not at the call site. URIs without a scheme prefix surface `read: missing URI scheme in \"<uri>\"`. The `read?(uri)` null-returning variant requires parser support for the `?`-suffixed call form and stays deferred to a follow-up slice. Built-in honors user shadowing (`read = (uri) -> uri` takes precedence), mirroring how `Bytes` / `Regex` / `throw` / `trace` honor shadows."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-084" }
  tags { "stdlib"; "io"; "sandbox" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Default-deny sandbox: only allow `env:` until each additional scheme has an explicit policy"
      rationale =
        "The original Roadmap entry for `read()` flagged the sandbox boundary as a precondition for shipping. The simplest honest policy is default-deny: every scheme except the one we have written rules for surfaces a diagnostic naming the rejection. Picking `env:` first matches the canonical fixture pattern (Apple Pkl's own snippets read env variables more than file paths) and keeps the surface area manageable — adding `prop:` and `file:` later only needs an allow-list extension, not a re-architecture. Crucially, the rejection diagnostic must name the offending scheme: an opaque `unsupported uri` message would push the failure away from the policy boundary."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Hook `read` at the CallExpr layer, like `throw` / `trace`"
      rationale =
        "`read` is a top-level identifier in Apple Pkl's base scope, not behind an `import`. Placing it next to `throw` / `trace` keeps the shadow-aware dispatch logic localized and avoids touching the import resolver. The helper `eval_read_uri` is split out as a standalone function so the scheme dispatch table (and future allow-list extensions) reads as a flat match rather than nested CallExpr branches."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer the `read?(uri)` null-returning variant to a parser-extension slice"
      rationale =
        "Apple Pkl's `read?(uri)` is special syntax — a `?`-suffixed call form distinct from a regular nullable member access. Wiring it in would touch the parser, not just the evaluator, and the slice description for this entry deliberately limits scope to the sandbox-aware `read` path. The null-returning variant is straightforward once the parse form lands; the gating decision here is the policy boundary, not the diagnostic-vs-null choice."
    }
  }
}

local traceAndThrowBuiltins = new Scenario {
  id = "PKL-084"
  name = "trace and throw built-ins"
  description =
    "`throw(message)` recognized as a builtin call ahead of the generic call path. The argument must evaluate to a String; on success it pushes a diagnostic carrying the message verbatim and aborts evaluation (no value returned), letting the existing diagnostic surface reuse the `test.catch` capture path. Anything other than a String surfaces `throw expects a String argument`, and wrong arity surfaces `throw expects exactly one argument`. `trace(value)` recognized as a sibling builtin that evaluates the argument and returns it verbatim; the stderr-stamp side of Apple Pkl's `trace` is deferred to a follow-up slice because the only observable channel for it lives in the CLI layer and would balloon this slice into renderer / diagnostic territory. Both builtins honor user shadowing (`throw = (s) -> s` takes precedence) so the same identifier remains free for user-defined helpers, mirroring how `Bytes` / `Regex` honor shadows."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "stdlib"; "diagnostics" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Split `read` off into its own slice; ship `throw` + `trace` first"
      rationale =
        "The original PKL-084 bundled `read(uri)` with `throw` and `trace`, but `read` is a sandbox boundary, not just an stdlib call — it introduces external state (env / prop / file) and forces an allow-list policy decision before any implementation can ship without a footgun. `throw` and `trace` carry no such dependency: they are pure value-side builtins whose semantics are fully specified inside the evaluator. Shipping them first delivers the diagnostic-style escape hatch fixtures expect (`throw(\"...\")` aborts; `trace(x)` is a transparent inspection wrapper) while leaving the `read` sandbox question to a dedicated slice."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Recognize `throw` / `trace` at the call-expression layer, not in stdlib source"
      rationale =
        "`pkl:math` and the minimal `pkl:reflect` stub live as Pkl source strings in `builtin_stdlib_source`, but those are import-resolved modules. `throw` and `trace` are top-level identifiers in Apple Pkl's base scope, not behind an `import`. The closest existing pattern is `Bytes` / `Regex`, which are recognized at the `CallExpr` layer with explicit shadowing checks; placing `throw` / `trace` next to them keeps the dispatch logic localized and makes user shadowing work without touching the import resolver."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer the stderr side of `trace` to a follow-up slice"
      rationale =
        "Apple Pkl's `trace` writes a diagnostic line to stderr and returns the value. The value-side semantics ship today because they are testable without touching the CLI; the stderr side requires plumbing a diagnostic channel through the evaluator and the CLI's print path, which is a renderer-surface decision rather than a builtin-semantics decision. Tag the gap explicitly in the source comment so the next slice picks it up deliberately."
    }
  }
}

local pklReflectMinimal = new Scenario {
  id = "PKL-080"
  name = "minimal pkl:reflect support"
  description =
    "`builtin_stdlib_source` resolves `pkl:reflect` to a thin Pkl-source stub that exposes the most-cited type mirror constants as string-tagged placeholders (`anyType`, `booleanType`, `intType`, `floatType`, `numberType`, `stringType`, `durationType`, `dataSizeType`, `bytesType`, `pairType`, `listType`, `setType`, `mapType`, `listingType`, `mappingType`, `objectType`, `dynamicType`, `typedType`, `moduleType`, `unknownType`, `nothingType`), all tagged with the `pkl.base#<name>` prefix that is internal to this stub. The factory bindings `Class`, `Module`, `TypeAlias`, `Property`, and `DeclaredType` are lambdas: each accepts a string identifier (rather than a class value, which the value model cannot yet round-trip) and returns an Object container exposing `reflectee` (for the first four) or `referent` (for `DeclaredType`). Fixtures that only read mirror constants or assert `reflect.Class(name).reflectee == name` now parse, typecheck, and evaluate; upstream `reflect.pkl` fixtures that need a real `ClassValue`, runtime member introspection, or `isSubclassOf` remain out of scope and are picked up by follow-up slices once the value model grows."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-040" }
  tags { "stdlib"; "pkl-reflect" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Stub `pkl:reflect` as a Pkl-source module, mirroring the `pkl:math` / `pkl:test` pattern"
      rationale =
        "Existing stdlib stubs (`pkl:math` exposing Int helpers, `pkl:test` exposing `catch = null`) live as Pkl source strings in `builtin_stdlib_source`; the evaluator already imports and binds them through the regular import path. Adding `pkl:reflect` as a sibling entry keeps the implementation contained to one file and avoids touching the import resolver or value model. The alternative — hooking `reflect.Class(...)` as a special-cased builtin call — would need a new value variant and a privileged call path before any user-visible behaviour shipped."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Factory inputs are strings, not class values"
      rationale =
        "Upstream `reflect.Class(Foo)` passes the class itself; our value model has no `ClassValue` variant and the slice graph for one (typecheck integration + runtime member surface) is a major chunk of work that would block this slice indefinitely. Falling back to a string identifier loses static linkage between the call site and the declared class, but keeps the runtime model honest: a stub returning `new { reflectee = name }` is a faithful container for a name-keyed mirror, not a misleading fake-class wrapper. A follow-up slice can lift the API to `ClassValue` once the variant exists."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Omit `isSubclassOf` from the minimal stub"
      rationale =
        "Without a real subclass relation table, the only honest implementation is `(other) -> name == other.reflectee` — which silently misreports `Boolean.isSubclassOf(Any)` as `false`. A follow-up slice that introduces a base-type lattice (Any > Number > Int, Object > Typed > Dynamic, etc.) is the right place to add this; emitting it as a misleading stub now would let fixtures pass for the wrong reason. Tag the gap explicitly in the source comment so the next slice picks it up deliberately."
    }
  }
}

local upstreamJsonGoldDiff = new Scenario {
  id = "PKL-097"
  name = "diff JSON evaluation output against apple/pkl gold files"
  description =
    "`scripts/upstream-smoke.sh` gains a `JSON_GOLD_FIXTURES` list and an `eval_json_matches_gold` helper that runs the native CLI with `eval -f json`, byte-diffs the output against `LanguageSnippetTests/output/<dir>/<name>.json`, and prints `upstream json eval ok: <label> (gold match)` on success. The CLI's new `extract_output_value` helper unwraps a top-level `output { value = ... }` member before the renderer dispatches, mirroring the `output.value`-on-renderer invocation Apple Pkl uses for its renderer-test fixtures. Fixtures that route their data through `output.value` therefore render only the inner subtree, so `api/jsonRenderer1.json.pkl` matches the gold byte-for-byte. The remaining upstream JSON-renderer fixtures (`jsonRenderer2.json.pkl` / `3.json.pkl` / `6.json.pkl`) all need converters, Float numerics, or stdlib types (List / Set / Map / Pair / IntSeq / Dynamic) outside the implemented slice; those stay off the list and are picked up incrementally as the related slices land."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-071"; "PKL-072"; "PKL-096" }
  tags { "compatibility"; "upstream"; "renderer" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Honor `output.value` in the CLI rather than wiring the full Apple Pkl `output { renderer }` driver"
      rationale =
        "A complete `output {}` driver requires class-name tagging on every ObjectValue (so the CLI can read `output.renderer`'s class to pick a format), plus runtime support for `output.renderer = new JsonRenderer { converters { ... } }` with path / type-keyed converter lambdas. That is several slices of work. The `extract_output_value` helper isolates the smallest piece — `output.value` extraction — that lets a JSON-renderer fixture line up with its gold when the user passes `-f json` explicitly. The `-f` flag remains the source of truth for renderer choice; honoring `output.renderer` lands as a follow-up once class-name tagging exists."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Curate the JSON gold list explicitly, like the PCF list"
      rationale =
        "Same gating logic as PKL-096: an explicit list is auditable and a regression makes the script fail noisily, while an auto-discovery sweep would silently mask regressions. Starting with one entry (`api/jsonRenderer1.json`) keeps the diff infrastructure honest — anyone adding a fixture has to first verify it gold-matches manually, and the script catches drift afterwards."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Document the deferred fixtures in the script and the spec, not as TODOs in code"
      rationale =
        "The three deferred fixtures (`jsonRenderer2/3/6`) each fail for different concrete reasons (converters, Float, missing stdlib types). Listing them as TODO comments in the script would rot every time we add a feature; tracking them as `dependsOn` notes in the spec narrative keeps the slice graph the source of truth and the script as a pure executable contract."
    }
  }
}

local upstreamFixtureSweep = new Scenario {
  id = "PKL-096"
  name = "evaluate broader upstream Pkl fixtures with gold byte-diff"
  description =
    "`scripts/upstream-smoke.sh` carries an explicit list of `LanguageSnippetTests/input/<dir>/<name>.pkl` fixtures whose `pkl eval` output already matches the upstream gold `.pcf` file byte-for-byte. The script iterates the list, runs the fixture through the native CLI, diffs against `LanguageSnippetTests/output/<dir>/<name>.pcf`, and prints `upstream eval ok: <label> (gold match)` on success or a unified diff plus non-zero exit on any mismatch. The `parse_ok` and `eval_contains` paths from the original script remain so parser-only fixtures and the project-specific diagnostic-text fixture (`classes/constraints8.pkl`) keep their checks. The list lifts coverage from 7 hand-coded fixtures to 25 (`basic` 12, `classes` 3, `modules` 8, `objects` 1, `types` 1) and the trailing `upstream-smoke: <N> gold-match fixtures passed` summary lets the pkspec contract assert the total count instead of every individual line."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075"; "PKL-077"; "PKL-085" }
  tags { "compatibility"; "upstream"; "renderer" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Curate the passing list manually rather than auto-discovering at runtime"
      rationale =
        "Auto-iterating every `.pkl` under `input/` and skipping mismatches would silently mask real regressions: a fixture that flips from passing to failing (because of a renderer change or an evaluator bug) would just drop off the list with no diagnostic. An explicit list inverts that: the script fails on any mismatch, and a fixture cannot rejoin the list without a deliberate edit. New passes are surfaced by re-running the discovery sweep manually before each compatibility slice — that's the gating decision the slice description demands."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Cover modules / classes / objects / types alongside basic/, not just `basic/`"
      rationale =
        "The slice description says `bulk of input/basic`, but the discovery sweep showed only 12 of 97 basic/ fixtures pass byte-for-byte today (the rest depend on `amends \"pkl:test\"` shorthand, Float numerics, generators, or `pkl:reflect`). The same sweep across `classes/`, `modules/`, `objects/`, and `types/` adds 13 more byte-for-byte matches that exercise complementary surface (class methods, amend chains, implicit receivers, union narrowing). Adding them now increases compatibility coverage without expanding the slice cost."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Print a tally line and assert it in the pkspec contract"
      rationale =
        "The previous pkspec contract listed every individual `upstream eval ok: <label>` it expected to see; that meant every additional fixture required a contract-side update that read like noise. The trailing `upstream-smoke: <N> gold-match fixtures passed` line lets the contract assert the total count plus a small representative sample, so adding a fixture only changes one number and a few example lines instead of an enumerated list. The script still exits non-zero on the first individual mismatch so the contract failure points to the offending fixture."
    }
  }
}

local bytesLiteralAndMethods = new Scenario {
  id = "PKL-083"
  name = "Bytes literal and Bytes methods"
  description =
    "`Bytes(<Listing of Int>)` is recognized as a constructor form ahead of the generic call path; each Listing element must be an Int in 0..=255 and the resulting `BytesValue` wraps a MoonBit `Bytes` instance. `Bytes.fromBase64(\"<base64>\")` is the static-style decoder counterpart, surfacing malformed base64 input as a diagnostic rather than a raise. The `.length` and `.base64` properties expose the byte count and the base64 encoding of the underlying bytes; `.getOrNull(i)` returns the byte at index `i` (as `IntValue` 0..=255) or `null` when out of range; `.toList()` materializes the bytes back into a `Listing<Int>` so existing list helpers keep working. `String.toBytes()` joins the dispatch table on the String side, encoding the input as UTF-8 via `moonbitlang/core/encoding/utf8`. The PCF renderer round-trips a `BytesValue` back through the constructor (`Bytes(new Listing { 65; 66; 67 })`) so the parser can re-evaluate the literal verbatim; JSON / YAML / Properties project the bytes as their base64 encoding (a quoted string), matching the projection shape used by Apple Pkl for opaque stdlib values."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-077" }
  tags { "evaluator"; "renderer"; "bytes"; "stdlib" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Pull in moonbitlang/core/encoding/{base64,utf8} instead of hand-rolling the codecs"
      rationale =
        "Both base64 and UTF-8 codecs ship in MoonBit core (`moonbitlang/core/encoding/base64` and `moonbitlang/core/encoding/utf8`). Reimplementing either would double the Bytes-related code without buying compatibility — they already match the upstream Apple Pkl semantics. Adding the imports keeps the slice focused on Pkl-side wiring (value variant, constructor intercepts, method / property dispatch, renderer surface) and inherits the codec semantics from the maintained core packages."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Validate byte values 0..=255 at construction, not at access"
      rationale =
        "Out-of-range bytes are a programmer error that almost always originates from the Listing literal that built the Bytes — surfacing the rejection at the constructor (with the offending value in the diagnostic) points to the right line. Validating at access would push the failure to wherever the value happens to be read first, which loses the source location and lets the bad Bytes value flow through other operations (renderers, comparisons) before failing."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Round-trip PCF through the Listing constructor; project base64 in non-PCF formats"
      rationale =
        "PCF is the only output format that flows back into our parser, so the Listing-of-Int constructor is the only round-trip-safe form (the parser already understands `Bytes(<Listing>)` because of the constructor intercept). JSON / YAML / Properties do not have a native bytes type and base64 is the upstream-compatible representation — the same opaque-value pattern we use for Duration / DataSize / Regex. The two shapes intentionally differ because the round-trip target differs."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Provide `Bytes.fromBase64` instead of overloading the `Bytes(...)` constructor"
      rationale =
        "Overloading `Bytes(\"<base64>\")` to mean \"decode this string\" would conflict with the future `Bytes(<other-shape>)` overload Apple Pkl supports (e.g. raw byte literal syntax, sequence of hex pairs). Keeping the decoder under the explicit `Bytes.fromBase64` name leaves the bare `Bytes(...)` constructor unambiguous as the Listing-of-Int form, and matches the static-method spelling Apple Pkl uses for analogous decoders elsewhere in the stdlib."
    }
  }
}

local cliPklTestRunner = new Scenario {
  id = "PKL-095"
  name = "CLI test runner integrates pkl:test facts"
  description =
    "`pkl test <file.pkl>` evaluates the file the same way `eval` does, then walks a top-level `facts: Mapping<String, Listing<Boolean>>` member: each entry is one fact, each Listing element is one assertion, and the fact passes only when every assertion is `BoolValue(true)`. The runner prints one `PASS <name> (N assertions)` or `FAIL <name>: assertion #i of N did not evaluate to true` line per fact, then a trailing `<passed> passed, <failed> failed` summary, and exits non-zero on any failure. Modules without a `facts` member print only the summary (zero passed, zero failed) and exit zero — matching the `moon test` behaviour for empty test files. The minimal slice intentionally requires the explicit typed `facts` shape rather than the `amends \"pkl:test\"` shorthand because the shorthand needs the full `pkl:test` module to flow through the import system; that lift stays a follow-up."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-058" }
  tags { "cli"; "pkl-test" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Require the explicit `facts: Mapping<String, Listing<Boolean>>` shape, not `amends \"pkl:test\"`"
      rationale =
        "`amends \"pkl:test\"` relies on the import resolver loading the upstream `pkl:test` module so the `facts { [\"...\"] { ... } }` shorthand picks up its declared shape. Our resolver currently short-circuits `pkl:` URIs to a stub, so the shorthand collapses to an empty mapping when actually evaluated. The slice scope draws the line at the explicit type so the runner can ship today; the shorthand support is a strictly larger lift that needs the full `pkl:test` module to flow through the resolver."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Walk the evaluated value rather than re-parsing the source"
      rationale =
        "Routing through `eval_path` reuses every constraint, typecheck, and renderer behaviour the rest of the CLI depends on, so a fact like `xs.map((x) -> x.length) == [3, 4, 5]` evaluates with the same semantics as a regular eval. A separate parser would have to re-implement the assertion grammar and would silently drift from the rest of the evaluator."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Report per-fact pass/fail with the failing assertion index, short-circuiting within a fact"
      rationale =
        "A fact bundles a small group of related assertions; once one fails the rest of the same fact are no longer evidence — they could trivially pass with a stale value. Naming the first failing assertion's 1-based index plus the total assertion count gives enough information to find the offending line without burying the user in cascading diagnostics. Per-fact (rather than per-assertion) granularity also matches the upstream `pkl test` output shape."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Use stdout assertions in the pkspec contracts rather than exit-code checks"
      rationale =
        "`moon run cmd/mpkl --target native -- ...` swallows the inner binary's exit code (it returns moon's own exit code, not the binary's). Asserting on stdout — `PASS <name>`, `FAIL <name>`, and the trailing summary — captures the same information through the only channel the test harness can observe through the wrapper, and the binary itself still exits non-zero so direct invocations behave correctly for users. Lifting the exit-code assertion is a strictly larger CLI-runner change."
    }
  }
}

local cliFormatFlag = new Scenario {
  id = "PKL-094"
  name = "CLI --format flag for eval"
  description =
    "The `pkl eval` subcommand accepts both the short `-f` and the long `--format` flag and dispatches to the matching renderer. The format string is validated against the closed set `pcf` / `json` / `yaml` / `properties` before evaluation begins; an unrecognised format fails fast with `unsupported format: <text>`. Inside the dispatch, `pcf` has its own explicit arm rather than acting as the unmatched fallback, so adding a future renderer surfaces as a missing-arm warning at compile time. The default format remains `pcf` when neither flag is present, matching the existing CLI contract and the upstream `pkl eval` default. Both short and long forms are tested via the pkspec contracts: `cli eval --format long form` exercises `--format json`, `cli eval --format pcf` exercises the explicit `pcf` arm, and the existing `cli eval json` / `cli eval yaml` / `cli eval properties` tests stay on the short form to cover the original surface."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-072"; "PKL-073"; "PKL-074" }
  tags { "cli"; "renderer" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Promote pcf into the dispatch match instead of leaving it as the else fallback"
      rationale =
        "The previous chain ran `if json ... else if yaml ... else if properties ... else pcf`, which silently absorbed any new format token that slipped past the up-front validation. Making `pcf` an explicit `match` arm fails the compile when a new format is added without a matching renderer hookup, which keeps the validation list and the dispatch list in sync by construction."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Test both short and long forms via separate pkspec scenarios"
      rationale =
        "The flag-parsing loop in `cmd/mpkl/main.mbt` treats `-f` and `--format` symmetrically — they share a single branch in the argument scanner — but the contract surface should still exercise both spellings independently so a future refactor that collapses the parsing path cannot regress one form without the other. Two new scenarios (`cli eval --format long form`, `cli eval --format pcf`) cover the long form and the explicit `pcf` dispatch; the existing three short-form scenarios keep their coverage of the short flag."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Keep `pcf` as the default rather than requiring an explicit flag"
      rationale =
        "Upstream `pkl eval path.pkl` (no flag) emits PCF. Changing the default here would silently break existing automation that relies on PCF-shaped output. The slice only adds explicit `pcf` dispatch and the long-form flag; the flag-less behavior stays identical to the previous release."
    }
  }
}

local collectionElementConstraints = new Scenario {
  id = "PKL-093"
  name = "Listing and Mapping element constraint propagation"
  description =
    "`pkl_constrained_type_annotation_has_supported_constraint` recurses into the `Listing<T>` and `Mapping<K, V>` wrappers so element-level constraint annotations register as supported. The value-rejection cascade gains a collection branch after the Int / String branches: for a `Listing<T>` annotation on a `ListingValue`, every element re-enters the cascade with `T` as both display and source name; for a `Mapping<K, V>` annotation on a `MappingValue`, each entry's key is checked against `K` and each entry's value against `V`. The first rejecting element produces the diagnostic and short-circuits the cascade so error messages name a single failing predicate rather than a list. Nested wrappers (`Listing<Listing<Int(isPositive)>>`, `Mapping<String, Listing<Int(isBetween(0, 9))>>`) compose naturally because each recursion uses the same entry point; depth is capped at 8 to keep cycle-like aliases bounded."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-091"; "PKL-075" }
  tags { "evaluator"; "typechecker"; "constraint"; "collection" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Recurse through the existing entry points rather than threading a separate per-element checker"
      rationale =
        "The constrained-type cascade is already the value-side authority for Int and String predicates. Routing the per-element check back through `pkl_constrained_type_annotation_value_rejection_message_from_source` means any constraint family that lands later (Float, user-defined factories, future types) inherits collection support for free without touching the collection plumbing. The depth bound on the same path keeps recursive aliases (`typealias R = Listing<R>`) from looping the runtime."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Short-circuit on the first rejecting element instead of reporting every failure at once"
      rationale =
        "Apple Pkl reports the first failing constraint and aborts — listing every failure would multiply the diagnostic count on common typos (missing constraint, wrong predicate). Short-circuiting matches that behavior and keeps the diagnostic vocabulary identical to the scalar path; `length rejects` reads the same whether it fired on a top-level value or the third element of a Listing."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Reuse `generic_argument_text` / `split_top_level_generic_arguments` from the typechecker"
      rationale =
        "Both helpers already balance angle-bracket and paren nesting correctly for `Listing<Pair<Int, Int>>` / `Mapping<String, Listing<Int>>` shapes. Reusing them keeps a single source of truth for the collection-type grammar and avoids a parallel parser that would drift the moment one side learns a new wrapper type."
    }
  }
}

local stringConstraintPredicates = new Scenario {
  id = "PKL-091"
  name = "String constraint predicates"
  description =
    "`String(...)` annotations recognise three predicate shapes — length comparisons (`length > 0`, `length >= 1`, etc., plus `<` / `<=` / `==` / `!=`), `length.NAME(...)` method calls that reuse the Int predicate grammar (`length.isBetween(1, 64)`, `length.isPositive`, `length.isGreaterThan(N)`, `length.isLessThan(N)`), and full-input regex matches (`matches(Regex(\"<pattern>\"))`). Negation via the `!` prefix wraps any of these. Predicates run as part of the same constrained-type-annotation rejection cascade as the Int predicates: `pkl_constrained_type_annotation_has_supported_constraint` returns true when a String constraint is present, the runtime value-rejection path dispatches on String values, and the typecheck literal-expression path dispatches on String literals. Diagnostics keep the constraint name verbatim (`length > 0`, `length.isBetween`, `matches`, `!matches`, etc.) so the rejection message reads back to the original source shape."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-077"; "PKL-081" }
  tags { "evaluator"; "typechecker"; "constraint"; "string" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror the Int constraint cascade rather than introducing a parallel pipeline"
      rationale =
        "The Int constraint cascade already covers the three integration points a new constraint family needs (`has_supported_constraint` gate, runtime value rejection, typecheck literal rejection). Mirroring its shape — a `ConstraintStringPredicate` enum plus `_predicates(type_name)` / `_rejection_message_from_source` helpers — keeps the surface area small and lets a future Float or collection-element constraint follow the same template. The dispatch point inside `pkl_constrained_type_annotation_value_rejection_message_from_source` adds a String branch after the existing Int branch, so non-String constrained types are unaffected."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Parse the constraint text rather than retyping the constraint as an Expr"
      rationale =
        "Constraint text arrives as the raw source between `String(` and `)`. Retyping it through the parser would mean threading a parser dependency into the constraint module and recompiling the constraint on every value check. Parsing the three documented shapes textually — operator-based comparison, `length.`-prefixed method call delegating back to the Int parser, and `matches(Regex(\"...\"))` literal — is enough to cover the slice scope and keeps the constraint module self-contained."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Reuse the moonbitlang/regexp engine that PKL-081 added rather than caching compiled patterns"
      rationale =
        "Patterns inside constraint text are short-lived: the same constrained type is matched against many values, but the regex source is fixed. Compiling on each `matches(...)` predicate evaluation is wasteful but never quadratic — caching the compiled regex would need a constraint-level value store and only matters once a workload uses thousands of constrained values per second. Defer caching until profiling justifies it; for now the predicate compiles inside `pkl_string_predicate_accepts` and treats a malformed pattern as a deterministic rejection so the constraint cascade still produces a stable diagnostic."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Anchor `matches(Regex(...))` to the entire string, matching `Regex.matches`"
      rationale =
        "`String(matches(Regex(\"...\")))` says \"the entire value matches this regex\", not \"the regex matches somewhere in the value\". PKL-081 made the same choice for `Regex.matches`, so anchoring here keeps the two surfaces consistent — `String(matches(Regex(p)))` accepts iff `Regex(p).matches(value)` returns true. Substring matches stay reachable via the unanchored regex (`Regex(\".*pattern.*\")`) without changing the predicate semantics."
    }
  }
}

local regexLiteralAndMethods = new Scenario {
  id = "PKL-081"
  name = "Regex literal and Regex methods"
  description =
    "`Regex(\"<pattern>\")` is recognized as a constructor form before the generic call path runs; the call's single String argument is captured verbatim as a `RegexValue(String)` carrying the pattern. The `.pattern` property exposes the original source pattern as a `String`. Five Regex methods dispatch through the same MemberAccess / SafeMemberAccess sites as the other stdlib value methods: `.matches(input)` returns true only when the regex covers the entire input (anchored on both ends), `.find(input)` returns the first match's text or `null`, `.findAll(input)` returns a `Listing<String>` of every non-overlapping match, `.replace(input, repl)` substitutes the first match, and `.replaceAll(input, repl)` substitutes every non-overlapping match. Compilation is deferred to the first method call so a Regex value can be constructed even if its pattern is later unused; an invalid pattern reports a diagnostic at method-call time. The PCF renderer round-trips a `RegexValue(p)` back as `Regex(\"<escaped-p>\")`; JSON / YAML / Properties project the pattern as a plain string."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-077" }
  tags { "evaluator"; "renderer"; "regex"; "stdlib" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Pull in moonbitlang/regexp instead of writing a pure-MoonBit regex engine"
      rationale =
        "Apple Pkl's regex grammar is the standard PCRE-compatible flavor; reimplementing it for this slice would dwarf every other stdlib slice combined and gain nothing for compatibility. `moonbitlang/regexp` 0.3.5 is a maintained MoonBit-native package with PCRE-style features (character classes, anchors, alternation, repetition, capture groups). Adding it as a dep keeps the slice focused on Pkl-side wiring (value variant, method dispatch, renderer surface) and lets the regex semantics inherit a well-tested implementation."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Compile the pattern lazily at method-call time, not at constructor time"
      rationale =
        "Compiling `Regex(\"<pat>\")` eagerly forces the entire program to fail at construction even when the regex is dead code (e.g. a typealias body that's never instantiated). Lazy compilation localizes the failure to the actual `.matches` / `.find` / etc. call, which both matches user intuition and lets a Regex value participate in renderers (PCF / JSON / YAML / Properties) without ever invoking the engine."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Anchor `.matches` to the whole input rather than searching for a substring match"
      rationale =
        "Apple Pkl's `String.matches(regex)` returns true iff the entire input matches; `.find` / `.findAll` cover the unanchored substring case. Mirroring that split here keeps the Regex API consistent with the existing String API (`.contains` / `.startsWith` / `.endsWith` for unanchored checks, `.matches` for full-input). The implementation checks the match's `before` and `after` views are both empty to distinguish a full match from a partial one."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Project Regex as the pattern string in JSON / YAML / Properties; round-trip as Regex(\"...\") in PCF"
      rationale =
        "JSON / YAML / Properties have no native regex type, so the only deterministic projection is the source pattern as a quoted string — matching the same shape we use for Duration / DataSize. PCF, on the other hand, is the format that flows back into the parser; emitting `Regex(\"<escaped-pattern>\")` lets the same Regex value re-evaluate to itself, which is the property the rest of the renderer surface relies on."
    }
  }
}

local typeAliasedCallableArgumentEvaluation = new Scenario {
  id = "PKL-069"
  name = "evaluate typealiased Pkl callable argument annotations"
  description =
    "Function, lambda, and class method calls resolve typealiased parameter annotations through the alias chain at runtime, so a parameter declared `x: Small` with `typealias Small = Int(isBetween(0, 10))` triggers the same predicate cascade as `x: Int(isBetween(0, 10))`. Built-in and user-defined constrained predicates fire alike, and the diagnostic preserves the original alias name (`Small`) while running the resolved constraint against the argument value."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-066"; "PKL-068" }
  tags { "evaluator"; "callable"; "typealias" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror the return-side alias resolution on the argument side"
      rationale =
        "`eval_callable_return_rejection_message` already resolves a return-type alias via `eval_resolved_type_alias` before running the predicate cascade. The argument side was bypassing alias resolution entirely — it called the non-`_from_source` predicate variants on the raw type name, which silently ignored anything that wasn't an inline constrained type. Switching the argument path to the same `_from_source` predicate variants closes the bypass and reuses the existing typealias chain walker."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Reuse the typealias bindings collected from the program's declarations"
      rationale =
        "`eval_type_alias_bindings(declarations)` is the same input used by the return-side path. Computing it inside the argument-rejection helper keeps the call sites unchanged: every dispatcher (lambda application, function call, class method call) already passes `declarations`, so no new threading is needed."
    }
  }
}

local hiddenAndLocalMembers = new Scenario {
  id = "PKL-087"
  name = "hidden and local object members"
  description =
    "Object-body members declared with the `hidden` modifier or the `local` keyword are kept inside the evaluated `ObjectValue` (so `lookup_member` still resolves bare-name reads against them) but are skipped by every renderer (PCF / JSON / YAML / Properties). Module-level `hidden` bindings get the same render-side filter; module-level `local` already routed through `parse_local_decl`, which marks the binding `exported: false` so the renderer never sees it in the first place. The render filter is a single `visible_members` projection applied at the entry of each renderer's member loop, keyed off a reserved `@hidden$` name prefix that the lexer rejects as an identifier character so it cannot collide with user-declared properties."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-070"; "PKL-071"; "PKL-072"; "PKL-073"; "PKL-074" }
  tags { "evaluator"; "renderer"; "object" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mark hidden members via a name-prefix marker instead of widening ValueMember"
      rationale =
        "Adding a `hidden : Bool` field to `ValueMember` would force updating ~334 struct-literal constructions in the test suite (the source uses shorthand field-name punning that MoonBit cannot extend with a default). A reserved name prefix (`@hidden$`) achieves the same goal — distinguishing renderable from non-renderable members — without touching the struct shape, and the lexer's rejection of `@` / `$` in identifiers guarantees the prefix cannot collide with anything in user source."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Resolve bare-name reads against either the bare or prefixed form in `lookup_member`"
      rationale =
        "Apple Pkl's `hidden` keeps the member reachable from outside the object (renderers drop it; member access still resolves it). The bare-name lookup must therefore match the prefixed entry transparently. Extending `lookup_member` to try both forms keeps the visibility contract intact without forcing every caller to know about the prefix."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Split visibility-consumption between module-level and object-body parsers"
      rationale =
        "Module-level `local` is a binding-declaration keyword that routes through `parse_local_decl` and produces `exported: false` bindings. Reusing the object-body visibility consumer at module level would swallow that keyword before `parse_local_decl` could see it, breaking 16 existing tests. The split — `consume_member_visibility_modifiers` for object bodies (handles both `hidden` text and `local` keyword) and `consume_module_visibility_modifiers` for module level (handles only `hidden` text) — keeps the keyword's existing role intact."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Treat `local` and `hidden` identically on the render side"
      rationale =
        "Apple Pkl's `hidden` keeps the member reachable via member access; `local` is supposed to be scoped to the declaring body and unreachable from outside. Our evaluator currently lacks sibling-visibility for object-body members (the existing tests of sibling references show `unbound identifier`), so the stricter `local` scoping isn't observable yet. Producing identical render-filtering for both modifiers ships the renderer contract now and leaves the stricter scoping for a follow-up slice that bundles sibling visibility."
    }
  }
}

local objectBodyForGenerators = new Scenario {
  id = "PKL-085"
  name = "evaluate object body for-generators"
  description =
    "`for (var in source) { ... }` and `for (var1, var2 in source) { ... }` inside an object body iterate the source (Listing or Mapping) and splice each iteration's members into the surrounding object. For Listings, the single-variable form binds the element; the two-variable form binds (index, element). For Mappings, the two-variable form binds (key, value). Per-iteration members are merged via `merge_value_members`, so later iterations overwrite earlier writes to the same name (matching Apple Pkl's `for`-as-property-generator semantics). The construct is encoded as a synthetic `@for` ObjectMember whose value is a new `ForGenerator(var1, var2, source, body)` `Expr` variant; `eval_object_members` recognises the reserved name and spreads the resulting `ObjectValue`'s members into the parent. Composes with `when`-conditionals inside the body — the @when spread per iteration contributes (or skips) members according to the condition."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075"; "PKL-086" }
  tags { "evaluator"; "object" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Promote `for` and `in` to reserved keywords"
      rationale =
        "Apple Pkl marks both as reserved words — they can never be property names. Adding them to `keyword_or_identifier` lets `parse_object_body_members` dispatch on the keyword's syntax kind directly and lets the binding-form parser look for `in_kw` as the source separator. The upstream parser suite (802 fixtures) still passes after the change, so no fixture uses `for` or `in` as an identifier."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Add a dedicated `ForGenerator` `Expr` variant instead of reusing a wrapper expression"
      rationale =
        "The for-generator's payload — loop variable name(s), source expression, and body members — does not fit into any existing `Expr` shape (the body is an `Array[ObjectMember]`, not an `Expr`). Encoding it as `(var1, var2_opt, source, body)` in a new variant keeps the surface explicit at every parser / evaluator / typechecker site. The typechecker treats the variant as `UnknownType` because for-generators only appear inside object bodies via the synthetic `@for` member, never as a free-standing expression."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Merge per-iteration members across iterations rather than appending duplicates"
      rationale =
        "Apple Pkl's `for`-as-property-generator semantics are last-write-wins per name — writing `result = x` inside the body for each iteration yields one `result` member set to the final iteration's value, not three duplicates. Our regular object-body evaluation keeps duplicate names (the renderer / amend chain resolves them downstream), but per-iteration spreading is a stronger contract; using `merge_value_members` between iterations matches the user's mental model and prevents the resulting `ObjectValue` from growing without bound for large sources."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Custom in-place skipper for binding-side type annotations"
      rationale =
        "Apple Pkl allows `for (n: Int in source)` and `for (n: Listing<Pair<Int, Int>> in source)`. Reusing `parse_type_annotation` here doesn't work because its `parse_type_text` greedily consumes tokens until `=` / `{` / `}` / `,`, which swallows the `in` keyword and the source expression. A small custom loop that stops at `,` / `in` / `)` while balancing parens / brackets / angles keeps the typed-binding contract intact without weakening the existing type-annotation parser."
    }
  }
}

local objectBodyWhenConditionals = new Scenario {
  id = "PKL-086"
  name = "evaluate object body when-conditionals"
  description =
    "`when (cond) { ... } else { ... }` inside an object body picks the then-branch when the condition evaluates to `true` and the else-branch otherwise; the picked branch's members are spliced into the surrounding object body alongside any sibling properties. `else` is optional — a false condition without an `else` contributes no members. The condition expression sees the enclosing module's bindings (so `when (stage == \"prod\")` works), and each branch may declare multiple members. The construct is desugared at parse time into a synthetic `@when` object member whose value is a `ConditionalExpr` between the two branch `ObjectLiteral`s; `eval_object_members` recognises the reserved name and spreads the resulting `ObjectValue`'s members into the parent."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "evaluator"; "object" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary =
        "Encode `when` as a synthetic `@when` ObjectMember rather than changing the ObjectMember shape"
      rationale =
        "Promoting `ObjectMember` from a struct to an enum (with separate `Property` and `WhenBranch` variants) would ripple through every place that constructs or inspects object members — parser, evaluator, typechecker, renderers, four separate match arms. Encoding `when` as a reserved-named ObjectMember whose value is a `ConditionalExpr` between two `ObjectLiteral`s keeps the change local: the parser emits one extra branch in `parse_object_body_members`, and the evaluator spreads on the reserved name. `@` is rejected as an identifier character by the lexer, so the reserved name cannot collide with anything in user source."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Spread branch members at evaluation time rather than at parse time"
      rationale =
        "Apple Pkl evaluates the condition at module-evaluation time and the branches see the surrounding object's bindings (forward references, class defaults, amend chains). Spreading at parse time would require copying the branch's `ObjectMember`s into the surrounding array, which loses the source position for diagnostics and forces the parser to know about evaluation order. Spreading at evaluation time, after `eval_expr_with_bindings` resolves the conditional, keeps the parser oblivious to runtime semantics and lets the existing scoping machinery (`eval_object_members` already iterates in order with forward-reference support) handle the resolution."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Promote `when` from an identifier to a reserved keyword"
      rationale =
        "Apple Pkl marks `when` as a reserved word — it can never be a property name. Adding `when` to `keyword_or_identifier` matches that contract and lets `parse_object_body_members` dispatch on the keyword's syntax kind directly. The upstream parser suite (802 fixtures) and smoke tests still pass, so no existing fixture uses `when` as an identifier."
    }
  }
}

local nullCoalescingAndLet = new Scenario {
  id = "PKL-088"
  name = "null-coalescing operator and let expressions"
  description =
    "The `??` operator picks the right-hand value when the left evaluates to `NullValue`, and is right-associative so `a ?? b ?? fallback` short-circuits left-to-right. `let (name = value) body` introduces a single scoped binding, with the body able to reference outer bindings and inner let-expressions able to shadow the outer name. The two compose: `let (fallback = ...) raw ?? fallback`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "evaluator"; "expressions" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Desugar `let (name = value) body` into `((name) -> body)(value)` at parse time"
      rationale =
        "Pkl's let-expression is just a single-parameter lambda applied to one value — same scoping rules, same closure capture, same return-validation. Desugaring at the parser level means the rest of the evaluator continues to operate on the existing `LambdaExpr` + `CallExpr` machinery (closure capture, parameter rejection, return validation) without a new AST node or eval arm. The CST node keeps the `let_decl` kind so the source-mapped diagnostic surface stays intact."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Lean on the existing `NullCoalesce` binary operator rather than synthesizing a new short-circuit form"
      rationale =
        "The lexer / parser / typechecker / evaluator already wire `??` through `BinaryOp::NullCoalesce` (it lit up the moment the existing slice landed), with `NullCoalesce` evaluating the right-hand side only when the left produces `NullValue`. PKL-088 ships the spec contract that pins down the behavior — right-associativity, short-circuit semantics, type-of-result — without changing the implementation."
    }
  }
}

local pklMathExpansion = new Scenario {
  id = "PKL-079"
  name = "expand pkl:math beyond maxInt32"
  description =
    "`pkl:math` exposes Int range constants (`maxInt32`, `minInt32`, `maxInt`, `minInt`) and Int-side helpers (`abs(x)`, `min(a, b)`, `max(a, b)`). The helpers are declared as top-level lambda bindings inside the synthetic `pkl:math` source so they round-trip through the regular `exported: true` path and become members of the imported module's `ObjectValue` — `import \"pkl:math\" as math; math.max(a, b)` evaluates without further dispatch work. `maxInt` / `minInt` track the 32-bit `Int` representation; once a 64-bit slot exists they expand to match the Java-derived Apple Pkl bounds."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-007"; "PKL-078" }
  tags { "stdlib"; "pkl-math" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Declare helpers as lambda bindings, not `function` declarations"
      rationale =
        "Our parser marks `function name(...) = body` declarations with `exported: false`, which keeps them out of the imported module's `ObjectValue`. Apple Pkl's `pkl:math` exposes these helpers as plain functions on the module, so to match the reachable-from-an-import contract we declare them as `name = (...) -> body` instead. The semantics are identical (both forms produce a `FunctionValue`), but the binding flag flips the lambda form into the exported set."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Track `maxInt` / `minInt` against the implemented Int width"
      rationale =
        "Apple Pkl's `Int` is 64-bit (Java `long`), so its `maxInt` / `minInt` are `+/-2^63`. Our `IntValue` carries a 32-bit MoonBit `Int`. Reporting Apple Pkl's 64-bit limits here would mean lying about what literals will actually round-trip through evaluation (anything beyond 32-bit overflows during parsing today). The constants therefore expose the implementation-actual range; PKL-092 / a follow-up Int-64 slice will widen them once the value model supports the bigger slot."
    }
    new Decision {
      date = "2026-05-15"
      summary =
        "Defer Float-bearing math (`sqrt` / `pow` / `log` / `exp` / `ceil` / `floor` / `round`) to PKL-092"
      rationale =
        "Apple Pkl's `pkl:math` exposes `sqrt(Float)`, `pow(Float, Float)`, `log(Float)`, etc. None of these can be implemented honestly against `IntValue` alone — `sqrt(4) = 2` happens to be integer but `sqrt(2)` cannot be represented. Float-bearing math arrives with `FloatValue` in PKL-092, alongside the Float constraint predicates."
    }
  }
}

local pklBaseInt = new Scenario {
  id = "PKL-078"
  name = "expose pkl:base Int operations"
  description =
    "Int properties (`abs`, `isEven`, `isOdd`) and methods (`toString()`, `toString(radix)`, `toChar()`) dispatch against `IntValue` receivers via the same `MemberAccess` / `CallExpr` interception as the Listing / Mapping / String builtins. `toString(radix)` accepts radices 2..36 and writes a leading `-` for negative inputs. `toChar()` projects a Unicode code point (0..0x10FFFF) to a single-character `StringValue`. Int builtins compose with String / Listing pipelines, so `xs.map((n) -> n.toString(16)).join(\",\")` returns a hex-CSV `StringValue`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-077" }
  tags { "stdlib"; "pkl-base"; "numeric" }
  reviewStatus = "approved"
  severity = "minor"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Implement radix conversion in-tree rather than via a third-party crate"
      rationale =
        "MoonBit's `Int` type does not expose a built-in radix-aware `toString`. Pulling in a numeric-formatting library for one method would balloon the dependency surface; implementing the loop ourselves (a 20-line helper that walks the digit table) keeps the slice focused. The radix bound (2..36) matches Java's `Integer.toString(int, int radix)` and Apple Pkl's `Int.toString(radix: Int(isBetween(2, 36)))` constraint."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer `toFloat()` and Float-side projections until a real `Float` value lands"
      rationale =
        "Apple Pkl's Int surface includes `toFloat(): Float`, and the Roadmap entry called for matching Float-side projections. Our value model has no `FloatValue` yet — numeric literals like `1.23` currently fail to evaluate. Implementing `toFloat` against `IntValue` alone would mean returning an `IntValue` again (since there's no other slot), which is misleading. The Float surface arrives with PKL-092, at which point `toFloat()` slots in alongside the new value variant."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Reject `toChar` code points outside the Unicode range explicitly"
      rationale =
        "Apple Pkl's `Int.toChar()` errors when the receiver is outside `0..0x10FFFF`. Our `Char::unsafe_to_char` would happily accept any 32-bit input, but a code point above `0x10FFFF` is not a valid Unicode scalar and the resulting `StringValue` would be ill-formed. The explicit bound check matches Apple Pkl's behavior and protects downstream renderers (JSON / YAML / Properties string-escape paths) from surrogate-pair leakage."
    }
  }
}

local pklBaseString = new Scenario {
  id = "PKL-077"
  name = "expose pkl:base String operations"
  description =
    "String properties (`length`, `isEmpty`) and methods (`toUpperCase()`, `toLowerCase()`, `contains(s)`, `startsWith(p)`, `endsWith(s)`, `indexOf(s)`, `replaceAll(old, new)`, `replaceFirst(old, new)`, `take(n)`, `drop(n)`, `split(sep)`, `padStart(width, padStr)`, `padEnd(width, padStr)`) dispatch against `StringValue` receivers via the same `MemberAccess` / `CallExpr` interception as the Listing / Mapping builtins. `indexOf` returns `-1` for missing substrings (matching Apple Pkl rather than returning null). `split` projects to `Listing<String>`, so `s.split(\",\").map(...).join(...)` pipelines through the Listing builtins. `take` and `drop` saturate at the string bounds. All operations are code-unit-based (matching Apple Pkl's Java-string-derived semantics)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-076" }
  tags { "stdlib"; "pkl-base"; "string" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Map `indexOf` absent result to `-1`, not `null`"
      rationale =
        "Apple Pkl's `String.indexOf` returns `Int` with `-1` for absent substrings; a separate `indexOfOrNull` returns the nullable form. Mirroring that convention here keeps Pkl source ported from upstream working without rewriting `if (idx == -1)` checks into null guards. The MoonBit primitive (`String::find`) returns `Int?`, so the wrapper applies the `-1` fallback at the dispatch boundary."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Accept `padChar` as a single-character String, not a `Char` value"
      rationale =
        "Apple Pkl's `padStart` / `padEnd` take a `Char` parameter, but our value model has no separate `Char` type — character literals evaluate to `StringValue` of length one. Accepting a String and using its full content as the pad sequence is a strict superset of the Apple Pkl behavior for single-character pads and avoids forcing a `Char` value into the model for one builtin. If a future slice introduces `Char`, the pad parameter narrows naturally."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer regex-bearing String operations (`matches`, `replaceAllMapped`) to PKL-081"
      rationale =
        "Apple Pkl's String surface includes regex-bearing operations (`matches(Regex)`, `replaceAllMapped(Regex, (MatchResult) -> String)`). The regex slice (PKL-081) brings its own value type and constraint integration; folding those into this slice would force premature design choices. PKL-077 ships the non-regex slice — toUpperCase / split / replaceAll etc. — and PKL-081 will extend it without touching the dispatcher."
    }
  }
}

local pklBaseMapping = new Scenario {
  id = "PKL-076"
  name = "expose pkl:base Mapping operations"
  description =
    "Mapping properties (`length`, `isEmpty`, `keys`, `values`) and methods (`containsKey(k)`, `getOrNull(k)`, `fold(init, op)`) dispatch against `MappingValue` receivers via the same `MemberAccess` / `CallExpr` interception as the Listing builtins. `keys` and `values` project to `ListingValue` in declaration order (Apple Pkl returns `Set<K>` for `keys`, but our value model has no separate Set yet — the deviation is documented in the decisions). `getOrNull(k)` returns `NullValue` when the key is missing. `fold` invokes a 3-argument callback `(acc, key, value)` per entry via the shared `apply_function_value` helper. Listing builtins continue to dispatch on Listing receivers, so `m.values.filter(...).fold(...)` pipelines through both surfaces correctly."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075" }
  tags { "stdlib"; "pkl-base"; "mapping" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Project `keys` as `Listing<K>` until a real `Set` value lands"
      rationale =
        "Apple Pkl's `Mapping.keys` returns `Set<K>`, which has its own equality / iteration semantics. Our value model represents `Set(...)` literals as `ListingValue` already, so synthesizing a separate `SetValue` just for `keys` would mean either retrofitting Set throughout the evaluator now (large slice) or returning a one-off type the rest of the code can't manipulate. Returning `Listing<K>` matches what `Set(...)` becomes after evaluation today, and the contract upgrades naturally when a real `Set` lands."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Fold callback receives `(acc, key, value)` triple"
      rationale =
        "Apple Pkl's `Mapping.fold` exposes both the entry key and value to the accumulator. Reusing the `apply_function_value` helper with a 3-element argument array keeps the per-call validation / return checking consistent with Listing's `fold`, and means the only Mapping-specific code is the per-entry iteration shape."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer `entries -> Listing<Pair>` projection to a later slice"
      rationale =
        "Apple Pkl's `Mapping.entries` returns a `Listing<Pair<K,V>>`. We do not have a `Pair` value type yet (it depends on the broader `pkl:base` class surface in PKL-080). Implementing `entries` ahead of `Pair` would force an ad-hoc representation we'd need to migrate later, so this slice ships `keys` / `values` instead and `entries` arrives with Pair / reflect."
    }
  }
}

local pklBaseListing = new Scenario {
  id = "PKL-075"
  name = "expose pkl:base Listing operations"
  description =
    "Listing properties (`length`, `isEmpty`, `first`, `last`, `distinct`) and methods (`contains(x)`, `reverse()`, `take(n)`, `drop(n)`, `join(sep)`, `map(fn)`, `filter(p)`, `fold(init, op)`) dispatch against `ListingValue` receivers in the evaluator. Property-style access (`xs.length`) is handled in the `MemberAccess` arm; method calls (`xs.contains(1)`) are handled in the `CallExpr(MemberAccess(...), args)` arm before falling through to the regular callable path. Higher-order methods (`map` / `filter` / `fold`) accept a `FunctionValue` callback and invoke it per element via a shared `apply_function_value` helper that mirrors `eval_lambda_application` for already-evaluated arguments. Chained calls (`xs.filter(p).map(f).fold(0, g)`) work because each step re-evaluates its receiver as a `ListingValue`."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009"; "PKL-066" }
  tags { "stdlib"; "pkl-base"; "listing" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Dispatch builtins on the receiver shape, not via a synthetic class binding"
      rationale =
        "Apple Pkl exposes Listing operations through a `pkl:base.Listing<T>` class. Our class lookup is keyed off typed-object class names, and `ListingValue` is not represented as a typed object — synthesizing one just to satisfy the dispatcher would balloon the surface (constructor flow, amend rules, etc.). Intercepting `MemberAccess` / `CallExpr` for `ListingValue` receivers keeps the evaluator changes local and leaves the class system unchanged for PKL-089 generics work later."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Share `apply_function_value` between Listing higher-order builtins"
      rationale =
        "`map` / `filter` / `fold` all need to invoke a `FunctionValue` against already-evaluated element values, which differs from the existing `eval_lambda_application` (Expr-based arguments). Extracting `apply_function_value` once means each Listing builtin's body stays focused on its iteration shape and the per-call rejection / return validation lives in one place. The helper is reusable by Mapping (PKL-076) and String (PKL-077) builtins once those land."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Saturate `take` / `drop` instead of erroring on out-of-range counts"
      rationale =
        "Apple Pkl's `Listing.take(n)` and `.drop(n)` clamp `n` to the listing's bounds rather than raising — `xs.take(100)` on a 3-element listing returns the whole listing, and `xs.drop(100)` returns the empty listing. Mirroring that policy keeps user-facing behavior intuitive and avoids leaking an internal index-bounds error from data-shape variation."
    }
  }
}

local propertiesRenderer = new Scenario {
  id = "PKL-074"
  name = "render Pkl values as Java Properties"
  description =
    "The CLI `eval -f properties` (or `--format properties`) flag emits a Java Properties document matching Apple Pkl's `pkl eval -f properties` shape: ObjectValue and MappingValue members flatten into dotted keys (`a.b.c`), Mapping keys are coerced to strings, scalar values emit as unquoted `key = value` lines with property-style escaping for `\\`, `\\n`, `\\t`, `\\r`, `\\f`, leading space, `:`, `=`, `!`, and `#`. ListingValue renders as a compact JSON-style single-line value (`[1,2,3]`), with the JSON `:` separators property-escaped to `\\:`. NullValue leaves are omitted (mirroring Apple Pkl's `omitNullProperties = true` default), empty Object / Mapping leaves are dropped entirely, and empty Listings emit `key = []`. Top-level non-mapping values produce an empty document."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-072"; "PKL-073" }
  tags { "renderer"; "properties"; "cli" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror Apple Pkl's dotted-flatten Properties projection"
      rationale =
        "Apple Pkl's Properties renderer commits to a deterministic projection: nested Object / Mapping flatten into dot-joined keys, ListingValue stays as a single inline JSON-style scalar (so the line count matches the leaf count, not the listing length), and NullValue leaves are dropped by default. Mirroring that projection now means existing Pkl configurations ported here serialize to .properties without divergence, and adding `omitNullProperties = false` / `restrictCharset = true` / converters later remains an opaque extension instead of a re-architecting."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Apply property-style escaping symmetrically to keys and values"
      rationale =
        "Java Properties readers strip leading whitespace and use `=`, `:`, ` ` (space), `!`, `#`, and `\\` as syntactic delimiters. Apple Pkl's renderer escapes all of those in both keys and values (with a slight asymmetry: leading space is escaped in values, every space is escaped in keys, trailing space is left alone in values). Following that scheme here keeps round-trip behavior intact for any conforming Java Properties parser."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Defer `restrictCharset = true` Unicode escaping to a stdlib slice"
      rationale =
        "Apple Pkl's `restrictCharset = true` mode emits `\\uXXXX` escapes for every non-ASCII code point so the resulting file is safe for legacy ISO-8859-1 .properties readers. That knob lives on the `PropertiesRenderer` stdlib class, which arrives as part of PKL-079 stdlib expansion. Until then, the default `restrictCharset = false` behavior — pass Unicode through verbatim — is enough for modern JVM consumers."
    }
  }
}

local yamlRenderer = new Scenario {
  id = "PKL-073"
  name = "render Pkl values as YAML"
  description =
    "The CLI `eval -f yaml` (or `--format yaml`) flag emits a YAML document matching Apple Pkl's `pkl eval -f yaml` block-style shape: ObjectValue and MappingValue project to block mappings (Mapping keys are coerced to strings, indented two spaces per level), ListingValue projects to block sequences at the parent column with `- value` entries, and empty composites use the `[]` / `{}` flow form. String scalars stay bare when they parse as plain YAML, switch to single-quoted with `''` escapes for leading indicators / numeric-or-keyword shapes / inline `: ` / ` #` / trailing whitespace, and switch to double-quoted with `\\n`, `\\t`, `\\r`, `\\\\`, `\\\"`, and `\\uXXXX` escapes when the value contains control characters or a backslash. The default `eval` output stays PCF."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-072" }
  tags { "renderer"; "yaml"; "cli" }
  reviewStatus = "approved"
  severity = "major"
  decisions {
    new Decision {
      date = "2026-05-15"
      summary = "Mirror Apple Pkl's block-style YAML projection rules"
      rationale =
        "Apple Pkl's YAML renderer commits to a deterministic block-style projection (sequences emit `- item` at the parent column, mappings emit `key: value` with two-space indentation, empties use the flow `[]` / `{}` form). Mirroring that projection now means existing Pkl configurations ported here serialize to YAML without divergence, and adding `indentWidth` / `omitNullProperties` / converters later remains an opaque extension instead of a re-architecting."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Reuse the JSON `-f` CLI flag rather than the `output { renderer }` block"
      rationale =
        "PKL-072 wires `eval -f json` through a CLI flag because the `output { renderer = new JsonRenderer { ... } }` shape depends on stdlib classes (`JsonRenderer`, `YamlRenderer`) that we have not implemented yet — that lives in PKL-079 stdlib expansion. Reusing the same flag for YAML keeps the CLI surface uniform; once the stdlib renderer classes land, the `output { renderer }` path simply re-invokes the same internal `render_value_as_yaml` entry point."
    }
    new Decision {
      date = "2026-05-15"
      summary = "Use double-quoted form for control-character strings instead of block scalars"
      rationale =
        "Apple Pkl uses `|`, `|-`, and `|+` block scalars for multiline / control-character strings to keep YAML output human-readable. That projection is non-trivial (indentation indicators, chomping indicators, leading-whitespace handling) and is best implemented as its own slice. Until then, double-quoted strings with the JSON-style `\\n` / `\\t` / `\\uXXXX` escapes produce equivalent YAML — slightly less readable but still spec-compliant and round-trippable through any YAML 1.1 parser."
    }
  }
}

