/// Forward-looking roadmap of pkspec scenarios.
///
/// Every entry here is `reviewStatus = "draft"`, so `pkspec spec --check`
/// ignores them — they exist as a structured TODO list, NOT as a binding
/// commitment. Promote to `specs/Spec.pkl` (and flip `reviewStatus` to
/// `"approved"`) when starting the slice.
///
/// Loose grouping (the ID ranges are conventional, not enforced):
///   PKL-099 .. PKL-106  CLI surface (format / repl / analyze / output driver)
///   PKL-107 .. PKL-109  diagnostics, upstream compatibility
///   PKL-110 .. PKL-118  typechecker rounding (generics inference, equality, narrowing)
///   PKL-119 .. PKL-124  stdlib expansion (Set/Pair/Map, math float, semver/json/yaml/xml)
///   PKL-125 .. PKL-127  renderer expansion (block scalars, plist/xml/protobuf, converters)
///   PKL-128             parser surface expansion
///   PKL-129             package / https URI import
///   PKL-130 .. PKL-131  documentation generation, codegen bridge
///   PKL-132             LSP server foundation
///   PKL-133 .. PKL-137  pkf / pkspec evaluation blockers (the `Any` type,
///                       Listing / Mapping stdlib methods, `when` conditional
///                       property, `amends` semantics). Tagged `pkf-pkspec`
///                       and ordered ahead of the rest of the roadmap.
@ModuleInfo { minPklVersion = "0.31.0" }
module specs.Roadmap

import "../pkspec/Spec.pkl"

// ── CLI surface ─────────────────────────────────────────────────────────────

local pklRepl: Spec.Scenario = new {
  id = "PKL-101"
  name = "pkl repl interactive evaluator"
  description =
    "`moon run cmd/main -- repl` opens an interactive read-eval-print loop: each line parses as either a binding (`x = 5`) or an expression and prints the rendered result. Reuses the `AnalysisSession` so each entry incrementally extends the module."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "cli"; "repl" }
  reviewStatus = "draft"
  severity = "minor"
}

// ── diagnostics, upstream compatibility ─────────────────────────────────────

local upstreamFixtureSweepExpansion: Spec.Scenario = new {
  id = "PKL-109"
  name = "upstream fixture sweep expansion"
  description =
    "Walk additional upstream `LanguageSnippetTests/input/*` subtrees (`api/`, `errors/`, `generators/`, `lambdas/`, `listings/`, `mappings/`, `methods/`, `objects/`, `packages/`, `projects/`) and promote every fixture that gold-matches byte-for-byte to the curated list. Tracks rolling coverage of the ~800-fixture upstream suite."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-096" }
  tags { "compatibility"; "upstream" }
  reviewStatus = "draft"
  severity = "major"
}

// ── typechecker rounding ────────────────────────────────────────────────────

local inheritanceDispatchHardening: Spec.Scenario = new {
  id = "PKL-117"
  name = "inheritance dispatch hardening remaining"
  description =
    "Abstract method enforcement and override-direction type compatibility. Super method calls (`super.method()`) landed as PKL-117a. The remaining items are both typechecker-side: scan all transitive parents for abstract methods that the concrete subclass hasn't overridden, and check that override-direction subtype rules hold (contravariant parameter types, covariant return type)."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-040"; "PKL-117a" }
  tags { "typechecker"; "inheritance"; "next" }
  reviewStatus = "draft"
  severity = "major"
}

local crossModuleTypecheckCompleteness: Spec.Scenario = new {
  id = "PKL-118"
  name = "cross-module typecheck round-trip completeness"
  description =
    "Imported modules' class definitions, type aliases, function signatures, and constraint annotations participate in the importing module's typecheck the same way local declarations do. Today some sites lose precision when crossing the import boundary."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-006" }
  tags { "typechecker"; "imports"; "pkf-pkspec" }
  reviewStatus = "draft"
  severity = "major"
}

// ── stdlib expansion ────────────────────────────────────────────────────────

local setPairMapIntSeqVariants: Spec.Scenario = new {
  id = "PKL-119"
  name = "Set / Pair / Map / IntSeq Value variants"
  description =
    "Introduce dedicated Value variants for `Set` / `Pair` / `Map` / `IntSeq` instead of folding into `ListingValue` / `MappingValue`. The renderer round-trip for these stdlib types becomes accurate (`Set(1, 2, 3)`, `Pair(a, b)`), and equality / iteration matches upstream semantics."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075" }
  tags { "evaluator"; "stdlib"; "renderer" }
  reviewStatus = "draft"
  severity = "major"
}

local pklRendererStdlibModules: Spec.Scenario = new {
  id = "PKL-124"
  name = "pkl:json / pkl:yaml / pkl:xml / pkl:protobuf stdlib modules"
  description =
    "Stdlib classes for the renderer surface (`JsonRenderer`, `YamlRenderer`, `XmlRenderer`, `ProtobufRenderer`) that the `output { renderer }` driver path looks up. Today the CLI dispatches renderers via the `-f` flag and the stdlib classes do not exist."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-104" }
  tags { "stdlib"; "renderer" }
  reviewStatus = "draft"
  severity = "major"
}

// ── renderer expansion ──────────────────────────────────────────────────────

local plistXmlProtobufRenderers: Spec.Scenario = new {
  id = "PKL-126"
  name = "plist / xml / protobuf renderers"
  description =
    "Three additional output formats matching Apple Pkl's renderer surface. plist follows the Apple plist DTD (Foundation property list, XML-1.0 form). XML emits Pkl objects as element trees. protobuf serializes against an externally provided `.proto` schema."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-070" }
  tags { "renderer"; "plist"; "xml"; "protobuf" }
  reviewStatus = "draft"
  severity = "major"
}

local rendererConverters: Spec.Scenario = new {
  id = "PKL-127"
  name = "renderer converter machinery"
  description =
    "JSON / YAML / Properties renderers honor `converters { [\"path\"] = (value) -> ...; [\"Class\"] = (value) -> ... }`. Path lookups beat class lookups; the converter return value replaces the source value in the rendered output."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-104" }
  tags { "renderer"; "converter" }
  reviewStatus = "draft"
  severity = "major"
}

// ── parser surface ─────────────────────────────────────────────────────────

local packagePklRegistry: Spec.Scenario = new {
  id = "PKL-129b"
  name = "package:// registry resolution"
  description =
    "`import \"package://pkg.pkl-lang.org/...\"` resolves through Apple Pkl's registry protocol: fetch the package metadata JSON, locate the zipball URL, fetch + extract the zipball, then look up the path fragment inside. Today the CLI recognises the URI scheme but always errors with a clear diagnostic; PKL-129 lands the underlying `https://` fetch path. The registry resolution is the follow-up that adds a zip unpacker, fragment routing, and (later) checksum / signature verification."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-129" }
  tags { "parser"; "imports"; "sandbox"; "pkf-pkspec" }
  reviewStatus = "draft"
  severity = "major"
}

// ── documentation, codegen, LSP ─────────────────────────────────────────────

local pkldoc: Spec.Scenario = new {
  id = "PKL-130"
  name = "pkldoc documentation generation"
  description =
    "`moon run cmd/main -- doc <module>` renders the module's class / typealias / function declarations as Markdown / HTML, using the doc-comment text already captured by the parser."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-080" }
  tags { "cli"; "pkldoc" }
  reviewStatus = "draft"
  severity = "minor"
}

local codegenBridge: Spec.Scenario = new {
  id = "PKL-131"
  name = "pkl-codegen bridge"
  description =
    "Lower a typechecked Pkl module to a target language schema (Java / Kotlin / Swift / Go). The bridge consumes the existing typechecker state via `pkl:reflect`'s minimal stub once expanded."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-080"; "PKL-110" }
  tags { "cli"; "codegen" }
  reviewStatus = "draft"
  severity = "major"
}

local lspServer: Spec.Scenario = new {
  id = "PKL-132"
  name = "LSP server foundation"
  description =
    "A Language Server Protocol server (stdio or socket transport) that surfaces hover, go-to-definition, find-references, completion, diagnostics, semantic tokens, and rename. The existing CST + typechecker + ripple-backed AnalysisSession provide the analysis substrate."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-107" }
  tags { "lsp"; "editor" }
  reviewStatus = "draft"
  severity = "major"
}

// ── pkf / pkspec evaluation blockers ───────────────────────────────────────
// These five slices are what `moon run cmd/main -- eval` is missing today
// to load and run pkf's `Taskfile.pkl` and pkspec's `specs/*.pkl`. They
// were derived by running the actual files through the evaluator on
// 2026-05-15 and collecting the diagnostics:
//   - `unknown type annotation Any?` / `Mapping<String, Any>` → PKL-133
//   - `unknown member toList` / `keys` / `values` → PKL-134
//   - `unknown member map` / `filter` / `flatMap` / `count` / etc. → PKL-135
//   - parser silently drops `when (cond) { property = value }` blocks
//     inside Listing / Mapping literals → PKL-136
//   - `amends "..."` base module's tests / scenarios / output binding
//     do not flow into the child's evaluation → PKL-137
// Promote PKL-133 first (smallest, no dependencies); the rest stack on
// top of it in numerical order.

entries: Listing<Spec.Scenario> = new {
  pklRepl
  upstreamFixtureSweepExpansion
  inheritanceDispatchHardening
  crossModuleTypecheckCompleteness
  setPairMapIntSeqVariants
  pklRendererStdlibModules
  plistXmlProtobufRenderers
  rendererConverters
  packagePklRegistry
  pkldoc
  codegenBridge
  lspServer
}
