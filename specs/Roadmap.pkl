/// Forward-looking roadmap of pkspec scenarios.
///
/// Every entry here is `reviewStatus = "draft"`, so `pkspec spec --check`
/// ignores them — they exist as a structured TODO list, NOT as a binding
/// commitment. Promote to `specs/Spec.pkl` (and flip `reviewStatus` to
/// `"approved"`) when starting the slice.
///
/// Loose grouping (the ID ranges are conventional, not enforced):
///   PKL-069             constraint-system round-off
///   PKL-070 .. PKL-074  renderers (pcf / json / yaml / properties)
///   PKL-075 .. PKL-084  stdlib expansion (pkl:base / pkl:math / pkl:reflect / regex / duration / read / trace)
///   PKL-085 .. PKL-088  object expression features (for / when / hidden / null-coalescing)
///   PKL-089 .. PKL-093  type system (generics + non-numeric constraints)
///   PKL-094 .. PKL-097  CLI surface and upstream compatibility expansion
@ModuleInfo { minPklVersion = "0.31.0" }
module specs.Roadmap

import "../pkspec/Spec.pkl"

// ── constraint-system round-off ─────────────────────────────────────────────


// ── renderers ───────────────────────────────────────────────────────────────

// ── stdlib expansion ────────────────────────────────────────────────────────

local pklReflectMinimal: Spec.Scenario = new {
  id = "PKL-080"
  name = "minimal pkl:reflect support"
  description =
    "`pkl:reflect.Type` / `Class` / `Property` enough for the upstream `reflect.pkl` fixtures: get the runtime type of a value, list class properties, and check whether a type is a subtype of another."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-040" }
  tags { "stdlib"; "pkl-reflect"; "next" }
  reviewStatus = "draft"
  severity = "minor"
  decisions {
    new Spec.Decision {
      date = "2026-05-15"
      summary = "Reflect is small but enables generator-style fixtures"
      rationale =
        "Several non-trivial Apple Pkl fixtures introspect their own module via `pkl:reflect`. Even a partial implementation unlocks a category of fixtures otherwise unreachable."
    }
  }
}

local readTraceThrow: Spec.Scenario = new {
  id = "PKL-084"
  name = "read trace and throw built-ins"
  description =
    "Built-in `read(uri)`, `read?(uri)`, `trace(value)`, and `throw(message)`. read covers `env:` / `prop:` / `file:` URIs at minimum, trace stamps a diagnostic without affecting the value, and throw aborts with a localized error."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-009" }
  tags { "stdlib"; "io"; "diagnostics" }
  reviewStatus = "draft"
  severity = "major"
  decisions {
    new Spec.Decision {
      date = "2026-05-15"
      summary = "read() is a sandbox boundary, not just an stdlib call"
      rationale =
        "read() introduces external state into the evaluator, which means we have to decide the sandboxing policy (env / prop / file scopes, default-deny vs allow-list) before the implementation. Treat this scenario as an architectural decision, not a quick add."
    }
  }
}

// ── object expression features ──────────────────────────────────────────────




// ── type system expansion ───────────────────────────────────────────────────

local genericClassDeclarations: Spec.Scenario = new {
  id = "PKL-089"
  name = "generic class declarations"
  description =
    "`class Box<T> { value: T }` declares a parameterized class; instances bind T at construction time and the typechecker propagates the binding through property and method accesses."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-040" }
  tags { "typechecker"; "generics"; "class" }
  reviewStatus = "draft"
  severity = "major"
}

local genericFunctionTypeParameters: Spec.Scenario = new {
  id = "PKL-090"
  name = "generic function type parameters"
  description =
    "Function declarations such as `function identity<T>(x: T): T = x` accept a type parameter list; the typechecker infers the binding from the argument types at call sites."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-089" }
  tags { "typechecker"; "generics"; "callable" }
  reviewStatus = "draft"
  severity = "major"
}

local floatConstraintPredicates: Spec.Scenario = new {
  id = "PKL-092"
  name = "Float constraint predicates"
  description =
    "Numeric constraint predicates (`isPositive`, `isBetween`, etc.) accept Float values alongside Int, including mixed Int / Float comparisons inside user-defined factories."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-078" }
  tags { "constraint"; "float" }
  reviewStatus = "draft"
  severity = "minor"
}

// ── CLI surface and upstream compatibility ──────────────────────────────────


entries: Listing<Spec.Scenario> = new {
  pklReflectMinimal
  readTraceThrow
  genericClassDeclarations
  genericFunctionTypeParameters
  floatConstraintPredicates
}
