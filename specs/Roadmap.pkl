/// Forward-looking roadmap of pkspec scenarios.
///
/// Every entry here is `reviewStatus = "draft"`, so `pkspec spec --check`
/// ignores them — they exist as a structured TODO list, NOT as a binding
/// commitment. Promote to `specs/Spec.pkl` (and flip `reviewStatus` to
/// `"approved"`) when starting the slice.
///
/// 2026-05-16 scope refocus: pkl-mbt is being positioned as a MoonBit
/// library (parser / typechecker / evaluator surface), so the slices
/// that overlap with Apple Pkl's own runtime tooling were removed:
///   - PKL-101 (repl)               — interactive CLI, low library value
///   - PKL-126b (xml renderer)      — `pkl eval -f xml` is already in upstream
///   - PKL-126c (protobuf renderer) — same; needs `.proto` schema parser
///   - PKL-127 (renderer converters) — same renderer surface
///   - PKL-130 (pkldoc)             — pkl's own `pkldoc` covers this
///   - PKL-132 (LSP)                — out of scope for the library slice
/// These can be reinstated later if a concrete consumer surfaces; for
/// now they sit in git history rather than the active roadmap.
///
/// Remaining grouping (the ID ranges are conventional, not enforced):
///   PKL-119      stdlib Value variants (Set / Pair / Map / IntSeq)
///   PKL-129b     parser / imports — package:// registry resolution
///   PKL-131      checker — codegen bridge (consumes typechecker state)
@ModuleInfo { minPklVersion = "0.31.0" }
module specs.Roadmap

import "../pkspec/Spec.pkl"

// ── eval / typechecker precision ────────────────────────────────────────────

local setPairMapIntSeqVariants: Spec.Scenario = new {
  id = "PKL-119"
  name = "Set / Pair / Map / IntSeq Value variants"
  description =
    "Introduce dedicated Value variants for `Set` / `Pair` / `Map` / `IntSeq` instead of folding into `ListingValue` / `MappingValue`. The renderer round-trip for these stdlib types becomes accurate (`Set(1, 2, 3)`, `Pair(a, b)`), equality / iteration matches upstream semantics, and the typechecker can keep them apart from the structurally similar `Listing` / `Mapping` shapes — the latter matters for consumers using pkl-mbt as a library, where collapsing the types loses information the embedder may need."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-075" }
  tags { "evaluator"; "typechecker"; "stdlib"; "next" }
  reviewStatus = "draft"
  severity = "major"
}

// ── parser / imports ───────────────────────────────────────────────────────

local packagePklRegistry: Spec.Scenario = new {
  id = "PKL-129b"
  name = "package:// registry resolution"
  description =
    "`import \"package://pkg.pkl-lang.org/...\"` resolves through Apple Pkl's registry protocol: fetch the package metadata JSON, locate the zipball URL, fetch + extract the zipball, then look up the path fragment inside. Today the CLI recognises the URI scheme but always errors with a clear diagnostic; PKL-129 lands the underlying `https://` fetch path. The registry resolution is the follow-up that adds a zip unpacker, fragment routing, and (later) checksum / signature verification."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-129" }
  tags { "parser"; "imports"; "sandbox"; "pkf-pkspec" }
  reviewStatus = "draft"
  severity = "major"
}

// ── checker ────────────────────────────────────────────────────────────────

local codegenBridge: Spec.Scenario = new {
  id = "PKL-131"
  name = "pkl-codegen bridge"
  description =
    "Lower a typechecked Pkl module to a target language schema (Java / Kotlin / Swift / Go / MoonBit). The bridge consumes the existing typechecker state via `pkl:reflect`'s minimal stub once expanded. For pkl-mbt as a MoonBit library, the natural first target is MoonBit itself — emit a `struct` / `enum` skeleton matching the Pkl class / typealias surface so embedders can round-trip their schemas through the same type system."
  contributes { "GOAL-PKL-PURE" }
  dependsOn { "PKL-080"; "PKL-110" }
  tags { "cli"; "codegen"; "typechecker" }
  reviewStatus = "draft"
  severity = "major"
}

entries: Listing<Spec.Scenario> = new {
  setPairMapIntSeqVariants
  packagePklRegistry
  codegenBridge
}
