local cliGenerics = new Test {
  name = "cli generic class and function declarations"
  description =
    "The native CLI evaluates a fixture that declares `class Box<T>`, `class Pair<A, B>`, `function identity<T>(x: T): T`, and `function pair_first<A, B>(a: A, b: B): A`, then instantiates and calls each. Type parameters are tolerated as UnknownType in the typechecker and accept-any in the evaluator's runtime annotation validators."
  tags { "moonbit"; "cli"; "generics"; "contract" }
  specRef { "PKL-089"; "PKL-090" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_generics.pkl"
  workdir = ".."
  expectStdoutContains {
    "intBox {"
    "value = 42"
    "stringBox {"
    "value = \"hello\""
    "mixedPair {"
    "first = 1"
    "second = \"two\""
    "identityInt = 7"
    "firstPair = 1"
  }
  timeoutSec = 120
}

local cliFloatPower = new Test {
  name = "cli float power intdiv modulo"
  description =
    "The native CLI evaluates a fixture that exercises `**`, `~/`, and `%` with Float operands, matching Apple Pkl's golden output: `2.0 ** 3 = 8.0`, `5.0 ~/ 3.0 = 1`, `5.5 % 6.5 = 5.5`, `5 % 6.5 = 5.0`."
  tags { "moonbit"; "cli"; "float"; "operator"; "contract" }
  specRef { "PKL-111" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_float_power.pkl"
  workdir = ".."
  expectStdoutContains {
    "power_int = 8.0"
    "power_float = 27.98409999999999"
    "int_div_float = 1"
    "int_div_mixed = 1"
    "mod_float = 5.5"
    "mod_mixed = 5.0"
  }
  timeoutSec = 120
}

local cliFloatThresholdConstraints = new Test {
  name = "cli float threshold constraint predicates"
  description =
    "The native CLI evaluates a fixture that exercises Float thresholds in numeric constraint predicates (`isBetween(0.5, 1.5)`, `isGreaterThan(0.5)`, `isLessThan(1.5)`, `isGreaterThan(-1.5)`) and prints the bindings without raising a constraint diagnostic."
  tags { "moonbit"; "cli"; "constraint"; "float"; "contract" }
  specRef { "PKL-112" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_float_threshold_constraints.pkl"
  workdir = ".."
  expectStdoutContains {
    "midRange = 1.0"
    "aboveHalf = 0.75"
    "belowOne = 1.25"
    "negativeBound = -1.0"
  }
  timeoutSec = 120
}

local cliEqualityTypeMatch = new Test {
  name = "cli equality type match"
  description =
    "The native CLI evaluates a fixture that exercises `==` and `!=` against compatible operand types â€” Int vs Int, Int vs Float (Apple Pkl admits this), Float vs Float, Bool vs Bool, and a nullable binding against `null`. The evaluation produces the expected booleans without raising a typecheck diagnostic, demonstrating that PKL-113 leaves valid programs untouched."
  tags { "moonbit"; "cli"; "typechecker"; "equality"; "contract" }
  specRef { "PKL-113" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_equality_type_match.pkl"
  workdir = ".."
  expectStdoutContains {
    "intMatch = true"
    "intVsFloat = true"
    "floatMismatch = true"
    "boolMismatch = true"
    "nameIsNull = true"
  }
  timeoutSec = 120
}

local cliIsOperator = new Test {
  name = "cli is operator runtime"
  description =
    "The native CLI evaluates a fixture that exercises the `is` operator at runtime: `5 is Int`, `1.5 is Float`, `Number` checks against both Int and Float values, a negative check (`\"x\" is Int = false`), and an `if (x is Int) ...` branch inside a function. No `parser-only` diagnostic is raised â€” the evaluator routes through `value_is_type` and produces concrete Bool values."
  tags { "moonbit"; "cli"; "evaluator"; "is-operator"; "contract" }
  specRef { "PKL-114" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_is_operator.pkl"
  workdir = ".."
  expectStdoutContains {
    "intCheck = true"
    "floatCheck = true"
    "numberInt = true"
    "numberFloat = true"
    "stringNotInt = false"
    "classified = \"int\""
    "classifiedFloat = \"float\""
  }
  timeoutSec = 120
}

local cliGenericTypealias = new Test {
  name = "cli generic typealias"
  description =
    "The native CLI evaluates a fixture that declares `typealias Box<T> = Listing<T>` and `typealias Pair<K, V> = Mapping<K, V>`, then instantiates `Box<Int>`, `Box<String>`, and `Pair<String, Int>`. Each declaration resolves through `try_generic_alias_substitution`, the listing / mapping elements typecheck against the substituted element types, and the evaluator emits the same PCF as the equivalent non-aliased annotation."
  tags { "moonbit"; "cli"; "typealias"; "generics"; "contract" }
  specRef { "PKL-115" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_generic_typealias.pkl"
  workdir = ".."
  expectStdoutContains {
    "ints {"
    "1"
    "2"
    "3"
    "words {"
    "\"a\""
    "\"b\""
    "scores {"
    "[\"alice\"] = 90"
    "[\"bob\"] = 80"
  }
  timeoutSec = 120
}

local cliTypeParameterBounds = new Test {
  name = "cli type parameter bounds"
  description =
    "The native CLI evaluates a fixture that exercises `<T : Number>` on a generic function and a generic class: `clamp(5)` returns `5`, `clamp(2.5)` returns `2.5`, and `new Container { value = 42 }` / `{ value = 3.14 }` produce the expected ObjectValue. The fixture intentionally only uses arguments that satisfy the bound; bound rejection is covered by the unit tests."
  tags { "moonbit"; "cli"; "generics"; "bounds"; "contract" }
  specRef { "PKL-116" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_type_parameter_bounds.pkl"
  workdir = ".."
  expectStdoutContains {
    "intResult = 5"
    "floatResult = 2.5"
    "intBox {"
    "value = 42"
    "floatBox {"
    "value = 3.14"
  }
  timeoutSec = 120
}

local cliAnyType = new Test {
  name = "cli any top type"
  description =
    "The native CLI evaluates a fixture that exercises `Any`-typed bindings (Int / String / Bool), a nullable `Any?` defaulted to null, and a `Mapping<String, Any>` carrying heterogeneous value types. Every binding typechecks (via the new `AnyType` short-circuit in `type_accepts`) and the evaluator emits the same PCF as the concrete annotations would."
  tags { "moonbit"; "cli"; "typechecker"; "any"; "pkf-pkspec"; "contract" }
  specRef { "PKL-133" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_any_type.pkl"
  workdir = ".."
  expectStdoutContains {
    "intHolder = 5"
    "stringHolder = \"hello\""
    "boolHolder = true"
    "nullable = null"
    "heterogeneousMap {"
    "[\"n\"] = 1"
    "[\"s\"] = \"x\""
    "[\"b\"] = true"
  }
  timeoutSec = 120
}

local cliListingMappingStdlib = new Test {
  name = "cli listing mapping stdlib"
  description =
    "The native CLI evaluates a fixture that exercises Listing.toList / length / isEmpty, Mapping.toMap / length / keys / values, and the `List<T>` type annotation. Each method returns the expected value and the rendered PCF matches the equivalent literal."
  tags { "moonbit"; "cli"; "stdlib"; "pkf-pkspec"; "contract" }
  specRef { "PKL-134" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_listing_mapping_stdlib.pkl"
  workdir = ".."
  expectStdoutContains {
    "xs {"
    "ys {"
    "listLen = 3"
    "listEmpty = false"
    "m {"
    "m2 {"
    "mapLen = 2"
    "mapKeys {"
    "\"a\""
    "\"b\""
    "mapValues {"
  }
  timeoutSec = 120
}

local cliFloatMagnitudeUnits = new Test {
  name = "cli float magnitude units"
  description =
    "The native CLI evaluates a fixture using Float-magnitude Duration and DataSize literals (`0.5.s`, `2.5.gib`, `1.h`, `5.gib`). The rendered output preserves the magnitude and unit, and accessing `.value` projects back to Int when integral or Float when fractional."
  tags { "moonbit"; "cli"; "parser"; "duration"; "datasize"; "float"; "contract" }
  specRef { "PKL-121" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_float_magnitude_units.pkl"
  workdir = ".."
  expectStdoutContains {
    "half_second = 0.5.s"
    "heavy = 2.5.gib"
    "one_hour = 1.h"
    "five_gib = 5.gib"
    "heavy_value = 2.5"
    "heavy_unit = \"gib\""
    "half_positive = true"
  }
  timeoutSec = 120
}

local cliAnnotationCapture = new Test {
  name = "cli annotation capture"
  description =
    "The native CLI's `parse` subcommand prints one summary line per captured annotation when at least one was found, identifying the declaration it attaches to (module / class / function / typealias) and the body shape (NoBody / ParenBody / BraceBody) plus the verbatim body text. Annotation-free sources keep the existing one-line `ok` output for byte-identity with prior fixtures."
  tags { "moonbit"; "cli"; "parser"; "annotation"; "contract" }
  specRef { "PKL-128d" }
  cmd = "moon run cmd/main --target native -- parse fixtures/cli_annotation_capture.pkl"
  workdir = ".."
  expectStdoutContains {
    "annotation ModuleInfo on module: BraceBody=( minPklVersion = \"0.31.0\" )"
    "annotation Deprecated on class Box: ParenBody=(\"removed in v3\")"
    "annotation Since on function helper: ParenBody=(version = \"0.5.0\")"
    "annotation Internal on typealias Alias: NoBody=()"
    "ok"
  }
  timeoutSec = 120
}

local cliYamlBlockScalars = new Test {
  name = "cli yaml block scalars"
  description =
    "The native CLI evaluates a fixture that declares `output { renderer = new YamlRenderer {} }` and several multiline String values. The YAML output renders them as literal block scalars: `|` (one trailing newline, clip), `|-` (no trailing newline, strip), `|+` (multiple trailing newlines, keep), with two-space content indentation. Strings whose lines start with whitespace fall back to double-quoted form, and listing items in block context also pick up the block-scalar projection."
  tags { "moonbit"; "cli"; "renderer"; "yaml"; "block-scalar"; "contract" }
  specRef { "PKL-125" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_yaml_block_scalars.pkl"
  workdir = ".."
  expectStdoutContains {
    "poem: |"
    "  roses are red"
    "  violets are blue"
    "stripped: |-"
    "  alpha"
    "  beta"
    "kept: |+"
    "  first"
    "  second"
    "single: one liner"
    "leading_space: \"first\\n  cannot block\\nlast\""
    "items:"
    "- |-"
    "  gamma"
    "- single"
  }
  timeoutSec = 120
}

local cliStringUnicode = new Test {
  name = "cli string unicode"
  description =
    "The native CLI evaluates a fixture that observes a String whose last glyph is a supplementary-plane code point (`đźŤŁ`, U+1F363). `length` keeps the existing UTF-16 code-unit count (5) for byte-identity with prior fixtures, while `codePointCount` reports the Unicode code-point count (4), `codePoints` and `chars` walk the code-point stream, and `codePointAt(3)` returns the supplementary code point as an Int."
  tags { "moonbit"; "cli"; "stdlib"; "string"; "unicode"; "contract" }
  specRef { "PKL-122" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_string_unicode.pkl"
  workdir = ".."
  expectStdoutContains {
    "u16_length = 5"
    "cp_count = 4"
    "127843"
    "\"đźŤŁ\""
    "sushi_cp = 127843"
  }
  timeoutSec = 120
}

local cliPlatformSemver = new Test {
  name = "cli platform semver"
  description =
    "The native CLI evaluates a fixture that imports `pkl:platform` and `pkl:semver`. The platform stub yields deterministic `stub-os` / `stub-arch` values; semver `parse(\"1.2.3-rc.1+build.42\")` populates major / minor / patch / preRelease / build, `isLessThan` orders `1.0.0-alpha < 1.0.0` (pre-release ranks below release), and `parseOrNull(\"not-a-version\")` returns null."
  tags { "moonbit"; "cli"; "stdlib"; "platform"; "semver"; "contract" }
  specRef { "PKL-123" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_platform_semver.pkl"
  workdir = ".."
  expectStdoutContains {
    "os_name = \"stub-os\""
    "arch_name = \"stub-arch\""
    "major = 1"
    "minor = 2"
    "patch = 3"
    "pre_release = \"rc.1\""
    "build = \"build.42\""
    "is_lt = true"
    "bad = null"
  }
  timeoutSec = 120
}

local cliReadNullable = new Test {
  name = "cli read nullable"
  description =
    "The native CLI evaluates a fixture that uses `read?(uri)` for both a missing env var and a non-`env:` scheme. Both calls return `null` instead of pushing a diagnostic, matching Apple Pkl's null-safe semantics."
  tags { "moonbit"; "cli"; "evaluator"; "read"; "nullable"; "contract" }
  specRef { "PKL-103" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_read_nullable.pkl"
  workdir = ".."
  expectStdoutContains {
    "maybe_missing = null"
    "maybe_bad_scheme = null"
  }
  timeoutSec = 120
}

local cliMathFloatOps = new Test {
  name = "cli math float ops"
  description =
    "The native CLI evaluates a fixture that imports `pkl:math` and calls `sqrt`, `pow`, `log`, `exp`, `floor`, `ceil`, `round`, plus reads `pi`. Each call returns the expected Float value computed via MoonBit's math intrinsics."
  tags { "moonbit"; "cli"; "stdlib"; "pkl-math"; "float"; "contract" }
  specRef { "PKL-120" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_math_float_ops.pkl"
  workdir = ".."
  expectStdoutContains {
    "sqrt16 = 4.0"
    "pow_2_10 = 1024.0"
    "exp_0 = 1.0"
    "floor_3_7 = 3.0"
    "ceil_3_2 = 4.0"
    "round_3_5 = 4.0"
    "pi_value = 3.141592653589793"
  }
  timeoutSec = 120
}

local cliSuperMethodCall = new Test {
  name = "cli super method call"
  description =
    "The native CLI evaluates a fixture where a subclass method body calls `super.method()` to chain into the parent class. The rendered output joins the subclass-side prefix with the parent-side return value."
  tags { "moonbit"; "cli"; "evaluator"; "inheritance"; "contract" }
  specRef { "PKL-117a" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_super_method_call.pkl"
  workdir = ".."
  expectStdoutContains { "msg = \"fluffy an animal\"" }
  timeoutSec = 120
}

local cliConstraintComposition = new Test {
  name = "cli constraint composition"
  description =
    "The native CLI evaluates a fixture that composes numeric constraint predicates with `&` (e.g. `Int(isPositive & isLessThan(10))`). Valid values render normally; the dispatcher enforces both halves of the composition independently."
  tags { "moonbit"; "cli"; "parser"; "constraints"; "contract" }
  specRef { "PKL-128c" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_constraint_composition.pkl"
  workdir = ".."
  expectStdoutContains {
    "small = 5"
    "bigger = 42"
    "negative = -3"
  }
  timeoutSec = 120
}

local cliScientificFloat = new Test {
  name = "cli scientific float"
  description =
    "The native CLI evaluates a fixture with scientific-notation Float literals (`1e10`, `2.5e-3`, `4E+8`, `1.5e2`). Each literal renders as a Float value with the expected magnitude."
  tags { "moonbit"; "cli"; "parser"; "lexer"; "float"; "contract" }
  specRef { "PKL-128b" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_scientific_float.pkl"
  workdir = ".."
  expectStdoutContains {
    "big = 10000000000.0"
    "small = 0.0025"
    "upper = 400000000.0"
    "mid = 150.0"
  }
  timeoutSec = 120
}

local cliHeredocString = new Test {
  name = "cli heredoc string"
  description =
    "The native CLI evaluates a fixture with triple-quoted heredoc strings. The leading newline is dropped and every line is dedented by the closing delimiter's indentation; the rendered output joins each line back with `\\n` separators."
  tags { "moonbit"; "cli"; "parser"; "lexer"; "string"; "contract" }
  specRef { "PKL-128b" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_heredoc_string.pkl"
  workdir = ".."
  expectStdoutContains {
    "greeting = \"hello\\nworld\\n\""
    "flat = \"no indent here\\n\""
  }
  timeoutSec = 120
}

local cliStringInterpolation = new Test {
  name = "cli string interpolation"
  description =
    "The native CLI evaluates a fixture that uses `\"... \\(expr) ...\"` interpolation with arithmetic, method calls, and an inner `\", \"` separator string. The rendered output shows each interpolation site replaced with its evaluated value."
  tags { "moonbit"; "cli"; "parser"; "evaluator"; "string"; "contract" }
  specRef { "PKL-128a" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_string_interpolation.pkl"
  workdir = ".."
  expectStdoutContains {
    "greeting = \"hello alpha, count is 4\""
    "joined = \"items: a, b, c\""
    "plain = \"no interp here\""
  }
  timeoutSec = 120
}

local cliDiagnosticPosition = new Test {
  name = "cli diagnostic position"
  description =
    "The native CLI parses a fixture with a deliberate syntax error and the output carries a `path:line:column: message` prefix. The diagnostic's byte offset is projected onto a line:column pair so editors can jump to the failing token. The broken fixture lives under `fixtures/error_cases/` so the project formatter doesn't try to round-trip it."
  tags { "moonbit"; "cli"; "diagnostics"; "position"; "contract" }
  specRef { "PKL-107" }
  cmd = "moon run cmd/main --target native -- parse fixtures/error_cases/diagnostic_position.pkl"
  workdir = ".."
  expectStdoutContains {
    "fixtures/error_cases/diagnostic_position.pkl:11:"
    "expected ), got eq"
  }
  timeoutSec = 120
}

local cliRendererConverters = new Test {
  name = "cli renderer converters"
  description =
    "The native CLI evaluates a fixture whose `output { renderer = new JsonRenderer { converters { ... } } }` declares two path-keyed converters: `[\"count\"] = (v) -> v * 10` and `[\"server.port\"] = (p) -> p + 1`. The post-eval pass rewrites both values before the JSON renderer fires, so `count = 5` shows as 50 and `server.port = 8080` shows as 8081 in the rendered output."
  tags { "moonbit"; "cli"; "renderer"; "converter"; "contract" }
  specRef { "PKL-105" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_renderer_converters.pkl"
  workdir = ".."
  expectStdoutContains {
    "\"count\": 50"
    "\"port\": 8081"
  }
  timeoutSec = 120
}

local cliOutputRendererDriver = new Test {
  name = "cli output renderer driver"
  description =
    "The native CLI evaluates a fixture that declares `output { renderer = new JsonRenderer {} }` without passing `-f`. The CLI reads the renderer class from the parsed AST, switches the format to `json`, strips the `output` block from the rendered envelope, and prints the JSON projection of the module's other properties."
  tags { "moonbit"; "cli"; "renderer"; "output"; "contract" }
  specRef { "PKL-104" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_output_renderer_driver.pkl"
  workdir = ".."
  expectStdoutContains {
    "\"name\": \"alpha\""
    "\"count\": 5"
  }
  timeoutSec = 120
}

local cliAmendsBaseMerge = new Test {
  name = "cli amends base merge"
  description =
    "The native CLI evaluates a child fixture that `amends` a sibling base module. The base provides a `Test` class, a `Severity` string-literal union typealias, and an empty `tests: Listing<Test>` slot; the child adds one entry referencing the base's class by its bare name. The child's typecheck succeeds (no `unknown type annotation Test`) and the rendered output shows the merged listing."
  tags { "moonbit"; "cli"; "evaluator"; "amends"; "pkf-pkspec"; "contract" }
  specRef { "PKL-137" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_amends_base_merge.pkl"
  workdir = ".."
  expectStdoutContains {
    "tests {"
    "name = \"alpha\""
  }
  timeoutSec = 120
}

local cliStdlibModifiers = new Test {
  name = "cli stdlib modifiers"
  description =
    "The native CLI evaluates a fixture using stdlib-style declarations: `external` modifier, abstract property slots (no `=` default), `<in T>` / `<out T>` variance modifiers, function type annotations, and a declarations-only module footprint. The rendered output skips abstract slots and keeps the regular bindings; declarations-only fragments evaluate to the empty ObjectValue."
  tags { "moonbit"; "cli"; "parser"; "stdlib"; "contract" }
  specRef { "PKL-140" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_stdlib_modifiers.pkl"
  workdir = ".."
  expectStdoutContains {
    "comparator = <function>"
    "filled = \"ok\""
  }
  timeoutSec = 120
}

local cliHttpsImports = new Test {
  name = "cli https URI import"
  description =
    "The native CLI evaluates a fixture whose `import` declaration points at a raw GitHub URL of another fixture in this repo. The HTTP fetch goes through `mizchi/x/http.get` under a `moonbitlang/async` event loop, and the imported module's bindings become available in the importing module's typecheck / evaluation pipeline."
  tags { "moonbit"; "cli"; "imports"; "pkf-pkspec"; "contract" }
  specRef { "PKL-129" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_https_import.pkl"
  workdir = ".."
  expectStdoutContains { "result = \"ok\"" }
  timeoutSec = 120
}

local cliPkspecPolish = new Test {
  name = "cli pkspec polish"
  description =
    "The native CLI evaluates a fixture that exercises the five drive-by gaps that blocked pkspec Test.pkl: brace-bodied `@ModuleInfo` annotation, multi-line typealias RHS, dot-chain across newlines, `module.foo` self-reference, and `List` / `Set` / `Map` / `Pair` constructor functions. The rendered output shows each form producing the expected value."
  tags { "moonbit"; "cli"; "parser"; "evaluator"; "stdlib"; "pkf-pkspec"; "contract" }
  specRef { "PKL-139" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_pkspec_polish.pkl"
  workdir = ".."
  expectStdoutContains {
    "doubled {"
    "\"ALPHA\""
    "selfRef {"
    "ctorList {"
    "ctorEmpty {}"
    "ctorSet {"
    "ctorMap {"
    "ctorPair {"
  }
  timeoutSec = 120
}

local cliNewBodyInference = new Test {
  name = "cli new body inference"
  description =
    "The native CLI evaluates a fixture that exercises bare `new { ... }` literals dispatched into listing / mapping / object bodies by the first significant token, plus empty `new {}` literals coerced to ListingValue / MappingValue via the binding's type annotation. Chained methods (`emptyListing.toList().map(...)`, `emptyMapping.keys`) succeed because the coercion runs before the method dispatch."
  tags { "moonbit"; "cli"; "parser"; "evaluator"; "pkf-pkspec"; "contract" }
  specRef { "PKL-138" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_new_body_inference.pkl"
  workdir = ".."
  expectStdoutContains {
    "xs {"
    "emptyListing {}"
    "m {"
    "emptyMapping {}"
    "obj {"
    "listingLen = 3"
    "mappingLen = 2"
    "emptyChained {}"
    "emptyMapKeys {}"
  }
  timeoutSec = 120
}

local cliWhenConditional = new Test {
  name = "cli when conditional property"
  description =
    "The native CLI evaluates a fixture that uses `when (cond) { ... } [else { ... }]` inside Listing, Mapping, and object bodies, plus `new Listing<T> { ... }` literals. Each conditional emits its inner body when the condition is true, skips it when false, falls back to the else branch when present, and produces the empty collection when no condition fires."
  tags { "moonbit"; "cli"; "parser"; "evaluator"; "pkf-pkspec"; "contract" }
  specRef { "PKL-136" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_when_conditional.pkl"
  workdir = ".."
  expectStdoutContains {
    "xs {"
    "ys {"
    "m {"
    "obj {"
    "empty {}"
    "[\"base\"] = 1"
    "[\"extra\"] = 2"
    "extra = 2"
  }
  timeoutSec = 120
}

local cliListingMappingFunctional = new Test {
  name = "cli listing mapping functional"
  description =
    "The native CLI evaluates a fixture that exercises `Listing.flatMap` / `count` / `every` / `any` / `none` / `find` / `findLast` / `findOrNull`, plus `Mapping.every` / `any` / `none` / `count`. Each method routes through `apply_function_value` per element and returns the value Apple Pkl produces for the equivalent call."
  tags { "moonbit"; "cli"; "stdlib"; "pkf-pkspec"; "contract" }
  specRef { "PKL-135" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_listing_mapping_functional.pkl"
  workdir = ".."
  expectStdoutContains {
    "countEven = 2"
    "everyPositive = true"
    "anyEven = true"
    "noneNegative = true"
    "firstEven = 2"
    "lastEven = 4"
    "missingOrNull = null"
    "flat {"
    "mEvery = true"
    "mAny = true"
    "mCount = 2"
    "mNone = true"
  }
  timeoutSec = 120
}

local cliGenericInference = new Test {
  name = "cli generic call-site inference"
  description =
    "The native CLI evaluates a fixture that depends on substituted generic types: `identity(7) + 1` typechecks and evaluates to `8` because T binds Int at the call site, and `intBox.value + 100` typechecks and evaluates to `105` because Box<T>'s value member instantiates as Int from the literal."
  tags { "moonbit"; "cli"; "generics"; "inference"; "contract" }
  specRef { "PKL-110" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_generic_inference.pkl"
  workdir = ".."
  expectStdoutContains {
    "intResult = 8"
    "intBox {"
    "value = 5"
    "boxedSum = 105"
  }
  timeoutSec = 120
}

local cliTestExamplesPass = new Test {
  name = "cli test examples gold match"
  description =
    "The native CLI `test` subcommand walks the `examples` member alongside `facts` and reports `PASS examples (N examples)` when the rendered envelope matches the `<file>-expected.pcf` golden byte-for-byte."
  tags { "moonbit"; "cli"; "pkl-test"; "examples"; "contract" }
  specRef { "PKL-100" }
  cmd = "moon run cmd/main --target native -- test fixtures/cli_test_examples.pkl"
  workdir = ".."
  expectStdoutContains { "PASS examples (2 examples)" }
  timeoutSec = 120
}

local cliTestExamplesFail = new Test {
  name = "cli test examples diff fail"
  description =
    "When the rendered `examples` envelope diverges from the `<file>-expected.pcf` golden the runner emits `FAIL examples diff against <path>` and contributes to the non-zero exit."
  tags { "moonbit"; "cli"; "pkl-test"; "examples"; "contract" }
  specRef { "PKL-100" }
  cmd = "moon run cmd/main --target native -- test fixtures/cli_test_examples_fail.pkl"
  workdir = ".."
  expectStdoutContains {
    "FAIL examples diff against fixtures/cli_test_examples_fail.pkl-expected.pcf"
  }
  timeoutSec = 120
}

local cliFormat = new Test {
  name = "cli format subcommand"
  description =
    "The native CLI `format` subcommand re-emits the source through the PCF renderer, normalizing whitespace and indentation. Today the formatter operates on the evaluated module value; trivia-preserving idempotent reformatting is a follow-up."
  tags { "moonbit"; "cli"; "format"; "contract" }
  specRef { "PKL-099" }
  cmd = "moon run cmd/main --target native -- format fixtures/cli_format.pkl"
  workdir = ".."
  expectStdoutContains {
    "name = \"hawk\""
    "age = 2"
    "nested {"
    "child = 1"
  }
  timeoutSec = 120
}

local cliFloat = new Test {
  name = "cli float numerics and constraints"
  description =
    "The native CLI evaluates a Float-heavy fixture, exercising Float literals, mixed Int / Float arithmetic, `Int / Int` widening to Float, and `Float(isPositive)` / `Float(isBetween(...))` / `Number(isPositive)` constraint predicates."
  tags { "moonbit"; "cli"; "float"; "constraint"; "contract" }
  specRef { "PKL-092" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_float.pkl"
  workdir = ".."
  expectStdoutContains {
    "pi = 3.14"
    "half = 2.5"
    "mixed = 3.5"
    "positive = 7.5"
    "between = 4.5"
    "number = 9"
  }
  timeoutSec = 120
}

local cliTrace = new Test {
  name = "cli trace pass-through"
  description =
    "The native CLI evaluates a fixture where `trace(value)` wraps its argument; the rendered output shows the inner values unchanged, confirming the builtin pass-through semantics ship as part of PKL-084."
  tags { "moonbit"; "cli"; "trace"; "contract" }
  specRef { "PKL-084" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_trace.pkl"
  workdir = ".."
  expectStdoutContains { "passed = 42"; "sum = 5" }
  timeoutSec = 120
}

local cliReflectStub = new Test {
  name = "cli reflect minimal stub"
  description =
    "The native CLI evaluates a fixture that imports `pkl:reflect` and reads mirror constants plus the `Class` factory `reflectee` field, exercising the minimal stub registered in `builtin_stdlib_source`."
  tags { "moonbit"; "cli"; "pkl-reflect"; "stdlib"; "contract" }
  specRef { "PKL-080" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_reflect.pkl"
  workdir = ".."
  expectStdoutContains {
    "intMirror = \"pkl.base#Int\""
    "stringMirror = \"pkl.base#String\""
    "fooReflectee = \"Foo\""
    "declared = \"Bar\""
  }
  timeoutSec = 120
}

local cliTestPass = new Test {
  name = "cli test passing facts"
  description =
    "The native CLI `test` subcommand walks a `facts: Mapping<String, Listing<Boolean>>` member, reports a PASS line per fact, and ends with the pass / fail summary."
  tags { "moonbit"; "cli"; "pkl-test"; "contract" }
  specRef { "PKL-095" }
  cmd = "moon run cmd/main --target native -- test fixtures/cli_test_pass.pkl"
  workdir = ".."
  expectStdoutContains {
    "PASS addition (2 assertions)"
    "PASS subtraction (1 assertions)"
    "2 passed, 0 failed"
  }
  timeoutSec = 120
}

local cliTestFail = new Test {
  name = "cli test failing facts"
  description =
    "The native CLI `test` subcommand reports a FAIL line for any fact whose Listing contains a non-true value, naming the offending assertion index, and prints the pass / fail summary."
  tags { "moonbit"; "cli"; "pkl-test"; "contract" }
  specRef { "PKL-095" }
  cmd = "moon run cmd/main --target native -- test fixtures/cli_test_fail.pkl"
  workdir = ".."
  expectStdoutContains {
    "PASS addition (1 assertions)"
    "FAIL broken: assertion #1 of 1 did not evaluate to true"
    "1 passed, 1 failed"
  }
  timeoutSec = 120
}

