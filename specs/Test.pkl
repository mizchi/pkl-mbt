    "unused-import: import `Helper` (from \"cli_lint_helper.pkl\") is never referenced"
    "unused-class-property: property `temp` of unused class `UnusedHelper` is never referenced"
    "shadowed-identifier: binding `Helper` shadows existing import of the same name"
  }
  timeoutSec = 120
}

