local cliEval = new Test {
  name = "cli eval"
  description = "The native CLI evaluates a Pkl file and prints module object properties."
  tags { "moonbit"; "cli"; "contract" }
  specRef { "PKL-009" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli.pkl"
  workdir = ".."
  expectStdoutContains { "name = \"hawk\"" }
  timeoutSec = 120
}

local cliEvalJson = new Test {
  name = "cli eval json"
  description = "The native CLI emits a JSON document when invoked with `-f json`."
  tags { "moonbit"; "cli"; "renderer"; "json"; "contract" }
  specRef { "PKL-072"; "PKL-094" }
  cmd = "moon run cmd/main --target native -- eval -f json fixtures/cli.pkl"
  workdir = ".."
  expectStdoutContains { "\"name\": \"hawk\""; "\"age\": 2" }
  timeoutSec = 120
}

local cliEvalFormatLong = new Test {
  name = "cli eval --format long form"
  description =
    "The native CLI accepts the `--format` long-form flag and dispatches to the JSON renderer."
  tags { "moonbit"; "cli"; "renderer"; "json"; "contract" }
  specRef { "PKL-094" }
  cmd = "moon run cmd/main --target native -- eval --format json fixtures/cli.pkl"
  workdir = ".."
  expectStdoutContains { "\"name\": \"hawk\""; "\"age\": 2" }
  timeoutSec = 120
}

local cliEvalFormatPcf = new Test {
  name = "cli eval --format pcf"
  description =
    "The native CLI accepts `--format pcf` explicitly and emits the same PCF output as the default."
  tags { "moonbit"; "cli"; "renderer"; "pcf"; "contract" }
  specRef { "PKL-094" }
  cmd = "moon run cmd/main --target native -- eval --format pcf fixtures/cli.pkl"
  workdir = ".."
  expectStdoutContains { "name = \"hawk\""; "age = 2" }
  timeoutSec = 120
}

local cliEvalYaml = new Test {
  name = "cli eval yaml"
  description = "The native CLI emits a YAML document when invoked with `-f yaml`."
  tags { "moonbit"; "cli"; "renderer"; "yaml"; "contract" }
  specRef { "PKL-073"; "PKL-094" }
  cmd = "moon run cmd/main --target native -- eval -f yaml fixtures/cli.pkl"
  workdir = ".."
  expectStdoutContains { "name: hawk"; "age: 2" }
  timeoutSec = 120
}

local cliEvalProperties = new Test {
  name = "cli eval properties"
  description = "The native CLI emits a Java Properties document when invoked with `-f properties`."
  tags { "moonbit"; "cli"; "renderer"; "properties"; "contract" }
  specRef { "PKL-074"; "PKL-094" }
  cmd = "moon run cmd/main --target native -- eval -f properties fixtures/cli.pkl"
  workdir = ".."
  expectStdoutContains { "name = hawk"; "age = 2" }
  timeoutSec = 120
}

local cliGenerics = new Test {
  name = "cli generic class and function declarations"
  description =
    "The native CLI evaluates a fixture that declares `class Box<T>`, `class Pair<A, B>`, `function identity<T>(x: T): T`, and `function pair_first<A, B>(a: A, b: B): A`, then instantiates and calls each. Type parameters are tolerated as UnknownType in the typechecker and accept-any in the evaluator's runtime annotation validators."
  tags { "moonbit"; "cli"; "generics"; "contract" }
  specRef { "PKL-089"; "PKL-090" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_generics.pkl"
  workdir = ".."
  expectStdoutContains {
    "intBox {"
    "value = 42"
    "stringBox {"
    "value = \"hello\""
    "mixedPair {"
    "first = 1"
    "second = \"two\""
    "identityInt = 7"
    "firstPair = 1"
  }
  timeoutSec = 120
}

local cliFloatPower = new Test {
  name = "cli float power intdiv modulo"
  description =
    "The native CLI evaluates a fixture that exercises `**`, `~/`, and `%` with Float operands, matching Apple Pkl's golden output: `2.0 ** 3 = 8.0`, `5.0 ~/ 3.0 = 1`, `5.5 % 6.5 = 5.5`, `5 % 6.5 = 5.0`."
  tags { "moonbit"; "cli"; "float"; "operator"; "contract" }
  specRef { "PKL-111" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_float_power.pkl"
  workdir = ".."
  expectStdoutContains {
    "power_int = 8.0"
    "power_float = 27.98409999999999"
    "int_div_float = 1"
    "int_div_mixed = 1"
    "mod_float = 5.5"
    "mod_mixed = 5.0"
  }
  timeoutSec = 120
}

local cliFloatThresholdConstraints = new Test {
  name = "cli float threshold constraint predicates"
  description =
    "The native CLI evaluates a fixture that exercises Float thresholds in numeric constraint predicates (`isBetween(0.5, 1.5)`, `isGreaterThan(0.5)`, `isLessThan(1.5)`, `isGreaterThan(-1.5)`) and prints the bindings without raising a constraint diagnostic."
  tags { "moonbit"; "cli"; "constraint"; "float"; "contract" }
  specRef { "PKL-112" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_float_threshold_constraints.pkl"
  workdir = ".."
  expectStdoutContains {
    "midRange = 1.0"
    "aboveHalf = 0.75"
    "belowOne = 1.25"
    "negativeBound = -1.0"
  }
  timeoutSec = 120
}

local cliGenericInference = new Test {
  name = "cli generic call-site inference"
  description =
    "The native CLI evaluates a fixture that depends on substituted generic types: `identity(7) + 1` typechecks and evaluates to `8` because T binds Int at the call site, and `intBox.value + 100` typechecks and evaluates to `105` because Box<T>'s value member instantiates as Int from the literal."
  tags { "moonbit"; "cli"; "generics"; "inference"; "contract" }
  specRef { "PKL-110" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_generic_inference.pkl"
  workdir = ".."
  expectStdoutContains {
    "intResult = 8"
    "intBox {"
    "value = 5"
    "boxedSum = 105"
  }
  timeoutSec = 120
}

local cliTestExamplesPass = new Test {
  name = "cli test examples gold match"
  description =
    "The native CLI `test` subcommand walks the `examples` member alongside `facts` and reports `PASS examples (N examples)` when the rendered envelope matches the `<file>-expected.pcf` golden byte-for-byte."
  tags { "moonbit"; "cli"; "pkl-test"; "examples"; "contract" }
  specRef { "PKL-100" }
  cmd = "moon run cmd/main --target native -- test fixtures/cli_test_examples.pkl"
  workdir = ".."
  expectStdoutContains { "PASS examples (2 examples)" }
  timeoutSec = 120
}

local cliTestExamplesFail = new Test {
  name = "cli test examples diff fail"
  description =
    "When the rendered `examples` envelope diverges from the `<file>-expected.pcf` golden the runner emits `FAIL examples diff against <path>` and contributes to the non-zero exit."
  tags { "moonbit"; "cli"; "pkl-test"; "examples"; "contract" }
  specRef { "PKL-100" }
  cmd = "moon run cmd/main --target native -- test fixtures/cli_test_examples_fail.pkl"
  workdir = ".."
  expectStdoutContains {
    "FAIL examples diff against fixtures/cli_test_examples_fail.pkl-expected.pcf"
  }
  timeoutSec = 120
}

local cliFormat = new Test {
  name = "cli format subcommand"
  description =
    "The native CLI `format` subcommand re-emits the source through the PCF renderer, normalizing whitespace and indentation. Today the formatter operates on the evaluated module value; trivia-preserving idempotent reformatting is a follow-up."
  tags { "moonbit"; "cli"; "format"; "contract" }
  specRef { "PKL-099" }
  cmd = "moon run cmd/main --target native -- format fixtures/cli_format.pkl"
  workdir = ".."
  expectStdoutContains {
    "name = \"hawk\""
    "age = 2"
    "nested {"
    "child = 1"
  }
  timeoutSec = 120
}

local cliFloat = new Test {
  name = "cli float numerics and constraints"
  description =
    "The native CLI evaluates a Float-heavy fixture, exercising Float literals, mixed Int / Float arithmetic, `Int / Int` widening to Float, and `Float(isPositive)` / `Float(isBetween(...))` / `Number(isPositive)` constraint predicates."
  tags { "moonbit"; "cli"; "float"; "constraint"; "contract" }
  specRef { "PKL-092" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_float.pkl"
  workdir = ".."
  expectStdoutContains {
    "pi = 3.14"
    "half = 2.5"
    "mixed = 3.5"
    "positive = 7.5"
    "between = 4.5"
    "number = 9"
  }
  timeoutSec = 120
}

local cliTrace = new Test {
  name = "cli trace pass-through"
  description =
    "The native CLI evaluates a fixture where `trace(value)` wraps its argument; the rendered output shows the inner values unchanged, confirming the builtin pass-through semantics ship as part of PKL-084."
  tags { "moonbit"; "cli"; "trace"; "contract" }
  specRef { "PKL-084" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_trace.pkl"
  workdir = ".."
  expectStdoutContains { "passed = 42"; "sum = 5" }
  timeoutSec = 120
}

local cliReflectStub = new Test {
  name = "cli reflect minimal stub"
  description =
    "The native CLI evaluates a fixture that imports `pkl:reflect` and reads mirror constants plus the `Class` factory `reflectee` field, exercising the minimal stub registered in `builtin_stdlib_source`."
  tags { "moonbit"; "cli"; "pkl-reflect"; "stdlib"; "contract" }
  specRef { "PKL-080" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli_reflect.pkl"
  workdir = ".."
  expectStdoutContains {
    "intMirror = \"pkl.base#Int\""
    "stringMirror = \"pkl.base#String\""
    "fooReflectee = \"Foo\""
    "declared = \"Bar\""
  }
  timeoutSec = 120
}

local cliTestPass = new Test {
  name = "cli test passing facts"
  description =
    "The native CLI `test` subcommand walks a `facts: Mapping<String, Listing<Boolean>>` member, reports a PASS line per fact, and ends with the pass / fail summary."
  tags { "moonbit"; "cli"; "pkl-test"; "contract" }
  specRef { "PKL-095" }
  cmd = "moon run cmd/main --target native -- test fixtures/cli_test_pass.pkl"
  workdir = ".."
  expectStdoutContains {
    "PASS addition (2 assertions)"
    "PASS subtraction (1 assertions)"
    "2 passed, 0 failed"
  }
  timeoutSec = 120
}

local cliTestFail = new Test {
  name = "cli test failing facts"
  description =
    "The native CLI `test` subcommand reports a FAIL line for any fact whose Listing contains a non-true value, naming the offending assertion index, and prints the pass / fail summary."
  tags { "moonbit"; "cli"; "pkl-test"; "contract" }
  specRef { "PKL-095" }
  cmd = "moon run cmd/main --target native -- test fixtures/cli_test_fail.pkl"
  workdir = ".."
  expectStdoutContains {
    "PASS addition (1 assertions)"
    "FAIL broken: assertion #1 of 1 did not evaluate to true"
    "1 passed, 1 failed"
  }
  timeoutSec = 120
}

local upstreamSmoke = new Test {
  name = "upstream apple pkl fixture smoke"
  description =
    "Curated `pkl eval` fixtures from the apple/pkl submodule run through the native CLI and diff byte-for-byte against the upstream gold output (PCF and JSON)."
  tags { "moonbit"; "upstream"; "compatibility"; "contract" }
  specRef {
    "PKL-011"
    "PKL-012"
    "PKL-013"
    "PKL-014"
    "PKL-060"
    "PKL-096"
    "PKL-097"
  }
  cmd = "./scripts/upstream-smoke.sh"
  workdir = ".."
  expectStdoutContains {
    "upstream parse ok: basic/import1.pkl"
    "upstream eval ok: basic/parens (gold match)"
    "upstream eval ok: basic/import1 (gold match)"
    "upstream eval ok: basic/baseModule (gold match)"
    "upstream eval ok: basic/comments (gold match)"
    "upstream eval ok: basic/indexExpressions (gold match)"
    "upstream eval ok: classes/class1 (gold match)"
    "upstream eval ok: modules/amendModule1 (gold match)"
    "upstream eval ok: types/nothingWithUnions (gold match)"
    "upstream eval ok: classes/constraints8.pkl"
    "upstream json eval ok: api/jsonRenderer1.json (gold match)"
    "upstream-smoke: 25 gold-match fixtures passed"
    "upstream-smoke: 1 json gold-match fixtures passed"
  }
  timeoutSec = 240
}

local upstreamParserSuite = new Test {
  name = "upstream apple pkl parser suite"
  description =
    "All apple/pkl LanguageSnippetTests parser fixtures, excluding the same invalid cases as ParserComparisonTest, parse through the native CLI."
  tags { "moonbit"; "upstream"; "parser"; "compatibility"; "contract" }
  specRef { "PKL-015" }
  cmd = "./scripts/upstream-parse-suite.sh"
  workdir = ".."
  expectStdoutContains { "ok 802" }
  timeoutSec = 180
}

tests {
  moonUnit
  cliEval
  cliEvalJson
  cliEvalFormatLong
  cliEvalFormatPcf
  cliEvalYaml
  cliEvalProperties
  cliFloat
  cliFloatPower
  cliFloatThresholdConstraints
  cliFormat
  cliTestExamplesPass
  cliTestExamplesFail
  cliGenerics
  cliGenericInference
  cliTrace
  cliReflectStub
  cliTestPass
  cliTestFail
  upstreamSmoke
  upstreamParserSuite
}
