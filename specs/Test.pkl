local cliEval = new Test {
  name = "cli eval"
  description = "The native CLI evaluates a Pkl file and prints module object properties."
  tags { "moonbit"; "cli"; "contract" }
  specRef { "PKL-009" }
  cmd = "moon run cmd/main --target native -- eval fixtures/cli.pkl"
  workdir = ".."
  expectStdoutContains { "name = \"hawk\"" }
  timeoutSec = 120
}

local cliEvalJson = new Test {
  name = "cli eval json"
  description = "The native CLI emits a JSON document when invoked with `-f json`."
  tags { "moonbit"; "cli"; "renderer"; "json"; "contract" }
  specRef { "PKL-072"; "PKL-094" }
  cmd = "moon run cmd/main --target native -- eval -f json fixtures/cli.pkl"
  workdir = ".."
  expectStdoutContains { "\"name\": \"hawk\""; "\"age\": 2" }
  timeoutSec = 120
}

local cliEvalFormatLong = new Test {
  name = "cli eval --format long form"
  description =
    "The native CLI accepts the `--format` long-form flag and dispatches to the JSON renderer."
  tags { "moonbit"; "cli"; "renderer"; "json"; "contract" }
  specRef { "PKL-094" }
  cmd = "moon run cmd/main --target native -- eval --format json fixtures/cli.pkl"
  workdir = ".."
  expectStdoutContains { "\"name\": \"hawk\""; "\"age\": 2" }
  timeoutSec = 120
}

local cliEvalFormatPcf = new Test {
  name = "cli eval --format pcf"
  description =
    "The native CLI accepts `--format pcf` explicitly and emits the same PCF output as the default."
  tags { "moonbit"; "cli"; "renderer"; "pcf"; "contract" }
